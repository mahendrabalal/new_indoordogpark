rumb\",\"children\":[[\"$\",\"$L4\",null,{\"href\":\"/\",\"children\":\"Home\"}],[\"$\",\"span\",null,{\"children\":\"›\"}],[\"$\",\"$L4\",null,{\"href\":\"/states\",\"children\":\"States\"}],[\"$\",\"span\",null,{\"children\":\"›\"}],[\"$\",\"span\",null,{\"children\":\"Tennessee\"}]]}],[\"$\",\"div\",null,{\"className\":\"hero-eyebrow\",\"children\":\"Volunteer State Dog Parks\"}],[\"$\",\"h1\",null,{\"children\":\"Dog Parks in Tennessee\"}],[\"$\",\"div\",null,{\"className\":\"hero-description\",\"children\":[[\"$\",\"p\",\"0\",{\"children\":[\"Tennessee has embraced dog culture with Southern hospitality, creating a welcoming environment for canine companions across its three distinct regions. Nashville's explosive population growth has driven significant investment in pet infrastructure, with the metro now maintaining over 15 dedicated dog parks and a thriving industry of dog-friendly patios and breweries along the East Nashville and Germantown corridors. The city's famous \\\"Dog Day\\\" festivals draw thousands, reflecting a community that considers pets full-fledged family members. Memphis maintains its own character, with Shelby Farms Park housing one of the South's largest off-leash areas at over 200 acres.\"]}],[\"$\",\"p\",\"1\",{\"children\":[\"Knoxville and the East Tennessee region provide gateway access to the Great Smoky Mountains, one of America's most visited national parks—and one that welcomes leashed dogs on two specific trails. The state's affordable cost of living and strong job growth have attracted young dog-owning families from across the country, spurring development of premium indoor facilities and dog-friendly apartment communities. Tennessee's moderate climate allows year-round outdoor activity, though summer humidity in the lowlands can be challenging during midday hours. Our directory covers over 140 verified Tennessee locations, from Nashville's urban parks to Memphis's legendary Shelby Farms and the mountain-adjacent facilities around Knoxville.\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-cta-row\",\"children\":[[\"$\",\"$L4\",null,{\"href\":\"/cities\",\"className\":\"hero-cta primary\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-map\"}],\"Browse cities\"]}],[\"$\",\"$L4\",null,{\"href\":\"/list-your-park\",\"className\":\"hero-cta ghost\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-plus-circle\"}],\"Submit a park\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-footnotes\",\"children\":[[\"$\",\"span\",\"Nashville metro complete\",{\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-arrow-repeat\"}],\" \",\"Nashville metro complete\"]}],[\"$\",\"span\",\"Smoky Mountain area covered\",{\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-arrow-repeat\"}],\" \",\"Smoky Mountain area covered\"]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"state-hero-visual\",\"children\":[\"$\",\"div\",null,{\"className\":\"hero-image-card\",\"children\":[[\"$\",\"$L5\",null,{\"src\":\"/images/states/tennessee/hero.webp\",\"alt\":\"Tennessee dog park landscape\",\"fill\":true,\"priority\":true,\"sizes\":\"(max-width: 900px) 100vw, 40vw\",\"style\":{\"objectFit\":\"cover\"},\"unoptimized\":true}],[\"$\",\"div\",null,{\"className\":\"hero-image-gradient\"}]]}]}]]}]}],\"$L6\",\"$L7\",\"$L8\",\"$L9\"]}],\"$La\"],null,\"$Lb\"]}],\"loading\":null,\"isPartial\":false}\n6:[\"$\",\"section\",null,{\"className\":\"state-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell\",\"children\":[\"$\",\"div\",null,{\"className\":\"feature-grid\",\"children\":[[[\"$\",\"div\",\"Nashville's Growth\",{\"className\":\"feature-card accent\",\"children\":[[\"$\",\"div\",null,{\"className\":\"feature-icon\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-info-circle\"}]}],[\"$\",\"div\",null,{\"className\":\"insight-tag\",\"children\":\"Music City Dogs\"}],[\"$\",\"h3\",null,{\"children\":\"Nashville's Growth\"}],[\"$\",\"p\",null,{\"children\":[\"Nashville's dog scene has ex