{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/states/layout,_N_T_/states/[slug]/layout,_N_T_/states/[slug]/page,_N_T_/states/washington"},"segmentPaths":["/_tree","/_full","/states/$d$slug/__PAGE__","/states/$d$slug","/states","/_index","/_head"]},"html":"<!DOCTYPE html><!--j39O7b4H81jaidut2lEaa--><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/e4af272ccee01ff0-s.p.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/images/logo/logo.png\" as=\"image\" type=\"image/png\"/><link rel=\"preload\" as=\"image\" href=\"/images/states/washington/hero.webp\"/><link rel=\"preload\" as=\"image\" imageSrcSet=\"/_next/image?url=%2Fimages%2Fcities%2Fseattle%2Fhero.webp&amp;w=256&amp;q=75 256w, /_next/image?url=%2Fimages%2Fcities%2Fseattle%2Fhero.webp&amp;w=384&amp;q=75 384w, /_next/image?url=%2Fimages%2Fcities%2Fseattle%2Fhero.webp&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fimages%2Fcities%2Fseattle%2Fhero.webp&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fimages%2Fcities%2Fseattle%2Fhero.webp&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fimages%2Fcities%2Fseattle%2Fhero.webp&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fimages%2Fcities%2Fseattle%2Fhero.webp&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fimages%2Fcities%2Fseattle%2Fhero.webp&amp;w=1920&amp;q=75 1920w\" imageSizes=\"(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 25vw\"/><link rel=\"preload\" as=\"image\" imageSrcSet=\"/_next/image?url=%2Fimages%2Fcities%2Ftacoma-wa%2Fhero.webp&amp;w=256&amp;q=75 256w, /_next/image?url=%2Fimages%2Fcities%2Ftacoma-wa%2Fhero.webp&amp;w=384&amp;q=75 384w, /_next/image?url=%2Fimages%2Fcities%2Ftacoma-wa%2Fhero.webp&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fimages%2Fcitie