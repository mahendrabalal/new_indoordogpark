06-a2d01a15ee8aa63c.js\",\"4561\",\"static/chunks/4561-fcca530cf2bd8bc5.js\",\"6123\",\"static/chunks/app/states/%5Bslug%5D/page-709f31f79bef81b5.js\"],\"default\"]\n25:I[8437,[\"8500\",\"static/chunks/8500-41fa79ac743d83f1.js\",\"2365\",\"static/chunks/2365-7389548ffb58ad16.js\",\"5772\",\"static/chunks/5772-c985b8ef30d7cbb9.js\",\"7206\",\"static/chunks/7206-a2d01a15ee8aa63c.js\",\"4561\",\"static/chunks/4561-fcca530cf2bd8bc5.js\",\"6123\",\"static/chunks/app/states/%5Bslug%5D/page-709f31f79bef81b5.js\"],\"Image\"]\n19:[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"suppressHydrationWarning\":true,\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://www.indoordogpark.org/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"States\\\",\\\"item\\\":\\\"https://www.indoordogpark.org/states\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"New York\\\",\\\"item\\\":\\\"https://www.indoordogpark.org/states/new-york\\\"}]}\"}}],[\"$\",\"$L11\",null,{\"variant\":\"light\"}],[\"$\",\"$L24\",null,{}],[\"$\",\"main\",null,{\"className\":\"state-page-layout\",\"children\":[[\"$\",\"section\",null,{\"className\":\"state-hero-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell state-hero-shell\",\"children\":[[\"$\",\"div\",null,{\"className\":\"state-hero-copy\",\"children\":[[\"$\",\"nav\",null,{\"className\":\"hero-breadcrumbs\",\"aria-label\":\"Breadcrumb\",\"children\":[[\"$\",\"$L12\",null,{\"href\":\"/\",\"children\":\"Home\"}],[\"$\",\"span\",null,{\"children\":\"›\"}],[\"$\",\"$L12\",null,{\"href\":\"/states\",\"children\":\"States\"}],[\"$\",\"span\",null,{\"children\":\"›\"}],[\"$\",\"span\",null,{\"children\":\"New York\"}]]}],[\"$\",\"div\",null,{\"className\":\"hero-eyebrow\",\"children\":\"Empire State Dog Scene\"}],[\"$\",\"h1\",null,{\"children\":\"Dog Parks in New York\"}],[\"$\",\"div\",null,{\"className\":\"hero-description\",\"children\":[[\"$\",\"p\",\"0\",{\"children\":[\"New York State is home to one of the most vibrant and diverse dog cultures in America, anchored by New York City's legendary park system. Despite the urban density, NYC maintains over 100 designated off-leash areas across its five boroughs, with Central Park's off-leash hours (before 9 AM and after 9 PM) drawing thousands of dogs daily. The city's real estate constraints have driven innovation—rooftop dog parks in Manhattan, underground facilities in Brooklyn, and the famous \\\"dog runs\\\" that transform small urban spaces into social hubs. Beyond the city, Long Island, the Hudson Valley, and Upstate New York offer sprawling parks where dogs can run free.\"]}],[\"$\",\"p\",\"1\",{\"children\":[\"New York's dog culture reflects its diverse population. You'll find luxurious grooming-and-play facilities on the Upper East Side, community-run volunteer-maintained runs in Brooklyn, and massive state park trail systems in the Catskills and Adirondacks. The state's four-season climate means parks adapt throughout the year—heated indoor facilities boom in winter, while summer sees dog-friendly beaches on Long Island draw weekend crowds. Our directory tracks over 180 verified locations across New York State, from Manhattan's compact urban runs to the 50+ acre off-leash areas in Westchester County and beyond.\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-cta-row\",\"children\":[[\"$\",\"$L12\",null,{\"href\":\"/cities\",\"className\":\"hero-cta primary\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-map\"}],\"Browse cities\"]}],[\"$\",\"$L12\",null,{\"href\":\"/list-your-park\",\"className\":\"hero-cta ghost\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-plus-circle\"}],\"Submit a park\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-footnotes\",\"children\":[[\