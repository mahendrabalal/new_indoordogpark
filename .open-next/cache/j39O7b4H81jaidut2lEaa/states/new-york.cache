ype\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://www.indoordogpark.org/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"States\\\",\\\"item\\\":\\\"https://www.indoordogpark.org/states\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"New York\\\",\\\"item\\\":\\\"https://www.indoordogpark.org/states/new-york\\\"}]}\"}}],[\"$\",\"$L2\",null,{\"variant\":\"light\"}],[\"$\",\"$L3\",null,{}],[\"$\",\"main\",null,{\"className\":\"state-page-layout\",\"children\":[[\"$\",\"section\",null,{\"className\":\"state-hero-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell state-hero-shell\",\"children\":[[\"$\",\"div\",null,{\"className\":\"state-hero-copy\",\"children\":[[\"$\",\"nav\",null,{\"className\":\"hero-breadcrumbs\",\"aria-label\":\"Breadcrumb\",\"children\":[[\"$\",\"$L4\",null,{\"href\":\"/\",\"children\":\"Home\"}],[\"$\",\"span\",null,{\"children\":\"›\"}],[\"$\",\"$L4\",null,{\"href\":\"/states\",\"children\":\"States\"}],[\"$\",\"span\",null,{\"children\":\"›\"}],[\"$\",\"span\",null,{\"children\":\"New York\"}]]}],[\"$\",\"div\",null,{\"className\":\"hero-eyebrow\",\"children\":\"Empire State Dog Scene\"}],[\"$\",\"h1\",null,{\"children\":\"Dog Parks in New York\"}],[\"$\",\"div\",null,{\"className\":\"hero-description\",\"children\":[[\"$\",\"p\",\"0\",{\"children\":[\"New York State is home to one of the most vibrant and diverse dog cultures in America, anchored by New York City's legendary park system. Despite the urban density, NYC maintains over 100 designated off-leash areas across its five boroughs, with Central Park's off-leash hours (before 9 AM and after 9 PM) drawing thousands of dogs daily. The city's real estate constraints have driven innovation—rooftop dog parks in Manhattan, underground facilities in Brooklyn, and the famous \\\"dog runs\\\" that transform small urban spaces into social hubs. Beyond the city, Long Island, the Hudson Valley, and Upstate New York offer sprawling parks where dogs can run free.\"]}],[\"$\",\"p\",\"1\",{\"children\":[\"New York's dog culture reflects its diverse population. You'll find luxurious grooming-and-play facilities on the Upper East Side, community-run volunteer-maintained runs in Brooklyn, and massive state park trail systems in the Catskills and Adirondacks. The state's four-season climate means parks adapt throughout the year—heated indoor facilities boom in winter, while summer sees dog-friendly beaches on Long Island draw weekend crowds. Our directory tracks over 180 verified locations across New York State, from Manhattan's compact urban runs to the 50+ acre off-leash areas in Westchester County and beyond.\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-cta-row\",\"children\":[[\"$\",\"$L4\",null,{\"href\":\"/cities\",\"className\":\"hero-cta primary\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-map\"}],\"Browse cities\"]}],[\"$\",\"$L4\",null,{\"href\":\"/list-your-park\",\"className\":\"hero-cta ghost\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-plus-circle\"}],\"Submit a park\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-footnotes\",\"children\":[[\"$\",\"span\",\"NYC all five boroughs covered\",{\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-arrow-repeat\"}],\" \",\"NYC all five boroughs covered\"]}],[\"$\",\"span\",\"Upstate trails included\",{\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-arrow-repeat\"}],\" \",\"Upstate trails included\"]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"state-hero-visual\",\"children\":[\"$\",\"div\",null,{\"className\":\"hero-image-card\",\"children\":[[\"$\",\"$L5\",null,{\"src\":\"/images/states/new-york/hero.webp\",\"alt\":\"New York dog park landscape\",\"fill\":true,\"priority\":true,\"sizes\":\"(max-width: 900px) 100vw, 40vw\",\"style\":{\"objectFit\":\"cover\"},\"unoptimized\":true}],[\"$\",\"div