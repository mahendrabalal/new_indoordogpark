{\"href\":\"/cities/san-francisco\",\"className\":\"rounded-full border border-gray-300 px-4 py-2 text-sm text-gray-700 transition hover:border-purple-500 hover:text-purple-600\",\"children\":\"San Francisco\"}],[\"$\",\"$L12\",null,{\"href\":\"/cities/san-diego\",\"className\":\"rounded-full border border-gray-300 px-4 py-2 text-sm text-gray-700 transition hover:border-purple-500 hover:text-purple-600\",\"children\":\"San Diego\"}],[\"$\",\"$L12\",null,{\"href\":\"/blog\",\"className\":\"rounded-full border border-gray-300 px-4 py-2 text-sm text-gray-700 transition hover:border-purple-500 hover:text-purple-600\",\"children\":\"Dog Park Tips\"}]]}]]}]\n19:[\"$\",\"p\",null,{\"children\":\"© 2025 IndoorDogPark. All rights reserved\"}]\n1a:[\"$\",\"div\",null,{\"className\":\"footer-bottom-links\",\"children\":[[\"$\",\"$L12\",null,{\"href\":\"/terms\",\"children\":\"Terms\"}],[\"$\",\"$L12\",null,{\"href\":\"/privacy\",\"children\":\"Privacy\"}],[\"$\",\"$L12\",null,{\"href\":\"/cookie-preferences\",\"children\":\"Cookie Preferences\"}]]}]\n1c:[\"$\",\"div\",null,{\"className\":\"timeline-year\",\"children\":\"Research\"}]\n1d:[\"$\",\"p\",null,{\"children\":\"We research and verify indoor dog parks, daycare centers, and training facilities to ensure accurate, up-to-date information for pet parents.\"}]\n1e:[\"$\",\"div\",null,{\"className\":\"timeline-item\",\"children\":[[\"$\",\"div\",null,{\"className\":\"timeline-dot timeline-pink\"}],[\"$\",\"div\",null,{\"className\":\"timeline-card\",\"children\":[[\"$\",\"div\",null,{\"className\":\"timeline-year\",\"children\":\"Organize\"}],[\"$\",\"p\",null,{\"children\":[\"We organize listings with detailed amenities, hours, pricing, and photos so you can compare options and find the perfect fit for your dog. Learn more about \",[\"$\",\"$L12\",null,{\"href\":\"/how-it-works\",\"style\":{\"color\":\"#2c3e50\",\"textDecoration\":\"underline\",\"fontWeight\":600},\"children\":\"how our directory works\"}],\".\"]}]]}]]}]\n1f:[\"$\",\"div\",null,{\"className\":\"timeline-item\",\"children\":[[\"$\",\"div\",null,{\"className\":\"timeline-dot timeline-green\"}],[\"$\",\"div\",null,{\"className\":\"timeline-card\",\"children\":[[\"$\",\"div\",null,{\"className\":\"timeline-year\",\"children\":\"Connect\"}],[\"$\",\"p\",null,{\"children\":\"We connect dog owners with facilities through our directory, helping parks reach new customers and helping owners discover new spaces.\"}]]}]]}]\n20:[\"$\",\"div\",null,{\"className\":\"timeline-item\",\"children\":[[\"$\",\"div\",null,{\"className\":\"timeline-dot timeline-green\"}],[\"$\",\"div\",null,{\"className\":\"timeline-card\",\"children\":[[\"$\",\"div\",null,{\"className\":\"timeline-year\",\"children\":\"Before You Go\"}],[\"$\",\"p\",null,{\"children\":\"Ensure your dog is up-to-date on vaccinations and has received a clean bill of health from your veterinarian. Many facilities require proof of vaccinations before entry. Call ahead to understand specific requirements, reservation policies, and what to bring.\"}]]}]]}]\n21:[\"$\",\"div\",null,{\"className\":\"timeline-item\",\"children\":[[\"$\",\"div\",null,{\"className\":\"timeline-dot timeline-pink\"}],[\"$\",\"div\",null,{\"className\":\"timeline-card\",\"children\":[[\"$\",\"div\",null,{\"className\":\"timeline-year\",\"children\":\"During Your Visit\"}],[\"$\",\"p\",null,{\"children\":\"Supervise your dog closely, especially during the first few visits. Be aware of your dog's body language and stress signals. Respect other dogs' space and follow facility rules regarding toys, treats, and play styles. Keep your phone accessible but avoid distractions that prevent proper supervision.\"}]]}]]}]\n22:[\"$\",\"div\",null,{\"className\":\"timeline-item\",\"children\":[[\"$\",\"div\",null,{\"className\":\"timeline-dot timeline-green\"}],[\"$\",\"div\",null,{\"className\":\"timeline-card\",\"children\":[[\"$\",\"div\",null,{\"className\":\"timeline-year\",\"children\":\"Making It a Success\"}],[\"$\",\"p\",null,{\"children\":\"Start with shorter visits during off-peak hours when the facility is less crowded. Gradually increase visit duration as your dog becomes more comfortable. Bring water, clean-up supplies, and any necessary medications. Take advantage of staff knowledge—they can offer valuable insights about facility features and dog behavior.\"}]]}]]}]\n23:[\"$\",\"section\",null,{\"className\":\"about-modern-section\",\"style\":{\"padding\":\"40px 20px\"},\"children\":[\"$\",\"div\",null,{\"className\":\"about-modern-container\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"about-modern-section-title-center\",\"children\":\"Our Commitment\"}],[\"$\",\"div\",null,{\"className\":\"about-modern-values-grid\",\"children\":[[\"$\",\"div\",null,{\"className\":\"about-modern-value-card\",\"children\":[[\"$\",\"div\",null,{\"className\":\"value-icon-modern value-icon-green\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-check-circle-fill\"}]}],[\"$\",\"h3\",null,{\"children\":\"Accurate Information\"}],[\"$\",\"p\",null,{\"children\":\"We verify listings and regularly update our directory to ensure the information you find is current and reliable.\"}]]}],[\"$\",\"div\",null,{\"className\":\"about-modern-value-card\",\"children\":[[\"$\",\"div\",null,{\"className\":\"value-icon-modern value-icon-pink\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-unlock-fill\"}]}],[\"$\",\"h3\",null,{\"children\":\"Free to Use\"}],[\"$\",\"p\",null,{\"children\":\"Our directory is free for dog owners. We believe everyone should have access to information about safe play spaces for their pets.\"}]]}],[\"$\",\"div\",null,{\"className\":\"about-modern-value-card\",\"children\":[[\"$\",\"div\",null,{\"className\":\"value-icon-modern value-icon-green\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-shield-check-fill\"}]}],[\"$\",\"h3\",null,{\"children\":\"Community First\"}],[\"$\",\"p\",null,{\"children\":[\"Park owners can \",[\"$\",\"$L12\",null,{\"href\":\"/list-your-park\",\"style\":{\"color\":\"#2c3e50\",\"textDecoration\":\"underline\",\"fontWeight\":600},\"children\":\"list their facilities\"}],\", and dog owners can submit new discoveries. We grow through community contributions.\"]}]]}]]}]]}]}]\n24:[\"$\",\"section\",null,{\"className\":\"about-modern-section-alt\",\"style\":{\"padding\":\"40px 20px\"},\"children\":[\"$\",\"div\",null,{\"className\":\"about-modern-container\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"about-modern-section-title-center\",\"children\":\"Why Indoor Dog Parks Matter\"}],[\"$\",\"div\",null,{\"className\":\"about-modern-content-layout\",\"children\":[[\"$\",\"div\",null,{\"className\":\"about-modern-text-content\",\"children\":[[\"$\",\"p\",null,{\"className\":\"about-modern-text\",\"children\":[\"Indoor dog parks have emerged as a vital solution for pet owners across America, addressing challenges that traditional outdoor parks cannot. As our communities face increasingly unpredictable weather patterns, extreme temperatures, and urbanization, the need for climate-controlled canine recreation spaces has never been more apparent. Unlike traditional dog parks that leave pets exposed to harsh weather conditions, indoor facilities provide a safe, comfortable environment year-round. Whether it's scorching summer heat, freezing winter temperatures, heavy rainfall, or poor air quality from wildfires, indoor dog parks ensure your furry friend can exercise and socialize in optimal conditions. Read more about the benefits in our \",[\"$\",\"$L12\",null,{\"href\":\"/blog\",\"style\":{\"color\":\"#2c3e50\",\"textDecoration\":\"underline\",\"fontWeight\":600},\"children\":\"blog articles\"}],\" and \",[\"$\",\"$L12\",null,{\"href\":\"/faq\",\"style\":{\"color\":\"#2c3e50\",\"textDecoration\":\"underline\",\"fontWeight\":600},\"children\":\"frequently asked questions\"}],\".\"]}],[\"$\",\"h3\",null,{\"className\":\"about-modern-section-title\",\"style\":{\"fontSize\":\"1.5rem\",\"marginTop\":\"30px\",\"marginBottom\":\"15px\"},\"children\":\"Health and Safety Benefits\"}],[\"$\",\"p\",null,{\"className\":\"about-modern-text\",\"children\":\"Indoor dog parks offer numerous health and safety advantages. Controlled environments reduce the risk of heatstroke during summer months and hypothermia in winter. Surfaces are typically softer and more forgiving than concrete or packed dirt, reducing joint stress and injury risk. Many facilities also implement strict vaccination requirements and health screenings, creating safer spaces for all dogs. These facilities often feature better lighting, security measures, and staff supervision compared to public outdoor parks. Owners can exercise their dogs without worrying about unleashed aggressive animals, inadequate fencing, or unsafe equipment. For senior dogs, puppies, or dogs with mobility issues, indoor parks provide a more accessible and accommodating space for exercise.\"}]]}],[\"$\",\"div\",null,{\"className\":\"about-modern-image-content\",\"children\":[\"$\",\"figure\",null,{\"style\":{\"margin\":0},\"children\":[[\"$\",\"$L1b\",null,{\"src\":\"/images/about/indoordogpark-health-&-safety.jpg\",\"alt\":\"Indoor dog park with multiple dogs playing safely in a climate-controlled environment with soft surfaces and proper supervision\",\"width\":600,\"height\":500,\"style\":{\"width\":\"100%\",\"height\":\"500px\",\"borderRadius\":\"1rem\",\"objectFit\":\"cover\",\"objectPosition\":\"center\"}}],[\"$\",\"figcaption\",null,{\"style\":{\"textAlign\":\"center\",\"marginTop\":\"0.75rem\",\"fontSize\":\"0.875rem\",\"color\":\"#64748b\",\"fontStyle\":\"italic\"},\"children\":\"Indoor dog parks provide safe, comfortable environments regardless of weather\"}]]}]}]]}]]}]}]\n25:[\"$\",\"section\",null,{\"className\":\"about-modern-section\",\"style\":{\"padding\":\"40px 20px\"},\"children\":[\"$\",\"div\",null,{\"className\":\"about-modern-container\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"about-modern-section-title-center\",\"children\":\"What to Look for in an Indoor Dog Park\"}],[\"$\",\"p\",null,{\"className\":\"about-modern-text\",\"style\":{\"textAlign\":\"center\",\"maxWidth\":\"900px\",\"margin\":\"0 auto 40px\",\"fontSize\":\"1.1rem\"},\"children\":[\"Choosing the right indoor dog park involves considering several important factors to ensure a safe, enjoyable experience for both you and your pet. Check out our \",[\"$\",\"$L12\",null,{\"href\":\"/how-it-works\",\"style\":{\"color\":\"#2c3e50\",\"textDecoration\":\"underline\",\"fontWeight\":600},\"children\":\"guide on how to use our directory\"}],\" and explore \",[\"$\",\"$L12\",null,{\"href\":\"/blog\",\"style\":{\"color\":\"#2c3e50\",\"textDecoration\":\"underline\",\"fontWeight\":600},\"children\":\"helpful articles\"}],\" for more tips.\"]}],[\"$\",\"div\",null,{\"className\":\"about-modern-values-grid\",\"children\":[[\"$\",\"div\",null,{\"className\":\"about-modern-value-card\",\"children\":[[\"$\",\"div\",null,{\"className\":\"value-icon-modern value-icon-green\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-shield-check-fill\"}]}],[\"$\",\"h3\",null,{\"children\":\"Safety Measures\"}],[\"$\",\"p\",null,{\"children\":\"Look for facilities with proper fencing, secure entry systems, vaccination requirements, and trained staff who monitor play sessions. Well-maintained equipment and non-slip surfaces are essential for preventing injuries.\"}]]}],[\"$\",\"div\",null,{\"className\":\"about-modern-value-card\",\"children\":[[\"$\",\"div\",null,{\"className\":\"value-icon-modern value-icon-pink\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-thermometer-half\"}]}],[\"$\",\"h3\",null,{\"children\":\"Climate Control\"}],[\"$\",\"p\",null,{\"children\":\"Effective heating, cooling, and ventilation systems ensure comfortable temperatures year-round. Good air quality and proper humidity levels are crucial for canine respiratory health and comfort.\"}]]}],[\"$\",\"div\",null,{\"className\":\"about-modern-value-card\",\"children\":[[\"$\",\"div\",null,{\"className\":\"value-icon-modern value-icon-green\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-rulers\"}]}],[\"$\",\"h3\",null,{\"children\":\"Size and Layout\"}],[\"$\",\"p\",null,{\"children\":\"Consider the size of play areas relative to your dog's needs. Some facilities offer separate spaces for large and small dogs, active and passive play zones, and specialized areas for training or agility.\"}]]}],[\"$\",\"div\",null,{\"className\":\"about-modern-value-card\",\"children\":[[\"$\",\"div\",null,{\"className\":\"value-icon-modern value-icon-pink\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-list-check\"}]}],[\"$\",\"h3\",null,{\"children\":\"Amenities\"}],[\"$\",\"p\",null,{\"children\":\"Modern indoor parks often include water stations, waste stations, seating areas, viewing areas, training equipment, grooming facilities, and retail shops. Some even offer daycare services and training classes.\"}]]}],[\"$\",\"div\",null,{\"className\":\"about-modern-value-card\",\"children\":[[\"$\",\"div\",null,{\"className\":\"value-icon-modern value-icon-green\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-clock-history\"}]}],[\"$\",\"h3\",null,{\"children\":\"Operating Hours\"}],[\"$\",\"p\",null,{\"children\":\"Flexible scheduling is important for working pet parents. Many indoor facilities offer extended hours, weekend availability, and reservation systems to accommodate busy lifestyles.\"}]]}],[\"$\",\"div\",null,{\"className\":\"about-modern-value-card\",\"children\":[[\"$\",\"div\",null,{\"className\":\"value-icon-modern value-icon-pink\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-currency-dollar\"}]}],[\"$\",\"h3\",null,{\"children\":\"Pricing Structure\"}],[\"$\",\"p\",null,{\"children\":\"Compare membership fees, day pass rates, and package deals. Consider whether the facility offers trial passes, referral discounts, or special rates for seniors, students, or multiple-dog households.\"}]]}]]}]]}]}]\n26:[\"$\",\"section\",null,{\"className\":\"about-modern-section-alt\",\"style\":{\"padding\":\"40px 20px\"},\"children\":[\"$\",\"div\",null,{\"className\":\"about-modern-container\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"about-modern-section-title-center\",\"children\":\"Benefits for Every Type of Dog\"}],[\"$\",\"div\",null,{\"className\":\"about-modern-content-layout\",\"children\":[[\"$\",\"div\",null,{\"className\":\"about-modern-text-content\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"about-modern-section-title\",\"style\":{\"fontSize\":\"1.5rem\",\"marginBottom\":\"15px\"},\"children\":\"Puppies and Young Dogs\"}],[\"$\",\"p\",null,{\"className\":\"about-modern-text\",\"children\":[\"Indoor dog parks are ideal environments for puppy socialization and early training. Controlled settings allow young dogs to interact with others in a safe, supervised space while learning appropriate play behaviors. Consistent temperatures and clean surfaces reduce health risks for developing immune systems. Find \",[\"$\",\"$L12\",null,{\"href\":\"/\",\"style\":{\"color\":\"#2c3e50\",\"textDecoration\":\"underline\",\"fontWeight\":600},\"children\":\"puppy-friendly facilities\"}],\" in our directory.\"]}],[\"$\",\"h3\",null,{\"className\":\"about-modern-section-title\",\"style\":{\"fontSize\":\"1.5rem\",\"marginTop\":\"30px\",\"marginBottom\":\"15px\"},\"children\":\"Senior Dogs\"}],[\"$\",\"p\",null,{\"className\":\"about-modern-text\",\"children\":\"Older dogs benefit from indoor parks' softer surfaces, which are easier on aging joints and paws. Climate-controlled environments prevent temperature-related stress, while smaller, quieter spaces can accommodate dogs who prefer calmer interactions. Many facilities offer senior-specific play times with reduced noise and activity levels.\"}],[\"$\",\"h3\",null,{\"className\":\"about-modern-section-title\",\"style\":{\"fontSize\":\"1.5rem\",\"marginTop\":\"30px\",\"marginBottom\":\"15px\"},\"children\":\"High-Energy Breeds\"}],[\"$\",\"p\",null,{\"className\":\"about-modern-text\",\"children\":\"Breeds requiring extensive exercise benefit from indoor parks' year-round availability. Regardless of weather conditions, these dogs can maintain their exercise routines, preventing destructive behaviors that arise from pent-up energy. Many facilities feature agility equipment and larger play spaces designed for active breeds.\"}],[\"$\",\"h3\",null,{\"className\":\"about-modern-section-title\",\"style\":{\"fontSize\":\"1.5rem\",\"marginTop\":\"30px\",\"marginBottom\":\"15px\"},\"children\":\"Small and Toy Breeds\"}],[\"$\",\"p\",null,{\"className\":\"about-modern-text\",\"children\":\"Many indoor facilities offer separate play areas specifically designed for smaller dogs, preventing overwhelming interactions with larger breeds. These spaces provide safe environments where small dogs can socialize and exercise without intimidation or risk of injury.\"}]]}],[\"$\",\"div\",null,{\"className\":\"about-modern-image-content\",\"children\":[\"$\",\"figure\",null,{\"style\":{\"margin\":0},\"children\":[[\"$\",\"$L1b\",null,{\"src\":\"/images/about/indoordogpark-all-age-size.jpg\",\"alt\":\"Dogs of various ages, sizes, and breeds playing together in an indoor dog park facility\",\"width\":600,\"height\":500,\"style\":{\"width\":\"100%\",\"height\":\"500px\",\"borderRadius\":\"1rem\",\"objectFit\":\"cover\",\"objectPosition\":\"center\"}}],[\"$\",\"figcaption\",null,{\"style\":{\"textAlign\":\"center\",\"marginTop\":\"0.75rem\",\"fontSize\":\"0.875rem\",\"color\":\"#64748b\",\"fontStyle\":\"italic\"},\"children\":\"Every dog can benefit from indoor recreation facilities\"}]]}]}]]}]]}]}]\n27:[\"$\",\"section\",null,{\"className\":\"about-modern-section\",\"style\":{\"padding\":\"40px 20px\"},\"children\":[\"$\",\"div\",null,{\"className\":\"about-modern-container\",\"children\":[\"$\",\"div\",null,{\"className\":\"about-modern-content-layout\",\"children\":[[\"$\",\"div\",null,{\"className\":\"about-modern-image-content\",\"children\":[\"$\",\"figure\",null,{\"style\":{\"margin\":0},\"children\":[[\"$\",\"$L1b\",null,{\"src\":\"/images/about/trend-of-indoordogpark.jpg\",\"alt\":\"A vibrant indoor dog park with multiple dogs playing and owners socializing, showing the growing trend of climate-controlled canine recreation facilities\",\"width\":600,\"height\":500,\"style\":{\"width\":\"100%\",\"height\":\"500px\",\"borderRadius\":\"1rem\",\"objectFit\":\"cover\",\"objectPosition\":\"center\"}}],[\"$\",\"figcaption\",null,{\"style\":{\"textAlign\":\"center\",\"marginTop\":\"0.75rem\",\"fontSize\":\"0.875rem\",\"color\":\"#64748b\",\"fontStyle\":\"italic\"},\"children\":\"The future of canine recreation is climate-controlled\"}]]}]}],[\"$\",\"div\",null,{\"className\":\"about-modern-text-content\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"about-modern-section-title\",\"children\":\"The Growing Trend of Indoor Dog Parks\"}],[\"$\",\"p\",null,{\"className\":\"about-modern-text\",\"children\":[\"The indoor dog park industry has experienced significant growth over the past decade, driven by changing climate patterns, increased urbanization, and a greater understanding of canine wellness needs. What began as a niche concept in metropolitan areas has expanded into a nationwide movement. Major cities across the United States now host multiple indoor dog park facilities, each offering unique amenities and services. From basic climate-controlled play spaces to luxury facilities featuring swimming pools, grooming salons, and cafés, the industry continues to evolve to meet diverse owner and pet needs. Explore facilities by \",[\"$\",\"$L12\",null,{\"href\":\"/states\",\"style\":{\"color\":\"#2c3e50\",\"textDecoration\":\"underline\",\"fontWeight\":600},\"children\":\"state\"}],\" or read more about this trend in our \",[\"$\",\"$L12\",null,{\"href\":\"/blog\",\"style\":{\"color\":\"#2c3e50\",\"textDecoration\":\"underline\",\"fontWeight\":600},\"children\":\"blog\"}],\".\"]}],[\"$\",\"p\",null,{\"className\":\"about-modern-text\",\"children\":\"This growth reflects a broader shift in how pet owners view their dogs' needs. Modern pet parents recognize that exercise and socialization are essential components of canine health and wellbeing, and they're seeking reliable, consistent solutions that aren't dependent on weather conditions or outdoor park availability. As more facilities open and existing ones expand, indoor dog parks are becoming integral parts of pet-friendly communities. They serve as gathering places for dog owners, support local economies, and contribute to overall community health by promoting responsible pet ownership and canine wellness.\"}]]}]]}]}]}]\n28:[\"$\",\"section\",null,{\"className\":\"about-modern-section-alt\",\"style\":{\"padding\":\"40px 20px\"},\"children\":[\"$\",\"div\",null,{\"className\":\"about-modern-container\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"about-modern-section-title-center\",\"children\":\"Who We Serve\"}],[\"$\",\"div\",null,{\"className\":\"about-modern-partners-grid\",\"children\":[[\"$\",\"div\",null,{\"className\":\"about-modern-partner-card\",\"children\":[\"$\",\"$L12\",null,{\"href\":\"/\",\"style\":{\"color\":\"inherit\",\"textDecoration\":\"none\"},\"children\":\"DOG OWNERS\"}]}],[\"$\",\"div\",null,{\"className\":\"about-modern-partner-card\",\"children\":[\"$\",\"$L12\",null,{\"href\":\"/list-your-park\",\"style\":{\"color\":\"inherit\",\"textDecoration\":\"none\"},\"children\":\"PARK OPERATORS\"}]}],[\"$\",\"div\",null,{\"className\":\"about-modern-partner-card\",\"children\":[\"$\",\"$L12\",null,{\"href\":\"/list-your-park\",\"style\":{\"color\":\"inherit\",\"textDecoration\":\"none\"},\"children\":\"DAYCARE FACILITIES\"}]}],[\"$\",\"div\",null,{\"className\":\"about-modern-partner-card\",\"children\":[\"$\",\"$L12\",null,{\"href\":\"/list-your-park\",\"style\":{\"color\":\"inherit\",\"textDecoration\":\"none\"},\"children\":\"TRAINING CENTERS\"}]}]]}]]}]}]\n29:[\"$\",\"section\",null,{\"className\":\"about-modern-cta\",\"children\":[\"$\",\"div\",null,{\"className\":\"about-modern-container\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"about-modern-cta-title\",\"children\":\"Have a Park to Add?\"}],[\"$\",\"p\",null,{\"className\":\"about-modern-cta-text\",\"children\":\"Know of an indoor dog park that's not in our directory? Own a facility you'd like listed? We welcome submissions from the community.\"}],[\"$\",\"div\",null,{\"className\":\"about-modern-cta-buttons\",\"children\":[[\"$\",\"$L12\",null,{\"href\":\"/list-your-park\",\"className\":\"btn-modern-green\",\"children\":\"Submit a Park\"}],[\"$\",\"$L12\",null,{\"href\":\"/contact\",\"className\":\"btn-modern-pink\",\"children\":\"Contact Us\"}]]}]]}]}]\n2a:[\"$\",\"footer\",null,{\"className\":\"footer-new\",\"children\":[\"$\",\"div\",null,{\"className\":\"footer-container\",\"children\":[[\"$\",\"div\",null,{\"className\":\"footer-grid\",\"children\":[[\"$\",\"div\",null,{\"className\":\"footer-column\",\"children\":[[\"$\",\"h4\",null,{\"className\":\"footer-heading\",\"children\":\"IndoorDogPark\"}],[\"$\",\"ul\",null,{\"className\":\"footer-links\",\"children\":[[\"$\",\"li\",null,{\"children\":[\"$\",\"$L12\",null,{\"href\":\"/about\",\"children\":\"About us\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L12\",null,{\"href\":\"/partners\",\"children\":\"Partners\"}]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"footer-column\",\"children\":[[\"$\",\"h4\",null,{\"className\":\"footer-heading\",\"children\":\"Discover\"}],[\"$\",\"ul\",null,{\"className\":\"footer-links\",\"children\":[[\"$\",\"li\",null,{\"children\":[\"$\",\"$L12\",null,{\"href\":\"/\",\"children\":\"Browse parks\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L12\",null,{\"href\":\"/how-it-works\",\"children\":\"How it works\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L12\",null,{\"href\":\"/blog\",\"children\":\"Blog\"}]}]]}]]}]