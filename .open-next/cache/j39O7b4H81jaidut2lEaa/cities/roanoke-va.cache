ll,{\"type\":\"application/ld+json\",\"suppressHydrationWarning\":true,\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"FAQPage\\\",\\\"mainEntity\\\":[{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"Are there indoor dog parks in Roanoke, VA?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"Currently, Roanoke features several high-quality outdoor off-leash parks and professional indoor boarding/daycare facilities like B & B K-9 Kennels. Check our directory for the latest indoor play updates.\\\"}},{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"What are the rules for dog licensing in Roanoke?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"All dogs 4 months or older must be licensed with the City of Roanoke. You need a current rabies certificate and licenses must be renewed by January 1st each year.\\\"}}]}\"}}]\n27:[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"suppressHydrationWarning\":true,\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://www.indoordogpark.org/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Dog Parks Directory\\\",\\\"item\\\":\\\"https://www.indoordogpark.org/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Roanoke\\\"}]}\"}}]\n28:[\"$\",\"$L11\",null,{\"variant\":\"light\"}]\n29:[\"$\",\"$L2e\",null,{\"items\":[{\"id\":\"city-hero\",\"title\":\"City Overview\",\"level\":1},{\"id\":\"city-insights\",\"title\":\"Quick Facts\",\"level\":1},{\"id\":\"city-comparison\",\"title\":\"Top Comparisons\",\"level\":1},{\"id\":\"park-collections\",\"title\":\"Park Collections\",\"level\":1},{\"id\":\"neighborhood-clusters\",\"title\":\"Neighborhoods\",\"level\":1},{\"id\":\"park-types-guide\",\"title\":\"Park Type Guide\",\"level\":1},{\"id\":\"map-and-neighborhoods\",\"title\":\"Map & Neighborhoods\",\"level\":1},{\"id\":\"planning-essentials\",\"title\":\"Planning Essentials\",\"level\":1},{\"id\":\"expert-tips\",\"title\":\"Expert Advice\",\"level\":1},{\"id\":\"park-directory\",\"title\":\"Full Directory\",\"level\":1},{\"id\":\"owner-cta\",\"title\":\"Owner & Franchise\",\"level\":1},{\"id\":\"faq-section\",\"title\":\"FAQs\",\"level\":1},{\"id\":\"related-resources\",\"title\":\"More Resources\",\"level\":1}]}]\n2a:[\"$\",\"main\",null,{\"className\":\"city-page-layout\",\"children\":[[\"$\",\"div\",null,{\"className\":\"mobile-toc-button\",\"children\":[\"$\",\"$L2f\",null,{\"className\":\"mobile-toc-trigger\",\"targetSelector\":\".table-of-contents\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-list-ul\"}],[\"$\",\"span\",null,{\"children\":\"Contents\"}]]}]}],[\"$\",\"section\",null,{\"id\":\"city-hero\",\"className\":\"city-hero-section \",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell city-hero-shell\",\"children\":[[\"$\",\"div\",null,{\"className\":\"city-hero-copy\",\"children\":[[\"$\",\"div\",null,{\"className\":\"hero-breadcrumbs\",\"children\":[[\"$\",\"$L12\",null,{\"href\":\"/\",\"children\":\"Home\"}],[\"$\",\"i\",null,{\"className\":\"bi bi-chevron-right\"}],[\"$\",\"span\",null,{\"children\":\"Dog Parks Directory\"}],[\"$\",\"i\",null,{\"className\":\"bi bi-chevron-right\"}],[\"$\",\"strong\",null,{\"children\":\"Roanoke\"}]]}],[\"$\",\"p\",null,{\"className\":\"hero-eyebrow\",\"children\":\"City spotlight\"}],[\"$\",\"h1\",null,{\"children\":\"Dog-Friendly Roanoke\"}],\"$undefined\",[\"$\",\"p\",null,{\"className\":\"hero-description\",\"children\":\"Experience the Star City's blend of mountain adventure and urban dog parks along the Blue Ridge.\"}],[\"$\",\"div\",null,{\"className\":\"city-rich-description\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"rich-description-paragraph\",\"children\":[\"Roanoke, the \\\"Star City\\\" of the Blue Ridge, offers a stunning backdrop for pet owners who value both mountain adventure and urban play. The region is anchored by \",[\"$\",\"$L12\",\"1\",{\"href\":\"https://www.playroanoke.com/parks-facilities/thrasher-park/\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"rich-link\",\"children\":\"Thrasher Park\"}],null,\", featuring separate grassy enclosures for different-sized breeds. In the historic center, \",[\"$\",\"$L12\",\"4\",{\"href\":\"https://www.petdata.com/for-pet-owners/rnk/license-online\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"rich-link\",\"children\":\"Highland Park\"}],null,\" provides a spacious one-acre run with a dedicated puppy section, ensuring safe socialization. Nearby, the wood-chipped \",[\"$\",\"$L12\",\"7\",{\"href\":\"https://www.salemva.gov/Facilities/Facility/Details/Rotary-Dog-Park-14\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"rich-link\",\"children\":\"Salem Rotary Dog Park\"}],null,\" offers a shaded alternative for summer heat. This park network, integrated with the \",[\"$\",\"$L12\",\"10\",{\"href\":\"https://www.playroanoke.com/greenways/\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"rich-link\",\"children\":\"Roanoke Valley Greenways\"}],null,\", creates an ideal environment for active pups to explore.\"]}],[\"$\",\"p\",\"1\",{\"className\":\"rich-description-paragraph\",\"children\":[\"Navigating local regulations is key for Roanoke pet owners. All dogs aged four months or older must be licensed annually with a current rabies certificate. The city also enforces strict tethering laws—limiting it to three hours during the day and prohibiting it at night—to ensure humane care. For premium services, B & B K-9 Kennels (5.0★) leads the valley in quality. By balancing these standards with dog-friendly breweries and shaded trails, Roanoke provides a safe \\\"third place\\\" for the canine community. Whether visiting for a weekend hike or living downtown, owners can rely on our \",[\"$\",\"$L12\",\"1\",{\"href\":\"https://www.indoordogpark.org/owner-resources\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"rich-link\",\"children\":\"owner resources\"}],null,\" for expert local guidance.\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-cta-row\",\"children\":[[\"$\",\"$L2f\",null,{\"className\":\"hero-cta primary\",\"targetId\":\"park-directory\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-list-check\"}],\"Browse directory\"]}],[\"$\",\"$L2f\",null,{\"className\":\"hero-cta ghost\",\"targetId\":\"map-and-neighborhoods\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-geo-alt\"}],\"Open map\"]}],[\"$\",\"$L12\",null,{\"href\":\"/list-your-park\",\"className\":\"hero-cta text-link\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-plus-circle\"}],\"Submit a park\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-footnotes\",\"children\":[[\"$\",\"span\",\"Data refreshed weekly\",{\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-sparkles\"}],\" \",\"Data refreshed weekly\"]}],\"$L30\"]}]]}],\"$L31\"]}]}],\"$L32\",\"$L33\",\"$L34\",\"$L35\",\"$L36\",\"$L37\",\"$L38\",\"$L39\",\"$L3a\",\"$L3b\",\"$L3c\",\"$L3d\"]}]\n2b:[\"$\",\"footer\",null,{\"className\":\"footer-new\",\"children\":[\"$\",\"div\",null,{\"className\":\"footer-container\",\"children\":[[\"$\",\"div\",null,{\"className\":\"footer-grid\",\"children\":[[\"$\",\"div\",null,{\"className\":\"footer-column\",\"children\":[[\"$\",\"h4\",null,{\"className\":\"footer-heading\",\"children\":\"IndoorDogPark\"}],[\"$\",\"ul\",null,{\"className\":\"footer-links\",\"children\":[[\"$\",\"li\",null,{\"children\":[\"$\",\"$L12\",null,{\"href\":\"/about\",\"children\":\"About us\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L12\",null,{\"href\":\"/partners\",\"children\":\"Partners\"}]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"footer-column\"