3\\\",null,{\\\"children\\\":\\\"Feature your park\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Upgrade to a featured listing and reach active pet parents.\\\"}],[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-arrow-up-right\\\"}]]}],[\\\"$\\\",\\\"$L12\\\",null,{\\\"href\\\":\\\"/blog\\\",\\\"className\\\":\\\"resource-card\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"resource-icon\\\",\\\"children\\\":[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-journal-text\\\"}]}],[\\\"$\\\",\\\"h3\\\",null,{\\\"children\\\":\\\"Latest guides\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Training tips, travel itineraries, and product spotlights.\\\"}],[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-arrow-up-right\\\"}]]}]]}]]}]}]\\n\"])</script><script>self.__next_f.push([1,\"3d:[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"© 2025 IndoorDogPark. All rights reserved\\\"}]\\n3e:[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"footer-bottom-links\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L12\\\",null,{\\\"href\\\":\\\"/terms\\\",\\\"children\\\":\\\"Terms\\\"}],[\\\"$\\\",\\\"$L12\\\",null,{\\\"href\\\":\\\"/privacy\\\",\\\"children\\\":\\\"Privacy\\\"}],[\\\"$\\\",\\\"$L12\\\",null,{\\\"href\\\":\\\"/cookie-preferences\\\",\\\"children\\\":\\\"Cookie Preferences\\\"}]]}]\\n\"])</script><script>self.__next_f.push([1,\"4a:I[6869,[],\\\"IconMark\\\"]\\n1c:null\\n\"])</script><script>self.__next_f.push([1,\"20:[[\\\"$\\\",\\\"title\\\",\\\"0\\\",{\\\"children\\\":\\\"Dog Parks in Columbia, TN | Map \\u0026 Reviews | Indoor Dog Park\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"1\\\",{\\\"name\\\":\\\"description\\\",\\\"content\\\":\\\"Explore 31 dog parks and dog-friendly spots in Columbia. Compare ratings, amenities, hours, and map locations.\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"2\\\",{\\\"name\\\":\\\"application-name\\\",\\\"content\\\":\\\"Indoor Dog Park\\\"}],[\\\"$\\\",\\\"link\\\",\\\"3\\\",{\\\"rel\\\":\\\"author\\\",\\\"