n Rd\",\"city\":\"Columbia\",\"state\":\"TN\",\"zipCode\":\"38401\",\"full_address\":\"1419 Hardison Rd, Columbia, TN 38401, USA\",\"latitude\":35.7461902,\"longitude\":-87.0170144,\"googlePlaceId\":\"ChIJo1ryyRp7Y4gRKN_YVoj93LQ\",\"phone\":\"(931) 623-3005\",\"website\":\"http://www.afreedomjourney.com/\",\"photos\":null,\"rating\":4.3,\"reviewCount\":23,\"openingHours\":{},\"amenities\":{\"Onsite services\":true,\"Indoor facilities\":true,\"Professional staff\":true,\"Climate controlled\":true,\"Wheelchair accessible entrance\":false,\"Parking available\":true,\"Easy access\":true},\"pricing\":{\"pricingSource\":\"website\",\"isFree\":false},\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"lastUpdated\":null,\"dataQuality\":\"verified\",\"photo\":null,\"faqs\":[],\"source\":\"static\",\"listingType\":\"free\"},{\"id\":\"ChIJpRXgXfp5Y4gRzCpVaMLDXCY\",\"name\":\"Animal Care Center of Carters Creek\",\"businessType\":\"Dog Park\",\"description\":\"Pet parents in the area rave about Animal Care Center of Carters Creek.  What makes this veterinary care special is its friendly, knowledgeable, excellent. The staff's dedication to creating a positive experience for both dogs and their owners is evident in every visit. everyone is wonderful here Located in a parking area, This facility specializes in Pet care and Professional services. For more information, call (931) 444-5687. Visit their website at http://yourpetsnewvet.com/ to learn more about their services and pricing.\",\"slug\":\"animal-care-center-of-carters-creek\",\"address\":\"2690 Spring Meade Blvd\",\"street\":\"2690 Spring Meade Blvd\",\"city\":\"Columbia\",\"state\":\"TN\",\"zipCode\":\"38401\",\"full_address\":\"2690 Spring Meade Blvd, Columbia, TN 38401, USA\",\"latitude\":35.712501,\"longitude\":-86.974687,\"googlePlaceId\":\"ChIJpRXgXfp5Y4gRzCpVaMLDXCY\",\"phone\":\"(931) 444-5687\",\"website\":\"http://yourpetsnewvet.com/\",\"photos\":null,\"rating\":4.7,\"reviewCount\":482,\"openingHours\":{\