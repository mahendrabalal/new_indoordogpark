sActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/bark-public-house\",\"name\":\"Bark Public House\",\"url\":\"https://www.indoordogpark.org/parks/bark-public-house\",\"sameAs\":[\"https://barkpublic.com/\"],\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"609 9th Ave S\",\"addressLocality\":\"Nashville\",\"addressRegion\":\"TN\",\"postalCode\":\"37203\",\"addressCountry\":\"US\"},\"telephone\":\"(615) 669-0814\",\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":4.6,\"reviewCount\":208},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":36.1513473,\"longitude\":-86.7808709}},{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/centennial-dog-park\",\"name\":\"Centennial Dog Park\",\"url\":\"https://www.indoordogpark.org/parks/centennial-dog-park\",\"sameAs\":[\"http://www.nashville.gov/Parks-and-Recreation/Parks/Dog-Parks.aspx\"],\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"2500 West End Ave\",\"addressLocality\":\"Nashville\",\"addressRegion\":\"TN\",\"postalCode\":\"37203\",\"addressCountry\":\"US\"},\"telephone\":\"(615) 862-8400\",\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":4.6,\"reviewCount\":5367},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":36.14840849999999,\"longitude\":-86.8177584}},{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/central-dog-park\",\"name\":\"Central Dog Park\",\"url\":\"https://www.indoordogpark.org/parks/central-dog-park\",\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"1508 3rd Ave N\",\"addressLocality\":\"Nashville\",\"addressRegion\":\"TN\",\"postalCode\":\"37208\",\"addressCountry\":\"US\"},\"telephone\":\"\",\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":5,\"reviewCount\":7},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":36.18198150000001,\"longitude\":-86.7887444}},{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.or