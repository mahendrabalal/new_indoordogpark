dren\\\":[\\\"Plan the perfect dog outing in \\\",\\\"Nashville\\\"]}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Borrow best practices from local trainers, rangers, and experienced pet parents.\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"planning-grid\\\",\\\"children\\\":[[\\\"$\\\",\\\"article\\\",\\\"Peak \\u0026 quiet windows\\\",{\\\"className\\\":\\\"planning-card\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"planning-icon\\\",\\\"children\\\":[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-clock-history\\\"}]}],[\\\"$\\\",\\\"h3\\\",null,{\\\"children\\\":\\\"Peak \\u0026 quiet windows\\\"}],[\\\"$\\\",\\\"ul\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"li\\\",\\\"6–9 AM: high energy social hour\\\",{\\\"children\\\":\\\"6–9 AM: high energy social hour\\\"}],[\\\"$\\\",\\\"li\\\",\\\"10 AM–3 PM weekdays: calm training-friendly window\\\",{\\\"children\\\":\\\"10 AM–3 PM weekdays: calm training-friendly window\\\"}],[\\\"$\\\",\\\"li\\\",\\\"After 4 PM: sunset crowd + cooler temps\\\",{\\\"children\\\":\\\"After 4 PM: sunset crowd + cooler temps\\\"}]]}]]}],[\\\"$\\\",\\\"article\\\",\\\"Essentials checklist\\\",{\\\"className\\\":\\\"planning-card\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"planning-icon\\\",\\\"children\\\":[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-backpack\\\"}]}],[\\\"$\\\",\\\"h3\\\",null,{\\\"children\\\":\\\"Essentials checklist\\\"}],[\\\"$\\\",\\\"ul\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"li\\\",\\\"Leash + harness for entry/exit control\\\",{\\\"children\\\":\\\"Leash + harness for entry/exit control\\\"}],[\\\"$\\\",\\\"li\\\",\\\"Collapsible water bowl and fresh water\\\",{\\\"children\\\":\\\"Collapsible water bowl and fresh water\\\"}],[\\\"$\\\",\\\"li\\\",\\\"Plenty of waste bags and high-value treats\\\",{\\\"children\\\":\\\"Plenty of waste bags and high-value treats\\\"}]]}]]}],[\\\"$\\\",\\\"article\\\",\\\"Local regulations\\\",{\\\"className\\\":\\\"planning-card\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"planning-icon\\\",\\\"children\\\":[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-shield-check\\\"}]}],[\\\"$\\\",\\\"h3\\\",null,{\\\"children\\\":\\\"Local regulations\\\"}],[\\\"$\\\",\\\"ul\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"li\\\",\\\"Keep proof of vaccinations or city license handy\\\",{\\\"children\\\":\\\"Keep proof of vaccinations or city license handy\\\"}],[\\\"$\\\",\\\"li\\\",\\\"Voice control required in most off-leash zones\\\",{\\\"children\\\":\\\"Voice control required in most off-leash zones\\\"}],[\\\"$\\\",\\\"li\\\",\\\"Limit three dogs per handler in public parks\\\",{\\\"children\\\":\\\"Limit three dogs per handler in public parks\\\"}]]}]]}],[\\\"$\\\",\\\"article\\\",\\\"Community etiquette\\\",{\\\"className\\\":\\\"planning-card\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"planning-icon\\\",\\\"children\\\":[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-heart\\\"}]}],[\\\"$\\\",\\\"h3\\\",null,{\\\"children\\\":\\\"Community etiquette\\\"}],[\\\"$\\\",\\\"ul\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"li\\\",\\\"Scan the park before entering and remove prong collars\\\",{\\\"children\\\":\\\"Scan the park before entering and remove prong collars\\\"}],[\\\"$\\\",\\\"li\\\",\\\"Monitor play styles and intervene early\\\",{\\\"children\\\":\\\"Monitor play styles and intervene early\\\"}],[\\\"$\\\",\\\"li\\\",\\\"Share shaded space and refill water when you're done\\\",{\\\"children\\\":\\\"Share shaded space and refill water when you're done\\\"}]]}]]}]]}]]}]}]\\n\"])</script><script>self.__next_f.push([1,\"3a:[\\\"$\\\",\\\"section\\\",null,{\\\"id\\\":\\\"owner-cta\\\",\\\"className\\\":\\\"owner-cta-section\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"section-shell\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"section-