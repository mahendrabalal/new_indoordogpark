l,{\\\"className\\\":\\\"hero-breadcrumbs\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L12\\\",null,{\\\"href\\\":\\\"/\\\",\\\"children\\\":\\\"Home\\\"}],[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-chevron-right\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"children\\\":\\\"Dog Parks Directory\\\"}],[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-chevron-right\\\"}],[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"Gastonia\\\"}]]}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"hero-eyebrow\\\",\\\"children\\\":\\\"Gateway to Adventure\\\"}],[\\\"$\\\",\\\"h1\\\",null,{\\\"children\\\":\\\"Gastonia Getaways\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"hero-chip-row\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",\\\"0\\\",{\\\"className\\\":\\\"hero-chip\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"chip-label\\\",\\\"children\\\":\\\"State Park\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"chip-value\\\",\\\"children\\\":\\\"1\\\"}],\\\"$undefined\\\"]}],[\\\"$\\\",\\\"div\\\",\\\"1\\\",{\\\"className\\\":\\\"hero-chip\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"chip-label\\\",\\\"children\\\":\\\"Dog Parks\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"chip-value\\\",\\\"children\\\":\\\"2\\\"}],\\\"$undefined\\\"]}]]}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"hero-description\\\",\\\"children\\\":\\\"Gastonia puts you at the doorstep of real adventure. With Crowders Mountain State Park minutes away, it is the perfect base camp for hiking dogs, while the city itself offers great parks and greenways.\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"city-rich-description\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",\\\"0\\\",{\\\"className\\\":\\\"rich-description-paragraph\\\",\\\"children\\\":[\\\"Gastonia, North Carolina, serves as the perfect launchpad for dogs with an adventurous spirit. Dominating the landscape is \\\",[\\\"$\\\",\\\"$L12\\\",\\