en:props:parks:7\",\"$36:props:children:props:children:props:parks:8\",\"$36:props:children:props:children:props:parks:9\",\"$36:props:children:props:children:props:parks:10\",\"$36:props:children:props:children:props:parks:11\",\"$36:props:children:props:children:props:parks:12\",\"$36:props:children:props:children:props:parks:13\",\"$36:props:children:props:children:props:parks:14\",\"$36:props:children:props:children:props:parks:15\",\"$36:props:children:props:children:props:parks:16\",\"$36:props:children:props:children:props:parks:17\",\"$36:props:children:props:children:props:parks:18\",\"$36:props:children:props:children:props:parks:19\",\"$36:props:children:props:children:props:parks:20\",\"$36:props:children:props:children:props:parks:21\",\"$36:props:children:props:children:props:parks:22\",\"$36:props:children:props:children:props:parks:23\",\"$36:props:children:props:children:props:parks:24\",\"$36:props:children:props:children:props:parks:25\",\"$36:props:children:props:children:props:parks:26\",\"$36:props:children:props:children:props:parks:27\",\"$36:props:children:props:children:props:parks:28\",\"$36:props:children:props:children:props:parks:29\"]}}]}],\"$undefined\"]}]}]\n39:[\"$\",\"section\",null,{\"id\":\"map-and-neighborhoods\",\"className\":\"map-experience-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell\",\"children\":[[\"$\",\"div\",null,{\"className\":\"section-heading\",\"children\":[[\"$\",\"span\",null,{\"className\":\"section-eyebrow\",\"children\":\"Interactive planning\"}],[\"$\",\"h2\",null,{\"children\":\"See everything laid out on the map\"}],[\"$\",\"p\",null,{\"children\":\"Use the live map to lock in nearby options, preview ratings, and save time hopping between neighborhoods.\"}]]}],[\"$\",\"div\",null,{\"className\":\"map-grid\",\"children\":[[\"$\",\"div\",null,{\"className\":\"map-panel\",\"children\":[\"$\",\"$L48\",null,{\"parks\":\"$36:props:children:props:children:props:parks\"}]}],[\"$\",\"div