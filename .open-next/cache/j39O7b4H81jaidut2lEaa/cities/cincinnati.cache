e\",\"city\":\"Cincinnati\",\"state\":\"OH\",\"zipCode\":\"45244\",\"full_address\":\"6666 Clough Pike, Cincinnati, OH 45244, USA\",\"latitude\":39.0994362,\"longitude\":-84.3688409,\"googlePlaceId\":\"ChIJAwvAJqeuQYgRHDzSe7LShWY\",\"phone\":\"(513) 231-7387\",\"website\":\"https://www.familypetcenter.com/\",\"rating\":4.7,\"reviewCount\":302,\"userRatingsTotal\":302,\"pricing\":{\"pricingSource\":\"unknown\",\"isFree\":false},\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"dataQuality\":\"verified\",\"openingHours\":{\"Monday\":\"7:00 AM – 7:00 PM\",\"Tuesday\":\"7:00 AM – 7:00 PM\",\"Wednesday\":\"7:00 AM – 7:00 PM\",\"Thursday\":\"7:00 AM – 7:00 PM\",\"Friday\":\"7:00 AM – 7:00 PM\",\"Saturday\":\"9:00 AM – 5:00 PM\",\"Sunday\":\"10:00 AM – 5:00 PM\"},\"faqs\":[],\"amenities\":{},\"source\":\"static\",\"listingType\":\"free\"},{\"id\":\"ChIJAa840qBLQIgRCQhsyTU5ZTA\",\"name\":\"Animal House\",\"businessType\":\"Indoor Dog Park\",\"description\":\"Animal House is a premier pet facility in Cincinnati that consistently earns praise from pet owners. With a 4.3-star rating from 841 reviews, This facility stands out for being professional and reliable and safe environment and great for socialization. Pet owners appreciate the attention to detail and the genuine care shown to every furry visitor. For more information, call (513) 931-6139. Visit their website for additional details.\",\"slug\":\"animal-house\",\"address\":\"7869 Hamilton Ave\",\"street\":\"7869 Hamilton Ave\",\"city\":\"Cincinnati\",\"state\":\"OH\",\"zipCode\":\"45231\",\"full_address\":\"7869 Hamilton Ave, Cincinnati, OH 45231, USA\",\"latitude\":39.236847,\"longitude\":-84.54806700000002,\"googlePlaceId\":\"ChIJAa840qBLQIgRCQhsyTU5ZTA\",\"phone\":\"(513) 931-6139\",\"website\":\"http://animalhousecincinnati.com/\",\"rating\":4.3,\"reviewCount\":841,\"userRatingsTotal\":841,\"pricing\":{\"pricingSource\":\"unknown\",\"isFree\":false},\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"