dogpark.org/parks/animal-house\",\"name\":\"Animal House\",\"url\":\"https://www.indoordogpark.org/parks/animal-house\",\"sameAs\":[\"http://animalhousecincinnati.com/\"],\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"7869 Hamilton Ave\",\"addressLocality\":\"Cincinnati\",\"addressRegion\":\"OH\",\"postalCode\":\"45231\",\"addressCountry\":\"US\"},\"telephone\":\"(513) 931-6139\",\"image\":null,\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":4.3,\"reviewCount\":841},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":39.236847,\"longitude\":-84.54806700000002}},{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/aquatics-exotics\",\"name\":\"Aquatics & Exotics\",\"url\":\"https://www.indoordogpark.org/parks/aquatics-exotics\",\"sameAs\":[\"http://www.aquaticsandexotics.com/\"],\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"7513 Hamilton Ave\",\"addressLocality\":\"Cincinnati\",\"addressRegion\":\"OH\",\"postalCode\":\"45231\",\"addressCountry\":\"US\"},\"telephone\":\"(513) 521-5500\",\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":4.4,\"reviewCount\":479},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":39.232118,\"longitude\":-84.548566}},{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/argos-pet-food-supply-madeira\",\"name\":\"Argos Pet Food & Supply - Madeira\",\"url\":\"https://www.indoordogpark.org/parks/argos-pet-food-supply-madeira\",\"sameAs\":[\"http://argospet.com/\"],\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"7713 Camargo Rd\",\"addressLocality\":\"Cincinnati\",\"addressRegion\":\"OH\",\"postalCode\":\"45243\",\"addressCountry\":\"US\"},\"telephone\":\"(513) 561-7966\",\"image\":null,\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":4.9,\"reviewCount\":44},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":39.1863032,\"longitude\":-84.3627768}},{\"@type\":\"SportsActivityLocation\",\"@id