g program designed to provide a means for sites to earn advertising fees by advertising and linking to Amazon.com. As an Amazon Associate I earn from qualifying purchases.\"}]}],[\"$\",\"div\",null,{\"className\":\"footer-bottom\",\"children\":[\"$L20\",\"$L21\"]}]]}]}]\na:[\"$\",\"$L22\",null,{}]\nb:[\"$\",\"$L23\",null,{\"children\":[\"$\",\"$24\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@25\"}]}]\n16:[\"$\",\"section\",null,{\"id\":\"city-comparison\",\"className\":\"city-comparison-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell\",\"children\":[\"$\",\"$L26\",null,{\"parks\":\"$8:props:children:3:props:children:props:children:props:parks\",\"cityName\":\"Maple Shade\"}]}]}]\n17:[\"$\",\"section\",null,{\"id\":\"park-collections\",\"className\":\"park-collections-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell\",\"children\":[[\"$\",\"div\",null,{\"className\":\"section-heading\",\"children\":[[\"$\",\"span\",null,{\"className\":\"section-eyebrow\",\"children\":\"Curated collections\"}],[\"$\",\"h2\",null,{\"children\":\"Choose the vibe that fits your next outing\"}],[\"$\",\"p\",null,{\"children\":\"Segmented park groupings built from live data so you can jump straight to the experiences that matter most.\"}]]}],false,[\"$\",\"div\",null,{\"className\":\"park-type-guide-wrapper\",\"children\":[\"$\",\"$L27\",null,{\"parksByType\":{\"Dog Park\":[\"$8:props:children:3:props:children:props:children:props:parks:0\",\"$8:props:children:3:props:children:props:children:props:parks:1\",\"$8:props:children:3:props:children:props:children:props:parks:2\"]}}]}],\"$undefined\"]}]}]\n18:[\"$\",\"section\",null,{\"id\":\"map-and-neighborhoods\",\"className\":\"map-experience-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell\",\"children\":[[\"$\",\"div\",null,{\"className\":\"section-heading\",\"children\":[[\"$\",\"span\",null,{\"className\":\"section-eyebrow\",\"children\":\"Interactiv