 facilities This facility specializes in Pet care and Professional services. For more information, call (856) 779-1903. \\\",\\\"slug\\\":\\\"the-groomer-s-in-llc\\\",\\\"address\\\":\\\"18 S Forklanding Rd\\\",\\\"street\\\":\\\"18 S Forklanding Rd\\\",\\\"city\\\":\\\"Maple Shade\\\",\\\"state\\\":\\\"NJ\\\",\\\"zipCode\\\":\\\"08052\\\",\\\"full_address\\\":\\\"18 S Forklanding Rd, Maple Shade, NJ 08052, USA\\\",\\\"latitude\\\":39.9547092,\\\"longitude\\\":-75.0018188,\\\"googlePlaceId\\\":\\\"ChIJvV9tKyXKxokRN_JCejReEZU\\\",\\\"phone\\\":\\\"(856) 779-1903\\\",\\\"website\\\":\\\"\\\",\\\"photos\\\":null,\\\"rating\\\":4.4,\\\"reviewCount\\\":190,\\\"openingHours\\\":{\\\"Monday\\\":\\\"8:30 AM – 5:00 PM\\\",\\\"Tuesday\\\":\\\"Closed\\\",\\\"Wednesday\\\":\\\"8:30 AM – 5:00 PM\\\",\\\"Thursday\\\":\\\"8:30 AM – 5:00 PM\\\",\\\"Friday\\\":\\\"Closed\\\",\\\"Saturday\\\":\\\"8:00 AM – 5:00 PM\\\",\\\"Sunday\\\":\\\"8:30 AM – 2:00 PM\\\"},\\\"amenities\\\":{\\\"Onsite services\\\":true,\\\"Indoor facilities\\\":true,\\\"Professional staff\\\":true,\\\"Climate controlled\\\":true,\\\"Wheelchair accessible entrance\\\":false,\\\"Parking available\\\":true,\\\"Easy access\\\":true},\\\"pricing\\\":{\\\"pricingSource\\\":\\\"website\\\",\\\"isFree\\\":false},\\\"placeTypes\\\":[\\\"point_of_interest\\\",\\\"establishment\\\"],\\\"lastUpdated\\\":null,\\\"dataQuality\\\":\\\"verified\\\",\\\"photo\\\":null,\\\"faqs\\\":[],\\\"source\\\":\\\"static\\\",\\\"listingType\\\":\\\"free\\\"},{\\\"id\\\":\\\"ChIJj-l75c7KxokRS78ni6py0u8\\\",\\\"name\\\":\\\"Villa La PAWS\\\",\\\"businessType\\\":\\\"Dog Park\\\",\\\"description\\\":\\\"$34\\\",\\\"slug\\\":\\\"villa-la-paws\\\",\\\"address\\\":\\\"119 E Kings Hwy\\\",\\\"street\\\":\\\"119 E Kings Hwy\\\",\\\"city\\\":\\\"Maple Shade\\\",\\\"state\\\":\\\"NJ\\\",\\\"zipCode\\\":\\\"08052\\\",\\\"full_address\\\":\\\"119 E Kings Hwy, Maple Shade, NJ 08052, USA\\\",\\\"latitude\\\":39.9472171,\\\"longitude\\\":-74.97612219999999