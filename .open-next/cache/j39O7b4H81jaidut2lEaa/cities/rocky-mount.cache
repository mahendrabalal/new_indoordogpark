ress\":\"412 S Barnes St\",\"street\":\"412 S Barnes St\",\"city\":\"Rocky Mount\",\"state\":\"NC\",\"zipCode\":\"27856\",\"full_address\":\"412 S Barnes St, Nashville, NC 27856, USA\",\"latitude\":35.9716103,\"longitude\":-77.9711213,\"googlePlaceId\":\"ChIJL_vy2Z9HrIkRCUzJGJo4OTU\",\"phone\":\"(919) 987-7531\",\"website\":\"https://bubblesandbowsofnashville.com/\",\"rating\":4.7,\"reviewCount\":64,\"userRatingsTotal\":64,\"pricing\":{\"pricingSource\":\"unknown\",\"isFree\":false},\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"dataQuality\":\"verified\",\"openingHours\":{\"Monday\":\"Closed\",\"Tuesday\":\"8:00 AM – 5:00 PM\",\"Wednesday\":\"8:00 AM – 5:00 PM\",\"Thursday\":\"8:00 AM – 5:00 PM\",\"Friday\":\"8:00 AM – 5:00 PM\",\"Saturday\":\"9:00 AM – 4:00 PM\",\"Sunday\":\"Closed\"},\"faqs\":[],\"amenities\":{},\"photos\":[{\"url\":\"/images/parks/northcarolina/bubbles-bows-pet-salon-and-boarding-of-nashville/bubbles-bows-pet-salon-and-boarding-of-nashville-1.jpg\",\"type\":\"photo\",\"source\":\"website\"},{\"url\":\"/images/parks/northcarolina/bubbles-bows-pet-salon-and-boarding-of-nashville/bubbles-bows-pet-salon-and-boarding-of-nashville-2.jpg\",\"type\":\"photo\",\"source\":\"website\"}],\"photo\":\"/images/parks/northcarolina/bubbles-bows-pet-salon-and-boarding-of-nashville/bubbles-bows-pet-salon-and-boarding-of-nashville-1.jpg\",\"source\":\"static\",\"listingType\":\"free\"},{\"id\":\"ChIJo9VJBuWGrokRW-PYCehTT5w\",\"name\":\"Buck Leonard Park\",\"businessType\":\"Indoor Dog Park\",\"description\":\"Buck Leonard Park has earned the trust of Rocky Mount residents. This facility features climate-controlled facilities for North Carolina's varied weather, experienced and certified staff, offering pet care. Their services creates a safe, climate-controlled environment. situated in a prime Rocky Mount location. Contact Buck Leonard Park today to schedule your dog's visit\",\"slug\":\"buck-leonard-park\",\"address\":\"929 S Grace St\",\"street\":\"92