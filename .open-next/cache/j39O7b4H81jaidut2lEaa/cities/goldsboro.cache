n\":5,\"item\":{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/stoney-creek-dog-park\",\"name\":\"Stoney Creek Dog Park\",\"url\":\"https://www.indoordogpark.org/parks/stoney-creek-dog-park\",\"description\":\"Pet owners in Goldsboro find Stoney Creek Dog Park to be a solid choice. This facility features air-conditioned spaces for hot summers, experienced and certified staff, offering pet care. Their...\",\"address\":{\"@type\":\"PostalAddress\",\"addressLocality\":\"Goldsboro\",\"addressRegion\":\"NC\",\"addressCountry\":\"US\"},\"image\":\"/images/parks/northcarolina/stoney-creek-dog-park/stoney-creek-dog-park-1.jpg\"}},{\"@type\":\"ListItem\",\"position\":6,\"item\":{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/wells-fargo-walking-park\",\"name\":\"Wells Fargo walking park\",\"url\":\"https://www.indoordogpark.org/parks/wells-fargo-walking-park\",\"description\":\"Pet owners in Goldsboro find Wells Fargo walking park to be a solid choice. This facility features climate-controlled facilities for North Carolina's varied weather, experienced and certified staff,...\",\"address\":{\"@type\":\"PostalAddress\",\"addressLocality\":\"Goldsboro\",\"addressRegion\":\"NC\",\"addressCountry\":\"US\"},\"image\":\"/images/parks/northcarolina/wells-fargo-walking-park/wells-fargo-walking-park-1.jpg\"}},{\"@type\":\"ListItem\",\"position\":7,\"item\":{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/carolina-air-dogs-dogworx\",\"name\":\"Carolina Air Dogs / Dogworx\",\"url\":\"https://www.indoordogpark.org/parks/carolina-air-dogs-dogworx\",\"description\":\"Pet owners in Goldsboro appreciate Carolina Air Dogs / Dogworx's reliable service. This facility features modern training facilities, North Carolina pet care professionals, offering pet care. Their...\",\"address\":{\"@type\":\"PostalAddress\",\"addressLocality\":\"Goldsboro\",\"addressRegion\":\"NC\",\"addressCountry\":\"US\"},\"image\":\"/images/parks/northcarolina/carolina-air-dogs-dogworx/carolina-air-dogs-dogworx-1.jpg\"}},{\"@type\":\"ListItem\",\"position\":8,\"item\":{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/hucks-place-boarding\",\"name\":\"Huck's Place Boarding\",\"url\":\"https://www.indoordogpark.org/parks/hucks-place-boarding\",\"description\":\"Pet owners in Goldsboro find Huck's Place Boarding to be a solid choice. This facility features heated areas for cooler winters, experienced and certified staff, offering pet care. Their services...\",\"address\":{\"@type\":\"PostalAddress\",\"addressLocality\":\"Goldsboro\",\"addressRegion\":\"NC\",\"addressCountry\":\"US\"},\"image\":\"/images/parks/northcarolina/huck-s-place-boarding/huck-s-place-boarding-1.jpg\"}},{\"@type\":\"ListItem\",\"position\":9,\"item\":{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/pet-palace-boarding-grooming\",\"name\":\"Pet Palace Boarding Grooming\",\"url\":\"https://www.indoordogpark.org/parks/pet-palace-boarding-grooming\",\"description\":\"North Carolina pet parents in Goldsboro choose Pet Palace Boarding Grooming for premium care. This facility features air-conditioned spaces for hot summers, North Carolina pet care professionals,...\",\"address\":{\"@type\":\"PostalAddress\",\"addressLocality\":\"Goldsboro\",\"addressRegion\":\"NC\",\"addressCountry\":\"US\"},\"image\":\"/images/parks/northcarolina/pet-palace-boarding-grooming/pet-palace-boarding-grooming-1.jpg\"}},{\"@type\":\"ListItem\",\"position\":10,\"item\":{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/two-paws-up\",\"name\":\"Two Paws Up\",\"url\":\"https://www.indoordogpark.org/parks/two-paws-up\",\"description\":\"Among Goldsboro's top-rated facilities, Two Paws Up excels in year-round care. This facility features climate-controlled facilities for North Carolina's varied weather, North Carolina pet care...\",\"address\":{\"@type\":\"PostalAddress\",\"addressLocality\":\"Goldsboro\",\"addressRegion\":\"NC\",\"addressCountry\":\"US\"},\"image\":\"/images/parks/northcarolina/two-paws-up/two-paws-up-1.jpg\"}}]}25:[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"suppressHydrationWarning\":true,\"dangerouslySetInnerHTML\":{\"__html\":\"$2d\"}}]\n2e:T1ded,{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"How many dog parks are available in Goldsboro?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Goldsboro has 34 dog parks and dog-friendly establishments, including traditional outdoor dog parks, indoor dog parks, and dog-friendly businesses like restaurants and shops. Each type offers unique benefits for different situations and dog personalities.\"}},{\"@type\":\"Question\",\"name\":\"Are there any indoor dog parks in the USA?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes! The United States is home to hundreds of indoor dog parks, and the industry is growing rapidly. IndoorDogPark.org maintains the most comprehensive directory available, currently tracking over 360 verified facilities across 155 cities nationwide. These climate-controlled spaces solve real problems for dog owners. In cities like Phoenix where summer temperatures can exceed 110°F, or Chicago where winter brings sub-zero temperatures for months, indoor parks become essential. They're also invaluable in rainy regions like Seattle or Portland, where outdoor parks stay muddy for much of the year. Our directory includes detailed profiles for each facility: amenities, pricing structures, operating hours, vaccination requirements, and real visitor experiences. We've aggregated over 106,000 user reviews from Google, Yelp, and other platforms to help you make informed decisions. Popular metro areas with the most options include Los Angeles (23 indoor facilities), Chicago (18 facilities), and New York City (15 facilities). But we've also documented smaller markets like Bend, Oregon, and Asheville, North Carolina, where innovative entrepreneurs are meeting local demand. To explore options near you, visit our main directory page or browse by state. Each listing includes photos, direct contact information, and links to facility websites where you can check current availability and make reservations.\"}},{\"@type\":\"Question\",\"name\":\"Are dog parks in Goldsboro free to use?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Most traditional outdoor dog parks in public spaces are free to use. However, indoor dog parks and specialized facilities typically require membership fees or day passes. Dog-friendly establishments like restaurants may have minimum purchase requirements or special pet menus.\"}},{\"@type\":\"Question\",\"name\":\"What are the requirements to visit dog parks in Goldsboro?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Most dog parks require that your dog be current on vaccinations (rabies, DHPP), licensed, and well-behaved. Some indoor facilities may require proof of vaccinations, health certificates, or temperament assessments. Always check specific park rules before visiting.\"}},{\"@type\":\"Question\",\"name\":\"What's the best time to visit dog parks in Goldsboro?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Early mornings (6–9 AM) and early evenings (4–7 PM) are typically the busiest times, offering great socialization opportunities. Midday visits are usually quieter, better for dogs who may be overwhelmed by crowds. Weekends are generally busier than weekdays. Consider your dog's personality and social comfort level when planning visits.\"}},{\"@type\":\"Question\",\"name\":\"Where to go with a dog when it's raining?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Rainy days don't have to mean canceled playtime. Indoor dog parks are specifically designed for exactly this scenario, offering climate-controlled environments where dogs can exercise and socialize safely. Our directory lists over 360 indoor facilities across the country. Many feature specialized surfaces like K9Grass or rubberized flooring that stay clean and dry regardless of weather. These surfaces are easier on joints than concrete and reduce injury risk compared to muddy outdoor parks. Beyond dedicated indoor parks, consider these alternatives: • Pet stores with play areas: Chains like PetSmart and Petco sometimes host indoor play sessions. • Dog-friendly cafes and restaurants: Many now welcome well-behaved dogs indoors, perfect for socialization in a calmer setting. • Indoor training facilities: Often open their spaces for play sessions between classes. • Doggy daycare centers: Many offer drop-in playtime options for non-members. Pro tip: Indoor facilities get significantly busier during bad weather, so call ahead or book reservations when possible. Many also offer online booking systems for convenience. Bonus: Most indoor parks include dog wash stations, so your pup can get clean before the ride home—no muddy paws in your car. Explore our directory to find indoor options near you, and filter by amenities like \\\"dog wash\\\" or \\\"separate small dog areas\\\" to find exactly what you need.\"}},{\"@type\":\"Question\",\"name\":\"Are there any size restrictions or separate areas for different sized dogs?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Many dog parks in Goldsboro offer separate areas for small dogs (under 25 lbs) and large dogs (over 25 lbs). This helps ensure safe play experiences. However, not all parks have this separation, so it's important to check ahead and supervise your dog's interactions.\"}},{\"@type\":\"Question\",\"name\":\"What should I bring when visiting a dog park in Goldsboro?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Essential items include: a leash (for entering and exiting), poop bags, fresh water and a bowl, your dog's vaccination records (especially for indoor facilities), and your phone for emergencies. Optional items include toys (check park rules first), treats for training, and a first-aid kit.\"}},{\"@type\":\"Question\",\"name\":\"Are there indoor dog park options available in Goldsboro?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Our directory currently lists 34 indoor dog parks in Goldsboro. Use the “Indoor Dog Park” filter on this page to jump straight to climate-controlled options.\"}},{\"@type\":\"Question\",\"name\":\"What is the most dog friendly city in the USA?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"This question sparks lively debates among dog owners, and the answer depends on what you value most. Based on our analysis of over 360 facilities across 155 cities, here's what the data reveals: California dominates in sheer numbers: Los Angeles, San Diego, and San Francisco collectively host 50+ indoor dog parks. But quantity isn't everything. Cities consistently ranking high for overall dog-friendliness include: • San Francisco: Over 40% of households include dogs (above the 38% national average), extensive off-leash beaches, and one of the highest concentrations of dog parks per capita. • Portland, Oregon: Known for progressive pet policies, abundant green spaces, and a culture where dogs are welcome almost everywhere—including many restaurants and breweries. • Seattle: Over 14 off-leash areas plus multiple indoor facilities, making it ideal for a city that gets 150+ rainy days annually. • Austin, Texas: Boasts some of the largest dog parks in the country, plus a vibrant dog-friendly dining scene. • Denver: High altitude doesn't stop Coloradans—the city maintains excellent park facilities and welcoming policies. However, \\\"friendliness\\\" extends beyond park counts. Factors like pet-friendly rental policies, veterinary care access, breed restrictions, and community culture matter just as much. Our directory lets you explore by city to see specific offerings. Check out our city guides for detailed breakdowns of parks, amenities, and local pet policies. We also maintain guides for major metro areas on our blog, covering everything from best parks to dog-friendly neighborhoods.\"}}]}26:[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"suppressHydrationWarning\":true,\"dangerouslySetInnerHTML\":{\"__html\":\"$2e\"}}]\n27:[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"suppressHydrationWarning\":true,\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://www.indoordogpark.org/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Dog Parks Directory\\\",\\\"item\\\":\\\"https://www.indoordogpark.org/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Goldsboro\\\"}]}\"}}]\n28:[\"$\",\"$L11\",null,{\"variant\":\"light\"}]\n29:[\"$\",\"$L2f\",null,{\"items\":[{\"id\":\"city-hero\",\"title\":\"City Overview\",\"level\":1},{\"id\":\"city-insights\",\"title\":\"Quick Facts\",\"level\":1},{\"id\":\"city-comparison\",\"title\":\"Top Comparisons\",\"level\":1},{\"id\":\"park-collections\",\"title\":\"Park Collections\",\"level\":1},{\"id\":\"neighborhood-clusters\",\"title\":\"Neighborhoods\",\"level\":1},{\"id\":\"park-types-guide\",\"title\":\"Park Type Guide\",\"level\":1},{\"id\":\"map-and-neighborhoods\",\"title\":\"Map & Neighborhoods\",\"level\":1},{\"id\":\"planning-essentials\",\"title\":\"Planning Essentials\",\"level\":1},{\"id\":\"expert-tips\",\"title\":\"Expert Advice\",\"level\":1},{\"id\":\"park-directory\",\"title\":\"Full Directory\",\"level\":1},{\"id\":\"owner-cta\",\"title\":\"Owner & Franchise\",\"level\":1},{\"id\":\"faq-section\",\"title\":\"FAQs\",\"level\":1},{\"id\":\"related-resources\",\"title\":\"More Resources\",\"level\":1}]}]\n2a:[\"$\",\"main\",null,{\"className\":\"city-page-layout\",\"children\":[[\"$\",\"div\",null,{\"className\":\"mobile-toc-button\",\"children\":[\"$\",\"$L30\",null,{\"className\":\"mobile-toc-trigger\",\"targetSelector\":\".table-of-contents\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-list-ul\"}],[\"$\",\"span\",null,{\"children\":\"Contents\"}]]}]}],[\"$\",\"section\",null,{\"id\":\"city-hero\",\"className\":\"city-hero-section \",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell city-hero-shell\",\"children\":[[\"$\",\"div\",null,{\"className\":\"city-hero-copy\",\"children\":[[\"$\",\"div\",null,{\"className\":\"hero-breadcrumbs\",\"children\":[[\"$\",\"$L12\",null,{\"href\":\"/\",\"children\":\"Home\"}],[\"$\",\"i\",null,{\"className\":\"bi bi-chevron-right\"}],[\"$\",\"span\",null,{\"children\":\"Dog Parks Directory\"}],[\"$\",\"i\",null,{\"className\":\"bi bi-chevron-right\"}],[\"$\",\"strong\",null,{\"children\":\"Goldsboro\"}]]}],[\"$\",\"p\",null,{\"className\":\"hero-eyebrow\",\"children\":\"City spotlight\"}],[\"$\",\"h1\",null,{\"children\":\"Dog Parks in Goldsboro, NC\"}],\"$undefined\",[\"$\",\"p\",null,{\"className\":\"hero-description\",\"children\":\"Experience the friendly community spirit of Goldsboro, with parks like Stoney Creek offering green space and social opportunities for local dogs.\"}],[\"$\",\"div\",null,{\"className\":\"city-rich-description\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"rich-description-paragraph\",\"children\":[\"Goldsboro, NC, home to Seymour Johnson Air Force Base, offers a tight-knit community atmosphere for dog owners. The city's primary destination for off-leash play is the Stoney Creek Dog Park, located within Stoney Creek Park. This facility features secure fencing and shaded areas, making it a reliable spot for daily exercise. Leashed walks are also encouraged throughout the \",[\"$\",\"$L12\",\"1\",{\"href\":\"https://www.goldsboronc.gov/parks-and-recreation/\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"rich-link\",\"children\":\"Goldsboro Parks\"}],null,\" system, providing a quiet retreat for nature lovers. Our \",[\"$\",\"$L12\",\"4\",{\"href\":\"https://www.indoordogpark.org/cities/goldsboro#park-directory\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"rich-link\",\"children\":\"Goldsboro directory\"}],null,\" connects residents with these essential local amenities.\"]}],[\"$\",\"p\",\"1\",{\"className\":\"rich-description-paragraph\",\"children\":[\"The city promotes responsible pet stewardship, requiring current vaccinations and adherence to leash ordinances. Goldsboro's relatively mild climate allows for year-round outdoor activity, though summer afternoons can be warm. Owners interested in community events can check our \",[\"$\",\"$L12\",\"1\",{\"href\":\"/blog\",\"target\":\"$undefined\",\"rel\":\"$undefined\",\"className\":\"rich-link\",\"children\":\"blog\"}],null,\" for regional updates. With its supportive environment and accessible green spaces, Goldsboro remains a comfortable and welcoming home for dogs and their families.\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-cta-row\",\"children\":[[\"$\",\"$L30\",null,{\"className\":\"hero-cta primary\",\"targetId\":\"park-directory\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-list-check\"}],\"Browse directory\"]}],[\"$\",\"$L30\",null,{\"className\":\"hero-cta ghost\",\"targetId\":\"map-and-neighborhoods\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-geo-alt\"}],\"Open map\"]}],[\"$\",\"$L12\",null,{\"href\":\"/list-your-park\",\"className\":\"hero-cta text-link\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-plus-circle\"}],\"Submit a park\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-footnotes\",\"children\":[[\"$\",\"span\",\"Data refreshed weekly\",{\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-sparkles\"}],\" \",\"Data refreshed weekly\"]}],[\"$\",\"span\",\"Live availability coming soon\",{\"children\":[[\"$\",\"i\",null,{\"className\":\