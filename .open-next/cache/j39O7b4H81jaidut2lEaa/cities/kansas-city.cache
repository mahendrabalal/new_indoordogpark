Source\":\"website\",\"isFree\":false},\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"lastUpdated\":null,\"dataQuality\":\"verified\",\"photo\":null,\"faqs\":[],\"source\":\"static\",\"listingType\":\"free\"},{\"id\":\"ChIJ1fCJ6Un_wIcRsDhkt2IO8xs\",\"name\":\"Dog Park at Love's Travel Stops\",\"businessType\":\"Dog Park\",\"description\":\"Located in Kansas City, Dog Park at Love's Travel Stops offers a welcoming space for pets to exercise and socialize.\\n\\nThis park is well-equipped with amenities such as indoor facilities for all-weather play, climate-controlled areas, professional staff on-site, convenient onsite services, ensuring a comfortable visit for both you and your pet. Visitors appreciate the clean environment and friendly atmosphere, reflected in its 4.5-star rating. Make sure to check the [official page](https://www.loves.com/dogparks) for membership info. For more dog-friendly spots, browse [Indoor Dog Park](https://www.indoordogpark.org/).\",\"slug\":\"dog-park-at-love-s-travel-stops\",\"address\":\"3201 North Ameristar Drive\",\"street\":\"3201 North Ameristar Drive\",\"city\":\"Kansas City\",\"state\":\"MO\",\"zipCode\":\"64161\",\"full_address\":\"3201 North Ameristar Drive, Kansas City, MO 64161, USA\",\"latitude\":39.1540118,\"longitude\":-94.4749878,\"googlePlaceId\":\"ChIJ1fCJ6Un_wIcRsDhkt2IO8xs\",\"phone\":\"(816) 381-8288\",\"website\":\"https://www.loves.com/dogparks\",\"photos\":null,\"rating\":4.5,\"reviewCount\":2,\"openingHours\":{\"Monday\":\"Open 24 hours\",\"Tuesday\":\"Open 24 hours\",\"Wednesday\":\"Open 24 hours\",\"Thursday\":\"Open 24 hours\",\"Friday\":\"Open 24 hours\",\"Saturday\":\"Open 24 hours\",\"Sunday\":\"Open 24 hours\"},\"amenities\":{\"Onsite services\":true,\"Indoor facilities\":true,\"Professional staff\":true,\"Climate controlled\":true,\"Wheelchair accessible entrance\":false,\"Parking available\":true,\"Easy access\":true},\"pricing\":{\"pricingSource\":\"website\",\"isFree\":false},\"placeTypes\":