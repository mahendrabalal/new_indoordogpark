Type\":\"free\"},{\"id\":\"ChIJB3DjYYnwwIcRW2Q9c0BUDWs\",\"name\":\"River Market Dog Park\",\"businessType\":\"Dog Park\",\"description\":\"If you're in Kansas City, bring your furry friend to River Market Dog Park for a great day out.\\n\\nThis park is well-equipped with amenities such as indoor facilities for all-weather play, climate-controlled areas, professional staff on-site, convenient onsite services, ensuring a comfortable visit for both you and your pet. With a solid 4.1-star rating from over 186 reviews, it's a highly recommended community favorite. For more details, you can visit the [official website](https://www.facebook.com/rivermarketOLA/) or check out local guides at [Indoor Dog Park](https://www.indoordogpark.org/).\",\"slug\":\"river-market-dog-park\",\"address\":\"419-499 Locust Ln\",\"street\":\"419-499 Locust Ln\",\"city\":\"Kansas City\",\"state\":\"MO\",\"zipCode\":\"64106\",\"full_address\":\"419-499 Locust Ln, Kansas City, MO 64106, USA\",\"latitude\":39.1099539,\"longitude\":-94.5779015,\"googlePlaceId\":\"ChIJB3DjYYnwwIcRW2Q9c0BUDWs\",\"phone\":\"\",\"website\":\"https://www.facebook.com/rivermarketOLA/\",\"photos\":null,\"rating\":4.1,\"reviewCount\":186,\"openingHours\":{\"Monday\":\"Open 24 hours\",\"Tuesday\":\"Open 24 hours\",\"Wednesday\":\"Open 24 hours\",\"Thursday\":\"Open 24 hours\",\"Friday\":\"Open 24 hours\",\"Saturday\":\"Open 24 hours\",\"Sunday\":\"Open 24 hours\"},\"amenities\":{\"Onsite services\":true,\"Indoor facilities\":true,\"Professional staff\":true,\"Climate controlled\":true,\"Wheelchair accessible entrance\":false,\"Parking available\":true,\"Easy access\":true},\"pricing\":{\"pricingSource\":\"website\",\"isFree\":false},\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"lastUpdated\":null,\"dataQuality\":\"verified\",\"photo\":null,\"faqs\":[],\"source\":\"static\",\"listingType\":\"free\"},{\"id\":\"ChIJX6h7LdXxwIcROuwY0KG4-0c\",\"name\":\"St. John's Dog Park\",\"businessType\":\"Dog Park\",\"description\":\"St. John's Dog Park provides a safe and fun environment for dogs of all sizes in the heart of Kansas City.\\n\\nThis park is well-equipped with amenities such as indoor facilities for all-weather play, climate-controlled areas, professional staff on-site, convenient onsite services, ensuring a comfortable visit for both you and your pet. With a solid 4.4-star rating from over 107 reviews, it's a highly recommended community favorite. Plan your visit today! For rules and hours, see the [park website](#) or verify details on [Indoor Dog Park](https://www.indoordogpark.org/).\",\"slug\":\"st-john-s-dog-park\",\"address\":\"898-800 N 4th St\",\"street\":\"898-800 N 4th St\",\"city\":\"Kansas City\",\"state\":\"MO\",\"zipCode\":\"66101\",\"full_address\":\"898-800 N 4th St, Kansas City, KS 66101, USA\",\"latitude\":39.1139039,\"longitude\":-94.61829519999999,\"googlePlaceId\":\"ChIJX6h7LdXxwIcROuwY0KG4-0c\",\"phone\":\"\",\"website\":\"\",\"photos\":null,\"rating\":4.4,\"reviewCount\":107,\"openingHours\":{\"Monday\":\"Open 24 hours\",\"Tuesday\":\"Open 24 hours\",\"Wednesday\":\"Open 24 hours\",\"Thursday\":\"Open 24 hours\",\"Friday\":\"Open 24 hours\",\"Saturday\":\"Open 24 hours\",\"Sunday\":\"Open 24 hours\"},\"amenities\":{\"Onsite services\":true,\"Indoor facilities\":true,\"Professional staff\":true,\"Climate controlled\":true,\"Wheelchair accessible entrance\":true,\"Parking available\":true,\"Easy access\":true},\"pricing\":{\"pricingSource\":\"website\",\"isFree\":false},\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"lastUpdated\":null,\"dataQuality\":\"verified\",\"photo\":null,\"faqs\":[],\"source\":\"static\",\"listingType\":\"free\"},{\"id\":\"ChIJM8WGj87lwIcRPPtuMXRFS18\",\"name\":\"Swope Dog Park\",\"businessType\":\"Dog Park\",\"description\":\"$16\",\"slug\":\"swope-dog-park\",\"address\":\"5051 E Gregory Blvd\",\"street\":\"5051 E Gregory Blvd\",\"city\":\"Kansas City\",\"state\":\"MO\",\"zipCode\":\"64132\",\"full_address\":\"505