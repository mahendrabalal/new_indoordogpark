ion\",null,{\"id\":\"nearby-cities\",\"className\":\"nearby-cities-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell\",\"children\":[[\"$\",\"div\",null,{\"className\":\"section-heading\",\"children\":[[\"$\",\"span\",null,{\"className\":\"section-eyebrow\",\"children\":\"Explore the region\"}],[\"$\",\"h2\",null,{\"children\":[\"Dog parks near \",\"Lodi\"]}],[\"$\",\"p\",null,{\"children\":\"Worth the drive? Check out top-rated indoor parks in neighboring cities.\"}]]}],[\"$\",\"$L4f\",null,{\"cities\":[{\"slug\":\"san-francisco\",\"name\":\"San Francisco\",\"parkCount\":50,\"avgRating\":4.6,\"totalReviews\":5477,\"featuredImage\":\"/images/cities/san-francisco/hero.webp\",\"longitude\":-122.43547849999999,\"state\":\"CA\",\"topParks\":[\"FUReverFUN Dog Care Services\",\"Tefani & So Dogcare\",\"Bark To Basics\"]},{\"slug\":\"los-angeles\",\"name\":\"Los Angeles\",\"parkCount\":40,\"avgRating\":4.6,\"totalReviews\":10974,\"featuredImage\":\"/images/cities/los-angeles/hero.webp\",\"longitude\":-118.3910675,\"state\":\"CA\",\"topParks\":[\"LAK9S\",\"PetCare LB\",\"Doggie Land Pet Services\"]},{\"slug\":\"san-diego\",\"name\":\"San Diego\",\"parkCount\":38,\"avgRating\":4.7,\"totalReviews\":24496,\"featuredImage\":\"/images/cities/san-diego/hero.webp\",\"longitude\":-117.151816,\"state\":\"CA\",\"topParks\":[\"San Diego Dog Training\",\"Precious Pet Care San Diego\",\"Man-K9 - San Diego Dog Training\"]},{\"slug\":\"sacramento\",\"name\":\"Sacramento\",\"parkCount\":23,\"avgRating\":4.6,\"totalReviews\":3715,\"featuredImage\":\"/images/cities/sacramento-ca/hero.webp\",\"longitude\":-121.4871158,\"state\":\"CA\",\"topParks\":[\"Paws N' Play\",\"PUPPY LOVE BOARDERS\",\"Doggie Bed & Breakfast\"]},{\"slug\":\"riverside-ca\",\"name\":\"Riverside\",\"parkCount\":6,\"avgRating\":4.4,\"totalReviews\":1937,\"featuredImage\":\"/images/cities/riverside-ca/hero.webp\",\"longitude\":-117.3903759,\"state\":\"CA\",\"topParks\":[\"Pat Merritt Dog Park\",\"Ruff H