"item\":{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/sycamore-lane-kennels\",\"name\":\"Sycamore Lane Kennels\",\"url\":\"https://www.indoordogpark.org/parks/sycamore-lane-kennels\",\"description\":\"Sycamore Lane Kennels anchors Lodi's dog-loving rhythm as a dog park that marries expansive play yards with concierge-level care. Located in Lodi, CA, the park is tucked near 5111 W Sargent Rd, Lodi,...\",\"address\":{\"@type\":\"PostalAddress\",\"addressLocality\":\"Lodi\",\"addressRegion\":\"CA\",\"addressCountry\":\"US\"}}},{\"@type\":\"ListItem\",\"position\":4,\"item\":{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/all-dogs-sports-park-llc\",\"name\":\"All Dogs Sports Park, LLC\",\"url\":\"https://www.indoordogpark.org/parks/all-dogs-sports-park-llc\",\"description\":\"Perched in Lodi, All Dogs Sports Park, LLC delivers a dog park experience where energetic romps and mindful training feel perfectly balanced. Located in Lodi, CA, the park is tucked near 5111 W...\",\"address\":{\"@type\":\"PostalAddress\",\"addressLocality\":\"Lodi\",\"addressRegion\":\"CA\",\"addressCountry\":\"US\"}}},{\"@type\":\"ListItem\",\"position\":5,\"item\":{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/vinewood-park\",\"name\":\"Vinewood Park\",\"url\":\"https://www.indoordogpark.org/parks/vinewood-park\",\"description\":\"Vinewood Park anchors Lodi's dog-loving rhythm as a dog park that marries expansive play yards with concierge-level care. Located in Lodi, CA, the park is tucked near 931 Virginia Ave, Lodi, CA 95242...\",\"address\":{\"@type\":\"PostalAddress\",\"addressLocality\":\"Lodi\",\"addressRegion\":\"CA\",\"addressCountry\":\"US\"}}}]}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Where can I take my dog in Lodi, CA?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Lodi offers excellent off-leash play at Vinewood Dog Park and Beckman Dog Park (the city's largest). Lodi Lake Park also features a dedicated off-leash area near the Mokelumne River on its southeast side.\"}},{\"@type\":\"Question\",\"name\":\"Are Lodi wineries dog-friendly?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes, Lodi is famous for its dog-friendly vineyards. Oak Farm Vineyards, Intercoastal Vineyards, m2 Wines, and Harney Lane all welcome leashed pups on their beautiful patios and grounds.\"}},{\"@type\":\"Question\",\"name\":\"Can I walk my dog at Lodi Lake?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Absolutely. While dogs must be on a leash in most areas and are restricted from the nature area, they can enjoy the dedicated off-leash zone near Turner Road and leashed walks along the Mokelumne River.\"}},{\"@type\":\"Question\",\"name\":\"Which restaurants in Lodi have dog-friendly patios?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Many downtown spots welcome pups, including Lodi Beer Co., West Oak Nosh, and Pietros Trattoria. The Dancing Fox and Five Window Beer Co. also offer pet-friendly outdoor seating.\"}}]}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://www.indoordogpark.org/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"California Dog Parks\",\"item\":\"https://www.indoordogpark.org/\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Lodi\"}]}</script><header class=\"header header-visible  header-light\"><div class=\"header-container\"><div class=\"header-left\"><a class=\"logo\" href=\"/\"><img alt=\"Indoor Dog Park logo\" width=\"140\" height=\"40\" decoding=\"async\" data-nimg=\"1\" style=\"color:transparent;object-fit:contain;height:auto\" src=\"/images/logo/logo.png\"/></a></div><div class=\"header-center\"><nav class=\"header-nav\" 