"longitude\":-122.43547849999999,\"state\":\"CA\",\"topParks\":[\"FUReverFUN Dog Care Services\",\"Tefani & So Dogcare\",\"Bark To Basics\"]},{\"slug\":\"los-angeles\",\"name\":\"Los Angeles\",\"parkCount\":40,\"avgRating\":4.6,\"totalReviews\":10974,\"featuredImage\":\"/images/cities/los-angeles/hero.webp\",\"longitude\":-118.3910675,\"state\":\"CA\",\"topParks\":[\"LAK9S\",\"PetCare LB\",\"Doggie Land Pet Services\"]},{\"slug\":\"san-diego\",\"name\":\"San Diego\",\"parkCount\":38,\"avgRating\":4.7,\"totalReviews\":24496,\"featuredImage\":\"/images/cities/san-diego/hero.webp\",\"longitude\":-117.151816,\"state\":\"CA\",\"topParks\":[\"San Diego Dog Training\",\"Precious Pet Care San Diego\",\"Man-K9 - San Diego Dog Training\"]},{\"slug\":\"sacramento\",\"name\":\"Sacramento\",\"parkCount\":23,\"avgRating\":4.6,\"totalReviews\":3715,\"featuredImage\":\"/images/cities/sacramento-ca/hero.webp\",\"longitude\":-121.4871158,\"state\":\"CA\",\"topParks\":[\"Paws N' Play\",\"PUPPY LOVE BOARDERS\",\"Doggie Bed & Breakfast\"]},{\"slug\":\"riverside-ca\",\"name\":\"Riverside\",\"parkCount\":6,\"avgRating\":4.4,\"totalReviews\":1937,\"featuredImage\":\"/images/cities/riverside-ca/hero.webp\",\"longitude\":-117.3903759,\"state\":\"CA\",\"topParks\":[\"Pat Merritt Dog Park\",\"Ruff House Pet Resort\",\"Orangecrest Dog Park\"]},{\"slug\":\"modesto\",\"name\":\"Modesto\",\"parkCount\":5,\"avgRating\":4.7,\"totalReviews\":839,\"featuredImage\":\"/images/cities/modesto-ca/hero.webp\",\"longitude\":-120.99135340000001,\"state\":\"CA\",\"topParks\":[\"For Wags N Wiggles Doggie Daycare and Boarding\",\"Country View Kennels\",\"C R Ranch\"]}]}]]}]}]\n1f:[\"$\",\"section\",null,{\"id\":\"faq-section\",\"className\":\"city-faq-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell\",\"children\":[\"$\",\"$L35\",null,{\"cityName\":\"Lodi\",\"parkCount\":5,\"faqs\":[{\"question\":\"Where can I take my dog in Lodi, CA?\",\"answer\":\"Lodi offers excellent off-leash play at Vinewood Dog Park and Beckman Dog Park (the city's largest). Lodi Lake Park also features a dedicated off-leash area near the Mokelumne River on its southeast side.\",\"category\":\"facilities\",\"popular\":true},{\"question\":\"Are Lodi wineries dog-friendly?\",\"answer\":\"Yes, Lodi is famous for its dog-friendly vineyards. Oak Farm Vineyards, Intercoastal Vineyards, m2 Wines, and Harney Lane all welcome leashed pups on their beautiful patios and grounds.\",\"category\":\"visits\",\"popular\":true},{\"question\":\"Can I walk my dog at Lodi Lake?\",\"answer\":\"Absolutely. While dogs must be on a leash in most areas and are restricted from the nature area, they can enjoy the dedicated off-leash zone near Turner Road and leashed walks along the Mokelumne River.\",\"category\":\"facilities\"},{\"question\":\"Which restaurants in Lodi have dog-friendly patios?\",\"answer\":\"Many downtown spots welcome pups, including Lodi Beer Co., West Oak Nosh, and Pietros Trattoria. The Dancing Fox and Five Window Beer Co. also offer pet-friendly outdoor seating.\",\"category\":\"dining\"}]}]}]}]\n20:[\"$\",\"section\",null,{\"id\":\"related-resources\",\"className\":\"related-resources-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell\",\"children\":[[\"$\",\"div\",null,{\"className\":\"section-heading\",\"children\":[[\"$\",\"span\",null,{\"className\":\"section-eyebrow\",\"children\":\"Keep exploring\"}],[\"$\",\"h2\",null,{\"children\":\"More ways to plan\"}],[\"$\",\"p\",null,{\"children\":\"Browse statewide guides, submit a listing, or connect with our team.\"}]]}],[\"$\",\"div\",null,{\"className\":\"resources-grid\",\"children\":[[\"$\",\"$L11\",null,{\"href\":\"/\",\"className\":\"resource-card\",\"children\":[[\"$\",\"div\",null,{\"className\":\"resource-icon\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-globe\"}]}],[\"$\",\"h3\",null,{\"children\":\"California overview\"}],[\"$\",\"p\",null,{\"children\":\"See every city we cover plus