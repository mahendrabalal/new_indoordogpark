x-pearl-pack\",\"name\":\"Pearl Pack Pavilion\",\"url\":\"https://www.indoordogpark.org/parks/priority-pdx-pearl-pack\",\"description\":\"Pearl District pavilion with gallery lighting, rentable stages, and partnerships with local chefs for brunch...\",\"address\":{\"@type\":\"PostalAddress\",\"addressLocality\":\"Portland\",\"addressRegion\":\"OR\",\"addressCountry\":\"US\"},\"image\":\"https://images.unsplash.com/photo-1487412720507-e7ab37603c6f?auto=format&fit=crop&w=900&q=80\"}},{\"@type\":\"ListItem\",\"position\":2,\"item\":{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/priority-pdx-rain-city\",\"name\":\"Rain City Rovers\",\"url\":\"https://www.indoordogpark.org/parks/priority-pdx-rain-city\",\"description\":\"Central Eastside warehouse strung with skylights, kombucha taps, and rentable event pods so rainy afternoons still feel...\",\"address\":{\"@type\":\"PostalAddress\",\"addressLocality\":\"Portland\",\"addressRegion\":\"OR\",\"addressCountry\":\"US\"},\"image\":\"https://images.unsplash.com/photo-1450778869180-41d0601e046e?auto=format&fit=crop&w=900&q=80\"}},{\"@type\":\"ListItem\",\"position\":3,\"item\":{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/priority-pdx-sip-stay\",\"name\":\"Sip & Stay Yard\",\"url\":\"https://www.indoordogpark.org/parks/priority-pdx-sip-stay\",\"description\":\"Slabtown taproom with retractable walls, hazy IPAs, and staff monitors so you can host brewery playdates rain or...\",\"address\":{\"@type\":\"PostalAddress\",\"addressLocality\":\"Portland\",\"addressRegion\":\"OR\",\"addressCountry\":\"US\"},\"image\":\"https://images.unsplash.com/photo-1508672019048-805c876b67e2?auto=format&fit=crop&w=900&q=80\"}},{\"@type\":\"ListItem\",\"position\":4,\"item\":{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/priority-pdx-eastbank\",\"name\":\"Eastbank Enrichment Collective\",\"url\":\"https://www.indoordogpark.org/parks/priority-pdx-eastbank\",\"description\":\"Buckman studio built for agility teams—think rubber flooring, scent work labs, and livestream-ready lighting for...\",\"address\":{\"@type\":\"PostalAddress\",\"addressLocality\":\"Portland\",\"addressRegion\":\"OR\",\"addressCountry\":\"US\"},\"image\":\"https://images.unsplash.com/photo-1477973770766-6228305816df?auto=format&fit=crop&w=900&q=80\"}}]}3:[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"suppressHydrationWarning\":true,\"dangerouslySetInnerHTML\":{\"__html\":\"$c\"}}]\nd:T4d3,{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Where can I walk my dog indoors in Portland?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Our directory currently lists 4 indoor dog parks in Portland. Use the “Indoor Dog Park” filter on this page to jump straight to climate-controlled options.\"}},{\"@type\":\"Question\",\"name\":\"How much do Portland indoor dog parks cost?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Expect $18–$25 drop-ins that include a pint or coffee credit, plus $110–$150 monthly memberships that unlock event rentals and late-night rain plans.\"}},{\"@type\":\"Question\",\"name\":\"Do memberships include brewery or event perks?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes—many Portland operators partner with craft beverage clubs so you can earn bar tabs, reserve private taproom yards, or host fundraisers with built-in beverage minimums.\"}},{\"@type\":\"Question\",\"name\":\"Can I rent the space for parties or breed meetups?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Indoor parks like Pearl Pack Pavilion provide projector-ready lounges, catering-friendly kitchens, and sound systems. Submit event dates 2–3 weeks ahead for staff and cleanup scheduling.\"}}]}4:[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"suppressHydrationWarning\":true,\"dangerouslySetInnerHTML\":{\"__html\":\"$d\"}}]\n5:[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"suppressHydrationWarning\":true,\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://www.indoordogpark.org/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Dog Parks Directory\\\",\\\"item\\\":\\\"https://www.indoordogpark.org/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Portland\\\"}]}\"}}]\n6:[\"$\",\"$Le\",null,{\"variant\":\"light\"}]\n7:[\"$\",\"$Lf\",null,{\"items\":[{\"id\":\"city-hero\",\"title\":\"City Overview\",\"level\":1},{\"id\":\"city-insights\",\"title\":\"Quick Facts\",\"level\":1},{\"id\":\"city-comparison\",\"title\":\"Top Comparisons\",\"level\":1},{\"id\":\"park-collections\",\"title\":\"Park Collections\",\"level\":1},{\"id\":\"neighborhood-clusters\",\"title\":\"Neighborhoods\",\"level\":1},{\"id\":\"park-types-guide\",\"title\":\"Park Type Guide\",\"level\":1},{\"id\":\"map-and-neighborhoods\",\"title\":\"Map & Neighborhoods\",\"level\":1},{\"id\":\"planning-essentials\",\"title\":\"Planning Essentials\",\"level\":1},{\"id\":\"expert-tips\",\"title\":\"Expert Advice\",\"level\":1},{\"id\":\"park-directory\",\"title\":\"Full Directory\",\"level\":1},{\"id\":\"owner-cta\",\"title\":\"Owner & Franchise\",\"level\":1},{\"id\":\"faq-section\",\"title\":\"FAQs\",\"level\":1},{\"id\":\"related-resources\",\"title\":\"More Resources\",\"level\":1}]}]\n8:[\"$\",\"main\",null,{\"className\":\"city-page-layout\",\"children\":[[\"$\",\"div\",null,{\"className\":\"mobile-toc-button\",\"children\":[\"$\",\"$L10\",null,{\"className\":\"mobile-toc-trigger\",\"targetSelector\":\".table-of-contents\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-list-ul\"}],[\"$\",\"span\",null,{\"children\":\"Contents\"}]]}]}],[\"$\",\"section\",null,{\"id\":\"city-hero\",\"className\":\"city-hero-section \",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell city-hero-shell\",\"children\":[[\"$\",\"div\",null,{\"className\":\"city-hero-copy\",\"children\":[[\"$\",\"div\",null,{\"className\":\"hero-breadcrumbs\",\"children\":[[\"$\",\"$L11\",null,{\"href\":\"/\",\"children\":\"Home\"}],[\"$\",\"i\",null,{\"className\":\"bi bi-chevron-right\"}],[\"$\",\"span\",null,{\"children\":\"Dog Parks Directory\"}],[\"$\",\"i\",null,{\"className\":\"bi bi-chevron-right\"}],[\"$\",\"strong\",null,{\"children\":\"Portland\"}]]}],[\"$\",\"p\",null,{\"className\":\"hero-eyebrow\",\"children\":\"Rain-or-shine playgrounds\"}],[\"$\",\"h1\",null,{\"children\":\"Indoor dog park in Portland\"}],[\"$\",\"div\",null,{\"className\":\"hero-chip-row\",\"children\":[[\"$\",\"div\",\"0\",{\"className\":\"hero-chip\",\"children\":[[\"$\",\"span\",null,{\"className\":\"chip-label\",\"children\":\"Brewery collabs\"}],[\"$\",\"span\",null,{\"className\":\"chip-value\",\"children\":\"15+\"}],\"$undefined\"]}],[\"$\",\"div\",\"1\",{\"className\":\"hero-chip\",\"children\":[[\"$\",\"span\",null,{\"className\":\"chip-label\",\"children\":\"Private rentals\"}],[\"$\",\"span\",null,{\"className\":\"chip-value\",\"children\":\"Book in-app\"}],\"$undefined\"]}]]}],[\"$\",\"p\",null,{\"className\":\"hero-description\",\"children\":\"Rainy climate + craft beverage culture means Portland indoor dog parks lean on brewery partnerships, event rentals, and artful warehouse conversions.\"}],[\"$\",\"div\",null,{\"className\":\"city-rich-description\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"rich-description-paragraph\",\"children\":[\"Portland’s reputation as a premier dog-friendly city is perfectly captured in its approach to indoor play, especially given the city’s average of over 150 rainy days annually. The local scene has matured beyond simple warehouses into \\\"third places\\\" where the Pacific Northwest’s craft beverage culture meets high-end pet care. In neighborhoods like Slabtown and the Central Eastside, former industrial buildings feature massive skylights and retractable walls that navigate Oregon’s unpredictable drizzle. These venues, often partnered with local breweries, allow owners to socialize over a flight of IPAs while their dogs explore rubberized agility courses. Data from \",[\"$\",\"$L11\",\"1\",{\"href\":\"https://www.portland.gov/parks\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"rich-link\",\"children\":\"Portland Parks & Recreation\"}],null,\" highlights a robust outdoor system, but the private indoor sector offers a mud-free alternative that is practically required for the area's dense population of apartment residents.\"]}],[\"$\",\"p\",\"1\",{\"className\":\"rich-description-paragraph\",\"children\":[\"Sustainability and community are the foundations of Portland’s indoor parks, with flexible membership tiers catering to frequent rainy-season users. Monthly dues generally Range from $110 to $150, often including \\\"happy hour\\\" perks and guest passes for roommates. For the casual visitor, drop-in sessions cost around $18 to $25 and frequently include a beverage credit. Safety is strictly managed through behavioral assessments and digital vaccination verification (Rabies, DHLPP, and Bordetella). Many venues also host community events like rescue adoption drives and breed-specific mixers. To help owners transition from a wet walk to an indoor run, our \",[\"$\",\"$L11\",\"1\",{\"href\":\"#planning-essentials\",\"className\":\"rich-link\",\"children\":\"planning essentials\"}],null,\" section provides tips on the best quick-dry gear and slip-proof paw protection. By blending environmental design with a deep commitment to the dog community, Portland’s indoor parks provide a quirky, social sanctuary regardless of the forecast.\"]}]]}],\"$L12\",\"$L13\"]}],\"$L14\"]}]}],\"$L15\",\"$L16\",\"$L17\",\"$L18\",\"$L19\",\"$L1a\",\"$undefined\",\"$L1b\",\"$L1c\",false,\"$L1d\",\"$L1e\"]}]\n9:[\"$\",\"footer\",null,{\"className\":\"footer-new\",\"children\":[\"$\",\"div\",null,{\"className\":\"footer-container\",\"children\":[[\"$\",\"div\",null,{\"className\":\"footer-grid\",\"children\":[[\"$\",\"div\",null,{\"className\":\"footer-column\",\"children\":[[\"$\",\"h4\",null,{\"className\":\"footer-heading\",\"children\":\"IndoorDogPark\"}],[\"$\",\"ul\",null,{\"className\":\"footer-links\",\"children\":[[\"$\",\"li\",null,{\"children\":[\"$\",\"$L11\",null,{\"href\":\"/about\",\"children\":\"About us\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L11\",null,{\"href\":\"/partners\",\"children\":\"Partners\"}]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"footer-column\",\"children\":[[\"$\",\"h4\",null,{\"className\":\"footer-heading\",\"children\":\"Discover\"}],[\"$\",\"ul\",null,{\"className\":\"footer-links\",\"children\":[[\"$\",\"li\",null,{\"children\":[\"$\",\"$L11\",null,{\"href\":\"/\",\"children\":\"Browse parks\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L11\",null,{\"href\":\"/how-it-works\",\"children\":\"How it works\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L11\",null,{\"href\":\"/blog\",\"children\":\"Blog\"}]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"footer-column\",\"children\":[[\"$\",\"h4\",null,{\"className\":\"footer-heading\",\"children\":\"Park Owners\"}],[\"$\",\"ul\",null,{\"className\":\"footer-links\",\"children\":[[\"$\",\"li\",null,{\"children\":[\"$\",\"$L11\",null,{\"href\":\"/list-your-park\",\"children\":\"List your park\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L11\",null,{\"href\":\"/owner-resources\",\"children\":\"Owner resources\"}]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"footer-column\",\"children\":[[\"$\",\"h4\",null,{\"className\":\"footer-heading\",\"children\":\"Support\"}],[\"$\",\"ul\",null,{\"className\":\"footer-links\",\"children\":[[\"$\",\"li\",null,{\"children\":[\"$\",\"$L11\",null,{\"href\":\"/contact\",\"children\":\"Contact us\"}]}],[\"$\",\"li\",