eadcrumbs\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L12\\\",null,{\\\"href\\\":\\\"/\\\",\\\"children\\\":\\\"Home\\\"}],[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-chevron-right\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"children\\\":\\\"California Dog Parks\\\"}],[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-chevron-right\\\"}],[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"Los Angeles\\\"}]]}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"hero-eyebrow\\\",\\\"children\\\":\\\"SoCal Sunshine Play\\\"}],[\\\"$\\\",\\\"h1\\\",null,{\\\"children\\\":\\\"Indoor Dog Park In Los Angeles\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"hero-chip-row\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",\\\"0\\\",{\\\"className\\\":\\\"hero-chip\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"chip-label\\\",\\\"children\\\":\\\"Verified Spots\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"chip-value\\\",\\\"children\\\":\\\"45+\\\"}],\\\"$undefined\\\"]}],[\\\"$\\\",\\\"div\\\",\\\"1\\\",{\\\"className\\\":\\\"hero-chip\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"chip-label\\\",\\\"children\\\":\\\"Avg Rating\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"chip-value\\\",\\\"children\\\":\\\"4.5 / 5\\\"}],\\\"$undefined\\\"]}]]}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"hero-description\\\",\\\"children\\\":\\\"Los Angeles offers a sprawling network of dog-friendly spaces, from the iconic canyons of the Hollywood Hills to the meticulously landscaped urban runs of Downtown LA. The city’s year-round sunshine makes it a global leader in outdoor canine recreation.\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"city-rich-description\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",\\\"0\\\",{\\\"className\\\":\\\"rich-description-paragraph\\\",\\\"children\\\":[\\\"Los Angeles represents the pinnacle of outdoor dog culture, where a Mediterranean climate creates unmatched demand for play spaces. Expansive geography allows owners to choose from rugged trails in the Santa Monica Mountains to sleek runs in Grand Park DTLA. According to \\\",[\\\"$\\\",\\\"$L12\\\",\\\"1\\\",{\\\"href\\\":\\\"https://www.laparks.org\\\",\\\"target\\\":\\\"_blank\\\",\\\"rel\\\":\\\"noopener noreferrer\\\",\\\"className\\\":\\\"rich-link\\\",\\\"children\\\":\\\"LA Parks\\\"}],null,\\\", the municipal system maintains over a dozen off-leash areas, including Sepulveda Basin, which caters to high-energy breeds. The \\\\\\\"LA Dog\\\\\\\" lifestyle is intertwined with wellness, often featuring specialized walkers and mobile grooming. Owners should consult our \\\",[\\\"$\\\",\\\"$L12\\\",\\\"4\\\",{\\\"href\\\":\\\"#planning-essentials\\\",\\\"target\\\":\\\"$undefined\\\",\\\"rel\\\":\\\"$undefined\\\",\\\"className\\\":\\\"rich-link\\\",\\\"children\\\":\\\"planning essentials\\\"}],null,\\\" for heat safety, as pavement temperatures can exceed safe levels for paws during summer. This diversity ensures that every pup, from Hollywood to the coast, has a place to thrive.\\\"]}],[\\\"$\\\",\\\"p\\\",\\\"1\\\",{\\\"className\\\":\\\"rich-description-paragraph\\\",\\\"children\\\":[\\\"Beyond the public sector, Los Angeles is a trendsetter in the premium dog social market. In neighborhoods like Silver Lake, indoor/outdoor hybrid clubs are emerging, offering splash pads, chilled fountains, and shaded cabanas. These facilities are community \\\\\\\"third places,\\\\\\\" hosting adoption events and workshops led by trainers. Safety is paramount, with air filtration and antimicrobial turf being the standard for venues. While public parks are free, private clubs offer a curated alternative for those seeking professional supervision. Membership models often include priority grooming and social mixers, fostering a tight-knit community. Whether seeking a trailhead hike or an urban run, Los Angeles provides a canine-centric infrastructure that matches the ambition and diversity of the city.\\\"]}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"hero-cta-row\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L30\\\",null,{\\\"className\\\":\\\"hero-cta primary\\\",\\\"targetId\\\":\\\"park-directory\\\",\\\"children\\\":[[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-list-check\\\"}],\\\"Browse directory\\\"]}],\\\"$L31\\\",\\\"$L32\\\"]}],\\\"$L33\\\"]}],\\\"$L34\\\"]}]}],\\\"$L35\\\",\\\"$L36\\\",\\\"$L37\\\",\\\"$L38\\\",\\\"$L39\\\",\\\"$L3a\\\",\\\"$undefined\\\",\\\"$L3b\\\",\\\"$L3c\\\",\\\"$L3d\\\",\\\"$L3e\\\",\\\"$L3f\\\"]}]\\n\"])</script><script>self.__next_f.push([1,\"2b:[\\\"$\\\",\\\"footer\\\",null,{\\\"className\\\":\\\"footer-new\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"footer-container\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"footer-grid\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"footer-column\\\",\\\"children\\\":[[\\\"$\\\",\\\"h4\\\",null,{\\\"className\\\":\\\"footer-heading\\\",\\\"children\\\":\\\"IndoorDogPark\\\"}],[\\\"$\\\",\\\"ul\\\",null,{\\\"className\\\":\\\"footer-links\\\",\\\"children\\\":[[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[\\\"$\\\",\\\"$L12\\\",null,{\\\"href\\\":\\\"/about\\\",\\\"children\\\":\\\"About us\\\"}]}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[\\\"$\\\",\\\"$L12\\\",null,{\\\"href\\\":\\\"/partners\\\",\\\"children\\\":\\\"Partners\\\"}]}]]}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"footer-column\\\",\\\"children\\\":[[\\\"$\\\",\\\"h4\\\",null,{\\\"className\\\":\\\"footer-heading\\\",\\\"children\\\":\\\"Discover\\\"}],[\\\"$\\\",\\\"ul\\\",null,{\\\"className\\\":\\\"footer-links\\\",\\\"children\\\":[[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[\\\"$\\\",\\\"$L12\\\",null,{\\\"href\\\":\\\"/\\\",\\\"children\\\":\\\"Browse parks\\\"}]}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[\\\"$\\\",\\\"$L12\\\",null,{\\\"href\\\":\\\"/how-it-works\\\",\\\"child