\\"$\\\",\\\"li\\\",\\\"10 AM–3 PM weekdays: calm training-friendly window\\\",{\\\"children\\\":\\\"10 AM–3 PM weekdays: calm training-friendly window\\\"}],[\\\"$\\\",\\\"li\\\",\\\"After 4 PM: sunset crowd + cooler temps\\\",{\\\"children\\\":\\\"After 4 PM: sunset crowd + cooler temps\\\"}]]}]]}],[\\\"$\\\",\\\"article\\\",\\\"Essentials checklist\\\",{\\\"className\\\":\\\"planning-card\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"planning-icon\\\",\\\"children\\\":[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-backpack\\\"}]}],[\\\"$\\\",\\\"h3\\\",null,{\\\"children\\\":\\\"Essentials checklist\\\"}],[\\\"$\\\",\\\"ul\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"li\\\",\\\"Leash + harness for entry/exit control\\\",{\\\"children\\\":\\\"Leash + harness for entry/exit control\\\"}],[\\\"$\\\",\\\"li\\\",\\\"Collapsible water bowl and fresh water\\\",{\\\"children\\\":\\\"Collapsible water bowl and fresh water\\\"}],[\\\"$\\\",\\\"li\\\",\\\"Plenty of waste bags and high-value treats\\\",{\\\"children\\\":\\\"Plenty of waste bags and high-value treats\\\"}]]}]]}],[\\\"$\\\",\\\"article\\\",\\\"Local regulations\\\",{\\\"className\\\":\\\"planning-card\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"planning-icon\\\",\\\"children\\\":[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-shield-check\\\"}]}],[\\\"$\\\",\\\"h3\\\",null,{\\\"children\\\":\\\"Local regulations\\\"}],[\\\"$\\\",\\\"ul\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"li\\\",\\\"Keep proof of vaccinations or city license handy\\\",{\\\"children\\\":\\\"Keep proof of vaccinations or city license handy\\\"}],[\\\"$\\\",\\\"li\\\",\\\"Voice control required in most off-leash zones\\\",{\\\"children\\\":\\\"Voice control required in most off-leash zones\\\"}],[\\\"$\\\",\\\"li\\\",\\\"Limit three dogs per handler in public parks\\\",{\\\"children\\\":\\\"Limit three dogs per handler in public parks\\\"}]]}]]}],[\\\"$\\\",\\\"article\\\"