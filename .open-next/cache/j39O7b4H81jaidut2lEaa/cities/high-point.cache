\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"Hedgecock Dog Park is the primary off-leash facility, featuring two acres of play space. A permit is required from the Parks \\u0026 Rec department.\\\"}},{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"Are there dog-friendly trails in High Point?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"Yes, the High Point Greenway system offers outstanding paved trails. The Piedmont Environmental Center also has miles of natural surface trails for leashed hikes.\\\"}},{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"What are the leash laws in High Point?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"High Point enforces a strict leash law. Dogs must be on a leash and under control when off the owner’s property. There are no exceptions for voice control in public parks.\\\"}},{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"Is High Point University dog-friendly?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"The campus is private and generally restricted, but the surrounding greenways and public city parks are very welcoming to pets.\\\"}}]}26:[\\\"$\\\",\\\"script\\\",null,{\\\"type\\\":\\\"application/ld+json\\\",\\\"suppressHydrationWarning\\\":true,\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"$2e\\\"}}]\\n27:[\\\"$\\\",\\\"script\\\",null,{\\\"type\\\":\\\"application/ld+json\\\",\\\"suppressHydrationWarning\\\":true,\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"{\\\\\\\"@context\\\\\\\":\\\\\\\"https://schema.org\\\\\\\",\\\\\\\"@type\\\\\\\":\\\\\\\"BreadcrumbList\\\\\\\",\\\\\\\"itemListElement\\\\\\\":[{\\\\\\\"@type\\\\\\\":\\\\\\\"ListItem\\\\\\\",\\\\\\\"position\\\\\\\":1,\\\\\\\"name\\\\\\\":\\\\\\\"Home\\\\\\\",\\\\\\\"item\\\\\\\":\\\\\\\"https://www.indoordogpark.org/\\\\\\\"},{\\\\\\\"@type\\\\\\\":\\\\\\\"ListItem\\\\\\\",\\\\\\\"position\\\\\\\":2,\\\\\\\"name\\\\\\\":\\\\\\\"Dog Parks Directory\\