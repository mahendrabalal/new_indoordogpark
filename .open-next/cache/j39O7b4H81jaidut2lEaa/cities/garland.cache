\\":\\\"mobile-toc-button\\\",\\\"children\\\":[\\\"$\\\",\\\"$L30\\\",null,{\\\"className\\\":\\\"mobile-toc-trigger\\\",\\\"targetSelector\\\":\\\".table-of-contents\\\",\\\"children\\\":[[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-list-ul\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"children\\\":\\\"Contents\\\"}]]}]}],[\\\"$\\\",\\\"section\\\",null,{\\\"id\\\":\\\"city-hero\\\",\\\"className\\\":\\\"city-hero-section \\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"section-shell city-hero-shell\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"city-hero-copy\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"hero-breadcrumbs\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L12\\\",null,{\\\"href\\\":\\\"/\\\",\\\"children\\\":\\\"Home\\\"}],[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-chevron-right\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"children\\\":\\\"Dog Parks Directory\\\"}],[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-chevron-right\\\"}],[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"Garland\\\"}]]}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"hero-eyebrow\\\",\\\"children\\\":\\\"City spotlight\\\"}],[\\\"$\\\",\\\"h1\\\",null,{\\\"children\\\":\\\"Dog Parks in Garland, TX\\\"}],\\\"$undefined\\\",[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"hero-description\\\",\\\"children\\\":\\\"Discover the dedicated off-leash spaces, wooded trails, and active canine community of Garland.\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"city-rich-description\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",\\\"0\\\",{\\\"className\\\":\\\"rich-description-paragraph\\\",\\\"children\\\":[\\\"Garland provides a welcoming and active environment for dog owners, characterized by its investment in high-quality outdoor recreation for pets. The city's first dedicated off-leash facility, \\\",[\\\"$\\\",\\\"$L12\\\",\\\"1\\\",{\\\"href\\\":\\\"https://www.garlandtx.gov/648/Dog-Park\\\",\\\"target\\\":\\\"_blank\\\",\\\"rel\\\":\\\"noopener noreferrer\\\",\\\"className\\\":\\\"rich-link\\\",\\\"children\\\":\\\"Garland Dog Park\\\"}],null,\\\", is a massive 3-acre destination that utilize three rotating paddocks to ensure healthy turf for both large and small breeds. This innovative approach to maintenance, combined with the city's extensive trail system through parks like Rowlett Creek Preserve, ensures that local pups have diverse environments for exercise and socialization. Garland's established neighborhoods and numerous community-focused green spaces provide a perfect backdrop for pet parents who value a robust outdoor lifestyle with their dogs.\\\"]}],[\\\"$\\\",\\\"p\\\",\\\"1\\\",{\\\"className\\\":\\\"rich-description-paragraph\\\",\\\"children\\\":[\\\"Responsible ownership in Garland is supported by municipal guidelines that prioritize animal welfare and community standards. The city requires that all resident dogs be licensed and sterilized as part of its commitment to responsible pet stewardship. In all public areas outside of designated dog parks, pets must be securely restrained by a handheld leash, and owners are legally responsible for the immediate removal of animal waste to preserve the beauty of local parks. Pet parents can stay informed about the best regional pet care and seasonal strategies through our \\\",[\\\"$\\\",\\\"$L12\\\",\\\"1\\\",{\\\"href\\\":\\\"https://www.indoordogpark.org/states/texas\\\",\\\"target\\\":\\\"_blank\\\",\\\"rel\\\":\\\"noopener noreferrer\\\",\\\"className\\\":\\\"rich-link\\\",\\\"children\\\":\\\"Texas state guides\\\"}],null,\\\". By following these local standards and participating in park stewardship, Garland residents help maintain the inclusive spirit and high quality of life that define their community.\\\"]}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"hero-cta-row\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L30\\\",null,{\\\"className\\\":\\\"hero-cta primary\\\",\\\"tar