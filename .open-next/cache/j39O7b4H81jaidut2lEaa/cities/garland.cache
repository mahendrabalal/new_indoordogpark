e vibe that fits your next outing\"}],[\"$\",\"p\",null,{\"children\":\"Segmented park groupings built from live data so you can jump straight to the experiences that matter most.\"}]]}],false,[\"$\",\"div\",null,{\"className\":\"park-type-guide-wrapper\",\"children\":[\"$\",\"$L29\",null,{\"parksByType\":{\"Dog Park\":[\"$14:props:children:props:children:props:parks:0\",\"$14:props:children:props:children:props:parks:1\",\"$14:props:children:props:children:props:parks:2\",\"$14:props:children:props:children:props:parks:3\",\"$14:props:children:props:children:props:parks:4\",\"$14:props:children:props:children:props:parks:5\",\"$14:props:children:props:children:props:parks:6\",\"$14:props:children:props:children:props:parks:7\",\"$14:props:children:props:children:props:parks:8\",\"$14:props:children:props:children:props:parks:9\",\"$14:props:children:props:children:props:parks:10\",\"$14:props:children:props:children:props:parks:11\",\"$14:props:children:props:children:props:parks:12\",\"$14:props:children:props:children:props:parks:13\",\"$14:props:children:props:children:props:parks:14\",\"$14:props:children:props:children:props:parks:15\",\"$14:props:children:props:children:props:parks:16\",\"$14:props:children:props:children:props:parks:17\",\"$14:props:children:props:children:props:parks:18\",\"$14:props:children:props:children:props:parks:19\",\"$14:props:children:props:children:props:parks:20\",\"$14:props:children:props:children:props:parks:21\",\"$14:props:children:props:children:props:parks:22\",\"$14:props:children:props:children:props:parks:23\",\"$14:props:children:props:children:props:parks:24\",\"$14:props:children:props:children:props:parks:25\",\"$14:props:children:props:children:props:parks:26\",\"$14:props:children:props:children:props:parks:27\"]}}]}],\"$undefined\"]}]}]\n17:[\"$\",\"section\",null,{\"id\":\"map-and-neighborhoods\",\"className\":\"map-experience-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell\",\"childre