ges/cities/san-francisco/hero.webp\",\"datePublished\":\"2024-01-01T00:00:00.000Z\",\"dateModified\":\"2026-02-06T03:34:24.608Z\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Indoor Dog Park\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://www.indoordogpark.org/images/logo/logo-512.png\"}},\"about\":{\"@type\":\"City\",\"name\":\"San Francisco, CA\"},\"mainEntity\":{\"@id\":\"https://www.indoordogpark.org/cities/san-francisco#itemlist\"},\"containsPlace\":[{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/alamo-square-dog-play-area\",\"name\":\"Alamo Square Dog Play Area\",\"url\":\"https://www.indoordogpark.org/parks/alamo-square-dog-play-area\",\"sameAs\":[\"https://sfrecpark.org/Facilities/Facility/Details/Alamo-Square-Dog-Play-Area-2\"],\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"Alamo Square Park\",\"addressLocality\":\"San Francisco\",\"addressRegion\":\"CA\",\"postalCode\":\"94117\",\"addressCountry\":\"US\"},\"telephone\":\"(415) 554-6364\",\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":4.7,\"reviewCount\":26},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":37.7760874,\"longitude\":-122.43547849999999}},{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/bark-avenue-doggy-day-care\",\"name\":\"Bark Avenue Doggy Day Care\",\"url\":\"https://www.indoordogpark.org/parks/bark-avenue-doggy-day-care\",\"sameAs\":[\"https://barkavesf.com/\"],\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"301 King St\",\"addressLocality\":\"San Francisco\",\"addressRegion\":\"CA\",\"postalCode\":\"94107\",\"addressCountry\":\"US\"},\"telephone\":\"(415) 954-2275\",\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":4.6,\"reviewCount\":31},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":37.775465700000005,\"longitude\":-122.39470490000001}},{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/bark-to-basics\",\"name\":\"Bark To Basics\",\"url\":\"https://www.indoordogpark.org/parks/bark-to-basics\",\"sameAs\":[\"http://www.barktobasicssf.com/\"],\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"150 Sears St\",\"addressLocality\":\"San Francisco\",\"addressRegion\":\"CA\",\"postalCode\":\"94112\",\"addressCountry\":\"US\"},\"telephone\":\"(415) 265-0684\",\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":5,\"reviewCount\":36},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":37.709196999999996,\"longitude\":-122.45482919999999}},{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/bernal-heights-dog-play-area\",\"name\":\"Bernal Heights Dog Play Area\",\"url\":\"https://www.indoordogpark.org/parks/bernal-heights-dog-play-area\",\"sameAs\":[\"https://sfrecpark.org/Facilities/Facility/Details/Bernal-Heights-Dog-Play-Areas-4\"],\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"Bernal Heights Blvd\",\"addressLocality\":\"San Francisco\",\"addressRegion\":\"CA\",\"postalCode\":\"94110\",\"addressCountry\":\"US\"},\"telephone\":\"\",\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":4.7,\"reviewCount\":86},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":37.742863799999995,\"longitude\":-122.41195660000001}},{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/better-nature-dog-training\",\"name\":\"Better Nature Dog Training\",\"url\":\"https://www.indoordogpark.org/parks/better-nature-dog-training\",\"sameAs\":[\"https://www.betternaturedogtraining.com/\"],\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"1334 Kobbe Ave C\",\"addressLocality\":\"San Francisco\",\"addressRegion\":\"CA\",\"postalCode\":\"94129\",\"addressCountry\":\"US\"},\"telephone\":\"(415) 305-0672\",\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":5,\"reviewCount\":17},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":37.7982069,\"longitude\":-122.4737