"name\":\"Charlotte\",\"parkCount\":46,\"avgRating\":4.7,\"totalReviews\":11949,\"featuredImage\":\"/images/cities/charlotte/hero.webp\",\"longitude\":-80.8705981,\"state\":\"NC\",\"topParks\":[\"Mango Dogs Carolinas\",\"Obedient K9 Academy\",\"Hakuna Matata Dog Care & Training, LLC\"]},{\"slug\":\"asheville\",\"name\":\"Asheville\",\"parkCount\":45,\"avgRating\":4.6,\"totalReviews\":9412,\"featuredImage\":\"/images/cities/asheville/hero.webp\",\"longitude\":-82.655746,\"state\":\"NC\",\"topParks\":[\"Asheville Dog Academy\",\"Kabler School For Dogs\",\"WNC Pet Care LLC\"]},{\"slug\":\"raleigh\",\"name\":\"Raleigh\",\"parkCount\":43,\"avgRating\":4.6,\"totalReviews\":9787,\"featuredImage\":\"/images/cities/raleigh/hero.webp\",\"longitude\":-78.8294296,\"state\":\"NC\",\"topParks\":[\"Topline K9 Solutions\",\"Proactive Dog Training, LLC\",\"Harmony Pet Resort & Spa\"]},{\"slug\":\"wilmington\",\"name\":\"Wilmington\",\"parkCount\":42,\"avgRating\":4.5,\"totalReviews\":10649,\"featuredImage\":\"/images/cities/wilmington/hero.webp\",\"longitude\":-77.85872540000001,\"state\":\"NC\",\"topParks\":[\"Off Leash K9 Training, LLC\",\"Cape Fearless Dog Training\",\"K9 Resorts Luxury Pet Hotel Wilmington\"]},{\"slug\":\"winston-salem\",\"name\":\"Winston-Salem\",\"parkCount\":41,\"avgRating\":4.4,\"totalReviews\":6313,\"featuredImage\":\"/images/cities/winston-salem/hero.webp\",\"longitude\":-80.3199222,\"state\":\"NC\",\"topParks\":[\"Winston-Salem Dog Care\",\"Cultured Canine Dog Training\",\"Camp Lucky Board and Train (Winston-Salem NC)\"]},{\"slug\":\"greensboro-nc\",\"name\":\"Greensboro\",\"parkCount\":41,\"avgRating\":4.6,\"totalReviews\":12317,\"featuredImage\":\"/images/cities/greensboro-nc/hero.webp\",\"longitude\":-79.7339981,\"state\":\"NC\",\"topParks\":[\"Something to Bark About Dog Training\",\"Sit Means Sit Dog Training Greensboro\",\"Rising Star Canine Ranch\"]}]}]]}]}]\n3d:[\"$\",\"section\",null,{\"id\":\"faq-section\",\"className\":\"city-faq-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell\",\"children\":[\"$\",\"$L4a\",null,{\"cityName\":\"Cary\",\"parkCount\":29,\"faqs\":[{\"question\":\"Where is the main dog park in Cary, NC?\",\"answer\":\"The Barkyard at Downtown Cary Park is a premier destination with separate high-energy and low-energy play zones. Godbold Dog Park and Jack Smith Park also offer excellent off-leash facilities.\",\"category\":\"facilities\",\"popular\":true},{\"question\":\"Do I need a membership for Cary dog parks?\",\"answer\":\"Yes, Cary requires a dog park pass for its municipal dog parks. Single-day passes and annual memberships are available and can be purchased at community centers.\",\"category\":\"membership\",\"popular\":true},{\"question\":\"How many miles of greenway are in Cary?\",\"answer\":\"Cary boasts over 80 miles of greenways. The Black Creek Greenway and White Oak Creek Greenway are extensive networks connecting parks, neighborhoods, and shopping areas.\",\"category\":\"planning\"},{\"question\":\"Are dogs allowed at Hemlock Bluffs Nature Preserve?\",\"answer\":\"Yes, leashed dogs are welcome on the mulch trails at Hemlock Bluffs. It’s a great spot for a shaded, scenic walk, though it is more of a nature walk than a rigorous hike.\",\"category\":\"facilities\"}],\"supportCard\":{\"kicker\":\"Cary residents\",\"title\":\"Get active\",\"description\":\"Explore the vast trail network or join a meetup group at The Barkyard.\",\"primary\":{\"label\":\"View Trail Map\",\"href\":\"/trails\"},\"secondary\":{\"label\":\"Park Rules\",\"href\":\"/rules\"},\"footnote\":\"A pass is your ticket to off-leash fun.\"}}]}]}]\n3e:[\"$\",\"section\",null,{\"id\":\"related-resources\",\"className\":\"related-resources-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell\",\"children\":[[\"$\",\"div\",null,{\"className\":\"section-heading\",\"children\":[[\"$\",\"span\",null,{\"className\":\"section-eyebrow\",\"children\":\"Keep exploring\"}],[\"$\",\"