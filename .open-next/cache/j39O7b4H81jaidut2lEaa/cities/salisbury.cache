\",null,{\"className\":\"bi bi-chevron-right\"}],[\"$\",\"strong\",null,{\"children\":\"Salisbury\"}]]}],[\"$\",\"p\",null,{\"className\":\"hero-eyebrow\",\"children\":\"Historic Center\"}],[\"$\",\"h1\",null,{\"children\":\"Salisbury Strolls\"}],[\"$\",\"div\",null,{\"className\":\"hero-chip-row\",\"children\":[[\"$\",\"div\",\"0\",{\"className\":\"hero-chip\",\"children\":[[\"$\",\"span\",null,{\"className\":\"chip-label\",\"children\":\"Dog Park\"}],[\"$\",\"span\",null,{\"className\":\"chip-value\",\"children\":\"1\"}],\"$undefined\"]}],[\"$\",\"div\",\"1\",{\"className\":\"hero-chip\",\"children\":[[\"$\",\"span\",null,{\"className\":\"chip-label\",\"children\":\"Greenway\"}],[\"$\",\"span\",null,{\"className\":\"chip-value\",\"children\":\"4+ mi\"}],\"$undefined\"]}]]}],[\"$\",\"p\",null,{\"className\":\"hero-description\",\"children\":\"Salisbury blends beautiful historic architecture with great green spaces. The Dog PAWS Park and the extensive Greenway system make it a hidden gem for dog owners.\"}],[\"$\",\"div\",null,{\"className\":\"city-rich-description\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"rich-description-paragraph\",\"children\":[\"Salisbury, North Carolina, offers a charming setting for dog owning, defined by its well-preserved historic downtown and its commitment to public parks. A walk through the \",[\"$\",\"$L12\",\"1\",{\"href\":\"https://www.visitsalisburync.com\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"rich-link\",\"children\":\"historic district\"}],null,\" with a leashed dog is a journey through time, with wide sidewalks and beautiful architecture. For more vigorous exercise, the Salisbury Greenway offers over 4 miles of paved trails that weave through the city, connecting neighborhoods and offering a safe, traffic-free route for walkers and runners.\"]}],[\"$\",\"p\",\"1\",{\"className\":\"rich-description-paragraph\",\"children\":[\"The city specifically caters to dog owners with \",[\"$\",\"$L12\",\"1\",{\"href\":\"https://www.indoordogpark.org/training-facilities\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"rich-link\",\"children\":\"excellent, fenced facilities\"}],null,\" like the Dog PAWS Park at the Salisbury Civic Center. This fenced off-leash area is a community favorite, providing a dedicated space for socialization and play. Additionally, places like Dan Nicholas Park (just outside the city) offer a vast array of recreational options where leashed dogs can join the family for a day of fun. Salisbury combines the aesthetic appeal of a historic town with the functional amenities active dog owners need.\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-cta-row\",\"children\":[[\"$\",\"$L30\",null,{\"className\":\"hero-cta primary\",\"targetId\":\"park-directory\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-list-check\"}],\"Browse directory\"]}],[\"$\",\"$L30\",null,{\"className\":\"hero-cta ghost\",\"targetId\":\"map-and-neighborhoods\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-geo-alt\"}],\"Open map\"]}],[\"$\",\"$L12\",null,{\"href\":\"/list-your-park\",\"className\":\"hero-cta text-link\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-plus-circle\"}],\"Submit a park\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-footnotes\",\"children\":[[\"$\",\"span\",\"Dog PAWS Park\",{\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-sparkles\"}],\" \",\"Dog PAWS Park\"]}],[\"$\",\"span\",\"Salisbury Greenway\",{\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-sparkles\"}],\" \",\"Salisbury Greenway\"]}],[\"$\",\"span\",\"City Park\",{\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-sparkles\"}],\" \",\"City Park\"]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"city-hero-visual\",\"children\":[\"$\",\"div\",null,{\"className\":\"hero-image-card\",\"children\":[[\"$\",\"$L31\",null,{\"src\":\"/images/cities/salisbury-nc/hero.png\",\"alt\":\"Salisbury dog park landscape\",\"fill\":true