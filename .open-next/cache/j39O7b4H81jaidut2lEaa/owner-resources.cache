/js/adsbygoogle.js?client=ca-pub-8688786543603411\" crossorigin=\"anonymous\"></script><link rel=\"preload\" href=\"https://www.googletagmanager.com/gtag/js?id=G-FR11969GE9\" as=\"script\"/><meta name=\"p:domain_verify\" content=\"0563fd1fc3dbf5ddf80e6b177ae94816\"/><link rel=\"preconnect\" href=\"https://fonts.googleapis.com\" crossorigin=\"anonymous\"/><link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin=\"anonymous\"/><link rel=\"preconnect\" href=\"https://images.unsplash.com\" crossorigin=\"anonymous\"/><link rel=\"preconnect\" href=\"https://cdn.jsdelivr.net\" crossorigin=\"anonymous\"/><link rel=\"dns-prefetch\" href=\"https://unpkg.com\"/><link rel=\"dns-prefetch\" href=\"https://www.googletagmanager.com\"/><link rel=\"dns-prefetch\" href=\"https://www.google-analytics.com\"/><link rel=\"preload\" href=\"/images/logo/logo.png\" as=\"image\" type=\"image/png\"/><link rel=\"manifest\" href=\"/manifest.json\"/><link rel=\"icon\" href=\"/favicon.ico.svg\" type=\"image/svg+xml\"/><link rel=\"alternate icon\" href=\"/icons/icon-192x192.png\" type=\"image/png\"/><link rel=\"apple-touch-icon\" href=\"/icons/icon-192x192.png\"/><meta name=\"theme-color\" content=\"#7c3aed\"/><meta name=\"next-size-adjust\" content=\"\"/><title>Owner Resources | Indoor Dog Park Business Guides | Indoor Dog Park</title><meta name=\"description\" content=\"Business guides, templates, and coaching resources for indoor dog park operators and dog-friendly business owners in California.\"/><meta name=\"application-name\" content=\"Indoor Dog Park\"/><link rel=\"author\" href=\"https://www.indoordogpark.org\"/><meta name=\"author\" content=\"Indoor Dog Park Team\"/><meta name=\"keywords\" content=\"indoor dog park business,dog park operations,pet business resources,dog facility management,pet business startup,dog park templates,California pet business,dog daycare resources\"/><meta name=\"creator\" content=\"Indoor Dog Park\"/><meta name=\"publisher\" content=\"Indoor Dog Park\"/><meta name=\"robots\" content=\"index, follow\"/><meta name=\"googlebot\" content=\"index, follow, max-video-preview:-1, max-image-preview:large, max-snippet:-1\"/><meta name=\"category\" content=\"Pet Services\"/><meta name=\"theme-color\" content=\"#7c3aed\"/><meta name=\"msapplication-TileColor\" content=\"#7c3aed\"/><meta name=\"apple-mobile-web-app-capable\" content=\"yes\"/><meta name=\"apple-mobile-web-app-status-bar-style\" content=\"black-translucent\"/><meta name=\"apple-mobile-web-app-title\" content=\"Indoor Dog Park\"/><meta name=\"mobile-web-app-capable\" content=\"yes\"/><link rel=\"canonical\" href=\"https://www.indoordogpark.org/owner-resources\"/><meta name=\"format-detection\" content=\"telephone=no, address=no, email=no\"/><meta property=\"og:title\" content=\"Owner Resources | Indoor Dog Park Business Guides\"/><meta property=\"og:description\" content=\"Business guides and resources for indoor dog park operators and pet business owners.\"/><meta property=\"og:url\" content=\"https://www.indoordogpark.org/owner-resources\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:site\" content=\"@indoordogpark\"/><meta name=\"twitter:creator\" content=\"@indoordogpark\"/><meta name=\"twitter:title\" content=\"Best Indoor Dog Parks in California | Indoor Dog Park\"/><meta name=\"twitter:description\" content=\"Find year-round indoor dog parks across California. Search by city, neighborhood, or zip to discover safe, climate-controlled play spaces for your dog.\"/><meta name=\"twitter:image\" content=\"https://www.indoordogpark.org/images/hero/hero.webp\"/><link rel=\"icon\" href=\"/favicon.ico.svg\" type=\"image/svg+xml\"/><link rel=\"icon\" href=\"/icons/icon-192x192.png\" sizes=\"192x192\" type=\"image/png\"/><link rel=\"apple-touch-icon\" href=\"/icons/icon-192x192.png\" sizes=\"192x192\" type=\"image/png\"/><script data-grow-initializer=\"\">!(function(){window.growMe||((window.growMe=function(e){window.growMe._.push(e);}),(window.growMe._=[]));var e=document.createElement(\"script\");(e.type=\"text/javascript\"),(e.src=\"https://faves.grow.me/main.js\"),(e.defer=!0),e.setAttribute(\"data-grow-faves-site-id\",\"U2l0ZTo2NWU3MDY3YS0wNzI0LTQ0NjktYTZmYS1iYzU0YWYzNWYzOTg=\");var t=document.getElementsByTagName(\"script\")[0];t.parentNode.insertBefore(e,t);})();</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"Organization\",\"name\":\"Indoor Dog Park\",\"url\":\"https://www.indoordogpark.org\",\"logo\":\"https://www.indoordogpark.org/images/logo/logo-512.png\",\"description\":\"California's premier directory for indoor dog parks, play areas, and dog-friendly facilities.\",\"sameAs\":[\"https://www.facebook.com/IndoorDogParkDirectory\",\"https://x.com/Indoordogp40934\",\"https://www.instagram.com/indoordogpark2025/\"],\"contactPoint\":{\"@type\":\"ContactPoint\",\"contactType\":\"Customer Service\",\"availableLanguage\":\"en\"}}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"WebSite\",\"name\":\"Indoor Dog Park\",\"url\":\"https://www.indoordogpark.org\",\"description\":\"Find the best indoor dog parks and facilities across California\",\"potentialAction\":{\"@type\":\"SearchAction\",\"target\":{\"@type\":\"EntryPoint\",\"urlTemplate\":\"https://www.indoordogpark.org/?search={search_term_string}\"},\"query-input\":\"required name=search_term_string\"}}</script><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body class=\"__className_8a4156\"><div hidden=\"\"><!--$--><!--/$--></div><!--$!--><template data-dgst=\"BAILOUT_TO_CLIENT_SIDE_RENDERING\"></template><!--/$--><div class=\"flex flex-col min-h-screen bg-slate-50 text-slate-900\"><header class=\"header header-visible  header-light\"><div class=\"header-container\"><div class=\"header-left\"><a class=\"logo\" href=\"/\"><img alt=\"Indoor Dog Park logo\" width=\"140\" height=\"40\" decoding=\"async\" data-nimg=\"1\" style=\"color:transparent;object-fit:contain;height:auto\" src=\"/images/logo/logo.png\"/></a></div><div class=\"header-center\"><nav class=\"header-nav\" aria-label=\"Main navigation\"><a class=\"header-nav-link\" href=\"/\">Browse Parks</a><div class=\"header-nav-item\"><button class=\"header-nav-link\" aria-haspopup=\"true\" aria-expanded=\"false\">Discover <i class=\"bi bi-chevron-down dropdown-icon \"></i></button><div class=\"header-dropdown \"><a class=\"header-dropdown-link\" href=\"/parks-with-bars\">Parks with Bars</a><a class=\"header-dropdown-link\" href=\"/training-facilities\">Training Facilities</a><a class=\"header-dropdown-link\" href=\"/how-it-works\">How It Works</a></div></div><div class=\"header-nav-item\"><button class=\"header-nav-link\" aria-haspopup=\"true\" aria-expanded=\"false\">Locations <i class=\"bi bi-chevron-down dropdown-icon \"></i></button><div class=\"header-dropdown \"><a class=\"header-dropdown-link\" href=\"/cities/san-francisco\">San Francisco</a><a class=\"header-dropdown-link\" href=\"/cities/los-angeles\">Los Angeles</a><a class=\"header-dropdown-link\" href=\"/cities/san-diego\">San Diego</a><a class=\"header-dropdown-link\" href=\"/cities/new-york\">New York</a><a class=\"header-dropdown-link\" href=\"/cities/seattle\">Seattle</a></div></div><a class=\"header-nav-link\" href=\"/about\">About</a><a class=\"header-nav-link\" href=\"/blog\">Blog</a></nav></div><div class=\"header-right\"><a class=\"header-link\" href=\"/contact\">Contact us</a><a class=\"header-link header-link-primary\" href=\"/list-your-park\">List your park</a><a class=\"header-link\" href=\"/signup\">Sign up</a><a class=\"header-link\" href=\"/login\">Log in</a><button class=\"menu-toggle\" aria-label=\"Toggle menu\" aria-expanded=\"false\"><i class=\"bi bi-list\"></i></button></div></div><div class=\"mobile-menu \" aria-hidden=\"true\"><a class=\"mobile-menu-item\" href=\"/\">Browse Parks</a><a class=\"mobile-menu-item\" href=\"/parks-with-bars\">Parks with Bars</a><a class=\"mobile-menu-item\" href=\"/training-facilities\">Training Facilities</a><a class=\"mobile-menu-item\" href=\"/how-it-works\">How It Works</a><a class=\"mobile-menu-item\" href=\"/blog\">Blog &amp; Guides</a><a class=\"mobile-menu-item\" href=\"/about\">About</a><a class=\"mobile-menu-item\" href=\"/contact\">Contact us</a><a class=\"mobile-menu-item\" href=\"/list-your-park\">List your park</a><a class=\"mobile-menu-item\" href=\"/signup\">Sign up</a><a class=\"mobile-menu-item\" href=\"/login\">Log in</a></div></header><main class=\"flex-1 pt-[70px] \"><section class=\"bg-gradient-to-br from-slate-900 to-violet-900 py-20 text-white\"><div class=\"mx-auto max-w-5xl px-4 text-center\"><p class=\"text-sm font-semibold uppercase tracking-[0.3em] text-violet-200\">Owner resources</p><h1 class=\"mt-4 text-4xl font-bold leading-tight md:text-5xl\">Run a thriving indoor dog park with confidence</h1><p class=\"mt-4 text-lg text-slate-200\">We package the tools, coaching, and benchmarks that California operators use to launch, scale, and delight their communities.</p><div class=\"mt-8 flex flex-wrap justify-center gap-4\"><a class=\"inline-flex items-center rounded-full bg-white px-6 py-3 font-semibold text-slate-900 hover:bg-slate-50\" href=\"/list-your-park\">List your park</a><a class=\"inline-flex items-center rounded-full border border-white/30 px-6 py-3 font-semibold text-white hover:border-white\" href=\"/contact\">Book a coaching call</a></div></div></section><section class=\"bg-white py-16\"><div class=\"mx-auto max-w-6xl px-4\"><div class=\"mb-8 text-center\"><p class=\"text-sm font-semibold uppercase tracking-[0.3em] text-violet-600\">Resource tracks</p><h2 class=\"mt-2 text-3xl font-bold text-slate-900\">Choose the stage you’re in</h2><p class=\"mt-4 text-lg text-slate-600 max-w-3xl mx-auto\">Whether you’re planning your first indoor dog park, optimizing daily operations, or scaling to multiple locations, we’ve curated resources based on real-world experience from successful California operators.</p></div><div class=\"grid gap-6 md:grid-cols-3\"><div class=\"rounded-3xl border border-slate-200 bg-slate-50/80 p-6\"><h3 class=\"text-2xl font-semibold text-slate-900\">Launch playbook</h3><p class=\"mt-3 text-sm text-slate-600\">Zoning research, insurance checklists, and vendor recommendations for brand-new facilities.</p><ul class=\"mt-4 space-y-2 text-sm text-slate-600\"><li class=\"flex items-start gap-2\"><i class=\"bi bi-check-circle-fill text-violet-500\" aria-hidden=\"true\"></i><span>Market sizing worksheet</span></li><li class=\"flex items-start gap-2\"><i class=\"bi bi-check-circle-fill text-violet-500\" aria-hidden=\"true\"></i><span>Floor plan inspiration</span></li><li class=\"flex items-start gap-2\"><i class=\"bi bi-check-circle-fill text-violet-500\" aria-hidden=\"true\"></i><span>Permitting cheat sheet</span></li></ul></div><div class=\"rounded-3xl border border-slate-200 bg-slate-50/80 p-6\"><h3 class=\"text-2xl font-semibold text-slate-900\">Operations toolkit</h3><p class=\"mt-3 text-sm text-slate-600\">Day-to-day templates that cover staffing, scheduling, cleaning routines, and safety drills.</p><ul class=\"mt-4 space-y-2 text-sm text-slate-600\"><li class=\"flex items-start gap-2\"><i class=\"bi bi-check-circle-fill text-violet-500\" aria-hidden=\"true\"></i><span>Shift handoff notes</span></li><li class=\"flex items-start gap-2\"><i class=\"bi bi-check-circle-fill text-violet-500\" aria-hidden=\"true\"></i><span>Incident reporting workflows</span></li><li class=\"flex items-start gap-2\"><i class=\"bi bi-check-circle-fill text-violet-500\" aria-hidden=\"true\"></i><span>Maintenance matrix</span></li></ul></div><div class=\"rounded-3xl border border-slate-200 bg-slate-50/80 p-6\"><h3 class=\"text-2xl font-semibold text-slate-900\">Growth lab</h3><p class=\"mt-3 text-sm text-slate-600\">Campaign templates, review activation guides, and retention playbooks for existing parks.</p><ul class=\"mt-4 space-y-2 text-sm text-slate-600\"><li class=\"flex items-start gap-2\"><i class=\"bi bi-check-circle-fill text-violet-500\" aria-hidden=\"true\"></i><span>Membership nurture series</span></li><li class=\"flex items-start gap-2\"><i class=\"bi bi-check-circle-fill text-violet-500\" aria-hidden=\"true\"></i><span>Referral promos</span></li><li class=\"flex items-start gap-2\"><i class=\"bi bi-check-circle-fill text-violet-500\" aria-hidden=\"true\"></i><span>Seasonal event calendar</span></li></ul></div></div><div class=\"mt-12 rounded-2xl border border-slate-200 bg-slate-50 p-8\"><h3 class=\"text-xl font-semibold text-slate-900 mb-4\">Why These Resources Matter</h3><p class=\"text-slate-600 mb-4\">Starting and running an indoor dog park requires navigating complex regulations, managing staff, maintaining safety standards, and building a loyal customer base. Our resources are compiled from interviews with successful park operators, industry best practices, and lessons learned from common pitfalls.</p><p class=\"text-slate-600\">Each resource track is designed to address specific challenges at different stages of your business journey, helping you avoid costly mistakes and accelerate your path to profitability.</p></div></div></section><section class=\"bg-slate-50 py-16\"><div class=\"mx-auto max-w-6xl px-4\"><div class=\"mb-8 flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between\"><div><p class=\"text-sm font-semibold uppercase tracking-[0.3em] text-violet-700\">Template library</p><h2 class=\"mt-2 text-3xl font-bold text-slate-900\">Ready-to-use docs</h2></div><p class=\"text-sm text-slate-500\">Need something custom? Email us and we’ll co-create a new resource.</p></div><p class=\"mb-8 text-slate-600 max-w-3xl\">Save hours of research and formatting with our professionally designed templates. Each document has been tested by real park operators and includes best practices for compliance, safety, and operational efficiency. All templates are customizable to fit your specific needs and local regulations.</p><div class=\"grid gap-6 md:grid-cols-2\"><div class=\"rounded-3xl border border-slate-200 bg-white p-6\"><div class=\"flex items-center justify-between\"><div><p class=\"text-xs font-semibold uppercase tracking-[0.3em] text-slate-500\">PDF</p><h3 class=\"mt-2 text-xl font-semibold text-slate-900\">Emergency response plan</h3></div><i class=\"bi bi-download text-2xl text-slate-400\" aria-hidden=\"true\"></i></div><p class=\"mt-3 text-sm text-slate-600\">Step-by-step protocol for injuries, severe weather, or facility issues. Download the PDF template or view online.</p><div class=\"mt-4 flex flex-wrap gap-3\"><a class=\"inline-flex items-center text-sm font-semibold text-violet-700 hover:text-violet-500\" download=\"\" href=\"/resources/emergency-response-plan.pdf\"><i class=\"bi bi-download mr-1\" aria-hidden=\"true\"></i>Download PDF</a><a class=\"inline-flex items-center text-sm font-semibold text-slate-600 hover:text-slate-900\" target=\"_blank\" href=\"/resources/emergency-response-plan.html\">View Online<i class=\"bi bi-arrow-right-short text-xl ml-1\" aria-hidden=\"true\"></i></a></div></div><div class=\"rounded-3xl border border-slate-200 bg-white p-6\"><div class=\"flex items-center justify-between\"><div><p class=\"text-xs font-semibold uppercase tracking-[0.3em] text-slate-500\">CSV/Excel</p><h3 class=\"mt-2 text-xl font-semibold text-slate-900\">Vaccination &amp; waiver tracker</h3></div><i class=\"bi bi-download text-2xl text-slate-400\" aria-hidden=\"true\"></i></div><p class=\"mt-3 text-sm text-slate-600\">Auto-calculates expiration reminders and sends follow-up emails. Includes formulas and email automation guide.</p><div class=\"mt-4 flex flex-wrap gap-3\"><a class=\"inline-flex items-center text-sm font-semibold text-violet-700 hover:text-violet-500\" target=\"_blank\" href=\"/resources/vaccination-waiver-tracker.html\"><i class=\"bi bi-file-earmark-text mr-1\" aria-hidden=\"true\"></i>View Template</a></div></div><div class=\"rounded-3xl border border-slate-200 bg-white p-6\"><div class=\"flex items-center justify-between\"><div><p class=\"text-xs font-semibold uppercase tracking-[0.3em] text-slate-500\">PDF/Template</p><h3 class=\"mt-2 text-xl font-semibold text-slate-900\">Partnership outreach kit</h3></div><i class=\"bi bi-download text-2xl text-slate-400\" aria-hidden=\"true\"></i></div><p class=\"mt-3 text-sm text-slate-600\">Pitch scripts, sponsorship tiers, and co-marketing briefs. Ready-to-use email templates for partnerships.</p><div class=\"mt-4 flex flex-wrap gap-3\"><a class=\"inline-flex items-center text-sm font-semibold text-violet-700 hover:text-violet-500\" target=\"_blank\" href=\"/resources/partnership-outreach-kit.html\"><i class=\"bi bi-file-earmark-text mr-1\" aria-hidden=\"true\"></i>View Template</a></div></div><div class=\"rounded-3xl border border-slate-200 bg-white p-6\"><div class=\"flex items-center justify-between\"><div><p class=\"text-xs font-semibold uppercase tracking-[0.3em] text-slate-500\">PDF/Checklist</p><h3 class=\"mt-2 text-xl font-semibold text-slate-900\">Staff onboarding checklist</h3></div><i class=\"bi bi-download text-2xl text-slate-400\" aria-hidden=\"true\"></i></div><p class=\"mt-3 text-sm text-slate-600\">Role expectations, training videos, and customer experience standards. Complete onboarding checklist for new hires.</p><div class=\"mt-4 flex flex-wrap gap-3\"><a class=\"inline-flex items-center text-sm font-semibold text-violet-700 hover:text-violet-500\" target=\"_blank\" href=\"/resources/staff-onboarding-checklist.html\"><i class=\"bi bi-file-earmark-text mr-1\" aria-hidden=\"true\"></i>View Template</a></div></div></div></div></section><section class=\"bg-white py-16\"><div class=\"mx-auto max-w-5xl px-4\"><div class=\"rounded-3xl border border-slate-200 bg-gradient-to-r from-violet-50 to-rose-50 p-8\"><p class=\"text-sm font-semibold uppercase tracking-[0.3em] text-violet-700\">Support system</p><h2 class=\"mt-3 text-3xl font-bold text-slate-900\">You don’t have to build alone</h2><p class=\"mt-4 text-slate-600 max-w-2xl\">Building a successful indoor dog park is challenging, but you don’t have to figure it out alone. Our community of park operators shares knowledge, troubleshoots problems together, and celebrates wins. Access expert guidance, proven strategies, and a network of peers who understand the unique challenges of running a pet facility.</p><div class=\"mt-6 grid gap-4 md:grid-cols-2\"><div class=\"rounded-2xl border border-white/70 bg-white/80 p-5\"><div class=\"mb-3 inline-flex h-10 w-10 items-center justify-center rounded-full bg-violet-600/10 text-violet-700\"><i class=\"bi bi-chat-dots\" aria-hidden=\"true\"></i></div><h3 class=\"text-lg font-semibold text-slate-900\">Office hours</h3><p class=\"mt-2 text-sm text-slate-600\">Live 1:1 coaching every Tuesday &amp; Thursday covering growth, pricing, and policies.</p></div><div class=\"rounded-2xl border border-white/70 bg-white/80 p-5\"><div class=\"mb-3 inline-flex h-10 w-10 items-center justify-center rounded-full bg-violet-600/10 text-violet-700\"><i class=\"bi bi-collection-play\" aria-hidden=\"true\"></i></div><h3 class=\"text-lg font-semibold text-slate-900\">Resource vault</h3><p class=\"mt-2 text-sm text-slate-600\">Video walkthroughs of the listing dashboard, review tools, and campaign manager.</p></div><div class=\"rounded-2xl border border-white/70 bg-white/80 p-5\"><div class=\"mb-3 inline-flex h-10 w-10 items-center justify-center rounded-full bg-violet-600/10 text-violet-700\"><i class=\"bi bi-people\" aria-hidden=\"true\"></i></div><h3 class=\"text-lg font-semibold text-slate-900\">Owner forum</h3><p class=\"mt-2 text-sm text-slate-600\">Invite-only Slack for sharing wins, staffing tips, and vendor recommendations.</p></div><div class=\"rounded-2xl border border-white/70 bg-white/80 p-5\"><div class=\"mb-3 inline-flex h-10 w-10 items-center justify-center rounded-full bg-violet-600/10 text-violet-700\"><i class=\"bi bi-lightbulb\" aria-hidden=\"true\"></i></div><h3 class=\"text-lg font-semibold text-slate-900\">Program experiments</h3><p class=\"mt-2 text-sm text-slate-600\">Pilot new features such as live waitlists, birthday bundles, and multi-park passes.</p></div></div></div></div></section><section class=\"bg-slate-900 py-16 text-white\"><div class=\"mx-auto flex max-w-4xl flex-col gap-6 text-center\"><h2 class=\"text-3xl font-bold\">Need a hands-on playbook?</h2><p class=\"text-lg text-slate-200\">Our owner success team will review your goals and send a personalized roadmap within a week.</p><div class=\"flex flex-wrap justify-center gap-4\"><a class=\"inline-flex items-center rounded-full bg-white px-6 py-3 font-semibold text-slate-900 hover:bg-violet-50\" href=\"/contact\">Request a strategy session</a><a class=\"inline-flex items-center rounded-full border border-white/30 px-6 py-3 font-semibold text-white hover:border-white\" href=\"/partners\">Explore partnerships</a></div></div></section></main><div class=\"jsx-80debf708dd09952 w-full bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 relative overflow-hidden\"><div class=\"jsx-80debf708dd09952 absolute inset-0 bg-[url(&#x27;/images/pattern.svg&#x27;)] opacity-5\"></div><div class=\"jsx-80debf708dd09952 absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent\"></div><div class=\"jsx-80debf708dd09952 absolute top-0 left-1/4 w-64 h-64 bg-indigo-500/20 rounded-full blur-[100px] animate-pulse\"></div><div style=\"animation-delay:1s\" class=\"jsx-80debf708dd09952 absolute bottom-0 right-1/4 w-64 h-64 bg-violet-500/20 rounded-full blur-[100px] animate-pulse\"></div><div class=\"jsx-80debf708dd09952 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-12 relative z-10\"><div class=\"jsx-80debf708dd09952 bg-white/95 backdrop-blur-xl rounded-[2rem] shadow-2xl border border-white/20 overflow-hidden transform hover:scale-[1.005] transition-all duration-500\"><div class=\"jsx-80debf708dd09952 grid md:grid-cols-2 gap-0 min-h-[320px]\"><div class=\"jsx-80debf708dd09952 p-6 md:p-8 flex flex-col justify-center relative bg-gradient-to-br from-white to-slate-50/50\"><div class=\"jsx-80debf708dd09952 inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-gradient-to-r from-indigo-500/10 to-violet-500/10 border border-indigo-200/50 backdrop-blur-sm mb-4 w-fit\"><span class=\"jsx-80debf708dd09952 relative flex h-2 w-2\"><span class=\"jsx-80debf708dd09952 animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-500 opacity-75\"></span><span class=\"jsx-80debf708dd09952 relative inline-flex rounded-full h-2 w-2 bg-gradient-to-r from-indigo-500 to-violet-500\"></span></span><span class=\"jsx-80debf708dd09952 text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-violet-600 text-[10px] font-black uppercase tracking-widest\">Live Safety Check</span></div><h2 class=\"jsx-80debf708dd09952 text-3xl md:text-4xl font-black text-slate-900 mb-4 leading-[1.1] tracking-tight\">Is it safe for<br class=\"jsx-80debf708dd09952\"/><span class=\"jsx-80debf708dd09952 text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 via-purple-600 to-violet-600 animate-gradient\">paws to pause?</span></h2><p class=\"jsx-80debf708dd09952 text-slate-600 text-base leading-relaxed font-medium mb-5 max-w-md\">Don&#x27;t guess. Check real-time pavement risk, heat index, and frostbite danger for your dog.</p><form class=\"jsx-80debf708dd09952 relative w-full max-w-lg\"><div class=\"jsx-80debf708dd09952 relative group\"><div class=\"jsx-80debf708dd09952 absolute -inset-1 bg-gradient-to-r from-indigo-600 via-purple-600 to-violet-600 rounded-3xl blur-xl opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-300 animate-tilt\"></div><div class=\"jsx-80debf708dd09952 relative flex items-center bg-white rounded-xl shadow-lg borde