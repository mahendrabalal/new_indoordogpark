ntent\":\"Pet Services\"}],[\"$\",\"meta\",\"11\",{\"name\":\"theme-color\",\"content\":\"#7c3aed\"}],[\"$\",\"meta\",\"12\",{\"name\":\"msapplication-TileColor\",\"content\":\"#7c3aed\"}],[\"$\",\"meta\",\"13\",{\"name\":\"apple-mobile-web-app-capable\",\"content\":\"yes\"}],[\"$\",\"meta\",\"14\",{\"name\":\"apple-mobile-web-app-status-bar-style\",\"content\":\"black-translucent\"}],[\"$\",\"meta\",\"15\",{\"name\":\"apple-mobile-web-app-title\",\"content\":\"Indoor Dog Park\"}],[\"$\",\"meta\",\"16\",{\"name\":\"mobile-web-app-capable\",\"content\":\"yes\"}],[\"$\",\"link\",\"17\",{\"rel\":\"canonical\",\"href\":\"https://www.indoordogpark.org/parks-with-bars\"}],[\"$\",\"meta\",\"18\",{\"name\":\"format-detection\",\"content\":\"telephone=no, address=no, email=no\"}],[\"$\",\"meta\",\"19\",{\"property\":\"og:title\",\"content\":\"Indoor Dog Parks with Bars | Dog-Friendly Bars & Play Spaces\"}],[\"$\",\"meta\",\"20\",{\"property\":\"og:description\",\"content\":\"Discover indoor dog parks with bars and restaurants. Find climate-controlled play spaces where you can enjoy drinks while your dog plays. Search by city or location.\"}],[\"$\",\"meta\",\"21\",{\"property\":\"og:url\",\"content\":\"https://www.indoordogpark.org/parks-with-bars\"}],[\"$\",\"meta\",\"22\",{\"property\":\"og:site_name\",\"content\":\"Indoor Dog Park\"}],[\"$\",\"meta\",\"23\",{\"property\":\"og:locale\",\"content\":\"en_US\"}],[\"$\",\"meta\",\"24\",{\"property\":\"og:image\",\"content\":\"https://www.indoordogpark.org/images/hero/hero.webp\"}],[\"$\",\"meta\",\"25\",{\"property\":\"og:image:width\",\"content\":\"1200\"}],[\"$\",\"meta\",\"26\",{\"property\":\"og:image:height\",\"content\":\"630\"}],[\"$\",\"meta\",\"27\",{\"property\":\"og:image:alt\",\"content\":\"Indoor Dog Parks with Bars - Dog-Friendly Bars & Play Spaces\"}],[\"$\",\"meta\",\"28\",{\"property\":\"og:type\",\"content\":\"website\"}],[\"$\",\"meta\",\"29\",{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",\"30\",{\"name\":\"twitter:site\",\"content\":\"@indoordogpark\"}],[\"$\",\"meta\",\"31\",{\"name\":\"twitter:creator\",\"content\":\"@indoordogpark\"}],[\"$\",\"meta\",\"32\",{\"name\":\"twitter:title\",\"content\":\"Indoor Dog Parks with Bars | Dog-Friendly Bars & Play Spaces\"}],[\"$\",\"meta\",\"33\",{\"name\":\"twitter:description\",\"content\":\"Discover indoor dog parks with bars and restaurants. Find climate-controlled play spaces where you can enjoy drinks while your dog plays. Search by city or location.\"}],[\"$\",\"meta\",\"34\",{\"name\":\"twitter:image\",\"content\":\"https://www.indoordogpark.org/images/hero/hero.webp\"}],[\"$\",\"link\",\"35\",{\"rel\":\"icon\",\"href\":\"/favicon.ico.svg\",\"type\":\"image/svg+xml\"}],[\"$\",\"link\",\"36\",{\"rel\":\"icon\",\"href\":\"/icons/icon-192x192.png\",\"sizes\":\"192x192\",\"type\":\"image/png\"}],[\"$\",\"link\",\"37\",{\"rel\":\"apple-touch-icon\",\"href\":\"/icons/icon-192x192.png\",\"sizes\":\"192x192\",\"type\":\"image/png\"}],[\"$\",\"$L23\",\"38\",{}]]\n24:T17e0,{\"@context\":\"https://schema.org\",\"@type\":\"CollectionPage\",\"@id\":\"https://www.indoordogpark.org#webpage\",\"name\":\"Indoor Dog Parks Directory\",\"description\":\"Find year-round indoor dog parks across California. Search by city, neighborhood, or zip to discover safe, climate-controlled play spaces for your dog.\",\"url\":\"https://www.indoordogpark.org\",\"mainEntity\":{\"@type\":\"ItemList\",\"@id\":\"https://www.indoordogpark.org#itemlist\",\"numberOfItems\":20,\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"item\":{\"@type\":\"SportsActivityLocation\",\"name\":\"A Bark Above Pet Salon\",\"url\":\"https://www.indoordogpark.org/parks/a-bark-above-pet-salon\",\"address\":{\"@type\":\"PostalAddress\",\"addressLocality\":\"Roanoke\",\"addressRegion\":\"VA\",\"addressCountry\":\"US\"}}},{\"@type\":\"ListItem\",\"position\":2,\"item\":{\"@type\":\"SportsActivityLocation\",\"name\":\"A Bark Away NJ\",\"u