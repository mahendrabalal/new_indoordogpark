pdated\":null,\"dataQuality\":\"verified\",\"photo\":null,\"faqs\":[],\"source\":\"static\",\"listingType\":\"free\"},{\"id\":\"ChIJmf-d103xwIcR4snbOIUtk9w\",\"name\":\"Bar K\",\"businessType\":\"Dog Park\",\"description\":\"$11\",\"slug\":\"bar-k\",\"address\":\"501 Berkley Pkwy\",\"street\":\"501 Berkley Pkwy\",\"city\":\"Kansas City\",\"state\":\"MO\",\"zipCode\":\"64120\",\"full_address\":\"501 Berkley Pkwy, Kansas City, MO 64120, USA\",\"latitude\":39.1146958,\"longitude\":-94.5778314,\"googlePlaceId\":\"ChIJmf-d103xwIcR4snbOIUtk9w\",\"phone\":\"(816) 474-2275\",\"website\":\"http://www.barkdogbar.com/\",\"photos\":null,\"rating\":4.7,\"reviewCount\":3328,\"openingHours\":{\"Monday\":\"12:00 – 9:00 PM\",\"Tuesday\":\"Closed\",\"Wednesday\":\"12:00 – 9:00 PM\",\"Thursday\":\"12:00 – 9:00 PM\",\"Friday\":\"9:00 AM – 9:00 PM\",\"Saturday\":\"9:00 AM – 9:00 PM\",\"Sunday\":\"9:00 AM – 8:00 PM\"},\"amenities\":{\"Onsite services\":true,\"Indoor facilities\":true,\"Professional staff\":true,\"Climate controlled\":true,\"Wheelchair accessible entrance\":true,\"Parking available\":true,\"Easy access\":true},\"pricing\":{\"pricingSource\":\"website\",\"isFree\":false},\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"lastUpdated\":null,\"dataQuality\":\"verified\",\"photo\":null,\"faqs\":[],\"source\":\"static\",\"listingType\":\"free\"},{\"id\":\"ChIJ44EyQzUEU4gRiWNvXx5YvUU\",\"name\":\"Bark & Fly Ranch\",\"businessType\":\"Indoor Dog Park\",\"description\":\"Bark & Fly Ranch has earned the trust of High Point residents. This facility features climate-controlled facilities for North Carolina's varied weather, caring and attentive team members, offering pet care. Their services ensures your dog stays comfortable year-round in North Carolina. situated in a prime High Point location. Reach out to Bark & Fly Ranch for a consultation\",\"slug\":\"bark-fly-ranch\",\"address\":\"8001 Clinard Farms Rd\",\"street\":\"8001 Clinard Farms Rd\",\"city\":\"High Point\",\"state\":\"NC\",\"zipCode\":\"27265\",\"full_address\":\"8001 Clinard Farms Rd, High Point, NC 27265, USA\",\"latitude\":36.0618219,\"longitude\":-79.98752809999999,\"googlePlaceId\":\"ChIJ44EyQzUEU4gRiWNvXx5YvUU\",\"phone\":\"(336) 931-0909\",\"website\":\"http://www.barknflyranch.com/\",\"rating\":4.2,\"reviewCount\":101,\"userRatingsTotal\":101,\"pricing\":{\"pricingSource\":\"unknown\",\"isFree\":false},\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"dataQuality\":\"verified\",\"openingHours\":{\"Monday\":\"7:30 AM – 6:00 PM\",\"Tuesday\":\"7:30 AM – 6:00 PM\",\"Wednesday\":\"7:30 AM – 6:00 PM\",\"Thursday\":\"7:30 AM – 6:00 PM\",\"Friday\":\"7:30 AM – 6:00 PM\",\"Saturday\":\"7:30 AM – 12:00 PM\",\"Sunday\":\"4:00 – 6:00 PM\"},\"faqs\":[],\"amenities\":{},\"photos\":[{\"url\":\"/images/parks/northcarolina/bark-fly-ranch/bark-fly-ranch-1.jpg\",\"type\":\"photo\",\"source\":\"website\"},{\"url\":\"/images/parks/northcarolina/bark-fly-ranch/bark-fly-ranch-2.jpg\",\"type\":\"photo\",\"source\":\"website\"}],\"photo\":\"/images/parks/northcarolina/bark-fly-ranch/bark-fly-ranch-1.jpg\",\"source\":\"static\",\"listingType\":\"free\"},{\"id\":\"ChIJmxx3R7nqwokRby81RjVyL4c\",\"name\":\"Bark & Meow\",\"businessType\":\"Indoor Dog Park\",\"description\":\"Bark & Meow has become the premier destination for Yonkers dog owners. This facility features spacious exercise zones, experienced and certified staff, offering pet care. Their services provides essential socialization for your pet. easily accessible from Yonkers's main areas. Discover why Yonkers pet parents choose Bark & Meow\",\"slug\":\"bark-meow\",\"address\":\"9a S Broadway\",\"street\":\"9a S Broadway\",\"city\":\"Yonkers\",\"state\":\"NY\",\"zipCode\":\"10591\",\"full_address\":\"9a S Broadway, Tarrytown, NY 10591, USA\",\"latitude\":41.0759463,\"longitude\":-73.8586351,\"googlePlaceId\":\"ChIJmxx3R7nqwokRby81RjVyL4c\",\"phone\":\"(914) 524-7373\",\"website\":\"http://www.barkandmeowinc.com/\",\"rating\":4.9,\"reviewCount\":64,\"userRatingsTotal\":64,\"pricing\":{\"pricingSource\":\"unknown\",\"isFree\":false},\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"dataQuality\":\"verified\",\"openingHours\":{\"Monday\":\"Closed\",\"Tuesday\":\"10:30 AM – 6:00 PM\",\"Wednesday\":\"10:30 AM – 6:00 PM\",\"Thursday\":\"10:30 AM – 6:00 PM\",\"Friday\":\"10:30 AM – 6:00 PM\",\"Saturday\":\"10:30 AM – 6:00 PM\",\"Sunday\":\"11:00 AM – 4:00 PM\"},\"faqs\":[],\"amenities\":{},\"photos\":[{\"url\":\"/images/parks/newyork/bark-meow/bark-meow-1.jpg\",\"type\":\"photo\",\"source\":\"website\"},{\"url\":\"/images/parks/newyork/bark-meow/bark-meow-2.jpg\",\"type\":\"photo\",\"source\":\"website\"}],\"photo\":\"/images/parks/newyork/bark-meow/bark-meow-1.jpg\",\"source\":\"static\",\"listingType\":\"free\"},{\"id\":\"ChIJJ2hG5fXtj4ARQqs0EdiFLiU\",\"name\":\"Bark & Ride\",\"businessType\":\"Dog Park\",\"description\":\"$12\",\"slug\":\"bark-ride\",\"address\":\"Stoneleaf Rd\",\"street\":\"Stoneleaf Rd\",\"city\":\"San Ramon\",\"state\":\"CA\",\"zipCode\":\"94582\",\"full_address\":\"Stoneleaf Rd, San Ramon, CA 94582\",\"latitude\":37.7726359,\"longitude\":-121.9186752,\"googlePlaceId\":\"ChIJJ2hG5fXtj4ARQqs0EdiFLiU\",\"phone\":\"\",\"website\":\"http://www.ci.san-ramon.ca.us/cms/One.aspx?portalId=10826130&pageId=11693008\",\"photos\":null,\"rating\":4.5,\"reviewCount\":77,\"pricing\":{\"pricingSource\":\"website\",\"isFree\":false,\"pricingType\":\"membership\"},\"placeTypes\":[\"dog_park\",\"park\",\"point_of_interest\",\"establishment\"],\"lastUpdated\":null,\"dataQuality\":\"verified\",\"photo\":null,\"faqs\":[{\"question\":\"What should I bring for check-in at Bark & Ride?\",\"answer\":\"Bring proof of current rabies and core vaccinations, a leash for entry and exit, and an ID tag with up-to-date contact info to breeze through check-in at Bark & Ride. Download the waiver from http://www.ci.san-ramon.ca.us/cms/One.aspx?portalId=10826130&pageId=11693008 and submit your dog profile before your visit.\",\"lastUpdated\":\"2025-11-14T19:36:02.813163+00:00\"},{\"question\":\"How does pricing work at Bark & Ride?\",\"answer\":\"Bark & Ride offers flexible memberships and punch cards so you can tailor visits to your routine. Contact the desk for the latest promotions or multi-dog discounts.\",\"lastUpdated\":\"2025-11-14T19:36:02.813163+00:00\"},{\"question\":\"Which amenities does Bark & Ride offer?\",\"answer\":\"The team rotates toys, agility props, and splash features weekly so repeat visits to Bark & Ride never feel stale. Expect shaded seating, rinse stations, and staff roaming the yards to keep playgroups safe.\",\"lastUpdated\":\"2025-11-14T19:36:02.813163+00:00\"},{\"question\":\"When is Bark & Ride open and where do I park?\",\"answer\":\"Hours rotate with weather and staffing, so call ahead to confirm current play blocks. Street and shared-lot parking is available nearby; arrive a few minutes early to grab a spot. Use posted signage around San Ramon to navigate any temporary closures.\",\"lastUpdated\":\"2025-11-14T19:36:02.813163+00:00\"},{\"question\":\"How do I contact the team at Bark & Ride?\",\"answer\":\"For reservations, temperament assessments, or party rentals, visit http://www.ci.san-ramon.ca.us/cms/One.aspx?portalId=10826130&pageId=11693008. The concierge team at Bark & Ride typically replies within one business day.\",\"lastUpdated\":\"2025-11-14T19:36:02.813163+00:00\"}],\"source\":\"static\",\"listingType\":\"free\"},{\"id\":\"ChIJLf03OdW2RIYRJ0IEXWokfOo\",\"name\":\"Bark & Zoom\",\"businessType\":\"Dog Park\",\"description\":\"Bark & Zoom has earned its reputation as a top Dog facility in Del Valle. Customers consistently mention the spacious play areas and excellent customer service, highlighting why this facility is a go-to destination for dog lovers. For more information, call (512) 817-2275.\",\"slug\":\"bark-zoom\",\"address\":\"2601 Cardinal Loop\",\"street\":\"2601 Cardinal Loop\",\"city\":\"Del Valle\",\"state\":\"TX\",\"zipCode\":\"78617\",\"full_address\":\"2601 Cardinal Loop, Del Valle, TX 78617, USA\",\"latitude\":30.2133695,\"longitude\":-97.6570394,\"googlePlaceId\":\"ChIJLf03OdW2RIYRJ0IEXWokfOo\",\"phone\":\"(512) 817-2275\",\"website\":\"http://barkandzoom.com/\",\"photos\":null,\"rating\":4.5,\"reviewCount\":282,\"openingHours\":{\"Monday\":\"Open 24 hours\",\"Tuesday\":\"Open 24 hours\",\"Wednesday\":\"Open 24 hours\",\"Thursday\":\"Open 24 hours\",\"Friday\":\"Open 24 hours\",\"Saturday\":\"Open 24 hours\",\"Sunday\":\"Open 24 hours\"},\"amenities\":{\"Onsite services\":true,\"Indoor facilities\":true,\"Professional staff\":true,\"Climate controlled\":true,\"Wheelchair accessible entrance\":true,\"Parking available\":true,\"Easy access\":true},\"pricing\":{\"pricingSource\":\"website\",\"isFree\":false},\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"lastUpdated\":null,\"dataQuality\":\"verified\",\"photo\":null,\"faqs\":[],\"source\":\"static\",\"listingType\":\"free\"}],\"initialShowSearchLayout\":true}]}]\n5:[\"$\",\"$L13\",null,{\"eyebrow\":\"Dog-friendly nightlife\",\"title\":\"Indoor dog parks with bars: what to expect and how to choose\",\"intro\":[\"Indoor dog parks with bars combine a climate-controlled play space for dogs with a bar, restaurant, or café area for people. These venues are popular when it is too hot, too cold, or too rainy for outdoor parks—and they can be a great option for social dogs and owners who want a relaxed place to hang out.\",\"Because food and drinks are involved, the best “parks with bars” tend to have clear safety rules, strong supervision, and thoughtful layouts that separate play zones from serving areas. Use the listings above to compare locations, then read the guide below for practical tips before you go.\"],\"sections\":[{\"heading\":\"What makes a great park-with-bar venue\",\"paragraphs\":[\"The best experiences come from venues that treat the dog park as the main attraction, not an afterthought. Look for clean flooring, ample room for dogs to move, and a clear plan for separating dogs by size or play style when needed.\",\"For humans, comfortable seating with good sight lines matters. Many venues also offer water stations, waste disposal, and staff who actively monitor play.\"],\"listItems\":[\"Clear rules posted at check-in (vaccines, age, temperament, supervision).\",\"Separate entry/exit and double-gated vestibules to prevent escapes.\",\"Visible staff oversight and an easy way to report issues.\",\"Good ventilation and routine cleaning throughout the day.\",\"Designated food/drink zones away from high-energy play.\"]},{\"heading\":\"Etiquette and safety tips (especially around food and drinks)\",\"paragraphs\":[\"Food and drinks can increase excitement. Plan for your dog’s success by arriving after a short walk, bringing high-value treats only if allowed, and avoiding peak hours if your dog is still learning polite greetings.\",\"If your venue serves alcohol, remember: dogs take cues from us. Staying attentive—rather than treating the park like a “hands-off” daycare—helps keep the space safe for everyone.\"],\"listItems\":[\"Watch body language: stiff posture, hard staring, or repeated mounting are signs to intervene.\",\"Avoid bringing toys if the venue discourages them (resource guarding).\",\"Keep drinks and food out of reach; ask staff about spill cleanup procedures.\",\"Know when to leave: overtired dogs can get snippy even if they started happy.\"]},{\"heading\":\"How to use this page to find the right match\",\"paragraphs\":[\"Start by searching your city, then refine by rating and price. Click a listing to open details, photos, and website links so you can confirm requirements and hours.\",\"If you are traveling, bookmark a few options. Policies vary, and some venues require registration, waivers, or proof of vaccinations before entry.\"],\"listItems\":[\"Use “Any Rating” to quickly narrow down to the most loved venues.\",\"Check the description for clues like “brewery,” “café,” or “restaurant.”\",\"Open the website to verify vaccination rules and whether reservations are needed.\",\"Use the map to pick spots close to your hotel, event, or neighborhood.\"]},{\"heading\":\"For owners: add or update your venue\",\"paragraphs\":[\"If you run an indoor dog park with a bar or food service, a complete listing helps customers understand your rules and reduces friction at check-in. Strong listings typically include accurate hours, pricing, photos of the play zones, and a short description of how you handle safety.\",\"You can submit your venue for free, or choose a featured placement for extra visibility.\"],\"listItems\":[\"Include vaccine requirements and any age restrictions.\",\"Mention play area separation (small/large, high/low energy).\",\"Add details about food/drink areas and leash policies.\",\"Upload multiple photos showing the space and seating layout.\"]}],\"faqs\":[{\"question\":\"Do indoor dog parks with bars usually require vaccinations?\",\"answer\":\"Yes. Most venues require proof of core vaccines, and many also require bordetella and a current rabies vaccine. Always check the venue website for the exact list and acceptable documentation.\"},{\"question\":\"Are these venues safe for puppies?\",\"answer\":\"It depends on the venue rules and your puppy’s age and vaccine status. Some locations have age minimums or puppy-specific play times. If your puppy is still learning social skills, choose off-peak hours and start with short visits.\"},{\"question\":\"How long should a first visit be?\",\"answer\":\"For many dogs, 30–60 minutes is a great first session. Watch for signs of overstimulation and leave while your dog is still having a good time so the experience ends on a positive note.\"},{\"question\":\"Can I bring outside food or treats?\",\"answer\":\"Policies vary. Some venues allow treats; others restrict them to prevent resource guarding. When in doubt, keep food and toys in your bag and follow staff guidance.\"}],\"links\":[{\"href\":\"/list-your-park\",\"title\":\"List your park\",\"description\":\"Own a dog-friendly venue? Submit a free listing or upgrade to featured placement.\"},{\"href\":\"/training-facilities\",\"title\":\"Training facilities\",\"description\":\"Find indoor training centers and agility spaces for skill-building and enrichment.\"},{\"href\":\"/contact\",\"title\":\"Contact\",\"description\":\"Found an incorrect listing or want to suggest a venue? Send us a message.\"}],\"className\":\"border-t border-gray-100\"}]\n6:[\"$\",\"div\",null,{\"className\":\"bg-gray-50 py-12 mt-12\",\"children\":[\"$\",\"div\",null,{\"className\":\"container mx-auto px-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-3xl font-bold text-gray-900 mb-8\",\"children\":\"Related Resources\"}],[\"$\",\"div\",null,{\"className\":\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8\",\"children\":[[\"$\",\"$L8\",null,{\"href\":\"/training-facilities\",\"className\":\"bg-white p-6 rounded-lg shadow-sm hover:shadow-md transition-shadow\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-xl font-semibold text-gray-900 mb-2\",\"children\":\"Training Facilities\"}],[\"$\",\"p\",null,{\"className\":\"text-gray-600\",\"children\":\"Find indoor dog training facilities and agility centers.\"}]]}],[\"$\",\"$L8\",null,{\"href\":\"/blog\",\"className\":\"bg-white p-6 rounded-lg shadow-sm hover:shadow-md transition-shadow\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-xl font-semibold text-gray-900 mb-2\",\"children\":\"Blog & Guides\"}],[\"$\",\"p\",null,{\"className\":\"text-gray-600\",\"children\":\"Read articles about dog parks, training, and pet care.\"}]]}]]}],false]}]}]\n7:[\"$\",\"$L14\",null,{\"children\":[\"$\",\"$9\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@15\"}]}]\n15:null\n","/parks-with-bars":"1:\"$Sreact.fragment\"\n2:I[7121,[],\"\"]\n3:I[4581,[],\"\"]\n0:{\"buildId\":\"j39O7b4H81jaidut2lEaa\",\"rsc\":[\"$\",\"$1\",\"c\