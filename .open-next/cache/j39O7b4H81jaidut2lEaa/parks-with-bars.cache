\\\":{\\\"Onsite services\\\":true,\\\"Indoor facilities\\\":true,\\\"Professional staff\\\":true,\\\"Climate controlled\\\":true,\\\"Wheelchair accessible entrance\\\":false,\\\"Parking available\\\":true,\\\"Easy access\\\":true},\\\"pricing\\\":{\\\"pricingSource\\\":\\\"website\\\",\\\"isFree\\\":false},\\\"placeTypes\\\":[\\\"point_of_interest\\\",\\\"establishment\\\"],\\\"lastUpdated\\\":null,\\\"dataQuality\\\":\\\"verified\\\",\\\"photo\\\":null,\\\"faqs\\\":[],\\\"source\\\":\\\"static\\\",\\\"listingType\\\":\\\"free\\\"},{\\\"id\\\":\\\"ChIJ-xqSm4FVhVQRlUov-Jvz6Rc\\\",\\\"name\\\":\\\"A Barkery Unleashed\\\",\\\"businessType\\\":\\\"Indoor Dog Park\\\",\\\"description\\\":\\\"Washington pet parents in Everett choose A Barkery Unleashed for premium care. This facility features heated spaces for comfortable year-round play, knowledgeable animal handlers, offering pet care. Their services offers peace of mind for busy Washington pet parents. conveniently located in the heart of Everett. Discover why Everett pet parents choose A Barkery Unleashed\\\",\\\"slug\\\":\\\"a-barkery-unleashed\\\",\\\"address\\\":\\\"1508 3rd St Suite B\\\",\\\"street\\\":\\\"1508 3rd St Suite B\\\",\\\"city\\\":\\\"Everett\\\",\\\"state\\\":\\\"WA\\\",\\\"zipCode\\\":\\\"98270\\\",\\\"full_address\\\":\\\"1508 3rd St Suite B, Marysville, WA 98270, USA\\\",\\\"latitude\\\":48.0506129,\\\"longitude\\\":-122.1766119,\\\"googlePlaceId\\\":\\\"ChIJ-xqSm4FVhVQRlUov-Jvz6Rc\\\",\\\"phone\\\":\\\"(425) 371-9803\\\",\\\"rating\\\":4.9,\\\"reviewCount\\\":105,\\\"userRatingsTotal\\\":105,\\\"photos\\\":null,\\\"photo\\\":null,\\\"placeTypes\\\":[\\\"point_of_interest\\\",\\\"establishment\\\"],\\\"dataQuality\\\":\\\"verified\\\",\\\"website\\\":\\\"http://abarkeryunleashed.com/\\\",\\\"openingHours\\\":{\\\"Monday\\\":\\\"9:00 AM – 5:00 PM\\\",\\\"Tuesday\\\":\\\"9:00 AM – 5:00 PM\\\",\\\"Wednesday\\\":\\\"9:00 AM – 7:30 PM\\\",\\\"Thursday\\\":\\\"9:00 AM – 7:00 PM\\\",\\\"Friday\\\":\\\"9:00 AM – 6:00 PM\\\",\\\"Saturday\\\":\\\"9:00 AM – 5:00 PM\\\",\\\"Sunday\\\":\\\"9:00 AM – 5:00 PM\\\"},\\\"pricing\\\":{\\\"pricingSource\\\":\\\"unknown\\\",\\\"isFree\\\":false},\\\"source\\\":\\\"static\\\",\\\"listingType\\\":\\\"free\\\"},{\\\"id\\\":\\\"ChIJL2aQD-LGlIARs0vA_nQtAws\\\",\\\"name\\\":\\\"AJ Country Kennel\\\",\\\"businessType\\\":\\\"Dog Park\\\",\\\"description\\\":\\\"$2b\\\",\\\"slug\\\":\\\"aj-country-kennel\\\",\\\"address\\\":\\\"15800 Idaho Ave\\\",\\\"street\\\":\\\"15800 Idaho Ave\\\",\\\"city\\\":\\\"Lemoore\\\",\\\"state\\\":\\\"CA\\\",\\\"zipCode\\\":\\\"93245\\\",\\\"full_address\\\":\\\"15800 Idaho Ave, Lemoore, CA 93245\\\",\\\"latitude\\\":36.2699326,\\\"longitude\\\":-119.74205719999999,\\\"googlePlaceId\\\":\\\"ChIJL2aQD-LGlIARs0vA_nQtAws\\\",\\\"phone\\\":\\\"(559) 582-5108\\\",\\\"website\\\":\\\"http://www.ajcountrykennel.com/\\\",\\\"photos\\\":null,\\\"rating\\\":4.8,\\\"reviewCount\\\":67,\\\"pricing\\\":{\\\"pricingSource\\\":\\\"website\\\",\\\"isFree\\\":false},\\\"placeTypes\\\":[\\\"point_of_interest\\\",\\\"establishment\\\"],\\\"lastUpdated\\\":null,\\\"dataQuality\\\":\\\"verified\\\",\\\"photo\\\":null,\\\"faqs\\\":[{\\\"question\\\":\\\"What should I bring for check-in at AJ Country Kennel?\\\",\\\"answer\\\":\\\"Bring proof of current rabies and core vaccinations, a leash for entry and exit, and an ID tag with up-to-date contact info to breeze through check-in at AJ Country Kennel. Download the waiver from http://www.ajcountrykennel.com/ and submit your dog profile before your visit.\\\",\\\"lastUpdated\\\":\\\"2025-11-14T19:36:02.813163+00:00\\\"},{\\\"question\\\":\\\"How does pricing work at AJ Country Kennel?\\\",\\\"answer\\\":\\\"AJ Country Kennel offers flexible memberships and punch cards so you can tailor visits to your routine. Contact the desk for the latest promotions or multi-dog discounts.\\\",\\\"lastUpdated\\\":\\\"2025-11-14T19:36:02.813163+00:00\\\"},{\\\"question\\\":\\\"Which amenities does AJ Country Kennel offer?\\\",\\\"answer\\\":\\\"The team rotates toys, agility props, and splash features weekly so repeat visits to AJ Country Kennel never feel stale. Expect shaded seating, rinse stations, and staff roaming the yards to keep playgroups safe.\\\",\\\"lastUpdated\\\":\\\"2025-11-14T19:36:02.813163+00:00\\\"},{\\\"question\\\":\\\"When is AJ Country Kennel open and where do I park?\\\",\\\"answer\\\":\\\"Hours rotate with weather and staffing, so call ahead to confirm current play blocks. Street and shared-lot parking is available nearby; arrive a few minutes early to grab a spot. Use posted signage around Lemoore to navigate any temporary closures.\\\",\\\"lastUpdated\\\":\\\"2025-11-14T19:36:02.813163+00:00\\\"},{\\\"question\\\":\\\"How do I contact the team at AJ Country Kennel?\\\",\\\"answer\\\":\\\"For reservations, temperament assessments, or party rentals, call (559) 582-5108, and visit http://www.ajcountrykennel.com/. The concierge team at AJ Country Kennel typically replies within one business day.\\\",\\\"lastUpdated\\\":\\\"2025-11-14T19:36:02.813163+00:00\\\"}],\\\"source\\\":\\\"static\\\",\\\"listingType\\\":\\\"free\\\"},{\\\"id\\\":\\\"ChIJ8TOQ-HTEw4kR4pNsl8-kl3E\\\",\\\"name\\\":\\\"All American Pet Resorts North Brunswick\\\",\\\"businessType\\\":\\\"Dog Park\\\",\\\"description\\\":\\\"$2c\\\",\\\"slug\\\":\\\"all-american-pet-resorts-north-brunswick\\\",\\\"address\\\":\\\"330 Thalia St\\\",\\\"street\\\":\\\"330 Thalia St\\\",\\\"city\\\":\\\"North Brunswick Township\\\",\\\"state\\\":\\\"NJ\\\",\\\"zipCode\\\":\\\"08902\\\",\\\"full_address\\\":\\\"330 Thalia St, North Brunswick Township, NJ 08902, USA\\\",\\\"latitude\\\":40.4461986,\\\"longitude\\\":-74.4942717,\\\"googlePlaceId\\\":\\\"ChIJ8TOQ-HTEw4kR4pNsl8-kl3E\\\",\\\"phone\\\":\\\"(732) 314-7272\\\",\\\"website\\\":\\\"https://www.allamericanpetresorts.com/north-brunswick/\\\",\\\"photos\\\":null,\\\"rating\\\":4.8,\\\"reviewCount\\\":288,\\\"openingHours\\\":{\\\"Mon