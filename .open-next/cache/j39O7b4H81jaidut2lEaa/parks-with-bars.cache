{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/parks-with-bars/layout,_N_T_/parks-with-bars/page,_N_T_/parks-with-bars,blog-posts,blog-list"},"segmentPaths":["/_tree","/_full","/parks-with-bars/__PAGE__","/parks-with-bars","/_index","/_head"]},"html":"<!DOCTYPE html><!--j39O7b4H81jaidut2lEaa--><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/e4af272ccee01ff0-s.p.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"stylesheet\" href=\"/_next/static/css/6aa7df2bae588751.css\" data-precedence=\"next\"/><link rel=\"stylesheet\" href=\"/_next/static/css/f4aeb25f618e7857.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/webpack-e195479f68b497a1.js\"/><script src=\"/_next/static/chunks/4bd1b696-0ae268a5a152f031.js\" async=\"\"></script><script src=\"/_next/static/chunks/3794-eed3cbe8441c422e.js\" async=\"\"></script><script src=\"/_next/static/chunks/main-app-55e3eb832edcecb4.js\" async=\"\"></script><script src=\"/_next/static/chunks/8500-41fa79ac743d83f1.js\" async=\"\"></script><script src=\"/_next/static/chunks/2365-7389548ffb58ad16.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/layout-fdf62186958bc494.js\" async=\"\"></script><script src=\"/_next/static/chunks/5772-c985b8ef30d7cbb9.js\" async=\"\"></script><script src=\"/_next/static/chunks/7206-a2d01a15ee8aa63c.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/not-found-c9cc1b59d40e8170.js\" async=\"\"></script><script async=\"\" src=\"https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8688786543603411\" crossorigin=\"anonymous\"></script><script src=\"/_next/static/chunks/4787-75d5847bcdedb074.js\" async=\"\