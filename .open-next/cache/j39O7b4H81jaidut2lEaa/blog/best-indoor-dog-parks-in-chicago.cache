SA\",\"rating\":5,\"reviewCount\":5,\"userRatingsTotal\":5,\"pricing\":{\"pricingSource\":\"unknown\",\"isFree\":false},\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"dataQuality\":\"verified\",\"openingHours\":{\"Monday\":\"Open 24 hours\",\"Tuesday\":\"Open 24 hours\",\"Wednesday\":\"Open 24 hours\",\"Thursday\":\"Open 24 hours\",\"Friday\":\"Open 24 hours\",\"Saturday\":\"Open 24 hours\",\"Sunday\":\"Open 24 hours\"},\"faqs\":[],\"amenities\":{},\"photos\":[{\"url\":\"/images/parks/northcarolina/dog-park/dog-park-1.jpg\",\"type\":\"photo\",\"source\":\"website\"},{\"url\":\"/images/parks/northcarolina/dog-park/dog-park-2.jpg\",\"type\":\"photo\",\"source\":\"website\"}],\"photo\":\"/images/parks/northcarolina/dog-park/dog-park-1.jpg\",\"source\":\"static\",\"listingType\":\"free\"}}]\n3d:[\"$\",\"$L3b\",\"ChIJubzB44LpU4gRZUSISya4nBA\",{\"park\":{\"id\":\"ChIJubzB44LpU4gRZUSISya4nBA\",\"name\":\"Dog Park\",\"businessType\":\"Indoor Dog Park\",\"description\":\"Dog Park has earned the trust of Salisbury residents. This facility features spacious exercise zones, North Carolina pet care professionals, offering pet care. Their services provides essential socialization for your pet. strategically positioned in Salisbury. Contact Dog Park today to schedule your dog's visit\",\"slug\":\"dog-park\",\"address\":\"1200 Salisbury Rd\",\"street\":\"1200 Salisbury Rd\",\"city\":\"Salisbury\",\"state\":\"NC\",\"zipCode\":\"27028\",\"full_address\":\"1200 Salisbury Rd, Mocksville, NC 27028, USA\",\"latitude\":35.8740971,\"longitude\":-80.55328569999999,\"googlePlaceId\":\"ChIJubzB44LpU4gRZUSISya4nBA\",\"website\":\"https://www.daviecountync.gov/1010/Dog-Parks\",\"rating\":4.5,\"reviewCount\":13,\"userRatingsTotal\":13,\"pricing\":{\"pricingSource\":\"unknown\",\"isFree\":false},\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"dataQuality\":\"verified\",\"openingHours\":{\"Monday\":\"5:00 AM – 8:00 PM\",\"Tuesday\":\"5:00 AM – 8:00 PM\",\"Wednesday\":\"5:00 AM – 8:00 PM\",\"Thursday\":\"5:00 AM – 8:00 PM\",\"Friday\":\"5:00 AM – 8:00 PM\",\"Saturday\":\"5:00 AM – 8:00 PM\",\"Sunday\":\"5:00 AM – 8:00 PM\"},\"faqs\":[],\"amenities\":{},\"photos\":[{\"url\":\"/images/parks/northcarolina/dog-park/dog-park-1.jpg\",\"type\":\"photo\",\"source\":\"website\"},{\"url\":\"/images/parks/northcarolina/dog-park/dog-park-2.jpg\",\"type\":\"photo\",\"source\":\"website\"}],\"photo\":\"/images/parks/northcarolina/dog-park/dog-park-1.jpg\",\"source\":\"static\",\"listingType\":\"free\"}}]\n3e:[\"$\",\"$L3b\",\"ChIJ9wBwMe9FQIgRJnM_BgfkD7Y\",{\"park\":{\"id\":\"ChIJ9wBwMe9FQIgRJnM_BgfkD7Y\",\"name\":\"pets\",\"businessType\":\"Indoor Dog Park\",\"description\":\"Pet parents in Hamilton rave about pets. What makes this facility special is its clean and well-maintained, convenient location. The staff's dedication to creating a positive experience for both dogs and their owners is evident in every visit. For more information, call (513) 498-1565.\",\"slug\":\"pets\",\"address\":\"5140 Princeton Glendale Rd\",\"street\":\"5140 Princeton Glendale Rd\",\"city\":\"Hamilton\",\"state\":\"OH\",\"zipCode\":\"45011\",\"full_address\":\"5140 Princeton Glendale Rd, Hamilton, OH 45011, USA\",\"latitude\":39.4280293,\"longitude\":-84.445409,\"googlePlaceId\":\"ChIJ9wBwMe9FQIgRJnM_BgfkD7Y\",\"phone\":\"(513) 498-1565\",\"rating\":0,\"reviewCount\":0,\"userRatingsTotal\":0,\"pricing\":{\"pricingSource\":\"unknown\",\"isFree\":false},\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"dataQuality\":\"verified\",\"openingHours\":{\"Monday\":\"Open 24 hours\",\"Tuesday\":\"Open 24 hours\",\"Wednesday\":\"Open 24 hours\",\"Thursday\":\"Open 24 hours\",\"Friday\":\"Open 24 hours\",\"Saturday\":\"Open 24 hours\",\"Sunday\":\"Open 24 hours\"},\"faqs\":[],\"amenities\":{},\"source\":\"static\",\"listingType\":\"free\"}}]\n3f:[\"$\",\"div\",null,{\"className\":\"mt-8 text-center\",\"children\":[\"$\",\"$L13\",null,{\"href\":\"/\",\"className\":\"inline-flex items-center px-6 py-3 bg-purple-600 text-white rounded-md hover:bg-purple-700 transition-colors font-medium\",\"children\":\"Browse All Parks →\"}]}]\n40:[\"$\",\"p\",null,{\"children\":\"© 2025 IndoorDogPark. All rights reserved\"}]\n41:[\"$\",\"div\",null,{\"className\":\"footer-bottom-links\",\"children\":[[\"$\",\"$L13\",null,{\"href\":\"/terms\",\"children\":\"Terms\"}],[\"$\",\"$L13\",null,{\"href\":\"/privacy\",\"children\":\"Privacy\"}],[\"$\",\"$L13\",null,{\"href\":\"/cookie-preferences\",\"children\":\"Cookie Preferences\"}]]}]\n4a:I[6355,[\"8500\",\"static/chunks/8500-41fa79ac743d83f1.js\",\"2365\",\"static/chunks/2365-7389548ffb58ad16.js\",\"5772\",\"static/chunks/5772-c985b8ef30d7cbb9.js\",\"7206\",\"static/chunks/7206-a2d01a15ee8aa63c.js\",\"6107\",\"static/chunks/6107-dcaf73e9eac71186.js\",\"5953\",\"static/chunks/app/blog/%5Bslug%5D/page-e5b6fb3afa92363b.js\"],\"default\"]\n43:[\"$\",\"i\",null,{\"className\":\"bi bi-facebook\"}]\n44:[\"$\",\"span\",null,{\"children\":\"Facebook\"}]\n45:[\"$\",\"a\",null,{\"href\":\"https://www.instagram.com/indoordogpark2025/\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"flex items-center gap-2 px-4 py-2 bg-gray-50 hover:bg-gray-100 rounded-lg transition-colors text-sm font-medium text-gray-700\",\"aria-label\":\"Follow us on Instagram\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-instagram\"}],[\"$\",\"span\",null,{\"children\":\"Instagram\"}]]}]\n46:[\"$\",\"a\",null,{\"href\":\"https://www.pinterest.com/indoordogpark/\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"flex items-center gap-2 px-4 py-2 bg-gray-50 hover:bg-gray-100 rounded-lg transition-colors text-sm font-medium text-gray-700\",\"aria-label\":\"Follow us on Pinterest\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-pinterest\"}],[\"$\",\"span\",null,{\"children\":\"Pinterest\"}]]}]\n47:[\"$\",\"$L4a\",null,{}]\n","/blog/$d$slug/__PAGE__":"1:\"$Sreact.fragment\"\n3:I[3676,[\"850