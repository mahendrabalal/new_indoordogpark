 rounded-lg transition-colors text-sm font-medium text-gray-700\",\"aria-label\":\"Follow us on X (Twitter)\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-twitter\"}],[\"$\",\"span\",null,{\"children\":\"X (Twitter)\"}]]}],[\"$\",\"a\",null,{\"href\":\"https://www.facebook.com/IndoorDogParkDirectory\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"flex items-center gap-2 px-4 py-2 bg-gray-50 hover:bg-gray-100 rounded-lg transition-colors text-sm font-medium text-gray-700\",\"aria-label\":\"Follow us on Facebook\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-facebook\"}],[\"$\",\"span\",null,{\"children\":\"Facebook\"}]]}],[\"$\",\"a\",null,{\"href\":\"https://www.instagram.com/indoordogpark2025/\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"flex items-center gap-2 px-4 py-2 bg-gray-50 hover:bg-gray-100 rounded-lg transition-colors text-sm font-medium text-gray-700\",\"aria-label\":\"Follow us on Instagram\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-instagram\"}],[\"$\",\"span\",null,{\"children\":\"Instagram\"}]]}],[\"$\",\"a\",null,{\"href\":\"https://www.pinterest.com/indoordogpark/\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"flex items-center gap-2 px-4 py-2 bg-gray-50 hover:bg-gray-100 rounded-lg transition-colors text-sm font-medium text-gray-700\",\"aria-label\":\"Follow us on Pinterest\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-pinterest\"}],[\"$\",\"span\",null,{\"children\":\"Pinterest\"}]]}]]}]]}]\n46:[\"$\",\"$L49\",null,{}]\n","/blog/$d$slug/__PAGE__":"1:\"$Sreact.fragment\"\n3:I[3676,[\"8500\",\"static/chunks/8500-41fa79ac743d83f1.js\",\"2365\",\"static/chunks/2365-7389548ffb58ad16.js\",\"5772\",\"static/chunks/5772-c985b8ef30d7cbb9.js\",\"7206\",\"static/chunks/7206-a2d01a15ee8aa63c.js\",\"6107\",\"static/chunks/6107-dcaf73e9eac71186.js\",\"5953\",\"static/chunks/app/blog/%5Bslug%5D/page-e5b6fb3afa92363b.js\"],\"default\"]\n4:I[85