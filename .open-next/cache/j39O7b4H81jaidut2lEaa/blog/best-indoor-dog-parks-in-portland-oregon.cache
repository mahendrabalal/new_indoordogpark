a7a7aea456e6d846511889756220b0ff98-1029x579.jpg?rect=226,0,579,579&w=96&h=96\"}},\"categories\":[{\"id\":5323753,\"name\":\"Dog Daycare\",\"slug\":\"dog-daycare\",\"description\":\"\",\"count\":0,\"link\":\"/blog/category/dog-daycare\",\"taxonomy\":\"category\",\"parent\":0,\"meta\":{}},{\"id\":91382944,\"name\":\"indoor dog park\",\"slug\":\"indoor-dog-park\",\"description\":\"\",\"count\":0,\"link\":\"/blog/category/indoor-dog-park\",\"taxonomy\":\"category\",\"parent\":0,\"meta\":{}}],\"tags\":[{\"id\":5473141,\"name\":\"Climate control\",\"slug\":\"climate-control\",\"description\":\"\",\"count\":0,\"link\":\"/blog/tag/climate-control\",\"taxonomy\":\"post_tag\",\"meta\":{}},{\"id\":53459804,\"name\":\"indoor dog park\",\"slug\":\"indoor-dog-park\",\"description\":\"\",\"count\":0,\"link\":\"/blog/tag/indoor-dog-park\",\"taxonomy\":\"post_tag\",\"meta\":{}}],\"featuredImage\":{\"id\":40605233,\"date\":\"2026-01-20T14:49:12.684Z\",\"slug\":\"dog-cages-in-cars-safety-smart-tech-and-legal-standards\",\"type\":\"attachment\",\"link\":\"https://cdn.sanity.io/images/ruuprk8g/production/4df06fbcc0523374e338628abbd73934fe209066-1024x1024.webp\",\"title\":{\"rendered\":\"Dog Cages in Cars\"},\"author\":3894619,\"caption\":{\"rendered\":\"Dog Cages in Cars\"},\"alt_text\":\"Dog Cages in Cars\",\"media_type\":\"image\",\"mime_type\":\"image/jpeg\",\"media_details\":{\"width\":1024,\"height\":1024,\"file\":\"dog-cages-in-cars-safety-smart-tech-and-legal-standards.jpg\",\"sizes\":{\"large\":{\"file\":\"dog-cages-in-cars-safety-smart-tech-and-legal-standards-large.jpg\",\"width\":1200,\"height\":1200,\"mime_type\":\"image/jpeg\",\"source_url\":\"https://cdn.sanity.io/images/ruuprk8g/production/4df06fbcc0523374e338628abbd73934fe209066-1024x1024.webp?w=1200\"},\"medium\":{\"file\":\"dog-cages-in-cars-safety-smart-tech-and-legal-standards-medium.jpg\",\"width\":800,\"height\":800,\"mime_type\":\"image/jpeg\",\"source_url\":\"https://cdn.sanity.io/images/ruuprk8g/production/4df06