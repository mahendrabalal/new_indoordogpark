ckdrop-blur-sm\",\"children\":[\"$\",\"$L22\",null,{\"type\":\"consumer\",\"source\":\"footer\",\"variant\":\"dark\"}]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"footer-social\",\"children\":[[\"$\",\"a\",null,{\"href\":\"https://x.com/Indoordogp40934\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"aria-label\":\"Follow us on X (Twitter)\",\"title\":\"Follow us on X (Twitter)\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-twitter\"}]}],[\"$\",\"a\",null,{\"href\":\"https://www.facebook.com/IndoorDogParkDirectory\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"aria-label\":\"Follow us on Facebook\",\"title\":\"Follow us on Facebook\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-facebook\"}]}],[\"$\",\"a\",null,{\"href\":\"https://www.instagram.com/indoordogpark2025/\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"aria-label\":\"Follow us on Instagram\",\"title\":\"Follow us on Instagram\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-instagram\"}]}],[\"$\",\"a\",null,{\"href\":\"https://www.pinterest.com/indoordogpark/\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"aria-label\":\"Follow us on Pinterest\",\"title\":\"Follow us on Pinterest\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-pinterest\"}]}],\"$undefined\",\"$undefined\",[\"$\",\"a\",null,{\"href\":\"https://digg.com/indoordogpark\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"aria-label\":\"Follow us on Digg\",\"title\":\"Follow us on Digg\",\"children\":[\"$\",\"svg\",null,{\"xmlns\":\"http://www.w3.org/2000/svg\",\"width\":\"1em\",\"height\":\"1em\",\"fill\":\"currentColor\",\"className\":\"bi\",\"viewBox\":\"0 0 512 512\",\"children\":[\"$\",\"path\",null,{\"d\":\"M81.7 172.3l-81.7 0 0 174.4 132.7 0 0-250.7-51 0 0 76.3zm0 133.4l-30.8 0 0-92.3 30.8 0 0 92.3zM378.9 172.3l0 174.4 81.8 0 0 28.5-81.8 0 0 40.8 133.1 0 0-243.7-133.1 0zm81.8 133.4l-30.8 0 0-92.3 30.8 0 0 92.3zm-235.6 41l82.1 0 0 28.5-82.1 0 0 40.8 133.3 0 0-