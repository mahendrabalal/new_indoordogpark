ere to Search\\\",\\\"level\\\":3},{\\\"id\\\":\\\"1-indoor-dog-parks-and-training-facilities\\\",\\\"title\\\":\\\"1. Indoor Dog Parks and Training Facilities\\\",\\\"level\\\":4},{\\\"id\\\":\\\"2-local-dog-training-schools\\\",\\\"title\\\":\\\"2. Local Dog Training Schools\\\",\\\"level\\\":4},{\\\"id\\\":\\\"3-veterinary-clinics\\\",\\\"title\\\":\\\"3. Veterinary Clinics\\\",\\\"level\\\":4},{\\\"id\\\":\\\"4-animal-shelters-and-humane-societies\\\",\\\"title\\\":\\\"4. Animal Shelters and Humane Societies\\\",\\\"level\\\":4},{\\\"id\\\":\\\"questions-to-ask-before-enrolling\\\",\\\"title\\\":\\\"Questions to Ask Before Enrolling\\\",\\\"level\\\":3},{\\\"id\\\":\\\"the-role-of-indoor-dog-parks-in-puppy-socialization\\\",\\\"title\\\":\\\"The Role of Indoor Dog Parks in Puppy Socialization\\\",\\\"level\\\":2},{\\\"id\\\":\\\"why-indoor-venues-excel-for-socialization\\\",\\\"title\\\":\\\"Why Indoor Venues Excel for Socialization\\\",\\\"level\\\":3},{\\\"id\\\":\\\"1-controlled-environment\\\",\\\"title\\\":\\\"1. Controlled Environment\\\",\\\"level\\\":4},{\\\"id\\\":\\\"2-weather-independence\\\",\\\"title\\\":\\\"2. Weather Independence\\\",\\\"level\\\":4},{\\\"id\\\":\\\"3-purpose-built-for-dogs\\\",\\\"title\\\":\\\"3. Purpose-Built for Dogs\\\",\\\"level\\\":4},{\\\"id\\\":\\\"4-professional-oversight\\\",\\\"title\\\":\\\"4. Professional Oversight\\\",\\\"level\\\":4},{\\\"id\\\":\\\"what-to-look-for-in-indoor-puppy-programs\\\",\\\"title\\\":\\\"What to Look for in Indoor Puppy Programs\\\",\\\"level\\\":3},{\\\"id\\\":\\\"diy-socialization-supplementing-classes-at-home\\\",\\\"title\\\":\\\"DIY Socialization: Supplementing Classes at Home\\\",\\\"level\\\":2},{\\\"id\\\":\\\"the-puppy-socialization-checklist\\\",\\\"title\\\":\\\"The Puppy Socialization Checklist\\\",\\\"level\\\":3},{\\\"id\\\":\\\"the-golden-rule-quality-over-quantity\\\",\\\"title\\\":\\\"The Golden Rule: Quality Over Quantity\\\",\\\"level\\\":3},{\\\"id\\\":\\\"common-puppy-s