href\":\"/privacy\",\"children\":\"Privacy\"}],[\"$\",\"$L13\",null,{\"href\":\"/cookie-preferences\",\"children\":\"Cookie Preferences\"}]]}]\n1f:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n1d:null\n21:[[\"$\",\"title\",\"0\",{\"children\":\"Puppy Socialization Classes | Indoor Dog Park\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"Find the best puppy socialization classes near you. Learn why the 8-16 week window is critical, what to look for in quality classes, and how indoor dog parks...\"}],[\"$\",\"meta\",\"2\",{\"name\":\"application-name\",\"content\":\"Indoor Dog Park\"}],[\"$\",\"meta\",\"3\",{\"name\":\"author\",\"content\":\"Bharat Thapa Magar\"}],[\"$\",\"meta\",\"4\",{\"name\":\"keywords\",\"content\":\"Dog Recreation, Pets care, California dog parks, indoor dog parks, dog-friendly\"}],[\"$\",\"meta\",\"5\",{\"name\":\"creator\",\"content\":\"Bharat Thapa Magar\"}],[\"$\",\"meta\",\"6\",{\"name\":\"publisher\",\"content\":\"Indoor Dog Park\"}],[\"$\",\"meta\",\"7\",{\"name\":\"robots\",\"content\":\"index, follow\"}],[\"$\",\"meta\",\"8\",{\"name\":\"googlebot\",\"content\":\"index, follow, max-video-preview:-1, max-image-preview:large, max-snippet:-1\"}],[\"$\",\"meta\",\"9\",{\"name\":\"category\",\"content\":\"Pet Services\"}],[\"$\",\"meta\",\"10\",{\"name\":\"theme-color\",\"content\":\"#7c3aed\"}],[\"$\",\"meta\",\"11\",{\"name\":\"msapplication-TileColor\",\"content\":\"#7c3aed\"}],[\"$\",\"meta\",\"12\",{\"name\":\"apple-mobile-web-app-capable\",\"content\":\"yes\"}],[\"$\",\"meta\",\"13\",{\"name\":\"apple-mobile-web-app-status-bar-style\",\"content\":\"black-translucent\"}],[\"$\",\"meta\",\"14\",{\"name\":\"apple-mobile-web-app-title\",\"content\":\"Indoor Dog Park\"}],[\"$\",\"meta\",\"15\",{\"name\":\"mobile-web-app-capable\",\"content\":\"yes\"}],[\"$\",\"meta\",\"16\",{\"name\":\"article:published_time\",\"content\"