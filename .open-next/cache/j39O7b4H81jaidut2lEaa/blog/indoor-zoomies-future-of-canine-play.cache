:\"indoor-parks\",\"title\":\"Indoor Parks\",\"level\":4},{\"id\":\"shared-traits\",\"title\":\"Shared Traits\",\"level\":4},{\"id\":\"8-training-and-enrichment-opportunities\",\"title\":\"8. Training and Enrichment Opportunities\",\"level\":2},{\"id\":\"9-the-zoomies-brand-the-future\",\"title\":\"9. The \\\"Zoomies\\\" Brand & The Future\",\"level\":2},{\"id\":\"10-how-to-prepare-for-your-first-visit\",\"title\":\"10. How to Prepare for Your First Visit\",\"level\":2},{\"id\":\"conclusion\",\"title\":\"Conclusion\",\"level\":2},{\"id\":\"faqs\",\"title\":\"FAQs\",\"level\":3}]}],[\"$\",\"div\",null,{\"className\":\"bg-white border border-gray-200 rounded-lg p-6\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-lg font-semibold text-gray-900 mb-4\",\"children\":\"Follow Us\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-gray-600 mb-4\",\"children\":\"Stay updated with the latest indoor dog park news and tips!\"}],[\"$\",\"div\",null,{\"className\":\"flex flex-wrap gap-3\",\"children\":[[\"$\",\"a\",null,{\"href\":\"https://x.com/Indoordogp40934\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"flex items-center gap-2 px-4 py-2 bg-gray-50 hover:bg-gray-100 rounded-lg transition-colors text-sm font-medium text-gray-700\",\"aria-label\":\"Follow us on X (Twitter)\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-twitter\"}],[\"$\",\"span\",null,{\"children\":\"X (Twitter)\"}]]}],[\"$\",\"a\",null,{\"href\":\"https://www.facebook.com/IndoorDogParkDirectory\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"flex items-center gap-2 px-4 py-2 bg-gray-50 hover:bg-gray-100 rounded-lg transition-colors text-sm font-medium text-gray-700\",\"aria-label\":\"Follow us on Facebook\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-facebook\"}],[\"$\",\"span\",null,{\"children\":\"Facebook\"}]]}],[\"$\",\"a\",null,{\"href\":\"https://www.instagram.com/indoordogpark2025/\",\"target\":\"_blank\",\"rel\":\"noopener no