 content.\\\",\\\"url\\\":\\\"\\\",\\\"link\\\":\\\"/blog/author/bharat-thapa-magar\\\",\\\"avatar_urls\\\":{\\\"24\\\":\\\"https://cdn.sanity.io/images/ruuprk8g/production/8713cd1871f637484fad5d88487bc635a6be491a-1170x2532.webp?rect=0,681,1170,1170\\u0026w=24\\u0026h=24\\\",\\\"48\\\":\\\"https://cdn.sanity.io/images/ruuprk8g/production/8713cd1871f637484fad5d88487bc635a6be491a-1170x2532.webp?rect=0,681,1170,1170\\u0026w=48\\u0026h=48\\\",\\\"96\\\":\\\"https://cdn.sanity.io/images/ruuprk8g/production/8713cd1871f637484fad5d88487bc635a6be491a-1170x2532.webp?rect=0,681,1170,1170\\u0026w=96\\u0026h=96\\\"}},\\\"categories\\\":[{\\\"id\\\":91382944,\\\"name\\\":\\\"indoor dog park\\\",\\\"slug\\\":\\\"indoor-dog-park\\\",\\\"description\\\":\\\"\\\",\\\"count\\\":0,\\\"link\\\":\\\"/blog/category/indoor-dog-park\\\",\\\"taxonomy\\\":\\\"category\\\",\\\"parent\\\":0,\\\"meta\\\":{}}],\\\"tags\\\":[{\\\"id\\\":5473141,\\\"name\\\":\\\"Climate control\\\",\\\"slug\\\":\\\"climate-control\\\",\\\"description\\\":\\\"\\\",\\\"count\\\":0,\\\"link\\\":\\\"/blog/tag/climate-control\\\",\\\"taxonomy\\\":\\\"post_tag\\\",\\\"meta\\\":{}},{\\\"id\\\":53459804,\\\"name\\\":\\\"indoor dog park\\\",\\\"slug\\\":\\\"indoor-dog-park\\\",\\\"description\\\":\\\"\\\",\\\"count\\\":0,\\\"link\\\":\\\"/blog/tag/indoor-dog-park\\\",\\\"taxonomy\\\":\\\"post_tag\\\",\\\"meta\\\":{}},{\\\"id\\\":90100489,\\\"name\\\":\\\"Pets care\\\",\\\"slug\\\":\\\"pets-care\\\",\\\"description\\\":\\\"\\\",\\\"count\\\":0,\\\"link\\\":\\\"/blog/tag/pets-care\\\",\\\"taxonomy\\\":\\\"post_tag\\\",\\\"meta\\\":{}},{\\\"id\\\":75385452,\\\"name\\\":\\\"Urbans-dogs\\\",\\\"slug\\\":\\\"urbans-dogs\\\",\\\"description\\\":\\\"\\\",\\\"count\\\":0,\\\"link\\\":\\\"/blog/tag/urbans-dogs\\\",\\\"taxonomy\\\":\\\"post_tag\\\",\\\"meta\\\":{}}],\\\"featuredImage\\\":{\\\"id\\\":10206235,\\\"date\\\":\\\"2025-12-31T01:00:44.198Z\\\",\\\"slug\\\":\\\"7-best-indoor-dog-parks-in-minneapolis\\\",\\\"type\\\":\\\"attac