sing and linking to Amazon.com. As an Amazon Associate I earn from qualifying purchases.\"}]}],[\"$\",\"div\",null,{\"className\":\"footer-bottom\",\"children\":[\"$L23\",\"$L24\"]}]]}]}]\n23:[\"$\",\"p\",null,{\"children\":\"© 2025 IndoorDogPark. All rights reserved\"}]\n24:[\"$\",\"div\",null,{\"className\":\"footer-bottom-links\",\"children\":[[\"$\",\"$L13\",null,{\"href\":\"/terms\",\"children\":\"Terms\"}],[\"$\",\"$L13\",null,{\"href\":\"/privacy\",\"children\":\"Privacy\"}],[\"$\",\"$L13\",null,{\"href\":\"/cookie-preferences\",\"children\":\"Cookie Preferences\"}]]}]\n1f:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n1d:null\n21:[[\"$\",\"title\",\"0\",{\"children\":\"Indoor Zoomies: Future of Canine Play | Indoor Dog Park\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"From \\\"FRAPs\\\" in your living room to the \\\"Indoor Zoomies\\\" park sensation, discover why indoor dog parks are taking over. A guide to safe, climate-controlled f...\"}],[\"$\",\"meta\",\"2\",{\"name\":\"application-name\",\"content\":\"Indoor Dog Park\"}],[\"$\",\"meta\",\"3\",{\"name\":\"author\",\"content\":\"Mahendra Balal\"}],[\"$\",\"meta\",\"4\",{\"name\":\"keywords\",\"content\":\"indoor dog park, indoor dog park, Pets care, Climate control, California dog parks, indoor dog parks, dog-friendly\"}],[\"$\",\"meta\",\"5\",{\"name\":\"creator\",\"content\":\"Mahendra Balal\"}],[\"$\",\"meta\",\"6\",{\"name\":\"publisher\",\"content\":\"Indoor Dog Park\"}],[\"$\",\"meta\",\"7\",{\"name\":\"robots\",\"content\":\"index, follow\"}],[\"$\",\"meta\",\"8\",{\"name\":\"googlebot\",\"content\":\"index, follow, max-video-preview:-1, max-image-preview:large, max-snippet:-1\"}],[\"$\",\"meta\",\"9\",{\"name\":\"category\",\"content\":\"Pet Services\"}],[\"$\",\"meta\",\"10\",{\"name\":\"theme-color\",\"content\":\"#7c3aed\"}],[\"$\",\"meta\",\"11\",{\"name\":\"msapplication