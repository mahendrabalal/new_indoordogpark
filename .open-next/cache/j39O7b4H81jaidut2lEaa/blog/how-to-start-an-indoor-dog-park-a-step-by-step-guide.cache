iant\":\"dark\"}]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"footer-social\",\"children\":[[\"$\",\"a\",null,{\"href\":\"https://x.com/Indoordogp40934\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"aria-label\":\"Follow us on X (Twitter)\",\"title\":\"Follow us on X (Twitter)\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-twitter\"}]}],[\"$\",\"a\",null,{\"href\":\"https://www.facebook.com/IndoorDogParkDirectory\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"aria-label\":\"Follow us on Facebook\",\"title\":\"Follow us on Facebook\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-facebook\"}]}],[\"$\",\"a\",null,{\"href\":\"https://www.instagram.com/indoordogpark2025/\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"aria-label\":\"Follow us on Instagram\",\"title\":\"Follow us on Instagram\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-instagram\"}]}],[\"$\",\"a\",null,{\"href\":\"https://www.pinterest.com/indoordogpark/\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"aria-label\":\"Follow us on Pinterest\",\"title\":\"Follow us on Pinterest\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-pinterest\"}]}],\"$undefined\",\"$undefined\",[\"$\",\"a\",null,{\"href\":\"https://digg.com/indoordogpark\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"aria-label\":\"Follow us on Digg\",\"title\":\"Follow us on Digg\",\"children\":[\"$\",\"svg\",null,{\"xmlns\":\"http://www.w3.org/2000/svg\",\"width\":\"1em\",\"height\":\"1em\",\"fill\":\"currentColor\",\"className\":\"bi\",\"viewBox\":\"0 0 512 512\",\"children\":[\"$\",\"path\",null,{\"d\":\"M81.7 172.3l-81.7 0 0 174.4 132.7 0 0-250.7-51 0 0 76.3zm0 133.4l-30.8 0 0-92.3 30.8 0 0 92.3zM378.9 172.3l0 174.4 81.8 0 0 28.5-81.8 0 0 40.8 133.1 0 0-243.7-133.1 0zm81.8 133.4l-30.8 0 0-92.3 30.8 0 0 92.3zm-235.6 41l82.1 0 0 28.5-82.1 0 0 40.8 133.3 0 0-243.7-133.3 0 0 174.4zm51.2-133.3l30.8 0 0 92.3-30.8 0 0-92.3zM153.3 96l51.3 0 0 51-51.3 0 0-51zm0 76.3l51.3 0 0 174.4-51.3 0 0-174.4z\"}]}]}]]}],[\"$\",\"div\",null,{\"className\":\"mt-8 border-t border-white/10 pt-8 text-center\",\"children\":[\"$\",\"p\",null,{\"className\":\"text-sm text-white/50\",\"children\":\"IndoorDogPark is a participant in the Amazon Services LLC Associates Program, an affiliate advertising program designed to provide a means for sites to earn advertising fees by advertising and linking to Amazon.com. As an Amazon Associate I earn from qualifying purchases.\"}]}],[\"$\",\"div\",null,{\"className\":\"footer-bottom\",\"children\":[\"$L1a\",\"$L1b\"]}]]}]}]\na:[\"$\",\"$L1c\",null,{\"children\":[\"$\",\"$1d\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@1e\"}]}]\ne:[\"$\",\"aside\",null,{\"className\":\"lg:sticky lg:top-24 h-fit\",\"children\":[\"$\",\"div\",null,{\"className\":\"space-y-6\",\"children\":[[\"$\",\"$L1f\",null,{\"items\":[{\"id\":\"why-indoor-dog-parks-are-the-future-of-pet-services\",\"title\":\"Why Indoor Dog Parks Are the Future of Pet Services\",\"level\":2},{\"id\":\"step-1-research-and-planning-your-indoor-dog-park\",\"title\":\"Step 1: Research and Planning Your Indoor Dog Park\",\"level\":3},{\"id\":\"step-2-location-and-design-the-heart-of-your-venture\",\"title\":\"Step 2: Location and Design - The Heart of Your Venture\",\"level\":3},{\"id\":\"key-design-considerations\",\"title\":\"Key Design Considerations:\",\"level\":4},{\"id\":\"step-3-equipment-and-amenities-that-set-you-apart\",\"title\":\"Step 3: Equipment and Amenities That Set You Apart\",\"level\":3},{\"id\":\"essential-equipment-list\",\"title\":\"Essential Equipment List:\",\"level\":4},{\"id\":\"step-4-health-and-safety-protocols-non-negotiable-standards\",\"title\":\"Step 4: Health and Safety Protocols - Non-Negotiable Standards\",\"level\":3},{\"id\":\"health-requirements\",\"title\":\"Health Requirements:\",\"level\":4},{\"id\":\"step-5-licensing-insurance-and-legal-requirements\",\"title\":\"Step 5: Licensing, Insurance, and Legal Requ