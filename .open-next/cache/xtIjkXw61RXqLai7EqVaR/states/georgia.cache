,null,{\"className\":\"section-shell state-hero-shell\",\"children\":[[\"$\",\"div\",null,{\"className\":\"state-hero-copy\",\"children\":[[\"$\",\"nav\",null,{\"className\":\"hero-breadcrumbs\",\"aria-label\":\"Breadcrumb\",\"children\":[[\"$\",\"$L4\",null,{\"href\":\"/\",\"children\":\"Home\"}],[\"$\",\"span\",null,{\"children\":\"›\"}],[\"$\",\"$L4\",null,{\"href\":\"/states\",\"children\":\"States\"}],[\"$\",\"span\",null,{\"children\":\"›\"}],[\"$\",\"span\",null,{\"children\":\"Georgia\"}]]}],[\"$\",\"div\",null,{\"className\":\"hero-eyebrow\",\"children\":\"Peach State Dog Parks\"}],[\"$\",\"h1\",null,{\"children\":\"Dog Parks in Georgia\"}],[\"$\",\"div\",null,{\"className\":\"hero-description\",\"children\":[[\"$\",\"p\",\"0\",{\"children\":[\"Georgia has transformed into a Southeastern dog park leader, driven primarily by Atlanta's explosive growth and the young professionals who've made the city home. The metro Atlanta area now maintains over 50 dedicated dog parks, with standouts like the 42-acre Freedom Park Dog Park in the Inman Park/Little Five Points area and the newly renovated Piedmont Park Dog Park drawing hundreds of visitors daily. The city's BeltLine project—a 22-mile loop of trails and parks circling the urban core—has become a dog-walking destination unto itself, with multiple official off-leash areas positioned along the route.\"]}],[\"$\",\"p\",\"1\",{\"children\":[\"Beyond Atlanta, Georgia offers surprising variety for dog owners. Savannah's historic squares and riverfront parks welcome leashed dogs, maintaining the city's famously dog-friendly reputation. The North Georgia mountains provide hiking opportunities through Chattahoochee National Forest, where leashed dogs can explore hundreds of miles of trails. Athens, home to the University of Georgia, has developed its own vibrant dog culture centered on the Oconee River Greenway and numerous dog-friendly brewery patios. Georgia's humid summers require the same heat awareness as other Southern states, but the state's abundance of shaded, tree-covered parks provides relief uncommon in more arid regions. Our directory covers over 110 verified Georgia locations.\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-cta-row\",\"children\":[[\"$\",\"$L4\",null,{\"href\":\"/cities\",\"className\":\"hero-cta primary\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-map\"}],\"Browse cities\"]}],[\"$\",\"$L4\",null,{\"href\":\"/list-your-park\",\"className\":\"hero-cta ghost\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-plus-circle\"}],\"Submit a park\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-footnotes\",\"children\":[[\"$\",\"span\",\"Atlanta metro complete\",{\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-arrow-repeat\"}],\" \",\"Atlanta metro complete\"]}],[\"$\",\"span\",\"North GA trails included\",{\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-arrow-repeat\"}],\" \",\"North GA trails included\"]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"state-hero-visual\",\"children\":[\"$\",\"div\",null,{\"className\":\"hero-image-card\",\"children\":[[\"$\",\"$L5\",null,{\"src\":\"/images/states/georgia/hero.webp\",\"alt\":\"Georgia dog park landscape\",\"fill\":true,\"priority\":true,\"sizes\":\"(max-width: 900px) 100vw, 40vw\",\"style\":{\"objectFit\":\"cover\"},\"unoptimized\":true}],[\"$\",\"div\",null,{\"className\":\"hero-image-gradient\"}]]}]}]]}]}],[\"$\",\"section\",null,{\"className\":\"state-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell\",\"children\":\"$L6\"}]}],\"$L7\",\"$L8\",\"$L9\"]}],\"$La\"],null,\"$Lb\"]}],\"loading\":null,\"isPartial\":false}\n6:[\"$\",\"div\",null,{\"className\":\"feature-grid\",\"children\":[[[\"$\",\"div\",\"Atlanta BeltLine\",{\"className\":\"feature-card accent\",\"children\":[[\"$\",\"div\",null,{\"className\":\"feature-icon\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-info-circle\"}]}],[\"$\",\"div\",null,{\"className\":\"insight-tag\",\"children\":\"Urban Hub\"}],[\"$\",\"h3\",null,{\"children\":\"Atlanta BeltLine\"}],[\"$\",\"p\",null,{\"children\":[\"Atlanta's BeltLine has become a dog-walking institution. The 22-mile trail system includes multiple off-leash areas and connects dozens of neighborhoods.\"]}]]}],[\"$\",\"div\",\"North Georgia Trails\",{\"className\":\"feature-card \",\"children\":[[\"$\",\"div\",null,{\"className\":\"feature-icon\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-info-circle\"}]}],[\"$\",\"div\",null,{\"className\":\"insight-tag\",\"children\":\"Mountain Access\"}],[\"$\",\"h3\",null,{\"children\":\"North Georgia Trails\"}],[\"$\",\"p\",null,{\"children\":[\"Chattahoochee National Forest offers hundreds of miles of dog-friendly trails. Popular areas include Amicalola Falls and Tallulah Gorge.\"]}]]}]],[[\"$\",\"div\",\"Summer Strategy\",{\"className\":\"feature-card\",\"children\":[[\"$\",\"div\",null,{\"className\":\"feature-icon\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-sun\"}]}],[\"$\",\"h3\",null,{\"children\":\"Summer Strategy\"}],[\"$\",\"ul\",null,{\"className\":\"planning-card-list\",\"children\":[[\"$\",\"li\",\"Georgia humidity requires early morning or evening visits\",{\"children\":[\"Georgia humidity requires early morning or evening visits\"]}],[\"$\",\"li\",\"Many parks have tree cover providing natural shade\",{\"children\":[\"Many parks have tree cover providing natural shade\"]}],[\"$\",\"li\",\"Always carry water—fountains may not be working\",{\"children\":[\"Always carry water—fountains may not be working\"]}]]}]]}],[\"$\",\"div\",\"Georgia Basics\",{\"className\":\"feature-card\",\"children\":[[\"$\",\"div\",null,{\"className\":\"feature-icon\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-signpost-2\"}]}],[\"$\",\"h3\",null,{\"children\":\"Georgia Basics\"}],[\"$\",\"ul\",null,{\"className\":\"planning-card-list\",\"children\":[[\"$\",\"li\",\"Rabies vaccination required statewide\",{\"children\":[\"Rabies vaccination req