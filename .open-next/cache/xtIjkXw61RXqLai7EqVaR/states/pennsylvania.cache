639b5ecd9.js\",\"5772\",\"static/chunks/5772-dddb55abe608617a.js\",\"7206\",\"static/chunks/7206-1c8c946f4e44e54c.js\",\"4561\",\"static/chunks/4561-f94d69f802929185.js\",\"6123\",\"static/chunks/app/states/%5Bslug%5D/page-98ace0e8cc547f86.js\"],\"Image\"]\n19:[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"suppressHydrationWarning\":true,\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://www.indoordogpark.org/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"States\\\",\\\"item\\\":\\\"https://www.indoordogpark.org/states\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Pennsylvania\\\",\\\"item\\\":\\\"https://www.indoordogpark.org/states/pennsylvania\\\"}]}\"}}],[\"$\",\"$L11\",null,{\"variant\":\"light\"}],[\"$\",\"$L24\",null,{}],[\"$\",\"main\",null,{\"className\":\"state-page-layout\",\"children\":[[\"$\",\"section\",null,{\"className\":\"state-hero-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell state-hero-shell\",\"children\":[[\"$\",\"div\",null,{\"className\":\"state-hero-copy\",\"children\":[[\"$\",\"nav\",null,{\"className\":\"hero-breadcrumbs\",\"aria-label\":\"Breadcrumb\",\"children\":[[\"$\",\"$L12\",null,{\"href\":\"/\",\"children\":\"Home\"}],[\"$\",\"span\",null,{\"children\":\"›\"}],[\"$\",\"$L12\",null,{\"href\":\"/states\",\"children\":\"States\"}],[\"$\",\"span\",null,{\"children\":\"›\"}],[\"$\",\"span\",null,{\"children\":\"Pennsylvania\"}]]}],[\"$\",\"div\",null,{\"className\":\"hero-eyebrow\",\"children\":\"Keystone State Canine Country\"}],[\"$\",\"h1\",null,{\"children\":\"Dog Parks in Pennsylvania\"}],[\"$\",\"div\",null,{\"className\":\"hero-description\",\"children\":[[\"$\",\"p\",\"0\",{\"children\":[\"Pennsylvania anchors the Mid-Atlantic dog scene with two major urban centers that have developed distinct approaches to canine recreation. Philadelphia's dense neighborhoods feature over 40 dedicated dog parks, from the historic Schuylkill River Dog Park with city skyline views to tight-knit community runs in neighborhoods like Fishtown and South Philly. Pittsburgh's three-rivers geography creates unique waterfront park opportunities, with the 6-acre Frick Park Dog Park drawing visitors from across the region for its woodland trails and year-round accessibility. Both cities have seen significant growth in premium indoor facilities as young professionals prioritize pet amenities.\"]}],[\"$\",\"p\",\"1\",{\"children\":[\"Beyond the metros, Pennsylvania offers surprising variety. The Pocono Mountains welcome dog-friendly hikers with hundreds of miles of trails through state forests. Bucks County and the Main Line suburbs maintain some of the Mid-Atlantic's most polished community dog parks, reflecting the region's affluent commitment to pet amenities. The state's hunting tradition means rural Pennsylvania is remarkably dog-tolerant, with many state game lands permitting leashed dogs year-round. Our directory covers over 130 verified Pennsylvania locations, from Center City Philadelphia's urban runs to the mountain parks of the Laurel Highlands, all with current hours, surface conditions, and community ratings.\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-cta-row\",\"children\":[[\"$\",\"$L12\",null,{\"href\":\"/cities\",\"className\":\"hero-cta primary\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-map\"}],\"Browse cities\"]}],[\"$\",\"$L12\",null,{\"href\":\"/list-your-park\",\"className\":\"hero-cta ghost\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-plus-circle\"}],\"Submit a park\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-footnotes\",\"children\":[[\"$\",\"span\",\"Philly and Pittsburgh complete\",{\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-arrow-repeat\"}],\" \",\"Philly and Pittsburgh complete\"]}],[\"$\",\"span\",\"Pocono trails mapped\",{\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-arrow-repeat\"}],\" \",\"Pocono trails mapped\"]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"state-hero-visual\",\"children\":[\"$\",\"div\",null,{\"className\":\"hero-image-card\",\"children\":[[\"$\",\"$L25\",null,{\"src\":\"/images/states/pennsylvania/hero.webp\",\"alt\":\"Pennsylvania dog park landscape\",\"fill\":true,\"priority\":true,\"sizes\":\"(max-width: 900px) 100vw, 40vw\",\"style\":{\"objectFit\":\"cover\"},\"unoptimized\":true}],[\"$\",\"div\",null,{\"className\":\"hero-image-gradient\"}]]}]}]]}]}],[\"$\",\"section\",null,{\"className\":\"state-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell\",\"children\":\"$L26\"}]}],\"$L27\",\"$L28\",\"$L29\"]}],\"$L2a\"]\n37:I[54561,[\"8500\",\"static/chunks/8500-98e13bcce54aa7a0.js\",\"7828\",\"static/chunks/7828-fd723da158040787.js\",\"2365\",\"static/chunks/2365-40fbe64639b5ecd9.js\",\"5772\",\"static/chunks/5772-dddb55abe608617a.js\",\"7206\",\"static/chunks/7206-1c8c946f4e44e54c.js\",\"4561\",\"static/chunks/4561-f94d69f802929185.js\",\"6123\",\"static/chunks/app/states/%5Bslug%5D/page-98ace0e8cc547f86.js\"],\"default\"]\n26:[\"$\",\"div\",null,{\"className\":\"feature-grid\",\"children\":[[[\"$\",\"div\",\"Philadelphia Dog Runs\",{\"className\":\"feature-card accent\",\"children\":[[\"$\",\"div\",null,{\"className\":\"feature-icon\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-info-circle\"}]}],[\"$\",\"div\",null,{\"className\":\"insight-tag\",\"children\":\"Urban Variety\"}],[\"$\",\"h3\",null,{\"children\":\"Philadelphia Dog Runs\"}],[\"$\",\"p\",null,{\"children\":[\"Philly maintains over 40 dedicated dog parks across diverse neighborhoods. The Schuylkill River Dog Park offers stunning city views.\"]}]]}],[\"$\",\"div\",\"Pittsburgh's Frick Park\",{\"className\":\"feature-card \",\"children\":[[\"$\",\"div\",null,{\"className\":\"feature-icon\