page-98ace0e8cc547f86.js\"],\"default\"]\n1b:I[90484,[],\"OutletBoundary\"]\n1c:\"$Sreact.suspense\"\n0:{\"buildId\":\"xtIjkXw61RXqLai7EqVaR\",\"rsc\":[\"$\",\"$1\",\"c\",{\"children\":[[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"suppressHydrationWarning\":true,\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://www.indoordogpark.org/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"States\\\",\\\"item\\\":\\\"https://www.indoordogpark.org/states\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"California\\\",\\\"item\\\":\\\"https://www.indoordogpark.org/states/california\\\"}]}\"}}],[\"$\",\"$L2\",null,{\"variant\":\"light\"}],[\"$\",\"$L3\",null,{}],[\"$\",\"main\",null,{\"className\":\"state-page-layout\",\"children\":[[\"$\",\"section\",null,{\"className\":\"state-hero-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell state-hero-shell\",\"children\":[[\"$\",\"div\",null,{\"className\":\"state-hero-copy\",\"children\":[[\"$\",\"nav\",null,{\"className\":\"hero-breadcrumbs\",\"aria-label\":\"Breadcrumb\",\"children\":[[\"$\",\"$L4\",null,{\"href\":\"/\",\"children\":\"Home\"}],[\"$\",\"span\",null,{\"children\":\"›\"}],[\"$\",\"$L4\",null,{\"href\":\"/states\",\"children\":\"States\"}],[\"$\",\"span\",null,{\"children\":\"›\"}],[\"$\",\"span\",null,{\"children\":\"California\"}]]}],[\"$\",\"div\",null,{\"className\":\"hero-eyebrow\",\"children\":\"Golden State Playgrounds\"}],[\"$\",\"h1\",null,{\"children\":\"Dog Parks in California\"}],[\"$\",\"div\",null,{\"className\":\"hero-description\",\"children\":[[\"$\",\"p\",\"0\",{\"children\":[\"California stands as the undisputed leader in dog-friendly infrastructure across the United States, with over 68% of households owning at least one pet according to the American Pet Products Association. From the foggy off-leash beaches of San Francisco's Fort Funston to the sprawling 43-acre Fiesta Island Dog Park in San Diego—one of the largest dedicated off-leash areas in the nation—the Golden State offers unmatched variety. The state's Mediterranean climate means year-round outdoor play is possible in most regions, though the Central Valley and desert areas have driven significant growth in climate-controlled indoor facilities, particularly during summer months when pavement temperatures can exceed 140°F.\"]}],[\"$\",\"p\",\"1\",{\"children\":[\"What sets California apart is its integration of dog parks into urban planning. Cities like Los Angeles require new residential developments over 50 units to include pet amenities, while San Francisco maintains over 25 official off-leash areas managed by dedicated volunteer groups. The state also leads in the premium \\\"dog social club\\\" concept—membership-based facilities in cities like San Jose and Irvine that combine indoor play, grooming, and daycare services. Whether you're seeking a rugged coastal trail in Half Moon Bay or an air-conditioned play space in Palm Springs, our verified directory covers over 240 locations with real-time updates on amenities, hours, and community reviews.\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-cta-row\",\"children\":[[\"$\",\"$L4\",null,{\"href\":\"/cities\",\"className\":\"hero-cta primary\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-map\"}],\"Browse cities\"]}],[\"$\",\"$L4\",null,{\"href\":\"/list-your-park\",\"className\":\"hero-cta ghost\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-plus-circle\"}],\"Submit a park\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-footnotes\",\"children\":[[\"$\",\"span\",\"Daily updates for LA & SF\",{\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-arrow-repeat\"}],\" \",\"Daily updates for LA & SF\"]}],[\"$\",\"span\",\"Coastal & Inland coverage included\",{\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-arrow-repeat\"}],\" \",\"Coastal & Inland coverage included\"]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"state-hero-visual\",\"children\":[\"$\",\"div\",null,{\"className\":\"hero-image-card\",\"children\":[[\"$\",\"$L5\",null,{\"src\":\"/images/states/california/hero.webp\",\"alt\":\"California dog park landscape\",\"fill\":true,\"priority\":true,\"sizes\":\"(max-width: 900px) 100vw, 40vw\",\"style\":{\"objectFit\":\"cover\"},\"unoptimized\":true}],[\"$\",\"div\",null,{\"className\":\"hero-image-gradient\"}]]}]}]]}]}],\"$L6\",\"$L7\",\"$L8\",\"$L9\"]}],\"$La\"],null,\"$Lb\"]}],\"loading\":null,\"isPartial\":false}\n6:[\"$\",\"section\",null,{\"className\":\"state-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell\",\"children\":[\"$\",\"div\",null,{\"className\":\"feature-grid\",\"children\":[[[\"$\",\"div\",\"Beach & Trail Variety\",{\"className\":\"feature-card accent\",\"children\":[[\"$\",\"div\",null,{\"className\":\"feature-icon\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-info-circle\"}]}],[\"$\",\"div\",null,{\"className\":\"insight-tag\",\"children\":\"Coastal Access\"}],[\"$\",\"h3\",null,{\"children\":\"Beach & Trail Variety\"}],[\"$\",\"p\",null,{\"children\":[\"California excels at outdoor variety. We recommend \",[\"$\",\"$L4\",\"1\",{\"href\":\"https://www.indoordogpark.org/cities/san-diego\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"text-primary hover:underline font-medium\",\"children\":\"San Diego\"}],null,\" for coastal runs and \",[\"$\",\"$L4\",\"4\",{\"href\":\"https://www.indoordogpark.org/cities/los-angeles\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"text-primary hover:underline font-medium\",\"children\":\"Los Angeles\"}],null,\" for hidden hillside parks.\"]}]]}],[\"$\",\"div\",\"Urban Indoor Shift\",{\"className\":\"feature-card \",\"children\":[[\"$\",\"div\",null,{\"className\"