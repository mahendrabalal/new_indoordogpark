em\\\",\\\"position\\\":2,\\\"name\\\":\\\"States\\\",\\\"item\\\":\\\"https://www.indoordogpark.org/states\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"North Carolina\\\",\\\"item\\\":\\\"https://www.indoordogpark.org/states/north-carolina\\\"}]}\"}}],[\"$\",\"$L2\",null,{\"variant\":\"light\"}],[\"$\",\"$L3\",null,{}],[\"$\",\"main\",null,{\"className\":\"state-page-layout\",\"children\":[[\"$\",\"section\",null,{\"className\":\"state-hero-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell state-hero-shell\",\"children\":[[\"$\",\"div\",null,{\"className\":\"state-hero-copy\",\"children\":[[\"$\",\"nav\",null,{\"className\":\"hero-breadcrumbs\",\"aria-label\":\"Breadcrumb\",\"children\":[[\"$\",\"$L4\",null,{\"href\":\"/\",\"children\":\"Home\"}],[\"$\",\"span\",null,{\"children\":\"›\"}],[\"$\",\"$L4\",null,{\"href\":\"/states\",\"children\":\"States\"}],[\"$\",\"span\",null,{\"children\":\"›\"}],[\"$\",\"span\",null,{\"children\":\"North Carolina\"}]]}],[\"$\",\"div\",null,{\"className\":\"hero-eyebrow\",\"children\":\"Tar Heel Dog Destinations\"}],[\"$\",\"h1\",null,{\"children\":\"Dog Parks in North Carolina\"}],[\"$\",\"div\",null,{\"className\":\"hero-description\",\"children\":[[\"$\",\"p\",\"0\",{\"children\":[\"North Carolina has experienced remarkable growth in dog-friendly infrastructure as the state's major cities have attracted young professionals and families who prioritize pet amenities. The Research Triangle region—Raleigh, Durham, and Chapel Hill—now rivals Austin and Denver for dog-friendliness, with Raleigh maintaining 12 dedicated dog parks and Durham's downtown brewery scene enthusiastically welcoming canine companions. Charlotte has invested heavily in greenway development, creating over 50 miles of paved trails connecting parks throughout the metro, many with dedicated off-leash areas positioned along the route.\"]}],[\"$\",\"p\",\"1\",{\"children\":[\"North Carolina's geographic diversity creates exceptional variety for dog owners. The Blue Ridge Mountains and Great Smoky Mountains offer hundreds of miles of dog-friendly hiking trails, while the Outer Banks provides some of the East Coast's best dog beach access during off-seasons. The state's mild climate—rarely experiencing extreme heat or cold—means year-round outdoor activity is feasible with reasonable precautions. Asheville has emerged as a mountain town phenomenon for dog lovers, with dog-friendly breweries, restaurants, and shops creating an entire culture around canine companionship. Our directory tracks over 160 verified North Carolina locations with detailed information on terrain, amenities, and seasonal considerations.\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-cta-row\",\"children\":[[\"$\",\"$L4\",null,{\"href\":\"/cities\",\"className\":\"hero-cta primary\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-map\"}],\"Browse cities\"]}],[\"$\",\"$L4\",null,{\"href\":\"/list-your-park\",\"className\":\"hero-cta ghost\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-plus-circle\"}],\"Submit a park\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-footnotes\",\"children\":[[\"$\",\"span\",\"Triangle and Charlotte coverage complete\",{\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-arrow-repeat\"}],\" \",\"Triangle and Charlotte coverage complete\"]}],[\"$\",\"span\",\"Mountain trails mapped\",{\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-arrow-repeat\"}],\" \",\"Mountain trails mapped\"]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"state-hero-visual\",\"children\":[\"$\",\"div\",null,{\"className\":\"hero-image-card\",\"children\":[[\"$\",\"$L5\",null,{\"src\":\"/images/states/north-carolina/hero.webp\",\"alt\":\"North Carolina dog park landscape\",\"fill\":true,\"priority\":true,\"sizes\":\"(max-width: 900px) 100vw, 40vw\",\"style\":{\"objectFit\":\"cover\"},\"unoptimized\":true}],[\"$\",\"div\",null,{\"className\":\"hero-image-gradient\"}]]}]}]]}]}],\"