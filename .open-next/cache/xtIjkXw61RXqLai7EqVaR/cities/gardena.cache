hen you're done\",{\"children\":\"Share shaded space and refill water when you're done\"}]]}]]}]]}]]}]}]\n3a:[\"$\",\"section\",null,{\"id\":\"owner-cta\",\"className\":\"owner-cta-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell\",\"children\":[[\"$\",\"span\",null,{\"className\":\"section-eyebrow\",\"children\":\"Partner with us\"}],[\"$\",\"h2\",null,{\"children\":\"Feature your Gardena dog park\"}],[\"$\",\"p\",null,{\"children\":\"Upgrade to a featured listing, share live availability, or pitch a new indoor concept. Our team drives qualified local pet parents every week.\"}],[\"$\",\"div\",null,{\"className\":\"hero-cta-row\",\"style\":{\"marginTop\":24},\"children\":[[\"$\",\"$L12\",null,{\"href\":\"/list-your-park\",\"className\":\"hero-cta primary\",\"children\":\"List a property\"}],[\"$\",\"$L12\",null,{\"href\":\"/contact\",\"className\":\"hero-cta ghost\",\"children\":\"Contact the team\"}]]}],\"$undefined\"]}]}]\n3b:[\"$\",\"section\",null,{\"id\":\"park-directory\",\"className\":\"park-directory-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell\",\"children\":[[\"$\",\"div\",null,{\"className\":\"section-heading\",\"children\":[[\"$\",\"span\",null,{\"className\":\"section-eyebrow\",\"children\":\"City directory\"}],[\"$\",\"h2\",null,{\"children\":[\"All dog parks in \",\"Gardena\"]}],[\"$\",\"p\",null,{\"children\":\"Filter-ready cards with ratings, amenities, and quick actions. Use the chips to jump between sections.\"}]]}],[\"$\",\"div\",null,{\"className\":\"category-chip-row\",\"children\":[[\"$\",\"$L2f\",\"Dog Park\",{\"targetId\":\"dog-park-parks\",\"children\":\"Dog Park\"}],[\"$\",\"$L2f\",\"Indoor Dog Park\",{\"targetId\":\"indoor-dog-park-parks\",\"children\":\"Indoor Dog Park\"}]]}],[[\"$\",\"div\",\"Dog Park\",{\"id\":\"dog-park-parks\",\"className\":\"directory-category\",\"children\":[[\"$\",\"div\",null,{\"className\":\"directory-header\",\"children\":[[\"$\",\"div\",null,{\"children\":