,null,{\"className\":\"planning-icon\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-shield-check\"}]}],[\"$\",\"h3\",null,{\"children\":\"Local regulations\"}],[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",\"Keep proof of vaccinations or city license handy\",{\"children\":\"Keep proof of vaccinations or city license handy\"}],[\"$\",\"li\",\"Voice control required in most off-leash zones\",{\"children\":\"Voice control required in most off-leash zones\"}],[\"$\",\"li\",\"Limit three dogs per handler in public parks\",{\"children\":\"Limit three dogs per handler in public parks\"}]]}]]}],[\"$\",\"article\",\"Community etiquette\",{\"className\":\"planning-card\",\"children\":[[\"$\",\"div\",null,{\"className\":\"planning-icon\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-heart\"}]}],[\"$\",\"h3\",null,{\"children\":\"Community etiquette\"}],[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",\"Scan the park before entering and remove prong collars\",{\"children\":\"Scan the park before entering and remove prong collars\"}],[\"$\",\"li\",\"Monitor play styles and intervene early\",{\"children\":\"Monitor play styles and intervene early\"}],[\"$\",\"li\",\"Share shaded space and refill water when you're done\",{\"children\":\"Share shaded space and refill water when you're done\"}]]}]]}]]}]]}]}]\n3c:[\"$\",\"section\",null,{\"id\":\"owner-cta\",\"className\":\"owner-cta-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell\",\"children\":[[\"$\",\"span\",null,{\"className\":\"section-eyebrow\",\"children\":\"Partner with us\"}],[\"$\",\"h2\",null,{\"children\":\"Feature your Dallas dog park\"}],[\"$\",\"p\",null,{\"children\":\"Upgrade to a featured listing, share live availability, or pitch a new indoor concept. Our team drives qualified local pet parents every week.\"}],[\"$\",\"div\",null,{\"className\":\"hero-cta-row\",\"style\":{\"marginTop\":24},\"children\":[[\"$\",\"$L12\",null,{\"href\":\"/list-your-park\",\"className\":\"h