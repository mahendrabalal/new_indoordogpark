ctionPage\",\"@id\":\"https://www.indoordogpark.org/cities/mooresville#webpage\",\"name\":\"Indoor Dog Parks in Mooresville, NC\",\"description\":\"Nestled on Lake Norman, Mooresville offers a fast-paced lifestyle with plenty of slow-down spots for dogs. From state park trails to lakeside walks, it is an active community.\",\"url\":\"https://www.indoordogpark.org/cities/mooresville\",\"image\":\"/images/cities/mooresville-nc/hero.png\",\"datePublished\":\"2024-01-01T00:00:00.000Z\",\"dateModified\":\"2026-02-06T02:41:30.690Z\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Indoor Dog Park\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://www.indoordogpark.org/images/logo/logo-512.png\"}},\"about\":{\"@type\":\"City\",\"name\":\"Mooresville, NC\"},\"mainEntity\":{\"@id\":\"https://www.indoordogpark.org/cities/mooresville#itemlist\"},\"containsPlace\":[{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/academy-street-park\",\"name\":\"Academy Street Park\",\"url\":\"https://www.indoordogpark.org/parks/academy-street-park\",\"sameAs\":[\"https://mooresvillenc.gov/government/departments/parks___recreation/parks/academy_park.php\"],\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"601 S Academy St\",\"addressLocality\":\"Mooresville\",\"addressRegion\":\"NC\",\"postalCode\":\"28115\",\"addressCountry\":\"US\"},\"telephone\":\"(704) 663-3800\",\"image\":\"/images/parks/northcarolina/academy-street-park/academy-street-park-1.jpg\",\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":4.5,\"reviewCount\":180},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":35.5758593,\"longitude\":-80.8238636}},{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/barks-rec-boarding\",\"name\":\"Barks & Rec Boarding\",\"url\":\"https://www.indoordogpark.org/parks/barks-rec-boarding\",\"sameAs\":[\"http://www.barksandrecboarding.com/\"],\"address\":{\"@type\":\"PostalAddress\",\"streetAddres