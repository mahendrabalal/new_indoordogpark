,null,{\\\"children\\\":\\\"Mooresville Motion\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"hero-chip-row\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",\\\"0\\\",{\\\"className\\\":\\\"hero-chip\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"chip-label\\\",\\\"children\\\":\\\"Lake Access\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"chip-value\\\",\\\"children\\\":\\\"Prime\\\"}],\\\"$undefined\\\"]}],[\\\"$\\\",\\\"div\\\",\\\"1\\\",{\\\"className\\\":\\\"hero-chip\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"chip-label\\\",\\\"children\\\":\\\"Hiking\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"chip-value\\\",\\\"children\\\":\\\" abundant\\\"}],\\\"$undefined\\\"]}]]}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"hero-description\\\",\\\"children\\\":\\\"Nestled on Lake Norman, Mooresville offers a fast-paced lifestyle with plenty of slow-down spots for dogs. From state park trails to lakeside walks, it is an active community.\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"city-rich-description\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",\\\"0\\\",{\\\"className\\\":\\\"rich-description-paragraph\\\",\\\"children\\\":[\\\"Mooresville, North Carolina, known as \\\\\\\"Race City USA,\\\\\\\" offers a pace of life that can be as fast or as slow as you like, especially when you have a dog. The main attraction for pet owners is undoubtedly \\\",[\\\"$\\\",\\\"$L12\\\",\\\"1\\\",{\\\"href\\\":\\\"https://www.ncparks.gov/state-parks/lake-norman-state-park\\\",\\\"target\\\":\\\"_blank\\\",\\\"rel\\\":\\\"noopener noreferrer\\\",\\\"className\\\":\\\"rich-link\\\",\\\"children\\\":\\\"Lake Norman State Park\\\"}],null,\\\". This expansive park offers miles of hiking trails that hug the shoreline, providing stunning views and a cool breeze off the water. While dogs must be leashed, the sensory experience of the forest and the lake makes for an unbeatable outing. It is