\"position\":9,\"item\":{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/classy-critters-pet-resort-spa-llc\",\"name\":\"Classy Critters Pet Resort & Spa LLC\",\"url\":\"https://www.indoordogpark.org/parks/classy-critters-pet-resort-spa-llc\",\"description\":\"North Carolina pet parents in Mooresville choose Classy Critters Pet Resort & Spa LLC for premium care. This facility features air-conditioned spaces for hot summers, North Carolina pet care...\",\"address\":{\"@type\":\"PostalAddress\",\"addressLocality\":\"Mooresville\",\"addressRegion\":\"NC\",\"addressCountry\":\"US\"},\"image\":\"/images/parks/northcarolina/classy-critters-pet-resort-spa-llc/classy-critters-pet-resort-spa-llc-1.jpg\"}},{\"@type\":\"ListItem\",\"position\":10,\"item\":{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/cornelius-road-park\",\"name\":\"Cornelius Road Park\",\"url\":\"https://www.indoordogpark.org/parks/cornelius-road-park\",\"description\":\"Cornelius Road Park has become the premier destination for Mooresville dog owners. This facility features spacious exercise zones, experienced and certified staff, offering pet care. Their services...\",\"address\":{\"@type\":\"PostalAddress\",\"addressLocality\":\"Mooresville\",\"addressRegion\":\"NC\",\"addressCountry\":\"US\"},\"image\":\"/images/parks/northcarolina/cornelius-road-park/cornelius-road-park-1.jpg\"}}]}25:[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"suppressHydrationWarning\":true,\"dangerouslySetInnerHTML\":{\"__html\":\"$2d\"}}]\n2e:T494,{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Are dogs allowed at Lake Norman State Park?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes, dogs are welcome on all hiking trails, such as the Lake Shore Trail, as long as they are on a leash no longer than six feet.\"}},{\"@type\":\"Question\",\"name\":\"Does Mooresville have a dog park?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"The Cornelius Road Park and nearby Stumpy Creek Park offer great walking areas, but for dedicated off-leash zones, many residents head to the Weddington Road Bark Park in nearby Concord.\"}},{\"@type\":\"Question\",\"name\":\"What are the leash laws in Mooresville?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Mooresville requires dogs to be under \\\"direct control or restraint\\\" in public. This effectively means a leash is required unless in a designated off-leash area.\"}},{\"@type\":\"Question\",\"name\":\"Can dogs swim in Lake Norman?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Swimming is generally restricted at designated swim beaches, but dogs often splash in quieter coves along trails. Always check for algae blooms before letting them in the water.\"}}]}26:[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"suppressHydrationWarning\":true,\"dangerouslySetInnerHTML\":{\"__html\":\"$2e\"}}]\n27:[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"suppressHydrationWarning\":true,\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://www.indoordogpark.org/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Dog Parks Directory\\\",\\\"item\\\":\\\"https://www.indoordogpark.org/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Mooresville\\\"}]}\"}}]\n28:[\"$\",\"$L11\",null,{\"variant\":\"light\"}]\n29:[\"$\",\"$L2f\",null,{\"items\":[{\"id\":\"city-hero\",\"title\":\"City Overview\",\"level\":1},{\"id\":\"city-insights\",\"title\":\"Quick Facts\",\"level\":1},{\"id\":\"city-comparison\",\"title\":\"Top Comparisons\",\"level\":1},{\"id\":\"park-collections\",\"title\":\"Park Collections\",\"level\":1},{\"id\":\"neighborhood-clusters\",\"title\":\"Neighborhoods\",\"level\":1},{\"id\":\"park-types-guide\",\"title\":\"Park Type Guide\",\"level\":1},{\"id\":\"map-and-neighborhoods\",\"title\":\"Map & Neighborhoods\",\"level\":1},{\"id\":\"planning-essentials\",\"title\":\"Planning Essentials\",\"level\":1},{\"id\":\"expert-tips\",\"title\":\"Expert Advice\",\"level\":1},{\"id\":\"park-directory\",\"title\":\"Full Directory\",\"level\":1},{\"id\":\"owner-cta\",\"title\":\"Owner & Franchise\",\"level\":1},{\"id\":\"faq-section\",\"title\":\"FAQs\",\"level\":1},{\"id\":\"related-resources\",\"title\":\"More Resources\",\"level\":1}]}]\n2a:[\"$\",\"main\",null,{\"className\":\"city-page-layout\",\"children\":[[\"$\",\"div\",null,{\"className\":\"mobile-toc-button\",\"children\":[\"$\",\"$L30\",null,{\"className\":\"mobile-toc-trigger\",\"targetSelector\":\".table-of-contents\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-list-ul\"}],[\"$\",\"span\",null,{\"children\":\"Contents\"}]]}]}],[\"$\",\"section\",null,{\"id\":\"city-hero\",\"className\":\"city-hero-section \",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell city-hero-shell\",\"children\":[[\"$\",\"div\",null,{\"className\":\"city-hero-copy\",\"children\":[[\"$\",\"div\",null,{\"className\":\"hero-breadcrumbs\",\"children\":[[\"$\",\"$L12\",null,{\"href\":\"/\",\"children\":\"Home\"}],[\"$\",\"i\",null,{\"className\":\"bi bi-chevron-right\"}],[\"$\",\"span\",null,{\"children\":\"Dog Parks Directory\"}],[\"$\",\"i\",null,{\"className\":\"bi bi-chevron-right\"}],[\"$\",\"strong\",null,{\"children\":\"Mooresville\"}]]}],[\"$\",\"p\",null,{\"className\":\"hero-eyebrow\",\"children\":\"Race City USA\"}],[\"$\",\"h1\",null,{\"children\":\"Mooresville Motion\"}],[\"$\",\"div\",null,{\"className\":\"hero-chip-row\",\"children\":[[\"$\",\"div\",\"0\",{\"className\":\"hero-chip\",\"children\":[[\"$\",\"span\",null,{\"className\":\"chip-label\",\"children\":\"Lake Access\"}],[\"$\",\"span\",null,{\"className\":\"chip-value\",\"children\":\"Prime\"}],\"$undefined\"]}],[\"$\",\"div\",\"1\",{\"className\":\"hero-chip\",\"children\":[[\"$\",\"span\",null,{\"className\":\"chip-label\",\"children\":\"Hiking\"}],[\"$\",\"span\",null,{\"className\":\"chip-value\",\"children\":\" abundant\"}],\"$undefined\"]}]]}],[\"$\",\"p\",null,{\"className\":\"hero-description\",\"children\":\"Nestled on Lake Norman, Mooresville offers a fast-paced lifestyle with plenty of slow-down spots for dogs. From state park trails to lakeside walks, it is an active community.\"}],[\"$\",\"div\",null,{\"className\":\"city-rich-description\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"rich-description-paragraph\",\"children\":[\"Mooresville, North Carolina, known as \\\"Race City USA,\\\" offers a pace of life that can be as fast or as slow as you like, especially when you have a dog. The main attraction for pet owners is undoubtedly \",[\"$\",\"$L12\",\"1\",{\"href\":\"https://www.ncparks.gov/state-parks/lake-norman-state-park\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"rich-link\",\"children\":\"Lake Norman State Park\"}],null,\". This expansive park offers miles of hiking trails that hug the shoreline, providing stunning views and a cool breeze off the water. While dogs must be leashed, the sensory experience of the forest and the lake makes for an unbeatable outing. It is a destination for hikers, trail runners, and nature lovers.\"]}],[\"$\",\"p\",\"1\",{\"className\":\"rich-description-paragraph\",\"children\":[\"Closer to town, parks like Cornelius Road Park and Mazeppa Park offer excellent amenities for daily exercise. These parks feature well-maintained walking loops that are popular with locals. The town’s rapid growth has brought with it a host of pet-friendly businesses, from breweries to supply stores, catering to a community that clearly loves its animals. Whether you are training for a 5k on the trails or just relaxing by the water, Mooresville offers a \",[\"$\",\"$L12\",\"1\",{\"href\":\"https://www.indoordogpark.org/\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"rich-link\",\"children\":\"high quality of life\"}],null,\" for dogs and their humans.\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-cta-row\",\"children\":[[\"$\",\"$L30\",null,{\"className\":\"hero-cta primary\",\"targetId\":\"park-directory\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-list-check\"}],\"Browse directory\"]}],[\"$\",\"$L30\",null,{\"className\":\"hero-cta ghost\",\"targetId\":\"map-and-neighborhoods\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-geo-alt\"}],\"Open map\"]}],[\"$\",\"$L12\",null,{\"href\":\"/list-your-park\",\"className\":\"hero-cta text-link\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-plus-circle\"}],\"Submit a park\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-footnotes\",\"children\":[[\"$\",\"span\",\"Lake Norman State Park\",{\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-sparkles\"}],\" \",\"Lake Norman State Park\"]}],[\"$\",\"span\",\"Cornelius Road Park\",{\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-sparkles\"}],\" \",\"Cornelius Road Park\"]}],[\"$\",\"span\",\"Stumpy Creek Park\",{\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-sparkles\"}],\" \",\"Stumpy Creek Park\"]}]]}]]}],\"$L31\"]}]}],\"$L32\",\"$L33\",\"$L34\",\"$L35\",\"$L36\",\"$L37\",\"$undefined\",\"$L38\",\"$L39\",\"$L3a\",\"$L3b\",\"$L3c\"]}]\n2b:[\"$\",\"footer\",null,{\"className\":\"footer-new\",\"children\":[\"$\",\"div\",null,{\"className\":\"footer-container\",\"children\":[[\"$\",\"div\",null,{\"className\":\"footer-grid\",\"children\":[[\"$\",\"div\",null,{\"className\":\"footer-column\",\"children\":[[\"$\",\"h4\",null,{\"className\":\"footer-heading\",\"children\":\"IndoorDogPark\"}],[\"$\",\"ul\",null,{\"className\":\"footer-links\",\"children\":[[\"$\",\"li\",null,{\"children\":[\"$\",\"$L12\",null,{\"href\":\"/about\",\"children\":\"About us\"}]}],[\"$\",\"li\",null,{\