\"href\":\"/contact\",\"children\":\"Contact us\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L10\",null,{\"href\":\"/faq\",\"children\":\"FAQ\"}]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"footer-column col-span-full md:col-span-2 lg:col-span-1\",\"children\":[[\"$\",\"h4\",null,{\"className\":\"footer-heading\",\"children\":\"Join the Pack\"}],[\"$\",\"p\",null,{\"className\":\"mb-4 text-sm text-white/70\",\"children\":\"Get the latest indoor dog park news and updates.\"}],[\"$\",\"div\",null,{\"className\":\"rounded-2xl border border-white/10 bg-white/5 p-4 backdrop-blur-sm\",\"children\":[\"$\",\"$L1e\",null,{\"type\":\"consumer\",\"source\":\"footer\",\"variant\":\"dark\"}]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"footer-social\",\"children\":[[\"$\",\"a\",null,{\"href\":\"https://x.com/Indoordogp40934\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"aria-label\":\"Follow us on X (Twitter)\",\"title\":\"Follow us on X (Twitter)\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-twitter\"}]}],[\"$\",\"a\",null,{\"href\":\"https://www.facebook.com/IndoorDogParkDirectory\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"aria-label\":\"Follow us on Facebook\",\"title\":\"Follow us on Facebook\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-facebook\"}]}],[\"$\",\"a\",null,{\"href\":\"https://www.instagram.com/indoordogpark2025/\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"aria-label\":\"Follow us on Instagram\",\"title\":\"Follow us on Instagram\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-instagram\"}]}],[\"$\",\"a\",null,{\"href\":\"https://www.pinterest.com/indoordogpark/\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"aria-label\":\"Follow us on Pinterest\",\"title\":\"Follow us on Pinterest\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-pinterest\"}]}],\"$undefined\",\"$undefined\",[\"$\",\"a\",null,{\"href\":\"https://digg.com/indoordogpark\",\"target\":\"_blank\",\"rel\":\"noop