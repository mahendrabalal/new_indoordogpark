\",\"$L40\",null,{\"src\":\"/images/cities/st-louis/hero.webp\",\"alt\":\"St. Louis dog park landscape\",\"fill\":true,\"priority\":true,\"sizes\":\"(max-width: 768px) 100vw, 540px\",\"unoptimized\":true}],[\"$\",\"div\",null,{\"className\":\"hero-image-gradient\"}]]}]}]\n32:[\"$\",\"$L41\",null,{\"city\":\"St. Louis\",\"state\":\"MO\"}]\n33:[\"$\",\"section\",null,{\"id\":\"city-insights\",\"className\":\"city-insights-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell\",\"children\":[\"$\",\"$L42\",null,{\"parks\":[{\"id\":\"ChIJHfN2-R212IcRhOtLhPMQr_k\",\"name\":\"Forest Park Southeast Members Only Dog Park\",\"businessType\":\"Dog Park\",\"description\":\"Forest Park Southeast Members Only Dog Park provides a safe and fun environment for dogs of all sizes in the heart of St. Louis.\\n\\nThis park is well-equipped with amenities such as indoor facilities for all-weather play, climate-controlled areas, professional staff on-site, convenient onsite services, ensuring a comfortable visit for both you and your pet. Visitors appreciate the clean environment and friendly atmosphere, reflected in its 4.1-star rating. For more details, you can visit the [official website](https://www.stlouis-mo.gov/parks/parks/browse-parks/amenity.cfm?id=504) or check out local guides at [Indoor Dog Park](https://www.indoordogpark.org/).\",\"slug\":\"forest-park-southeast-members-only-dog-park\",\"address\":\"4359 Chouteau Ave\",\"street\":\"4359 Chouteau Ave\",\"city\":\"St. Louis\",\"state\":\"MO\",\"zipCode\":\"63110\",\"full_address\":\"4359 Chouteau Ave, St. Louis, MO 63110, USA\",\"latitude\":38.63005599999999,\"longitude\":-90.2576936,\"googlePlaceId\":\"ChIJHfN2-R212IcRhOtLhPMQr_k\",\"phone\":\"\",\"website\":\"https://www.stlouis-mo.gov/parks/parks/browse-parks/amenity.cfm?id=504\",\"photos\":null,\"rating\":4.1,\"reviewCount\":80,\"openingHours\":{\"Monday\":\"6:00 AM – 8:00 PM\",\"Tuesday\":\"6:00 AM – 8:00 PM\",\"Wednesday\":\"6:00 AM – 8:00 PM\",\"Thur