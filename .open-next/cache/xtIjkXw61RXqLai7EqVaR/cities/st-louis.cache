w, 540px\",\"unoptimized\":true}],[\"$\",\"div\",null,{\"className\":\"hero-image-gradient\"}]]}]}]\n32:[\"$\",\"$L41\",null,{\"city\":\"St. Louis\",\"state\":\"MO\"}]\n33:[\"$\",\"section\",null,{\"id\":\"city-insights\",\"className\":\"city-insights-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell\",\"children\":[\"$\",\"$L42\",null,{\"parks\":[{\"id\":\"ChIJHfN2-R212IcRhOtLhPMQr_k\",\"name\":\"Forest Park Southeast Members Only Dog Park\",\"businessType\":\"Dog Park\",\"description\":\"Forest Park Southeast Members Only Dog Park provides a safe and fun environment for dogs of all sizes in the heart of St. Louis.\\n\\nThis park is well-equipped with amenities such as indoor facilities for all-weather play, climate-controlled areas, professional staff on-site, convenient onsite services, ensuring a comfortable visit for both you and your pet. Visitors appreciate the clean environment and friendly atmosphere, reflected in its 4.1-star rating. For more details, you can visit the [official website](https://www.stlouis-mo.gov/parks/parks/browse-parks/amenity.cfm?id=504) or check out local guides at [Indoor Dog Park](https://www.indoordogpark.org/).\",\"slug\":\"forest-park-southeast-members-only-dog-park\",\"address\":\"4359 Chouteau Ave\",\"street\":\"4359 Chouteau Ave\",\"city\":\"St. Louis\",\"state\":\"MO\",\"zipCode\":\"63110\",\"full_address\":\"4359 Chouteau Ave, St. Louis, MO 63110, USA\",\"latitude\":38.63005599999999,\"longitude\":-90.2576936,\"googlePlaceId\":\"ChIJHfN2-R212IcRhOtLhPMQr_k\",\"phone\":\"\",\"website\":\"https://www.stlouis-mo.gov/parks/parks/browse-parks/amenity.cfm?id=504\",\"photos\":null,\"rating\":4.1,\"reviewCount\":80,\"openingHours\":{\"Monday\":\"6:00 AM – 8:00 PM\",\"Tuesday\":\"6:00 AM – 8:00 PM\",\"Wednesday\":\"6:00 AM – 8:00 PM\",\"Thursday\":\"6:00 AM – 8:00 PM\",\"Friday\":\"6:00 AM – 8:00 PM\",\"Saturday\":\"6:00 AM – 8:00 PM\",\"Sunday\":\"6:00 AM – 8:00 PM\"},\"amenities\":{\"Onsite services\":true,\"Indoor facilities\":true,\"Professional staff\":true,\"Climate controlled\":true,\"Wheelchair accessible entrance\":true,\"Parking available\":true,\"Easy access\":true},\"pricing\":{\"pricingSource\":\"website\",\"isFree\":false},\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"lastUpdated\":null,\"dataQuality\":\"verified\",\"photo\":null,\"faqs\":[],\"source\":\"static\",\"listingType\":\"free\"},{\"id\":\"ChIJgaKxD6Cz2IcR1KAZdNeX-xg\",\"name\":\"Frenchtown Member's Only Dog Park\",\"businessType\":\"Dog Park\",\"description\":\"If you're in St. Louis, bring your furry friend to Frenchtown Member's Only Dog Park for a great day out.\\n\\nThis park is well-equipped with amenities such as indoor facilities for all-weather play, climate-controlled areas, professional staff on-site, convenient onsite services, ensuring a comfortable visit for both you and your pet. Locals enjoy the convenient location and the opportunity for their dogs to burn off energy. Make sure to check the [official page](http://www.frenchtowndogpark.com/xxxx) for membership info. For more dog-friendly spots, browse [Indoor Dog Park](https://www.indoordogpark.org/).\",\"slug\":\"frenchtown-member-s-only-dog-park\",\"address\":\"Emmet St\",\"street\":\"Emmet St\",\"city\":\"St. Louis\",\"state\":\"MO\",\"zipCode\":\"63104\",\"full_address\":\"Emmet St, St. Louis, MO 63104, USA\",\"latitude\":38.6099395,\"longitude\":-90.2049255,\"googlePlaceId\":\"ChIJgaKxD6Cz2IcR1KAZdNeX-xg\",\"phone\":\"\",\"website\":\"http://www.frenchtowndogpark.com/xxxx\",\"photos\":null,\"rating\":3.8,\"reviewCount\":58,\"openingHours\":{\"Monday\":\"6:00 AM – 9:00 PM\",\"Tuesday\":\"6:00 AM – 9:00 PM\",\"Wednesday\":\"6:00 AM – 9:00 PM\",\"Thursday\":\"6:00 AM – 9:00 PM\",\"Friday\":\"6:00 AM – 9:00 PM\",\"Saturday\":\"6:00 AM – 9:00 PM\",\"Sunday\":\"6:00 AM – 9:00 PM\"},\"amenities\":{\"Onsite services\":true,\"Indoor facilities\":true,\"Professional staff\":true,\"Climate controlled\":true,\"Wheelchair accessible entrance\":false,\"Parking available\":true,\"Easy access\":true},\"pricing\":{\"pricingSource\":\"website\",\"isFree\":false},\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"lastUpdated\":null,\"dataQuality\":\"verified\",\"photo\":null,\"faqs\":[],\"source\":\"static\",\"listingType\":\"free\"},{\"id\":\"ChIJCTm6g-Cy2IcRilORohZ5hCc\",\"name\":\"Laclede's Landing Dog Park\",\"businessType\":\"Dog Park\",\"description\":\"Laclede's Landing Dog Park provides a safe and fun environment for dogs of all sizes in the heart of St. Louis.\\n\\nThis park is well-equipped with amenities such as indoor facilities for all-weather play, climate-controlled areas, professional staff on-site, convenient onsite services, ensuring a comfortable visit for both you and your pet. Locals enjoy the convenient location and the opportunity for their dogs to burn off energy. Make sure to check the [official page](https://www.lacledeslanding.com/) for membership info. For more dog-friendly spots, browse [Indoor Dog Park](https://www.indoordogpark.org/).\",\"slug\":\"laclede-s-landing-dog-park\",\"address\":\"Laclede's Landing Blvd\",\"street\":\"Laclede's Landing Blvd\",\"city\":\"St. Louis\",\"state\":\"MO\",\"zipCode\":\"63102\",\"full_address\":\"Laclede's Landing Blvd, St. Louis, MO 63102, USA\",\"latitude\":38.63141029999999,\"longitude\":-90.18419329999999,\"googlePlaceId\":\"ChIJCTm6g-Cy2IcRilORohZ5hCc\",\"phone\":\"\",\"website\":\"https://www.lacledeslanding.com/\",\"photos\":null,\"rating\":3.8,\"reviewCount\":37,\"openingHours\":{\"Monday\":\"6:00 AM – 9:00 PM\",\"Tuesday\":\"6:00 AM – 9:00 PM\",\"Wednesday\":\"6:00 AM – 9:00 PM\",\"Thursday\":\"6:00 AM – 9:00 PM\",\"Friday\":\"6:00 AM – 9:00 PM\",\"Saturday\":\"6:00 AM – 9:00 PM\",\"Sunday\":\"6:00 AM – 9:00 PM\"},\"amenities\":{\"Onsite services\":true,\"Indoor facilities\":true,\"Professional staff\":true,\"Climate controlled\":true,\"Wheelchair accessible entrance\":true,\"Parking available\":true,\"Easy access\":true},\"pricing\":{\"pricingSource\":\"website\",\"isFree\":false},\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"lastUpdated\":null,\"dataQuality\":\"verified\",\"photo\":null,\"faqs\":[],\"source\":\"static\",\"listingType\":\"free\"},{\"id\":\"ChIJAQy4KBaz2IcRn7vbh1xVKWI\",\"name\":\"Lucas Dog Park (membership only)\",\"businessType\":\"Dog Park\",\"description\":\"Lucas Dog Park (membership only) provides a safe and fun environment for dogs of all sizes in the heart of St. Louis.\\n\\nThis park is well-equipped with amenities such as indoor facilities for all-weather play, climate-controlled areas, professional staff on-site, convenient onsite services, ensuring a comfortable visit for both you and your pet. Locals enjoy the convenient location and the opportunity for their dogs to burn off energy. For more details, you can visit the [official website](http://www.lucasparkdogpark.org/) or check out local guides at [Indoor Dog Park](https://www.indoordogpark.org/).\",\"slug\":\"lucas-dog-park-membership-only\",\"address\":\"St Charles St & 13th Street\",\"street\":\"St Charles St & 13th Street\",\"city\":\"St. Louis\",\"state\":\"MO\",\"zipCode\":\"63103\",\"full_address\":\"St Charles St & 13th Street, St. Louis, MO 63103, USA\",\"latitude\":38.6315353,\"longitude\":-90.1989297,\"googlePlaceId\":\"ChIJAQy4KBaz2IcRn7vbh1xVKWI\",\"phone\":\"\",\"website\":\"http://www.lucasparkdogpark.org/\",\"photos\":null,\"rating\":3.5,\"reviewCount\":54,\"openingHours\":{},\"amenities\":{\"Onsite services\":true,\"Indoor facilities\":true,\"Professional staff\":true,\"Climate controlled\":true,\"Wheelchair accessible entrance\":true,\"Parking available\":true,\"Easy access\":true},\"pricing\":{\"pricingSource\":\"website\",\"isFree\":false},\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"lastUpdated\":null,\"dataQuality\":\"verified\",\"photo\":null,\"faqs\":[],\"source\":\"static\",\"listingType\":\"free\"},{\"id\":\"ChIJ43rcT3G12IcRN6W5mgYLDd4\",\"name\":\"Shaw Dog Park (Membership Only)\",\"businessType\":\"Dog Park\",\"description\":\"If you're in St. Louis, bring your furry friend to Shaw Dog Park (Membership Only) for a great day out.\\n\\nThis park is well-equipped with amenities such as indoor facilities for all-weather play, climate-controlled areas, professional staff on-site, convenient onsite services, ensuring a comfortable visit for both you and your pet. Visitors appreciate the clean environment and friendly atmosphere, reflected in its 4.2-star rating. Plan your visit today! For rules and hours, see the [park website](http://shawstlouis.org/attractions-amenities/shaw-dog-park/) or verify details on [Indoor Dog Park](https://www.indoordogpark.org/).\",\"slug\":\"shaw-dog-park-membership-only\",\"address\":\"4101 Cleveland Ave\",\"street\":\"4101 Cleveland Ave\",\"city\":\"St. Louis\",\"state\":\"MO\",\"zipCode\":\"63110\",\"full_address\":\"4101 Cleveland Ave, St. Louis, MO 63110, USA\",\"latitude\":38.6117381,\"longitude\":-90.2515851,\"googlePlaceId\":\"ChIJ43rcT3G12IcRN6W5mgYLDd4\",\"phone\":\"(314) 771-3101\",\"website\":\"http://shawstlouis.org/attractions-amenities/shaw-dog-park/\",\"photos\":null,\"rating\":4.2,\"reviewCount\":23,\"openingHours\":{\"Monday\":\"6:00 AM – 10:00 PM\",\"Tuesday\":\"6:00 AM – 10:00 PM\",\"Wednesday\":\"6:00 AM – 10:00 PM\",\"Thursday\":\"6:00 AM – 10:00 PM\",\"Friday\":\"6:00 AM – 10:00 PM\",\"Saturday\":\"6:00 AM – 10:00 PM\",\"Sunday\":\"6:00 AM – 10:00 PM\"},\"amenities\":{\"Onsite services\":true,\"Indoor facilities\":true,\"Professional staff\":true,\"Climate controlled\":true,\"Wheelchair accessible entrance\":false,\"Parking available\":true,\"Easy access\":true},\"pricing\":{\"pricingSource\":\"website\",\"isFree\":false},\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"lastUpdated\":null,\"dataQuality\":\"verified\",\"photo\":null,\"faqs\":[],\"source\":\"static\",\"listingType\":\"free\"},{\"id\":\"ChIJ4-58m6S02IcRkeGFU6mNDH8\",\"name\":\"SLU Dog Park & Sculpture Garden\",\"businessType\":\"Dog Park\",\"description\":\"SLU Dog Park & Sculpture Garden provides a safe and fun environment for dogs of all sizes in the heart of St. Louis.\\n\\nThis park is well-equipped with amenities such as indoor facilities for all-weather play, climate-controlled areas, professional staff on-site, convenient onsite services, ensuring a comfortable visit for both you and your pet. Locals enjoy the convenient location and the opportunity for their dogs to burn off energy. For more details, you can visit the [official website](#) or check out local guides at [Indoor Dog Park](https://www.indoordogpark.org/).\",\"slug\":\"slu-dog-park-sculpture-garden\",\"address\":\"1 N Grand Blvd\",\"street\":\"1 N Grand Blvd\",\"city\":\"St. Louis\",\"state\":\"MO\",\"zipCode\":\"63103\",\"full_address\":\"1 N Grand Blvd, St. Louis, MO 63103, USA\",\"latitude\":38.6376386,\"longitude\":-90.23212529999999,\"googlePlaceId\":\"ChIJ4-58m6S02IcRkeGFU6mNDH8\",\"phone\":\"\",\"website\":\"\",\"photos\":null,\"rating\":3.9,\"reviewCount\":164,\"openingHours\":{\"Monday\":\"Closed\",\"Tuesday\":\"Closed\",\"Wednesday\":\"Closed\",\"Thursday\":\"Open 24 hours\",\"Friday\":\"Open 24 hours\",\"Saturday\":\"Open 24 hours\",\"Sunday\":\"Open 24 hours\"},\"amenities\":{\"Onsite services\":true,\"Indoor facilities\":true,\"Professional staff\":true,\"Climate controlled\":true,\"Wheelchair accessible entrance\":false,\"Parking available\":true,\"Easy access\":true},\"pricing\":{\"pricingSource\":\"website\",\"isFree\":false},\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"lastUpdated\":null,\"dataQuality\":\"verified\",\"photo\":null,\"faqs\":[],\"source\":\"static\",\"listingType\":\"free\"},{\"id\":\"ChIJnck47APK2IcRwweqa_uONBc\",\"name\":\"Southwest City Dog Park (Members Only)\",\"businessType\":\"Dog Park\",\"description\":\"Located in St. Louis, Southwest City Dog Park (Members Only) offers a welcoming space for pets to exercise and soci