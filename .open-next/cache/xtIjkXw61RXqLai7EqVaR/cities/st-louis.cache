\\":\\\\\\\"Forest Park offers miles of paths, but for a true hike, Castlewood State Park is a short drive away and offers stunning river views.\\\\\\\"}},{\\\\\\\"@type\\\\\\\":\\\\\\\"Question\\\\\\\",\\\\\\\"name\\\\\\\":\\\\\\\"Are dogs allowed in Forest Park?\\\\\\\",\\\\\\\"acceptedAnswer\\\\\\\":{\\\\\\\"@type\\\\\\\":\\\\\\\"Answer\\\\\\\",\\\\\\\"text\\\\\\\":\\\\\\\"Yes, dogs are welcome in Forest Park on a leash. It is one of the largest urban parks in the country and a favorite for dog walkers.\\\\\\\"}}]}\\\"}}]\\n27:[\\\"$\\\",\\\"script\\\",null,{\\\"type\\\":\\\"application/ld+json\\\",\\\"suppressHydrationWarning\\\":true,\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"{\\\\\\\"@context\\\\\\\":\\\\\\\"https://schema.org\\\\\\\",\\\\\\\"@type\\\\\\\":\\\\\\\"BreadcrumbList\\\\\\\",\\\\\\\"itemListElement\\\\\\\":[{\\\\\\\"@type\\\\\\\":\\\\\\\"ListItem\\\\\\\",\\\\\\\"position\\\\\\\":1,\\\\\\\"name\\\\\\\":\\\\\\\"Home\\\\\\\",\\\\\\\"item\\\\\\\":\\\\\\\"https://www.indoordogpark.org/\\\\\\\"},{\\\\\\\"@type\\\\\\\":\\\\\\\"ListItem\\\\\\\",\\\\\\\"position\\\\\\\":2,\\\\\\\"name\\\\\\\":\\\\\\\"Dog Parks Directory\\\\\\\",\\\\\\\"item\\\\\\\":\\\\\\\"https://www.indoordogpark.org/\\\\\\\"},{\\\\\\\"@type\\\\\\\":\\\\\\\"ListItem\\\\\\\",\\\\\\\"position\\\\\\\":3,\\\\\\\"name\\\\\\\":\\\\\\\"St. Louis\\\\\\\"}]}\\\"}}]\\n28:[\\\"$\\\",\\\"$L11\\\",null,{\\\"variant\\\":\\\"light\\\"}]\\n29:[\\\"$\\\",\\\"$L2e\\\",null,{\\\"items\\\":[{\\\"id\\\":\\\"city-hero\\\",\\\"title\\\":\\\"City Overview\\\",\\\"level\\\":1},{\\\"id\\\":\\\"city-insights\\\",\\\"title\\\":\\\"Quick Facts\\\",\\\"level\\\":1},{\\\"id\\\":\\\"city-comparison\\\",\\\"title\\\":\\\"Top Comparisons\\\",\\\"level\\\":1},{\\\"id\\\":\\\"park-collections\\\",\\\"title\\\":\\\"Park Collections\\\",\\\"level\\\":1},{\\\"id\\\":\\\"neighborhood-clusters\\\",\\\"title\\\":\\\"Neighborhoods\\\",\\\"level\\\":1},{\\\"id\\\":\\\"park-types-guide\\\",\\\"title\\\":\\\"Park Type Guide\