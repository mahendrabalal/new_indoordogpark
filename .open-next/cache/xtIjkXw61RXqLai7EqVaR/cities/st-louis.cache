v/parks/parks/browse-parks/amenity.cfm?id=504) or check out local guides at [Indoor Dog Park](https://www.indoordogpark.org/).\\\",\\\"slug\\\":\\\"forest-park-southeast-members-only-dog-park\\\",\\\"address\\\":\\\"4359 Chouteau Ave\\\",\\\"street\\\":\\\"4359 Chouteau Ave\\\",\\\"city\\\":\\\"St. Louis\\\",\\\"state\\\":\\\"MO\\\",\\\"zipCode\\\":\\\"63110\\\",\\\"full_address\\\":\\\"4359 Chouteau Ave, St. Louis, MO 63110, USA\\\",\\\"latitude\\\":38.63005599999999,\\\"longitude\\\":-90.2576936,\\\"googlePlaceId\\\":\\\"ChIJHfN2-R212IcRhOtLhPMQr_k\\\",\\\"phone\\\":\\\"\\\",\\\"website\\\":\\\"https://www.stlouis-mo.gov/parks/parks/browse-parks/amenity.cfm?id=504\\\",\\\"photos\\\":null,\\\"rating\\\":4.1,\\\"reviewCount\\\":80,\\\"openingHours\\\":{\\\"Monday\\\":\\\"6:00 AM – 8:00 PM\\\",\\\"Tuesday\\\":\\\"6:00 AM – 8:00 PM\\\",\\\"Wednesday\\\":\\\"6:00 AM – 8:00 PM\\\",\\\"Thursday\\\":\\\"6:00 AM – 8:00 PM\\\",\\\"Friday\\\":\\\"6:00 AM – 8:00 PM\\\",\\\"Saturday\\\":\\\"6:00 AM – 8:00 PM\\\",\\\"Sunday\\\":\\\"6:00 AM – 8:00 PM\\\"},\\\"amenities\\\":{\\\"Onsite services\\\":true,\\\"Indoor facilities\\\":true,\\\"Professional staff\\\":true,\\\"Climate controlled\\\":true,\\\"Wheelchair accessible entrance\\\":true,\\\"Parking available\\\":true,\\\"Easy access\\\":true},\\\"pricing\\\":{\\\"pricingSource\\\":\\\"website\\\",\\\"isFree\\\":false},\\\"placeTypes\\\":[\\\"point_of_interest\\\",\\\"establishment\\\"],\\\"lastUpdated\\\":null,\\\"dataQuality\\\":\\\"verified\\\",\\\"photo\\\":null,\\\"faqs\\\":[],\\\"source\\\":\\\"static\\\",\\\"listingType\\\":\\\"free\\\"},{\\\"id\\\":\\\"ChIJgaKxD6Cz2IcR1KAZdNeX-xg\\\",\\\"name\\\":\\\"Frenchtown Member's Only Dog Park\\\",\\\"businessType\\\":\\\"Dog Park\\\",\\\"description\\\":\\\"If you're in St. Louis, bring your furry friend to Frenchtown Member's Only Dog Park for a great day out.\\\\n\\\\nThis park is well-equipped with amenities such as indoor facilities for all-weather play, climate-controlled a