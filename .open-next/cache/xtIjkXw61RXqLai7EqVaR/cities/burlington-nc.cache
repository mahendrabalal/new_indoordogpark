egion\":\"NC\",\"postalCode\":\"27215\",\"addressCountry\":\"US\"},\"telephone\":\"(336) 449-9663\",\"image\":\"/images/parks/northcarolina/bark-avenue-pets-inc/bark-avenue-pets-inc-1.jpg\",\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":4.8,\"reviewCount\":6},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":36.0592303,\"longitude\":-79.5416286}},{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/bed-bone-boarding-and-grooming\",\"name\":\"Bed & Bone Boarding and Grooming\",\"url\":\"https://www.indoordogpark.org/parks/bed-bone-boarding-and-grooming\",\"sameAs\":[\"http://www.bedandbone.net/\"],\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"1956 Jones Dr\",\"addressLocality\":\"Burlington\",\"addressRegion\":\"NC\",\"postalCode\":\"27302\",\"addressCountry\":\"US\"},\"telephone\":\"(919) 563-4756\",\"image\":\"/images/parks/northcarolina/bed-bone-boarding-and-grooming/bed-bone-boarding-and-grooming-1.jpg\",\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":4.8,\"reviewCount\":180},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":36.0497188,\"longitude\":-79.2882209}},{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/bill-cooke-park\",\"name\":\"Bill Cooke Park\",\"url\":\"https://www.indoordogpark.org/parks/bill-cooke-park\",\"sameAs\":[\"https://www.cityofgraham.com/parks-facilities/\"],\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"1010 Townbranch Rd\",\"addressLocality\":\"Burlington\",\"addressRegion\":\"NC\",\"postalCode\":\"27253\",\"addressCountry\":\"US\"},\"telephone\":\"(336) 570-6718\",\"image\":\"/images/parks/northcarolina/bill-cooke-park/bill-cooke-park-1.jpg\",\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":4.6,\"reviewCount\":483},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":36.0727482,\"longitude\":-79.37823329999999}},{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.o