\",null,{\"parks\":[{\"id\":\"ChIJc3bvBIfVUogR-ksB4qYBrwc\",\"name\":\"Alamance Parks\",\"businessType\":\"Indoor Dog Park\",\"description\":\"Among Burlington's top-rated facilities, Alamance Parks excels in year-round care. This facility features modern training facilities, experienced and certified staff, offering pet care. Their services offers peace of mind for busy North Carolina pet parents. centrally located for Burlington residents. Experience the difference at Alamance Parks\",\"slug\":\"alamance-parks\",\"address\":\"3916 R Dean Coleman Rd\",\"street\":\"3916 R Dean Coleman Rd\",\"city\":\"Burlington\",\"state\":\"NC\",\"zipCode\":\"27215\",\"full_address\":\"3916 R Dean Coleman Rd, Burlington, NC 27215, USA\",\"latitude\":35.9949518,\"longitude\":-79.4400848,\"googlePlaceId\":\"ChIJc3bvBIfVUogR-ksB4qYBrwc\",\"phone\":\"(336) 229-2410\",\"website\":\"https://www.alamance-nc.com/recreation\",\"rating\":4.7,\"reviewCount\":32,\"userRatingsTotal\":32,\"pricing\":{\"pricingSource\":\"unknown\",\"isFree\":false},\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"dataQuality\":\"verified\",\"openingHours\":{\"Monday\":\"8:00 AM – 5:00 PM\",\"Tuesday\":\"8:00 AM – 5:00 PM\",\"Wednesday\":\"8:00 AM – 5:00 PM\",\"Thursday\":\"8:00 AM – 5:00 PM\",\"Friday\":\"8:00 AM – 5:00 PM\",\"Saturday\":\"8:00 AM – 5:00 PM\",\"Sunday\":\"8:00 AM – 5:00 PM\"},\"faqs\":[],\"amenities\":{},\"photos\":[{\"url\":\"/images/parks/northcarolina/alamance-parks/alamance-parks-1.jpg\",\"type\":\"photo\",\"source\":\"website\"},{\"url\":\"/images/parks/northcarolina/alamance-parks/alamance-parks-2.jpg\",\"type\":\"photo\",\"source\":\"website\"}],\"photo\":\"/images/parks/northcarolina/alamance-parks/alamance-parks-1.jpg\",\"source\":\"static\",\"listingType\":\"free\"},{\"id\":\"ChIJwwOh7DMsrYkRgWL8hOMaXes\",\"name\":\"Animal Park at the Conservators Center\",\"businessType\":\"Indoor Dog Park\",\"description\":\"Among Burlington's top-rated facilities, Animal Park at the Conservators Center excels in year-round care. This facility features modern training facilities, North Carolina pet care professionals, offering pet care. Their services ensures your dog stays comfortable year-round in North Carolina. easily accessible from Burlington's main areas. Discover why Burlington pet parents choose Animal Park at the Conservators Center\",\"slug\":\"animal-park-at-the-conservators-center\",\"address\":\"676 E Hughes Mill Rd\",\"street\":\"676 E Hughes Mill Rd\",\"city\":\"Burlington\",\"state\":\"NC\",\"zipCode\":\"27217\",\"full_address\":\"676 E Hughes Mill Rd, Burlington, NC 27217, USA\",\"latitude\":36.2560852,\"longitude\":-79.3109787,\"googlePlaceId\":\"ChIJwwOh7DMsrYkRgWL8hOMaXes\",\"phone\":\"(336) 421-0883\",\"website\":\"http://www.animalparknc.org/\",\"rating\":4.9,\"reviewCount\":804,\"userRatingsTotal\":804,\"pricing\":{\"pricingSource\":\"unknown\",\"isFree\":false},\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"dataQuality\":\"verified\",\"openingHours\":{\"Monday\":\"Closed\",\"Tuesday\":\"Closed\",\"Wednesday\":\"Closed\",\"Thursday\":\"Closed\",\"Friday\":\"Closed\",\"Saturday\":\"10:30 AM – 5:00 PM\",\"Sunday\":\"10:30 AM – 3:00 PM\"},\"faqs\":[],\"amenities\":{},\"photos\":[{\"url\":\"/images/parks/northcarolina/animal-park-at-the-conservators-center/animal-park-at-the-conservators-center-1.jpg\",\"type\":\"photo\",\"source\":\"website\"},{\"url\":\"/images/parks/northcarolina/animal-park-at-the-conservators-center/animal-park-at-the-conservators-center-2.jpg\",\"type\":\"photo\",\"source\":\"website\"}],\"photo\":\"/images/parks/northcarolina/animal-park-at-the-conservators-center/animal-park-at-the-conservators-center-1.jpg\",\"source\":\"static\",\"listingType\":\"free\"},{\"id\":\"ChIJrTUWZEkvU4gRbdsXjLuBFt4\",\"name\":\"Bark Avenue Pets Inc\",\"businessType\":\"Indoor Dog Park\",\"description\":\"Bark Avenue Pets Inc provides essential services for Burlington's dogs. This facility features air-conditioned spac