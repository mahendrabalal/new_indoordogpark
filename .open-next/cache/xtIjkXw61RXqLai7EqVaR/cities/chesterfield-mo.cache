"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"While the mall interior policy can vary, individual stores and the surrounding retail developments often welcome pets. Always check signage before entering.\"}}]}19:[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"suppressHydrationWarning\":true,\"dangerouslySetInnerHTML\":{\"__html\":\"$24\"}}],[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"suppressHydrationWarning\":true,\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"ItemList\\\",\\\"@id\\\":\\\"https://www.indoordogpark.org/cities/chesterfield-mo#itemlist\\\",\\\"name\\\":\\\"Dog Parks in Chesterfield\\\",\\\"description\\\":\\\"Top-rated dog parks and facilities in Chesterfield, MO\\\",\\\"numberOfItems\\\":1,\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"item\\\":{\\\"@type\\\":\\\"SportsActivityLocation\\\",\\\"@id\\\":\\\"https://www.indoordogpark.org/parks/eberwein-dog-park-membership-required\\\",\\\"name\\\":\\\"Eberwein Dog Park (Membership Required)\\\",\\\"url\\\":\\\"https://www.indoordogpark.org/parks/eberwein-dog-park-membership-required\\\",\\\"description\\\":\\\"Located in Chesterfield, Eberwein Dog Park (Membership Required) offers a welcoming space for pets to exercise and socialize.\\\\n\\\\nThis park is well-equipped with amenities such as indoor facilities for...\\\",\\\"address\\\":{\\\"@type\\\":\\\"PostalAddress\\\",\\\"addressLocality\\\":\\\"Chesterfield\\\",\\\"addressRegion\\\":\\\"MO\\\",\\\"addressCountry\\\":\\\"US\\\"}}}]}\"}}],[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"suppressHydrationWarning\":true,\"dangerouslySetInnerHTML\":{\"__html\":\"$25\"}}],\"$L26\",\"$L27\",\"$L28\",\"$L29\",\"$L2a\",\"$L2b\"]\n2c:I[90491,[\"8500\",\"static/chunks/8500-98e13bcce54aa7a0.js\",\"7828\",\"static/chunks/7828-fd723da158040787.js\",\"2365\",\"static/chunks/2365-40fbe64639b5ecd9.js\",\"5772\",\"static/chunks/5772-ddd