:{\"@type\":\"PostalAddress\",\"streetAddress\":\"3636 Virginia Beach Blvd #107\",\"addressLocality\":\"Virginia Beach\",\"addressRegion\":\"VA\",\"postalCode\":\"23452\",\"addressCountry\":\"US\"},\"telephone\":\"(757) 904-1450\",\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":4.9,\"reviewCount\":91},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":36.8415801,\"longitude\":-76.0970368}},{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/bayville-farms-park\",\"name\":\"Bayville Farms Park\",\"url\":\"https://www.indoordogpark.org/parks/bayville-farms-park\",\"sameAs\":[\"https://parks.virginiabeach.gov/outdoors/city-parks/bayville-farms-park\"],\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"4132 First Ct Rd\",\"addressLocality\":\"Virginia Beach\",\"addressRegion\":\"VA\",\"postalCode\":\"23455\",\"addressCountry\":\"US\"},\"telephone\":\"(757) 460-7569\",\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":4.7,\"reviewCount\":1603},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":36.90334119999999,\"longitude\":-76.1194854}},{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/beach-pups-pet-styling\",\"name\":\"Beach Pups Pet Styling\",\"url\":\"https://www.indoordogpark.org/parks/beach-pups-pet-styling\",\"sameAs\":[\"https://beachpupspetstyling.com/\"],\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"4676 Princess Anne Rd\",\"addressLocality\":\"Virginia Beach\",\"addressRegion\":\"VA\",\"postalCode\":\"23462\",\"addressCountry\":\"US\"},\"telephone\":\"(757) 904-3612\",\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":5,\"reviewCount\":22},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":36.81246279999999,\"longitude\":-76.1390727}},{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/blue-dog-pet-grooming-pleasure-house\",\"name\":\"Blue Dog Pet Grooming - Pleasure House\",\"url\":\"ht