,\"div\",\"ChIJ-52hNWFfwYkRJtuWBdtaYFw\",{\"className\":\"mini-park-card\",\"children\":[[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"children\":\"PetSmart Dog Training\"}],[\"$\",\"span\",null,{\"children\":\"Dog Park\"}]]}],[\"$\",\"strong\",null,{\"children\":\"5.0\"}]]}]],false]}]]}],[\"$\",\"div\",null,{\"className\":\"map-sidebar-card muted\",\"children\":[\"$\",\"p\",null,{\"children\":\"Tip: tap any map marker to open directions, amenities, and current open hours.\"}]}]]}]]}]]}]}]\n39:[\"$\",\"section\",null,{\"id\":\"planning-essentials\",\"className\":\"planning-essentials-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell\",\"children\":[[\"$\",\"div\",null,{\"className\":\"section-heading\",\"children\":[[\"$\",\"span\",null,{\"className\":\"section-eyebrow\",\"children\":\"Visit toolkit\"}],[\"$\",\"h2\",null,{\"children\":[\"Plan the perfect dog outing in \",\"Hamilton Township\"]}],[\"$\",\"p\",null,{\"children\":\"Borrow best practices from local trainers, rangers, and experienced pet parents.\"}]]}],[\"$\",\"div\",null,{\"className\":\"planning-grid\",\"children\":[[\"$\",\"article\",\"Peak & quiet windows\",{\"className\":\"planning-card\",\"children\":[[\"$\",\"div\",null,{\"className\":\"planning-icon\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-clock-history\"}]}],[\"$\",\"h3\",null,{\"children\":\"Peak & quiet windows\"}],[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",\"6–9 AM: high energy social hour\",{\"children\":\"6–9 AM: high energy social hour\"}],[\"$\",\"li\",\"10 AM–3 PM weekdays: calm training-friendly window\",{\"children\":\"10 AM–3 PM weekdays: calm training-friendly window\"}],[\"$\",\"li\",\"After 4 PM: sunset crowd + cooler temps\",{\"children\":\"After 4 PM: sunset crowd + cooler temps\"}]]}]]}],[\"$\",\"article\",\"Essentials checklist\",{\"className\":\"planning-card\",\"children\":[[\"$\",\"div\",null,{\"className\":\"planning-icon\",\"children\":[\"$\",\"i\",null,{\"className\"