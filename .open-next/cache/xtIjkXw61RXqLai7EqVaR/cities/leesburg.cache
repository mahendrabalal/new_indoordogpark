el\":1},{\"id\":\"city-comparison\",\"title\":\"Top Comparisons\",\"level\":1},{\"id\":\"park-collections\",\"title\":\"Park Collections\",\"level\":1},{\"id\":\"neighborhood-clusters\",\"title\":\"Neighborhoods\",\"level\":1},{\"id\":\"park-types-guide\",\"title\":\"Park Type Guide\",\"level\":1},{\"id\":\"map-and-neighborhoods\",\"title\":\"Map & Neighborhoods\",\"level\":1},{\"id\":\"planning-essentials\",\"title\":\"Planning Essentials\",\"level\":1},{\"id\":\"expert-tips\",\"title\":\"Expert Advice\",\"level\":1},{\"id\":\"park-directory\",\"title\":\"Full Directory\",\"level\":1},{\"id\":\"owner-cta\",\"title\":\"Owner & Franchise\",\"level\":1},{\"id\":\"faq-section\",\"title\":\"FAQs\",\"level\":1},{\"id\":\"related-resources\",\"title\":\"More Resources\",\"level\":1}]}]\n2a:[\"$\",\"main\",null,{\"className\":\"city-page-layout\",\"children\":[[\"$\",\"div\",null,{\"className\":\"mobile-toc-button\",\"children\":[\"$\",\"$L2f\",null,{\"className\":\"mobile-toc-trigger\",\"targetSelector\":\".table-of-contents\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-list-ul\"}],[\"$\",\"span\",null,{\"children\":\"Contents\"}]]}]}],[\"$\",\"section\",null,{\"id\":\"city-hero\",\"className\":\"city-hero-section \",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell city-hero-shell\",\"children\":[[\"$\",\"div\",null,{\"className\":\"city-hero-copy\",\"children\":[[\"$\",\"div\",null,{\"className\":\"hero-breadcrumbs\",\"children\":[[\"$\",\"$L12\",null,{\"href\":\"/\",\"children\":\"Home\"}],[\"$\",\"i\",null,{\"className\":\"bi bi-chevron-right\"}],[\"$\",\"span\",null,{\"children\":\"Dog Parks Directory\"}],[\"$\",\"i\",null,{\"className\":\"bi bi-chevron-right\"}],[\"$\",\"strong\",null,{\"children\":\"Leesburg\"}]]}],[\"$\",\"p\",null,{\"className\":\"hero-eyebrow\",\"children\":\"Loudoun County Living\"}],[\"$\",\"h1\",null,{\"children\":\"Dog Parks in Leesburg, VA\"}],\"$undefined\",[\"$\",\"p\",null,{\"className\":\"hero-description\",\"children\":\"Discover historic charm and premium off-leash spaces in the heart of Virginia's most pet-friendly county. From dedicated runs to expansive nature trails.\"}],[\"$\",\"div\",null,{\"className\":\"city-rich-description\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"rich-description-paragraph\",\"children\":[\"Leesburg, VA, serves as a premier hub for dog owners in Northern Virginia, balancing its deep historical roots with modern pet infrastructure. The city is anchored by the \",[\"$\",\"$L12\",\"1\",{\"href\":\"https://www.leesburgva.gov/government/departments/parks-recreation/parks/olde-izaak-walton-park\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"rich-link\",\"children\":\"Leesburg Dog Park\"}],null,\" at Olde Izaak Walton Park, which provides a well-maintained off-leash environment with separate sections for small and large breeds. For those who prefer scenic exercise, the 1,000-acre \",[\"$\",\"$L12\",\"4\",{\"href\":\"https://www.morvenpark.org\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"rich-link\",\"children\":\"Morven Park\"}],null,\" offers an expansive network of trails where dogs can explore the rolling Loudoun County landscape. Our \",[\"$\",\"$L12\",\"7\",{\"href\":\"https://www.indoordogpark.org/states/virginia\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"rich-link\",\"children\":\"Virginia state directory\"}],null,\" verifies these locations, reflecting a community culture that treats pets as essential residents.\"]}],[\"$\",\"p\",\"1\",{\"className\":\"rich-description-paragraph\",\"children\":[\"Navigating local rules is straightforward in Leesburg, provided owners adhere to the strict licensing mandates of Loudoun County. All dogs four months or older must be licensed, a process that ensures up-to-date rabies protection for the entire canine community. Beyond the dedicated runs at \",[\"$\",\"$L12\",\"1\",{\"href\":\"https://www.loudoun.gov/parks\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"rich-link\",\"children\":\"Creighton West Dog Park\"}],null,\", the region is famous for its pet-friendly social scene, including wineries and breweries that welcome leashed companions to join their owners. Whether utilizing our \",[\"$\",\"$L12\",\"4\",{\"href\":\"https://www.indoordogpark.org/owner-resources\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"rich-link\",\"children\":\"owner resources\"}],null,\" for training tips or walking the historic brick sidewalks of downtown, Leesburg provides a safe, high-quality environment where every dog can thrive in the heart of Virginia's hunt country.\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-cta-row\",\"children\":[[\"$\",\"$L2f\",null,{\"className\":\"hero-cta primary\",\"targetId\":\"park-directory\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-list-check\"}],\"Browse directory\"]}],[\"$\",\"$L2f\",null,{\"className\":\"hero-cta ghost\",\"targetId\":\"map-and-neighborhoods\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-geo-alt\"}],\"Open map\"]}],[\"$\",\"$L12\",null,{\"href\":\"/list-your-park\",\"className\":\"hero-cta text-link\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-plus-circle\"}],\"Submit a park\"]}]]}],\"$L30\"]}],\"$L31\"]}]}],\"$L32\",\"$L33\",\"$L34\",\"$L35\",\"$L36\",\"$L37\",\"$L38\",\"$L39\",\"$L3a\",\"$L3b\",\"$L3c\",\"$L3d\"]}]\n2b:[\"$\",\"footer\",null,{\"className\":\"footer-new\",\"children\":[\"$\",\"div\",null,{\"className\":\"footer-container\",\"children\":[[\"$\",\"div\",null,{\"className\":\"footer-grid\",\"children\":[[\"$\",\"div\",null,{\"className\":\"footer-column\",\"children\":[[\"$\",\"h4\",null,{\"className\":\"footer-heading\",\"children\":\"IndoorDogPark\"}],[\"$\",\"ul\",null,{\"className\":\"footer-links\",\"children\":[[\"$\",\"li\",null,{\"children\":[\"$\",\"$L12\",null,{\"href\":\"/about\",\"children\":\"About us\"}]}],[\"$\",\"li\",null,{\