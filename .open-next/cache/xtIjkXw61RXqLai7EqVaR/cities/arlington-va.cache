ry\":\"planning\"}],\"supportCard\":\"$undefined\"}]}]}]\n3f:[\"$\",\"section\",null,{\"id\":\"related-resources\",\"className\":\"related-resources-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell\",\"children\":[[\"$\",\"div\",null,{\"className\":\"section-heading\",\"children\":[[\"$\",\"span\",null,{\"className\":\"section-eyebrow\",\"children\":\"Keep exploring\"}],[\"$\",\"h2\",null,{\"children\":\"More ways to plan\"}],[\"$\",\"p\",null,{\"children\":\"Browse statewide guides, submit a listing, or connect with our team.\"}]]}],[\"$\",\"div\",null,{\"className\":\"resources-grid\",\"children\":[[\"$\",\"$L12\",null,{\"href\":\"/\",\"className\":\"resource-card\",\"children\":[[\"$\",\"div\",null,{\"className\":\"resource-icon\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-globe\"}]}],[\"$\",\"h3\",null,{\"children\":\"California overview\"}],[\"$\",\"p\",null,{\"children\":\"See every city we cover plus statewide insights.\"}],[\"$\",\"i\",null,{\"className\":\"bi bi-arrow-up-right\"}]]}],[\"$\",\"$L12\",null,{\"href\":\"/contact\",\"className\":\"resource-card\",\"children\":[[\"$\",\"div\",null,{\"className\":\"resource-icon\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-chat-dots\"}]}],[\"$\",\"h3\",null,{\"children\":\"Ask the team\"}],[\"$\",\"p\",null,{\"children\":\"Need custom data or media assets? We’re here.\"}],[\"$\",\"i\",null,{\"className\":\"bi bi-arrow-up-right\"}]]}],[\"$\",\"$L12\",null,{\"href\":\"/list-your-park\",\"className\":\"resource-card\",\"children\":[[\"$\",\"div\",null,{\"className\":\"resource-icon\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-megaphone\"}]}],[\"$\",\"h3\",null,{\"children\":\"Feature your park\"}],[\"$\",\"p\",null,{\"children\":\"Upgrade to a featured listing and reach active pet parents.\"}],[\"$\",\"i\",null,{\"className\":\"bi bi-arrow-up-right\"}]]}],[\"$\",\"$L12\",null,{\"href\":\"/blog\",\"className\":\"resource-card\",\"children\":[[\"$\",\"div\",null