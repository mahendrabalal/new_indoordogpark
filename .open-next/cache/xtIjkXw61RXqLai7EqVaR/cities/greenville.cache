ning\":true,\"dangerouslySetInnerHTML\":{\"__html\":\"$2d\"}}]\n2e:T45a,{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Where can I walk my dog in Greenville, NC?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"The Greenville Greenway system, especially along the Tar River, is outstanding. River Park North also offers miles of hiking trails suitable for leashed dogs.\"}},{\"@type\":\"Question\",\"name\":\"Is there an off-leash dog park in Greenville?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes, the Greenville Off-Leash Dog Park includes separate areas for large and small dogs. It’s a great spot for socialization and exercise.\"}},{\"@type\":\"Question\",\"name\":\"Is the ECU campus dog-friendly?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"The East Carolina University campus is generally open to leashed dogs in outdoor areas. It’s a park-like setting perfect for a long weekend stroll.\"}},{\"@type\":\"Question\",\"name\":\"Are there dog-friendly breweries in Greenville?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes, Greenville has a growing brewery scene with spots like Uptown Brewing Company often welcoming dogs in their outdoor spaces.\"}}]}26:[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"suppressHydrationWarning\":true,\"dangerouslySetInnerHTML\":{\"__html\":\"$2e\"}}]\n27:[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"suppressHydrationWarning\":true,\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://www.indoordogpark.org/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Dog Parks Directory\\\",\\\"item\\\":\\\"https://www.indoordogpark.org/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Greenville\\\"}]}\"}}]\n28:[\"$\",\"$L11\",null,{\"variant\":\"light\"}]\n29:[\"$\",\"$L2f\",null,{\"items\":[{\"id\":\"city-hero\",\"title\":\"City Overview\",\"level\":1},{\"id\":\"city-insights\",\"title\":\"Quick Facts\",\"level\":1},{\"id\":\"city-comparison\",\"title\":\"Top Comparisons\",\"level\":1},{\"id\":\"park-collections\",\"title\":\"Park Collections\",\"level\":1},{\"id\":\"neighborhood-clusters\",\"title\":\"Neighborhoods\",\"level\":1},{\"id\":\"park-types-guide\",\"title\":\"Park Type Guide\",\"level\":1},{\"id\":\"map-and-neighborhoods\",\"title\":\"Map & Neighborhoods\",\"level\":1},{\"id\":\"planning-essentials\",\"title\":\"Planning Essentials\",\"level\":1},{\"id\":\"expert-tips\",\"title\":\"Expert Advice\",\"level\":1},{\"id\":\"park-directory\",\"title\":\"Full Directory\",\"level\":1},{\"id\":\"owner-cta\",\"title\":\"Owner & Franchise\",\"level\":1},{\"id\":\"faq-section\",\"title\":\"FAQs\",\"level\":1},{\"id\":\"related-resources\",\"title\":\"More Resources\",\"level\":1}]}]\n2a:[\"$\",\"main\",null,{\"className\":\"city-page-layout\",\"children\":[[\"$\",\"div\",null,{\"className\":\"mobile-toc-button\",\"children\":[\"$\",\"$L30\",null,{\"className\":\"mobile-toc-trigger\",\"targetSelector\":\".table-of-contents\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-list-ul\"}],[\"$\",\"span\",null,{\"children\":\"Contents\"}]]}]}],[\"$\",\"section\",null,{\"id\":\"city-hero\",\"className\":\"city-hero-section \",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell city-hero-shell\",\"children\":[[\"$\",\"div\",null,{\"className\":\"city-hero-copy\",\"children\":[[\"$\",\"div\",null,{\"className\":\"hero-breadcrumbs\",\"children\":[[\"$\",\"$L12\",null,{\"href\":\"/\",\"children\":\"Home\"}],[\"$\",\"i\",null,{\"className\":\"bi bi-chevron-right\"}],[\"$\",\"span\",null,{\"children\":\"Dog Parks Directory\"}],[\"$\",\"i\",null,{\"className\":\"bi bi-chevron-right\"}],[\"$\",\"strong\",null,{\"children\":\"Greenville\"}]]}],[\"$\",\"p\",null,{\"className\":\"hero-eyebrow\",\"children\":\"Emerald City\"}],[\"$\",\"h1\",null,{\"children\":\"Greenville Greenways\"}],[\"$\",\"div\",null,{\"className\":\"hero-chip-row\",\"children\":[[\"$\",\"div\",\"0\",{\"className\":\"hero-chip\",\"children\":[[\"$\",\"span\",null,{\"className\":\"chip-label\",\"children\":\"Greenway Miles\"}],[\"$\",\"span\",null,{\"className\":\"chip-value\",\"children\":\"9+\"}],\"$undefined\"]}],[\"$\",\"div\",\"1\",{\"className\":\"hero-chip\",\"children\":[[\"$\",\"span\",null,{\"className\":\"chip-label\",\"children\":\"Waterfront\"}],[\"$\",\"span\",null,{\"className\":\"chip-value\",\"children\":\"Yes\"}],\"$undefined\"]}]]}],[\"$\",\"p\",null,{\"className\":\"hero-description\",\"children\":\"Greenville embraces its riverfront location. The Tar River Greenway is a scenic highlight, and the dedicated off-leash park ensures that dogs have a safe place to socialize.\"}],[\"$\",\"div\",null,{\"className\":\"city-rich-description\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"rich-description-paragraph\",\"children\":[\"Greenville, North Carolina, widely known as the \\\"Emerald City,\\\" offers a lush, green environment that is perfect for dog owners. The centerpiece of the city’s recreational life is the \",[\"$\",\"$L12\",\"1\",{\"href\":\"https://www.greenvillenc.gov/government/recreation-parks/tar-river-greenway\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"rich-link\",\"children\":\"Tar River Greenway\"}],null,\", a scenic paved trail that meanders along the riverbank. It provides a peaceful, traffic-free route for long walks, allowing dogs to sniff the river breeze while owners enjoy the views. It connects major assets like the Town Common and the university area, making it a functional commuter route as well as a leisure destination.\"]}],[\"$\",\"p\",\"1\",{\"className\":\"rich-description-paragraph\",\"children\":[\"For off-leash fun, the Greenville Off-Leash Dog Park provides the necessary fenced space for high-energy play. It is a well-used community asset where dogs can socialize safely. Just across the river, River Park North offers a more rugged experience with unpaved hiking trails and ponds, perfect for a weekend nature immersion. As the home of East Carolina University, the town has a vibrant, youthful energy, and you will often see students studying on the Town Common with their dogs or jogging along the greenways. This blend of riverfront beauty and college-town activity makes Greenville a dynamic place to \",[\"$\",\"$L12\",\"1\",{\"href\":\"https://www.indoordogpark.org/\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"rich-link\",\"children\":\"be a dog owner\"}],null,\".\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-cta-row\",\"children\":[[\"$\",\"$L30\",null,{\"className\":\"hero-cta primary\",\"targetId\":\"park-directory\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-list-check\"}],\"Browse directory\"]}],[\"$\",\"$L30\",null,{\"className\":\"hero-cta ghost\",\"targetId\":\"map-and-neighborhoods\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-geo-alt\"}],\"Open map\"]}],[\"$\",\"$L12\",null,{\"href\":\"/list-your-park\",\"className\":\"hero-cta text-link\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-plus-circle\"}],\"Submit a park\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-footnotes\",\"children\":[[\"$\",\"span\",\"Tar River Greenway\",{\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-sparkles\"}],\" \",\"Tar River Greenway\"]}],[\"$\",\"span\",\"Off-Leash Park\",{\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-sparkles\"}],\" \",\"Off-Leash Park\"]}],\"$L31\"]}]]}],\"$L32\"]}]}],\"$L33\",\"$L34\",\"$L35\",\"$L36\",\"$L37\",\"$L38\",\"$undefined\",\"$L39\",\"$L3a\",\"$L3b\",\"$L3c\",\"$L3d\"]}]\n2b:[\"$\",\"footer\",null,{\"className\":\"footer-new\",\"children\":[\"$\",\"div\",null,{\"className\":\"footer-container\",\"children\":[[\"$\",\"di