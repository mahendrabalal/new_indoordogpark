:\"PostalAddress\",\"addressLocality\":\"Greenville\",\"addressRegion\":\"NC\",\"addressCountry\":\"US\"},\"image\":\"/images/parks/northcarolina/four-paws-inn/four-paws-inn-1.jpg\"}},{\"@type\":\"ListItem\",\"position\":10,\"item\":{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/green-springs-park\",\"name\":\"Green Springs Park\",\"url\":\"https://www.indoordogpark.org/parks/green-springs-park\",\"description\":\"North Carolina pet parents in Greenville choose Green Springs Park for premium care. This facility features spacious exercise zones, experienced and certified staff, offering pet care. Their services...\",\"address\":{\"@type\":\"PostalAddress\",\"addressLocality\":\"Greenville\",\"addressRegion\":\"NC\",\"addressCountry\":\"US\"},\"image\":\"/images/parks/northcarolina/green-springs-park/green-springs-park-1.jpg\"}}]}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Where can I walk my dog in Greenville, NC?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"The Greenville Greenway system, especially along the Tar River, is outstanding. River Park North also offers miles of hiking trails suitable for leashed dogs.\"}},{\"@type\":\"Question\",\"name\":\"Is there an off-leash dog park in Greenville?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes, the Greenville Off-Leash Dog Park includes separate areas for large and small dogs. It’s a great spot for socialization and exercise.\"}},{\"@type\":\"Question\",\"name\":\"Is the ECU campus dog-friendly?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"The East Carolina University campus is generally open to leashed dogs in outdoor areas. It’s a park-like setting perfect for a long weekend stroll.\"}},{\"@type\":\"Question\",\"name\":\"Are there dog-friendly breweries in Greenville?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes, Greenville has a growing brewery scene with spots like Uptown Brewing Company often welcoming dogs in their outdoor spaces.\"}}]}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://www.indoordogpark.org/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Dog Parks Directory\",\"item\":\"https://www.indoordogpark.org/\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Greenville\"}]}</script><header class=\"header header-visible  header-light\"><div class=\"header-container\"><div class=\"header-left\"><a class=\"logo\" href=\"/\"><img alt=\"Indoor Dog Park logo\" width=\"140\" height=\"40\" decoding=\"async\" data-nimg=\"1\" style=\"color:transparent;object-fit:contain;height:auto\" src=\"/images/logo/logo.png\"/></a></div><div class=\"header-center\"><nav class=\"header-nav\" aria-label=\"Main navigation\"><a class=\"header-nav-link\" href=\"/\">Browse Parks</a><div class=\"header-nav-item\"><button class=\"header-nav-link\" aria-haspopup=\"true\" aria-expanded=\"false\">Discover <i class=\"bi bi-chevron-down dropdown-icon \"></i></button><div class=\"header-dropdown \"><a class=\"header-dropdown-link\" href=\"/parks-with-bars\">Parks with Bars</a><a class=\"header-dropdown-link\" href=\"/training-facilities\">Training Facilities</a><a class=\"header-dropdown-link\" href=\"/how-it-works\">How It Works</a></div></div><div class=\"header-nav-item\"><button class=\"header-nav-link\" aria-haspopup=\"true\" aria-expanded=\"false\">Locations <i class=\"bi bi-chevron-down dropdown-icon \"></i></button><div class=\"header-dropdown \"><a class=\"header-dropdown-link\" href=\"/cities/san-francisco\">San Francisco</a><a class=\"header-dropdown-link\" href=\"/cities/los-angeles\">Los Angeles</a><a class=\"header-dropdown-link\" href=\"/cities/san-diego\">San Diego</a><a class=\"header-dropdown-link\" href=\"/cities/new-york\">New Yo