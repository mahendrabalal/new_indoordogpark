,\"@id\":\"https://www.indoordogpark.org/parks/buffaloe-road-dog-park\",\"name\":\"Buffaloe Road Dog Park\",\"url\":\"https://www.indoordogpark.org/parks/buffaloe-road-dog-park\",\"sameAs\":[\"https://www.raleighnc.gov/parks/content/ParksRec/Articles/Parks/BuffaloeRoad.html\"],\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"5908 Buffaloe Rd\",\"addressLocality\":\"Raleigh\",\"addressRegion\":\"NC\",\"postalCode\":\"27604\",\"addressCountry\":\"US\"},\"telephone\":\"(919) 996-3285\",\"image\":\"/images/parks/northcarolina/buffaloe-road-dog-park/buffaloe-road-dog-park-1.jpg\",\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":4.5,\"reviewCount\":62},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":35.836939,\"longitude\":-78.5360553}},{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/camp-bow-wow-north-raleigh\",\"name\":\"Camp Bow Wow North Raleigh\",\"url\":\"https://www.indoordogpark.org/parks/camp-bow-wow-north-raleigh\",\"sameAs\":[\"https://www.campbowwow.com/north-raleigh/\"],\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"8320 Litchford Rd # 120\",\"addressLocality\":\"Raleigh\",\"addressRegion\":\"NC\",\"postalCode\":\"27615\",\"addressCountry\":\"US\"},\"telephone\":\"(984) 468-8527\",\"image\":\"/images/parks/northcarolina/camp-bow-wow-north-raleigh/camp-bow-wow-north-raleigh-1.jpg\",\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":4.7,\"reviewCount\":24},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":35.8925872,\"longitude\":-78.5995789}},{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/carolina-pines-dog-park\",\"name\":\"Carolina Pines Dog Park\",\"url\":\"https://www.indoordogpark.org/parks/carolina-pines-dog-park\",\"sameAs\":[\"http://www.raleighnc.gov/parks/content/ParksRec/Articles/Parks/CarolinaPines.html\"],\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"2305 Lake Wheeler Rd\",\"addressLocality\":\"Ral