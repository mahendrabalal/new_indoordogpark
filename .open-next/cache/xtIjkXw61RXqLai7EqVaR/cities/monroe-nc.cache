obile-toc-button\",\"children\":[\"$\",\"$L2f\",null,{\"className\":\"mobile-toc-trigger\",\"targetSelector\":\".table-of-contents\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-list-ul\"}],[\"$\",\"span\",null,{\"children\":\"Contents\"}]]}]}],[\"$\",\"section\",null,{\"id\":\"city-hero\",\"className\":\"city-hero-section \",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell city-hero-shell\",\"children\":[[\"$\",\"div\",null,{\"className\":\"city-hero-copy\",\"children\":[[\"$\",\"div\",null,{\"className\":\"hero-breadcrumbs\",\"children\":[[\"$\",\"$L12\",null,{\"href\":\"/\",\"children\":\"Home\"}],[\"$\",\"i\",null,{\"className\":\"bi bi-chevron-right\"}],[\"$\",\"span\",null,{\"children\":\"Dog Parks Directory\"}],[\"$\",\"i\",null,{\"className\":\"bi bi-chevron-right\"}],[\"$\",\"strong\",null,{\"children\":\"Monroe\"}]]}],[\"$\",\"p\",null,{\"className\":\"hero-eyebrow\",\"children\":\"Union County Hub\"}],[\"$\",\"h1\",null,{\"children\":\"Monroe & More\"}],[\"$\",\"div\",null,{\"className\":\"hero-chip-row\",\"children\":[[\"$\",\"div\",\"0\",{\"className\":\"hero-chip\",\"children\":[[\"$\",\"span\",null,{\"className\":\"chip-label\",\"children\":\"Dog Park\"}],[\"$\",\"span\",null,{\"className\":\"chip-value\",\"children\":\"1\"}],\"$undefined\"]}],[\"$\",\"div\",\"1\",{\"className\":\"hero-chip\",\"children\":[[\"$\",\"span\",null,{\"className\":\"chip-label\",\"children\":\"Nearby Lake\"}],[\"$\",\"span\",null,{\"className\":\"chip-value\",\"children\":\"Yes\"}],\"$undefined\"]}]]}],[\"$\",\"p\",null,{\"className\":\"hero-description\",\"children\":\"As the county seat, Monroe offers history and hospitality. Sunset Park provides a dedicated space for play, while the surrounding county offers massive recreational lakes and trails.\"}],[\"$\",\"div\",null,{\"className\":\"city-rich-description\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"rich-description-paragraph\",\"children\":[\"Monroe, North Carolina, serves as the hub of Union County, blending a rich history with accessible recreation. For daily exercise and socialization, \",[\"$\",\"$L12\",\"1\",{\"href\":\"https://www.monroenc.org/Departments/Parks-Recreation/Parks-Facilities/Sunset-Park\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"rich-link\",\"children\":\"Sunset Park\"}],null,\" is the local favorite, featuring a dedicated dog park where residents gather to let their pets play off-leash. It is a convenient, well-maintained community asset. The downtown area offers a glimpse into the region’s past, with historic buildings and a slow-paced atmosphere that is perfect for a relaxed afternoon walk.\"]}],[\"$\",\"p\",\"1\",{\"className\":\"rich-description-paragraph\",\"children\":[\"Beyond the city limits, Monroe is the gateway to some of the region’s best outdoor assets, most notably Cane Creek Park. This expansive park, often compared to state parks in quality, offers miles of hiking trails around a large trophy bass lake. It is a destination for Monroe residents who want a true nature escape with their dogs. Whether sticking to the local amenities at Sunset Park or heading out for a day of hiking at Cane Creek, Monroe offers a solid foundation for a \",[\"$\",\"$L12\",\"1\",{\"href\":\"https://www.indoordogpark.org/\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"rich-link\",\"children\":\"dog-friendly lifestyle\"}],null,\".\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-cta-row\",\"children\":[[\"$\",\"$L2f\",null,{\"className\":\"hero-cta primary\",\"targetId\":\"park-directory\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-list-check\"}],\"Browse directory\"]}],[\"$\",\"$L2f\",null,{\"className\":\"hero-cta ghost\",\"targetId\":\"map-and-neighborhoods\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-geo-alt\"}],\"Open map\"]}],[\"$\",\"$L12\",null,{\"href\":\"/list-your-park\",\"className\":\"hero-cta text-link\",\"children\":[[\"$\",\"i\",null,{\"class