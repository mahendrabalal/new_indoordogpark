null,{\"type\":\"application/ld+json\",\"suppressHydrationWarning\":true,\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"FAQPage\\\",\\\"mainEntity\\\":[{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"Where is the dog park in Monroe, NC?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"Sunset Park features a designated dog park area, making it a convenient spot for off-leash play within the city limits.\\\"}},{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"Are there hiking trails near Monroe?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"Yes, nearby Cane Creek Park provides excellent hiking trails around a large lake. It’s a great spot for a day trip with your dog.\\\"}},{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"What is the leash law in Monroe?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"Monroe requires dogs to be on a leash and under control when off the owner’s property. This is strictly enforced in public parks.\\\"}},{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"Is downtown Monroe pet-friendly?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"The revitalized downtown area is becoming more pet-friendly, with walkable sidewalks and occasional events that welcome leashed dogs.\\\"}}]}\"}}]\n5:[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"suppressHydrationWarning\":true,\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://www.indoordogpark.org/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Dog Parks Directory\\\",\\\"item\\\":\\\"https://www.indoordogpark.org/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Monroe\\\"}]}\"}}]\n6:[\"$\