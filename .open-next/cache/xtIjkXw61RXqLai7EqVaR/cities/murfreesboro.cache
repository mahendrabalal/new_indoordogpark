nk\\\",\\\"children\\\":\\\"Mayday Brewery\\\"}],null,\\\", which welcomes all dogs regardless of size or breed to its tasting room and patio. The city has also hosted prestigious canine events like the Cynosport Dog Agility World Games. While Murfreesboro's outdoor amenities are impressive, Tennessee's summer heat and humidity can pose challenges. \\\",[\\\"$\\\",\\\"$L12\\\",\\\"4\\\",{\\\"href\\\":\\\"https://www.indoordogpark.org/\\\",\\\"target\\\":\\\"_blank\\\",\\\"rel\\\":\\\"noopener noreferrer\\\",\\\"className\\\":\\\"rich-link\\\",\\\"children\\\":\\\"Indoor Dog Park\\\"}],null,\\\" provides a vital climate-controlled alternative, ensuring Murfreesboro's large dog population can maintain their exercise routines safely and comfortably throughout the year.\\\"]}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"hero-cta-row\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L30\\\",null,{\\\"className\\\":\\\"hero-cta primary\\\",\\\"targetId\\\":\\\"park-directory\\\",\\\"children\\\":[[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-list-check\\\"}],\\\"Browse directory\\\"]}],[\\\"$\\\",\\\"$L30\\\",null,{\\\"className\\\":\\\"hero-cta ghost\\\",\\\"targetId\\\":\\\"map-and-neighborhoods\\\",\\\"children\\\":[[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-geo-alt\\\"}],\\\"Open map\\\"]}],[\\\"$\\\",\\\"$L12\\\",null,{\\\"href\\\":\\\"/list-your-park\\\",\\\"className\\\":\\\"hero-cta text-link\\\",\\\"children\\\":[[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-plus-circle\\\"}],\\\"Submit a park\\\"]}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"hero-footnotes\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",\\\"15+ verified spots\\\",{\\\"children\\\":[[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-sparkles\\\"}],\\\" \\\",\\\"15+ verified spots\\\"]}],\\\"$L31\\\"]}]]}],\\\"$L32\\\"]}]}],\\\"$L33\\\",\\\"$L34\\\",\\\"$L35\\\",\\\"$L36\\\",\\\"$L37\\\",\\\"$L38\\\",\\\"$undefined\\\",\\\"$L39\\\",\\\"$L3a\\\",\\\"$L3b\\\"