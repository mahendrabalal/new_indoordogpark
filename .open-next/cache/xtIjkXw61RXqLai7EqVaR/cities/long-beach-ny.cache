, and map locations.\"}],[\"$\",\"meta\",\"2\",{\"name\":\"application-name\",\"content\":\"Indoor Dog Park\"}],[\"$\",\"link\",\"3\",{\"rel\":\"author\",\"href\":\"https://www.indoordogpark.org\"}],[\"$\",\"meta\",\"4\",{\"name\":\"author\",\"content\":\"Indoor Dog Park Team\"}],[\"$\",\"meta\",\"5\",{\"name\":\"keywords\",\"content\":\"indoor dog park,dog play area,dog recreation,indoor dog facility,dog daycare,dog training,dog boarding,pet services,canine activities,off-leash dog areas,California dog parks,dog-friendly spaces\"}],[\"$\",\"meta\",\"6\",{\"name\":\"creator\",\"content\":\"Indoor Dog Park\"}],[\"$\",\"meta\",\"7\",{\"name\":\"publisher\",\"content\":\"Indoor Dog Park\"}],[\"$\",\"meta\",\"8\",{\"name\":\"robots\",\"content\":\"index, follow\"}],[\"$\",\"meta\",\"9\",{\"name\":\"googlebot\",\"content\":\"index, follow, max-video-preview:-1, max-image-preview:large, max-snippet:-1\"}],[\"$\",\"meta\",\"10\",{\"name\":\"category\",\"content\":\"Pet Services\"}],[\"$\",\"meta\",\"11\",{\"name\":\"theme-color\",\"content\":\"#7c3aed\"}],[\"$\",\"meta\",\"12\",{\"name\":\"msapplication-TileColor\",\"content\":\"#7c3aed\"}],[\"$\",\"meta\",\"13\",{\"name\":\"apple-mobile-web-app-capable\",\"content\":\"yes\"}],[\"$\",\"meta\",\"14\",{\"name\":\"apple-mobile-web-app-status-bar-style\",\"content\":\"black-translucent\"}],[\"$\",\"meta\",\"15\",{\"name\":\"apple-mobile-web-app-title\",\"content\":\"Indoor Dog Park\"}],[\"$\",\"meta\",\"16\",{\"name\":\"mobile-web-app-capable\",\"content\":\"yes\"}],[\"$\",\"link\",\"17\",{\"rel\":\"canonical\",\"href\":\"https://www.indoordogpark.org/cities/long-beach-ny\"}],[\"$\",\"meta\",\"18\",{\"name\":\"format-detection\",\"content\":\"telephone=no, address=no, email=no\"}],[\"$\",\"meta\",\"19\",{\"property\":\"og:title\",\"content\":\"Indoor Dog Parks in Long Beach, NY | Map & Reviews |...\"}],[\"$\",\"meta\",\"20\",{\"property\":\"og:description\",\"content\":\"Explore 8 dog-friendly spots in Long Beach including 8 i