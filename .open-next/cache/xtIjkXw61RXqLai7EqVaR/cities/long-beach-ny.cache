\"streetAddress\":\"1610 Ave Y\",\"addressLocality\":\"Long Beach\",\"addressRegion\":\"NY\",\"postalCode\":\"11235\",\"addressCountry\":\"US\"},\"telephone\":\"(718) 743-2147\",\"image\":\"/images/parks/newyork/petco/petco-1.jpg\",\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":4.3,\"reviewCount\":2348},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":40.58999319999999,\"longitude\":-73.9534595}},{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/pup-pup-ripkens-pampered\",\"name\":\"Pup Pup & Ripkens Pampered\",\"url\":\"https://www.indoordogpark.org/parks/pup-pup-ripkens-pampered\",\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"874 W Beech St\",\"addressLocality\":\"Long Beach\",\"addressRegion\":\"NY\",\"postalCode\":\"11561\",\"addressCountry\":\"US\"},\"telephone\":\"(516) 298-4674\",\"image\":\"/images/parks/newyork/pup-pup-ripkens-pampered/pup-pup-ripkens-pampered-1.jpg\",\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":5,\"reviewCount\":1},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":40.5859103,\"longitude\":-73.6904897}}]}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"ItemList\",\"@id\":\"https://www.indoordogpark.org/cities/long-beach-ny#itemlist\",\"name\":\"Dog Parks in Long Beach\",\"description\":\"Top-rated dog parks and facilities in Long Beach, NY\",\"numberOfItems\":7,\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"item\":{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/fluid-dynamics-aquarium-services-and-store\",\"name\":\"Fluid Dynamics Aquarium Services and Store\",\"url\":\"https://www.indoordogpark.org/parks/fluid-dynamics-aquarium-services-and-store\",\"description\":\"Fluid Dynamics Aquarium Services and Store has become the premier destination for Long Beach dog owners. This facility features heated spaces for cold New York winters, experienced and cert