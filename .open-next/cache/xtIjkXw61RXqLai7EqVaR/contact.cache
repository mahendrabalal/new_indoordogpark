1\" crossorigin=\"anonymous\"></script><link rel=\"preload\" href=\"https://www.googletagmanager.com/gtag/js?id=G-FR11969GE9\" as=\"script\"/><meta name=\"p:domain_verify\" content=\"0563fd1fc3dbf5ddf80e6b177ae94816\"/><link rel=\"preconnect\" href=\"https://fonts.googleapis.com\" crossorigin=\"anonymous\"/><link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin=\"anonymous\"/><link rel=\"preconnect\" href=\"https://images.unsplash.com\" crossorigin=\"anonymous\"/><link rel=\"preconnect\" href=\"https://cdn.jsdelivr.net\" crossorigin=\"anonymous\"/><link rel=\"dns-prefetch\" href=\"https://unpkg.com\"/><link rel=\"dns-prefetch\" href=\"https://www.googletagmanager.com\"/><link rel=\"dns-prefetch\" href=\"https://www.google-analytics.com\"/><link rel=\"preload\" href=\"/images/logo/logo.png\" as=\"image\" type=\"image/png\"/><link rel=\"manifest\" href=\"/manifest.json\"/><link rel=\"icon\" href=\"/favicon.ico.svg\" type=\"image/svg+xml\"/><link rel=\"alternate icon\" href=\"/icons/icon-192x192.png\" type=\"image/png\"/><link rel=\"apple-touch-icon\" href=\"/icons/icon-192x192.png\"/><meta name=\"theme-color\" content=\"#7c3aed\"/><meta name=\"next-size-adjust\" content=\"\"/><title>Contact Us | Indoor Dog Park Support &amp; Feedback | Indoor Dog Park</title><meta name=\"description\" content=\"Have questions about our dog park directory? Contact the IndoorDogPark team for support, park listings, or partnership inquiries. We respond within 24 hours.\"/><meta name=\"application-name\" content=\"Indoor Dog Park\"/><link rel=\"author\" href=\"https://www.indoordogpark.org\"/><meta name=\"author\" content=\"Indoor Dog Park Team\"/><meta name=\"keywords\" content=\"contact indoor dog park,customer support,list a dog park,report issue,partnership inquiries,feedback\"/><meta name=\"creator\" content=\"Indoor Dog Park\"/><meta name=\"publisher\" content=\"Indoor Dog Park\"/><meta name=\"robots\" content=\"index, follow\"/><meta name=\"googlebot\" content=\"index, follow, max-video-preview:-1, max-image-preview:large, max-snippet:-1\"/><meta name=\"category\" content=\"Pet Services\"/><meta name=\"theme-color\" content=\"#7c3aed\"/><meta name=\"msapplication-TileColor\" content=\"#7c3aed\"/><meta name=\"apple-mobile-web-app-capable\" content=\"yes\"/><meta name=\"apple-mobile-web-app-status-bar-style\" content=\"black-translucent\"/><meta name=\"apple-mobile-web-app-title\" content=\"Indoor Dog Park\"/><meta name=\"mobile-web-app-capable\" content=\"yes\"/><link rel=\"canonical\" href=\"https://www.indoordogpark.org/contact\"/><meta name=\"format-detection\" content=\"telephone=no, address=no, email=no\"/><meta property=\"og:title\" content=\"Contact Us | Indoor Dog Park\"/><meta property=\"og:description\" content=\"Get in touch with the IndoorDogPark team. We are here to help with directory listings, support, and partnerships.\"/><meta property=\"og:url\" content=\"https://www.indoordogpark.org/contact\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:site\" content=\"@indoordogpark\"/><meta name=\"twitter:creator\" content=\"@indoordogpark\"/><meta name=\"twitter:title\" content=\"Best Indoor Dog Parks in California | Indoor Dog Park\"/><meta name=\"twitter:description\" content=\"Find year-round indoor dog parks across California. Search by city, neighborhood, or zip to discover safe, climate-controlled play spaces for your dog.\"/><meta name=\"twitter:image\" content=\"https://www.indoordogpark.org/images/hero/hero.webp\"/><link rel=\"icon\" href=\"/favicon.ico.svg\" type=\"image/svg+xml\"/><link rel=\"icon\" href=\"/icons/icon-192x192.png\" sizes=\"192x192\" type=\"image/png\"/><link rel=\"apple-touch-icon\" href=\"/icons/icon-192x192.png\" sizes=\"192x192\" type=\"image/png\"/><script data-grow-initializer=\"\">!(function(){window.growMe||((window.growMe=function(e){window.growMe._.push(e);}),(window.growMe._=[]));var e=document.createElement(\"script\");(e.type=\"text/javascript\"),(e.src=\"https://faves.grow.me/main.js\"),(e.defer=!0),e.setAttribute(\"data-grow-faves-site-id\",\"U2l0ZTo2NWU3MDY3YS0wNzI0LTQ0NjktYTZmYS1iYzU0YWYzNWYzOTg=\");var t=document.getElementsByTagName(\"script\")[0];t.parentNode.insertBefore(e,t);})();</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"Organization\",\"name\":\"Indoor Dog Park\",\"url\":\"https://www.indoordogpark.org\",\"logo\":\"https://www.indoordogpark.org/images/logo/logo-512.png\",\"description\":\"California's premier directory for indoor dog parks, play areas, and dog-friendly facilities.\",\"sameAs\":[\"https://www.facebook.com/IndoorDogParkDirectory\",\"https://x.com/Indoordogp40934\",\"https://www.instagram.com/indoordogpark2025/\"],\"contactPoint\":{\"@type\":\"ContactPoint\",\"contactType\":\"Customer Service\",\"availableLanguage\":\"en\"}}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"WebSite\",\"name\":\"Indoor Dog Park\",\"url\":\"https://www.indoordogpark.org\",\"description\":\"Find the best indoor dog parks and facilities across California\",\"potentialAction\":{\"@type\":\"SearchAction\",\"target\":{\"@type\":\"EntryPoint\",\"urlTemplate\":\"https://www.indoordogpark.org/?search={search_term_string}\"},\"query-input\":\"required name=search_term_string\"}}</script><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body class=\"__className_8a4156\"><div hidden=\"\"><!--$--><!--/$--></div><!--$!--><template data-dgst=\"BAILOUT_TO_CLIENT_SIDE_RENDERING\"></template><!--/$--><div class=\"flex flex-col min-h-screen\"><header class=\"header header-visible  header-light\"><div class=\"header-container\"><div class=\"header-left\"><a class=\"logo\" href=\"/\"><img alt=\"Indoor Dog Park logo\" width=\"140\" height=\"40\" decoding=\"async\" data-nimg=\"1\" style=\"color:transparent;object-fit:contain;height:auto\" src=\"/images/logo/logo.png\"/></a></div><div class=\"header-center\"><nav class=\"header-nav\" aria-label=\"Main navigation\"><a class=\"header-nav-link\" href=\"/\">Browse Parks</a><div class=\"header-nav-item\"><button class=\"header-nav-link\" aria-haspopup=\"true\" aria-expanded=\"false\">Discover <i class=\"bi bi-chevron-down dropdown-icon \"></i></button><div class=\"header-dropdown \"><a class=\"header-dropdown-link\" href=\"/parks-with-bars\">Parks with Bars</a><a class=\"header-dropdown-link\" href=\"/training-facilities\">Training Facilities</a><a class=\"header-dropdown-link\" href=\"/how-it-works\">How It Works</a></div></div><div class=\"header-nav-item\"><button class=\"header-nav-link\" aria-haspopup=\"true\" aria-expanded=\"false\">Locations <i class=\"bi bi-chevron-down dropdown-icon \"></i></button><div class=\"header-dropdown \"><a class=\"header-dropdown-link\" href=\"/cities/san-francisco\">San Francisco</a><a class=\"header-dropdown-link\" href=\"/cities/los-angeles\">Los Angeles</a><a class=\"header-dropdown-link\" href=\"/cities/san-diego\">San Diego</a><a class=\"header-dropdown-link\" href=\"/cities/new-york\">New York</a><a class=\"header-dropdown-link\" href=\"/cities/seattle\">Seattle</a></div></div><a class=\"header-nav-link\" href=\"/about\">About</a><a class=\"header-nav-link\" href=\"/blog\">Blog</a></nav></div><div class=\"header-right\"><a class=\"header-link\" href=\"/contact\">Contact us</a><a class=\"header-link header-link-primary\" href=\"/list-your-park\">List your park</a><a class=\"header-link\" href=\"/signup\">Sign up</a><a class=\"header-link\" href=\"/login\">Log in</a><button class=\"menu-toggle\" aria-label=\"Toggle menu\" aria-expanded=\"false\"><i class=\"bi bi-list\"></i></button></div></div><div class=\"mobile-menu \" aria-hidden=\"true\"><a class=\"mobile-menu-item\" href=\"/\">Browse Parks</a><a class=\"mobile-menu-item\" href=\"/parks-with-bars\">Parks with Bars</a><a class=\"mobile-menu-item\" href=\"/training-facilities\">Training Facilities</a><a class=\"mobile-menu-item\" href=\"/how-it-works\">How It Works</a><a class=\"mobile-menu-item\" href=\"/blog\">Blog &amp; Guides</a><a class=\"mobile-menu-item\" href=\"/about\">About</a><a class=\"mobile-menu-item\" href=\"/contact\">Contact us</a><a class=\"mobile-menu-item\" href=\"/list-your-park\">List your park</a><a class=\"mobile-menu-item\" href=\"/signup\">Sign up</a><a class=\"mobile-menu-item\" href=\"/login\">Log in</a></div></header><main class=\"flex-1\"><section class=\"contact-hero\"><div class=\"contact-hero-content\"><h1>Get in Touch</h1><p>At IndoorDogPark, we’re committed to providing you with the most comprehensive directory of indoor dog parks and play areas. Whether you’re a dog owner looking for the perfect spot, a business owner wanting to list your facility, or have questions about our platform, we’re here to help. Our team typically responds within 24 hours. For the fastest response, please use the contact form below or email us directly.</p></div></section><section class=\"contact-main\"><div class=\"contact-container\"><div class=\"contact-grid\"><div class=\"contact-info-section\"><h2>Contact Information</h2><div class=\"contact-info-card\"><div class=\"contact-info-icon\"><i class=\"bi bi-envelope\"></i></div><div class=\"contact-info-content\"><h3>Email</h3><p><a href=\"mailto:media@indoordogpark.org\">media@indoordogpark.org</a></p></div></div><div class=\"contact-info-card\"><div class=\"contact-info-icon\"><i class=\"bi bi-clock\"></i></div><div class=\"contact-info-content\"><h3>Response Time</h3><p>Within 24 hours</p><p class=\"contact-info-subtitle\">Email is the fastest way to reach us</p></div></div><div class=\"contact-info-card\"><div class=\"contact-info-icon\"><i class=\"bi bi-info-circle\"></i></div><div class=\"contact-info-content\"><h3>What We Can Help With</h3><ul class=\"contact-help-list\"><li>Park listings and submissions</li><li>Directory information updates</li><li>Technical support</li><li>Partnership opportunities</li><li>General inquiries</li></ul></div></div><div class=\"contact-info-card\"><div class=\"contact-info-icon\"><i class=\"bi bi-share-fill\"></i></div><div class=\"contact-info-content\"><h3>Connect With Us</h3><div class=\"flex flex-wrap gap-4 mt-3\"><a href=\"https://x.com/Indoordogp40934\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"flex items-center gap-2 text-purple-600 hover:text-purple-700 font-medium\" aria-label=\"Follow us on X (Twitter)\"><i class=\"bi bi-twitter\"></i><span>X (Twitter)</span></a><a href=\"https://www.facebook.com/IndoorDogParkDirectory\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"flex items-center gap-2 text-purple-600 hover:text-purple-700 font-medium\" aria-label=\"Follow us on Facebook\"><i class=\"bi bi-facebook\"></i><span>Facebook</span></a><a href=\"https://www.instagram.com/indoordogpark2025/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"flex items-center gap-2 text-purple-600 hover:text-purple-700 font-medium\" aria-label=\"Follow us on Instagram\"><i class=\"bi bi-instagram\"></i><span>Instagram</span></a><a href=\"https://www.pinterest.com/indoordogpark/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"flex items-center gap-2 text-purple-600 hover:text-purple-700 font-medium\" aria-label=\"Follow us on Pinterest\"><i class=\"bi bi-pinterest\"></i><span>Pinterest</span></a><a href=\"https://digg.com/indoordogpark\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"flex items-center gap-2 text-purple-600 hover:text-purple-700 font-medium\" aria-label=\"Follow us on Digg\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"1em\" height=\"1em\" fill=\"currentColor\" class=\"bi\" viewBox=\"0 0 512 512\"><path d=\"M81.7 172.3l-81.7 0 0 174.4 132.7 0 0-250.7-51 0 0 76.3zm0 133.4l-30.8 0 0-92.3 30.8 0 0 92.3zM378.9 172.3l0 174.4 81.8 0 0 28.5-81.8 0 0 40.8 133.1 0 0-243.7-133.1 0zm81.8 133.4l-30.8 0 0-92.3 30.8 0 0 92.3zm-235.6 41l82.1 0 0 28.5-82.1 0 0 40.8 133.3 0 0-243.7-133.3 0 0 174.4zm51.2-133.3l30.8 0 0 92.3-30.8 0 0-92.3zM153.3 96l51.3 0 0 51-51.3 0 0-51zm0 76.3l51.3 0 0 174.4-51.3 0 0-174.4z\"></path></svg><span>Digg</span></a></div></div></div></div><div class=\"contact-form-section\"><h2>Send us a Message</h2><form class=\"contact-form\"><div class=\"form-group\"><label for=\"name\">Full Name *</label><input type=\"text\" id=\"name\" required=\"\" placeholder=\"John Doe\" name=\"name\" value=\"\"/></div><div class=\"form-group\"><label for=\"email\">Email Address *</label><input type=\"email\" id=\"email\" required=\"\" placeholder=\"you@example.com\" name=\"email\" value=\"\"/></div><div class=\"form-group\"><label for=\"phone\">Phone Number</label><input type=\"tel\" id=\"phone\" placeholder=\"(555) 123-4567\" name=\"phone\" value=\"\"/></div><div class=\"form-group\"><label for=\"category\">Category *</label><select id=\"category\" name=\"category\" required=\"\"><option value=\"general\" selected=\"\">General Inquiry</option><option value=\"support\">Technical Support</option><option value=\"partnership\">Partnership</option><option value=\"feedback\">Feedback</option><option value=\"report\">Report an Issue</option><option value=\"list-park\">List a Park</option></select></div><div class=\"form-group\"><label for=\"subject\">Subject *</label><input type=\"text\" id=\"subject\" required=\"\" placeholder=\"How can we help?\" name=\"subject\" value=\"\"/></div><div class=\"form-group\"><label for=\"message\">Message *</label><textarea id=\"message\" name=\"message\" required=\"\" rows=\"6\" placeholder=\"Tell us more about your inquiry...\"></textarea></div><button type=\"submit\" class=\"submit-button\"><i class=\"bi bi-send\"></i>Send Message</button></form></div></div></div></section><section class=\"contact-topics\"><div class=\"contact-container\"><h2 class=\"text-center\">What Can You Contact Us About?</h2><div class=\"contact-topics-grid\"><div class=\"contact-topic-card\"><h3>List Your Park</h3><p>Add your indoor dog park to our directory and reach thousands of dog owners. Select “List a Park” in the contact form to get started.</p></div><div class=\"contact-topic-card\"><h3>Report an Issue</h3><p>Found incorrect information or have a concern? Use the contact form and select “Report an Issue” to let us know.</p></div><div class=\"contact-topic-card\"><h3>Partnership Opportunities</h3><p>Interested in collaborating? Select “Partnership” in the contact form to discuss opportunities with our team.</p></div><div class=\"contact-topic-card\"><h3>Technical Support</h3><p>Experiencing issues with the website or app? Select “Technical Support” and we’ll help troubleshoot.</p></div><div class=\"contact-topic-card\"><h3>Feedback &amp; Suggestions</h3><p>Have ideas to improve IndoorDogPark? Select “Feedback” to share your thoughts and suggestions.</p></div><div class=\"contact-topic-card\"><h3>General Inquiries</h3><p>Have a question that doesn’t fit into other categories? Select “General Inquiry” and we’ll be happy to help.</p></div></div></div></section><section class=\"contact-faq\"><div class=\"contact-container\"><h2>Frequently Asked Questions</h2><div class=\"faq-grid\"><div class=\"faq-item\"><h3>What should I do if I find incorrect information about a park?</h3><p>Please use the contact form above and select “Report an Issue” as your category. Include details about which park and what information needs to be corrected.</p></div><div class=\"faq-item\"><h3>How can I list my dog park on IndoorDogPark?</h3><p>Select “List a Park” from the category dropdown in the contact form, or visit our dedicated <a href=\"/list-your-park\">listing page</a> for more information about the process.</p></div><div class=\"faq-item\"><h3>How long does it take to get a response?</h3><p>We typically respond to inquiries within 24 business hours. Please mark your message as urgent if you need a faster response.</p></div><div class=\"faq-item\"><h3>Do you offer partnership opportunities?</h3><p>Yes! We’re always interested in partnerships. Please select “Partnership” in the contact form to discuss potential collaboration opportunities.</p></div><div class=\"faq-item\"><h3>I’m having technical issues. How can I get help?</h3><p>Select “Technical Support” in the contact form and describe the issue in detail. Our support team will help troubleshoot as quickly as possible.</p></div><div class=\"faq-item\"><h3>Can I provide feedback or suggestions?</h3><p>We’d love to hear your ideas! Select “Feedback” in the contact form to share your thoughts on how we can improve IndoorDogPark.</p></div><div class=\"faq-item\"><h3>Can I request a park to be added if it’s not in the directory?</h3><p>Absolutely! Use the contact form and select “List a Park” or “General Inquiry” to request that we add a park to our directory.</p></div><div class=\"faq-item\"><h3>How do I update information about my listed park?</h3><p>Use the contact form and select “List a Park” or “Report an Issue” to request updates. Include the park name and the information that needs to be changed.</p></div></div></div></section><section class=\"contact-faq\" style=\"background-color:#f9fafb\"><div class=\"contact-container\"><h2 class=\"text-center mb-8\">You Might Also Like</h2><div class=\"grid grid-cols-1 md:grid-cols-3 gap-6\"><a class=\"bg-white p-6 rounded-lg shadow-sm hover:shadow-md transition-shadow\" href=\"/faq\"><h3 class=\"text-xl font-semibold text-gray-900 mb-2\">FAQ</h3><p class=\"text-gray-600\">Find answers to common questions about using our directory and finding the perfect indoor dog park for your pet.</p></a><a class=\"bg-white p-6 rounded-lg shadow-sm hover:shadow-md transition-shadow\" href=\"/list-your-park\"><h3 class=\"text-xl font-semibold text-gray-900 mb-2\">List Your Park</h3><p class=\"text-gray-600\">Add your dog park to our directory and reach thousands of dog owners searching for quality indoor play spaces.</p></a></div></div></section></main><footer class=\"footer-new\"><div class=\"footer-container\"><div class=\"footer-grid\"><div class=\"footer-column\"><h4 class=\"footer-heading\">IndoorDogPark</h4><ul class=\"footer-links\"><li><a href=\"/about\">About us</a></li><li><a href=\"/partners\">Partners</a></li></ul></div><div class=\"footer-column\"><h4 class=\"footer-heading\">Discover</h4><ul class=\"footer-links\"><li><a href=\"/\">Browse parks</a></li><li><a href=\"/how-it-works\">How it works</a></li><li><a href=\"/blog\">Blog</a></li></ul></div><div class=\"footer-column\"><h4 class=\"footer-heading\">Park Owners</h4><ul class=\"footer-links\"><li><a href=\"/list-your-park\">List your park</a></li><li><a href=\"/owner-resources\">Owner resources</a></li></ul></div><div class=\"footer-column\"><h4 class=\"footer-heading\">Support</h4><ul class=\"footer-links\"><li><a href=\"/contact\">Contact us</a></li><li><a href=\"/faq\">FAQ</a></li></ul></div><div class=\"footer-column col-span-full md:col-span-2 lg:col-span-1\"><h4 class=\"footer-heading\">Join the Pack</h4><p class=\"mb-4 text-sm text-white/70\">Get the latest indoor dog park news and updates.</p><div class=\"rounded-2xl border border-white/10 bg-white/5 p-4 backdrop-blur-sm\"><div class=\" w-full\"><div class=\"mb-4 flex p-1 rounded-xl relative bg-white/10 border border-white/15\" role=\"tablist\" aria-label=\"Newsletter audience\"><div class=\"absolute inset-y-1 w-[calc(50%-4px)] rounded-lg transition-all duration-300 ease-in-out bg-white shadow-sm left-1\" aria-hidden=\"true\"></div><button type=\"button\" class=\"relative z-10 w-1/2 py-2 text-sm font-semibold rounded-lg transition-colors duration-200 text-gray-900\" role=\"tab\" aria-selected=\"true\" aria-controls=\"_R_1qelubr5b_-panel\">Dog owner</button><button type=\"button\" class=\"relative z-10 w-1/2 py-2 text-sm font-semibold rounded-lg transition-colors duration-200 text-white/70 hover:text-white\" role=\"tab\" aria-selected=\"false\" aria-controls=\"_R_1qelubr5b_-panel\">Park owner</button></div><form class=\"relative transition-all duration-300\"><div id=\"_R_1qelubr5b_-panel\" role=\"tabpanel\"><div class=\"relative z-10\"><label for=\"newsletter-email-footer\" class=\"sr-only\">Your Email</label><div class=\"relative group focus-within:text-inherit\"><input id=\"newsletter-email-footer\" type=\"email\" placeholder=\"Enter your email address\" required=\"\" class=\"peer w-full rounded-xl border px-4 py-3 pr-11 text-sm transition-all duration-200 outline-none shadow-sm\n                                bg-white/10 border-white/15 text-white placeholder:text-white/50\n                                hover:border-white/25 focus:border-white/35 focus:ring-4 focus:ring-white/10\n                            \" name=\"email\" value=\"\"/><div class=\"absolute right-3 top-1/2 -translate-y-1/2 transition-colors text-white/60  group-hover:text-[#FF5722] peer-focus:text-[#FF5722]\"><i class=\"bi bi-envelope text-lg \"></i></div></div></div><div class=\"mt-4\"><button type=\"submit\" class=\"w-full rounded-xl bg-[#FF5722] px-5 py-3 text-sm font-semibold text-white shadow-sm transition-all hover:bg-[#E64A19] hover:shadow-md focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#FF5722]/25 disabled:cursor-not-allowed disabled:opacity-60\">Join the pack</button><p class=\"mt-3 text-center text-xs text-white/70\">We’ll only email you when we have something worth sharing. Unsubscribe anytime.</p></div></div></form></div></div></div></div><div class=\"footer-social\"><a href=\"https://x.com/Indoordogp40934\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Follow us on X (Twitter)\" title=\"Follow us on X (Twitter)\"><i class=\"bi bi-twitter\"></i></a><a href=\"https://www.facebook.com/IndoorDogParkDirectory\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Follow us on Facebook\" title=\"Follow us on Facebook\"><i class=\"bi bi-facebook\"></i></a><a href=\"https://www.instagram.com/indoordogpark2025/\" target=\"_blank\" 