our dog's stay at Dog Park today\",\"slug\":\"dog-park\",\"address\":\"302 W Parris Ave\",\"street\":\"302 W Parris Ave\",\"city\":\"High Point\",\"state\":\"NC\",\"zipCode\":\"27262\",\"full_address\":\"302 W Parris Ave, High Point, NC 27262, USA\",\"latitude\":35.9857035,\"longitude\":-80.0311389,\"googlePlaceId\":\"ChIJcU0nUgAJU4gRJAnCwVVyqMQ\",\"rating\":0,\"reviewCount\":0,\"userRatingsTotal\":0,\"pricing\":{\"pricingSource\":\"unknown\",\"isFree\":false},\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"dataQuality\":\"verified\",\"faqs\":[],\"amenities\":{},\"photos\":[{\"url\":\"/images/parks/northcarolina/dog-park/dog-park-1.jpg\",\"type\":\"photo\",\"source\":\"website\"},{\"url\":\"/images/parks/northcarolina/dog-park/dog-park-2.jpg\",\"type\":\"photo\",\"source\":\"website\"}],\"photo\":\"/images/parks/northcarolina/dog-park/dog-park-1.jpg\",\"source\":\"static\",\"listingType\":\"free\"}}],\"$L40\",\"$L41\",\"$L42\"]}],\"$L43\"]}]}]\n34:[\"$\",\"div\",null,{\"className\":\"bg-gradient-to-r from-purple-50 to-purple-100 py-12 mt-12\",\"children\":[\"$\",\"div\",null,{\"className\":\"container mx-auto px-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-3xl font-bold text-gray-900 mb-4\",\"children\":\"Explore These Cities\"}],[\"$\",\"p\",null,{\"className\":\"text-gray-600 mb-6\",\"children\":\"This article mentions the following cities. Discover dog parks and resources in these locations.\"}],[\"$\",\"div\",null,{\"className\":\"flex flex-wrap gap-3\",\"children\":[[\"$\",\"$L13\",\"los angeles\",{\"href\":\"/cities/los-angeles\",\"className\":\"inline-flex items-center px-4 py-2 bg-white text-purple-700 rounded-lg hover:bg-purple-50 transition-colors font-medium shadow-sm\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-geo-alt mr-2\"}],\"Los Angeles\"]}],[\"$\",\"$L13\",\"new york\",{\"href\":\"/cities/new-york-nj\",\"className\":\"inline-flex items-center px-4 py-2 bg-white text-purple-700 rounded-lg hover:bg-purple-50 trans