com. As an Amazon Associate I earn from qualifying purchases.\"}]}],[\"$\",\"div\",null,{\"className\":\"footer-bottom\",\"children\":[\"$L23\",\"$L24\"]}]]}]}]\n23:[\"$\",\"p\",null,{\"children\":\"© 2025 IndoorDogPark. All rights reserved\"}]\n24:[\"$\",\"div\",null,{\"className\":\"footer-bottom-links\",\"children\":[[\"$\",\"$L13\",null,{\"href\":\"/terms\",\"children\":\"Terms\"}],[\"$\",\"$L13\",null,{\"href\":\"/privacy\",\"children\":\"Privacy\"}],[\"$\",\"$L13\",null,{\"href\":\"/cookie-preferences\",\"children\":\"Cookie Preferences\"}]]}]\n1f:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n25:T745,{\n  \"@context\": \"https://schema.org\",\n  \"@type\": \"BlogPosting\",\n  \"headline\": \"Best Places to Have a Dog Birthday Party\",\n  \"description\": \"Planning a dog birthday party? Discover the best venues in 2026 from indoor dog parks to dog-friendly breweries. Complete guide with costs, planning tips, and venue comparison.\",\n  \"image\": [\n    {\n      \"@type\": \"ImageObject\",\n      \"url\": \"https://cdn.sanity.io/images/ruuprk8g/production/6a41d7b6558c765ae4a67906727a2f707a3a216b-1024x1024.webp?w=1200\",\n      \"width\": 1024,\n      \"height\": 1024\n    }\n  ],\n  \"datePublished\": \"2025-12-28T00:03:21.485Z\",\n  \"dateModified\": \"2025-12-28T16:45:39Z\",\n  \"author\": {\n    \"@type\": \"Person\",\n    \"name\": \"Mahendra Balal\",\n    \"image\": {\n      \"@type\": \"ImageObject\",\n      \"url\": \"https://cdn.sanity.io/images/ruuprk8g/production/fe569ca7a7aea456e6d846511889756220b0ff98-1029x579.jpg?rect=226,0,579,579&w=96&h=96\"\n    },\n    \"description\": \"Mahendra is a professional pet-specific content writer.\"\n  },\n  \"publisher\": {\n    \"@type\": \"Organization\",\n    \"name\": \"Indoor Dog Park\",\n    \"logo\": {\n      \"@type\": \"ImageObject\",\n      \"url\": \"https://www.indoordogpark.org/images/logo/logo.png\"