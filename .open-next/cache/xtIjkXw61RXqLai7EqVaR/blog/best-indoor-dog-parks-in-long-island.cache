k/dog-park-2.jpg\",\"type\":\"photo\",\"source\":\"website\"}],\"photo\":\"/images/parks/northcarolina/dog-park/dog-park-1.jpg\",\"source\":\"static\",\"listingType\":\"free\"}}]\n44:[\"$\",\"$L42\",\"ChIJubzB44LpU4gRZUSISya4nBA\",{\"park\":{\"id\":\"ChIJubzB44LpU4gRZUSISya4nBA\",\"name\":\"Dog Park\",\"businessType\":\"Indoor Dog Park\",\"description\":\"Dog Park has earned the trust of Salisbury residents. This facility features spacious exercise zones, North Carolina pet care professionals, offering pet care. Their services provides essential socialization for your pet. strategically positioned in Salisbury. Contact Dog Park today to schedule your dog's visit\",\"slug\":\"dog-park\",\"address\":\"1200 Salisbury Rd\",\"street\":\"1200 Salisbury Rd\",\"city\":\"Salisbury\",\"state\":\"NC\",\"zipCode\":\"27028\",\"full_address\":\"1200 Salisbury Rd, Mocksville, NC 27028, USA\",\"latitude\":35.8740971,\"longitude\":-80.55328569999999,\"googlePlaceId\":\"ChIJubzB44LpU4gRZUSISya4nBA\",\"website\":\"https://www.daviecountync.gov/1010/Dog-Parks\",\"rating\":4.5,\"reviewCount\":13,\"userRatingsTotal\":13,\"pricing\":{\"pricingSource\":\"unknown\",\"isFree\":false},\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"dataQuality\":\"verified\",\"openingHours\":{\"Monday\":\"5:00 AM – 8:00 PM\",\"Tuesday\":\"5:00 AM – 8:00 PM\",\"Wednesday\":\"5:00 AM – 8:00 PM\",\"Thursday\":\"5:00 AM – 8:00 PM\",\"Friday\":\"5:00 AM – 8:00 PM\",\"Saturday\":\"5:00 AM – 8:00 PM\",\"Sunday\":\"5:00 AM – 8:00 PM\"},\"faqs\":[],\"amenities\":{},\"photos\":[{\"url\":\"/images/parks/northcarolina/dog-park/dog-park-1.jpg\",\"type\":\"photo\",\"source\":\"website\"},{\"url\":\"/images/parks/northcarolina/dog-park/dog-park-2.jpg\",\"type\":\"photo\",\"source\":\"website\"}],\"photo\":\"/images/parks/northcarolina/dog-park/dog-park-1.jpg\",\"source\":\"static\",\"listingType\":\"free\"}}]\n45:[\"$\",\"$L42\",\"ChIJjTRUv2dB3YkRQ-c-P0e6ZNo\",{\"park\":{\"id\":\"ChIJjTRUv2dB3YkRQ-c-P0e6ZNo\",\"name\":\"Pet Pro\",\"businessType\":\"Indoor Dog Park\",\"description\":\"Pet Pro provides dependable care for Newburgh's furry friends. This facility features spacious exercise zones, New York pet care professionals, offering pet care. Their services creates a safe, climate-controlled environment. centrally located for Newburgh residents. Reach out to Pet Pro for a consultation\",\"slug\":\"pet-pro\",\"address\":\"1606 NY-82\",\"street\":\"1606 NY-82\",\"city\":\"Newburgh\",\"state\":\"NY\",\"zipCode\":\"12540\",\"full_address\":\"1606 NY-82, Lagrangeville, NY 12540, USA\",\"latitude\":41.6273104,\"longitude\":-73.77171009999999,\"googlePlaceId\":\"ChIJjTRUv2dB3YkRQ-c-P0e6ZNo\",\"phone\":\"(845) 226-8335\",\"rating\":4.4,\"reviewCount\":68,\"userRatingsTotal\":68,\"pricing\":{\"pricingSource\":\"unknown\",\"isFree\":false},\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"dataQuality\":\"verified\",\"openingHours\":{\"Monday\":\"9:00 AM – 7:00 PM\",\"Tuesday\":\"9:00 AM – 7:00 PM\",\"Wednesday\":\"9:00 AM – 7:00 PM\",\"Thursday\":\"9:00 AM – 7:00 PM\",\"Friday\":\"9:00 AM – 7:00 PM\",\"Saturday\":\"9:00 AM – 7:00 PM\",\"Sunday\":\"9:00 AM – 5:00 PM\"},\"faqs\":[],\"amenities\":{},\"photos\":[{\"url\":\"/images/parks/newyork/pet-pro/pet-pro-1.jpg\",\"type\":\"photo\",\"source\":\"website\"},{\"url\":\"/images/parks/newyork/pet-pro/pet-pro-2.jpg\",\"type\":\"photo\",\"source\":\"website\"}],\"photo\":\"/images/parks/newyork/pet-pro/pet-pro-1.jpg\",\"source\":\"static\",\"listingType\":\"free\"}}]\n46:[\"$\",\"div\",null,{\"className\":\"mt-8 text-center\",\"children\":[\"$\",\"$L13\",null,{\"href\":\"/\",\"className\":\"inline-flex items-center px-6 py-3 bg-purple-600 text-white rounded-md hover:bg-purple-700 transition-colors font-medium\",\"children\":\"Browse All Parks →\"}]}]\n","/blog/$d$slug/__PAGE__":"1:\"$Sreact.fragment\"\n9:I[43676,[\"8500\",\"static/chunks/8500-98e13bcce54aa7a0.js\",\"7828\",\"static/chunks/7828-fd723da158040787.js\",\"2365\",\"sta