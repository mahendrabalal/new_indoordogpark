174.4 132.7 0 0-250.7-51 0 0 76.3zm0 133.4l-30.8 0 0-92.3 30.8 0 0 92.3zM378.9 172.3l0 174.4 81.8 0 0 28.5-81.8 0 0 40.8 133.1 0 0-243.7-133.1 0zm81.8 133.4l-30.8 0 0-92.3 30.8 0 0 92.3zm-235.6 41l82.1 0 0 28.5-82.1 0 0 40.8 133.3 0 0-243.7-133.3 0 0 174.4zm51.2-133.3l30.8 0 0 92.3-30.8 0 0-92.3zM153.3 96l51.3 0 0 51-51.3 0 0-51zm0 76.3l51.3 0 0 174.4-51.3 0 0-174.4z\"}]}]}]]}],[\"$\",\"div\",null,{\"className\":\"mt-8 border-t border-white/10 pt-8 text-center\",\"children\":[\"$\",\"p\",null,{\"className\":\"text-sm text-white/50\",\"children\":\"IndoorDogPark is a participant in the Amazon Services LLC Associates Program, an affiliate advertising program designed to provide a means for sites to earn advertising fees by advertising and linking to Amazon.com. As an Amazon Associate I earn from qualifying purchases.\"}]}],[\"$\",\"div\",null,{\"className\":\"footer-bottom\",\"children\":[\"$L23\",\"$L24\"]}]]}]}]\n23:[\"$\",\"p\",null,{\"children\":\"© 2025 IndoorDogPark. All rights reserved\"}]\n24:[\"$\",\"div\",null,{\"className\":\"footer-bottom-links\",\"children\":[[\"$\",\"$L13\",null,{\"href\":\"/terms\",\"children\":\"Terms\"}],[\"$\",\"$L13\",null,{\"href\":\"/privacy\",\"children\":\"Privacy\"}],[\"$\",\"$L13\",null,{\"href\":\"/cookie-preferences\",\"children\":\"Cookie Preferences\"}]]}]\n1f:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n25:T867,{\n  \"@context\": \"https://schema.org\",\n  \"@type\": \"BlogPosting\",\n  \"headline\": \"Best Indoor Dog Parks in Long Island\",\n  \"description\": \"Long Island's weather extremes—from freezing winters to sweltering summers—make indoor dog parks essential for year-round canine exercise and socialization. This comprehensive guide explores Long Island's best indoor dog parks, including Earth Dog (the region's only public indoor park) and Fido Fitness Club, with real data, pricing, and practical advice for finding the perfect facility for your furry friend.\",\n  \"image\": [\n    {\n      \"@type\": \"ImageObject\",\n      \"url\": \"https://cdn.sanity.io/images/ruuprk8g/production/b02d668dc6813337755e359d20148bc4c5844c14-1184x864.webp?w=1200\",\n      \"width\": 1184,\n      \"height\": 864\n    }\n  ],\n  \"datePublished\": \"2025-12-04T20:43:51.198Z\",\n  \"dateModified\": \"2025-12-04T21:33:35Z\",\n  \"author\": {\n    \"@type\": \"Person\",\n    \"name\": \"Indoor Dog Park Directory Team\",\n    \"image\": {\n      \"@type\": \"ImageObject\",\n      \"url\": \"https://cdn.sanity.io/images/ruuprk8g/production/f849e70b92252c6a55db9775da309c7f4009a685-2000x832.png?rect=584,0,832,832&w=96&h=96\"\n    },\n    \"description\": \"Indoor dog park content management team\"\n  },\n  \"publisher\": {\n    \"@type\": \"Organization\",\n    \"name\": \"Indoor Dog Park\",\n    \"logo\": {\n      \"@type\": \"ImageObject\",\n      \"url\": \"https://www.indoordogpark.org/images/logo/logo.png\",\n      \"width\": 200,\n      \"height\": 60\n    },\n    \"url\": \"https://www.indoordogpark.org\"\n  },\n  \"mainEntityOfPage\": {\n    \"@type\": \"WebPage\",\n    \"@id\": \"https://www.indoordogpark.org/blog/best-indoor-dog-parks-in-long-island\"\n  },\n  \"url\": \"https://www.indoordogpark.org/blog/best-indoor-dog-parks-in-long-island\",\n  \"wordCount\": 3255,\n  \"timeRequired\": \"PT17M\",\n  \"inLanguage\": \"en-US\",\n  \"isPartOf\": {\n    \"@type\": \"Blog\",\n    \"name\": \"Indoor Dog Park Blog\",\n    \"url\": \"https://www.indoordogpark.org/blog\"\n  },\n  \"keywords\": \"indoor dog park, long island, new york, Pets care, indoor dog park, Climate control, indoor dog parks, dog parks, California, dog friendly, pet care, dog training\",\n  \"articleSection\": [\n    \"indoor dog park\"\n  ]\n}26:T689,{\"@context\":\"https://schema.org\",\"@type\":\"VideoObject\",\"name\":\"Best Indoor Dog Parks in Long Island\",\"description\":\"Long Island's weather extremes—from freezing winters to sweltering summers—make indoor dog parks essential for year-round canine exercise and socialization. This comprehensive guide explores Long Island's best indoor dog parks, including Earth Dog (the region's only public indoor park) and Fido Fitness Club, with real data, pricing, and practical advice for finding the perfect facility for your furry friend.\",\"thumbnailUrl\":\"https://cdn.sanity.io/images/ruuprk8g/production/b02d668dc6813337755e359d20148bc4c5844c14-1184x864.webp?w=1200\",\"thumbnail\":{\"@type\":\"ImageObject\",\"url\":\"https://cdn.sanity.io/images/ruuprk8g/production/b02d668dc6813337755e359d20148bc4c5844c14-1184x864.webp?w=1200\",\"width\":1280,\"height\":720},\"uploadDate\":\"2025-12-04T20:43:51.198Z\",\"publicationDate\":\"2025-12-04T20:43:51.198Z\",\"contentUrl\":\"https://www.youtube.com/watch?v=c3mrjycuc58\",\"embedUrl\":\"https://www.youtube.com/embed/c3mrjycuc58\",\"interactionStatistic\":{\"@type\":\"InteractionCounter\",\"interactionType\":\"https://schema.org/WatchAction\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"Indoor Dog Park\",\"url\":\"https://www.indoordogpark.org\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://www.indoordogpark.org/images/logo/logo.png\",\"width\":200,\"height\":60}},\"isPartOf\":{\"@type\":\"BlogPosting\",\"@id\":\"https://www.indoordogpark.org/blog/best-indoor-dog-parks-in-long-island\"},\"potentialAction\":{\"@type\":\"WatchAction\",\"target\":\"https://www.youtube.com/watch?v=c3mrjycuc58\"},\"inLanguage\":\"en-US\",\"requiresSubscription\":false,\"isAccessibleForFree\":true,\"isFamilyFriendly\":true}1a:[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"$25\"}}],[[\"$\",\"script\",\"video-0\",{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"$26\"}}]],\"$L27\",\"$L28\",\"$L29\",\"$L2a\"]\n1d:null\n21:[[\"$\",\"title\",\"0\",{\"children\":\"Best Indoor Dog Parks in Long Island | Indoor Dog Park\"}],[\"$\",\"m