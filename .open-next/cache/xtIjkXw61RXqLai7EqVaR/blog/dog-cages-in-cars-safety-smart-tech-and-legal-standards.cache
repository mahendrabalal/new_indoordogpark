unt\":5,\"userRatingsTotal\":5,\"pricing\":{\"pricingSource\":\"unknown\",\"isFree\":false},\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"dataQuality\":\"verified\",\"openingHours\":{\"Monday\":\"Open 24 hours\",\"Tuesday\":\"Open 24 hours\",\"Wednesday\":\"Open 24 hours\",\"Thursday\":\"Open 24 hours\",\"Friday\":\"Open 24 hours\",\"Saturday\":\"Open 24 hours\",\"Sunday\":\"Open 24 hours\"},\"faqs\":[],\"amenities\":{},\"photos\":[{\"url\":\"/images/parks/northcarolina/dog-park/dog-park-1.jpg\",\"type\":\"photo\",\"source\":\"website\"},{\"url\":\"/images/parks/northcarolina/dog-park/dog-park-2.jpg\",\"type\":\"photo\",\"source\":\"website\"}],\"photo\":\"/images/parks/northcarolina/dog-park/dog-park-1.jpg\",\"source\":\"static\",\"listingType\":\"free\"}}]\n3f:[\"$\",\"$L3d\",\"ChIJubzB44LpU4gRZUSISya4nBA\",{\"park\":{\"id\":\"ChIJubzB44LpU4gRZUSISya4nBA\",\"name\":\"Dog Park\",\"businessType\":\"Indoor Dog Park\",\"description\":\"Dog Park has earned the trust of Salisbury residents. This facility features spacious exercise zones, North Carolina pet care professionals, offering pet care. Their services provides essential socialization for your pet. strategically positioned in Salisbury. Contact Dog Park today to schedule your dog's visit\",\"slug\":\"dog-park\",\"address\":\"1200 Salisbury Rd\",\"street\":\"1200 Salisbury Rd\",\"city\":\"Salisbury\",\"state\":\"NC\",\"zipCode\":\"27028\",\"full_address\":\"1200 Salisbury Rd, Mocksville, NC 27028, USA\",\"latitude\":35.8740971,\"longitude\":-80.55328569999999,\"googlePlaceId\":\"ChIJubzB44LpU4gRZUSISya4nBA\",\"website\":\"https://www.daviecountync.gov/1010/Dog-Parks\",\"rating\":4.5,\"reviewCount\":13,\"userRatingsTotal\":13,\"pricing\":{\"pricingSource\":\"unknown\",\"isFree\":false},\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"dataQuality\":\"verified\",\"openingHours\":{\"Monday\":\"5:00 AM – 8:00 PM\",\"Tuesday\":\"5:00 AM – 8:00 PM\",\"Wednesday\":\"5:00 AM – 8:00 PM\",\"Thursday\":