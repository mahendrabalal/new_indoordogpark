eferences\",\"children\":\"Cookie Preferences\"}]]}]\n1f:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n25:T840,{\n  \"@context\": \"https://schema.org\",\n  \"@type\": \"BlogPosting\",\n  \"headline\": \"Top 5 Best Indoor Dog Parks in Seattle\",\n  \"description\": \"Discover the top indoor dog parks in Seattle to beat the infamous rain. Complete latest guide to pricing, rules, and vibes for Dogwood, Growlerz, and more.\",\n  \"image\": [\n    {\n      \"@type\": \"ImageObject\",\n      \"url\": \"https://cdn.sanity.io/images/ruuprk8g/production/1b2c39b52dd2c728ce0ac966c542dedd9af6d333-1024x1024.webp?w=1200\",\n      \"width\": 1024,\n      \"height\": 1024\n    }\n  ],\n  \"datePublished\": \"2025-12-31T16:47:46.938Z\",\n  \"dateModified\": \"2025-12-31T17:04:45Z\",\n  \"author\": {\n    \"@type\": \"Person\",\n    \"name\": \"Sabita Thapa Magar\",\n    \"image\": {\n      \"@type\": \"ImageObject\",\n      \"url\": \"https://cdn.sanity.io/images/ruuprk8g/production/8b9bc312bf6976abfde95125f9833be6aabf42e0-1152x2048.jpg?rect=0,448,1152,1152&w=96&h=96\"\n    },\n    \"description\": \"Sabita Thapa Magar writes articles for indoordogpark.org, sharing useful insights and practical information for dog owners. She enjoys creating content that helps readers better understand and care for their dogs while promoting safe and fun indoor play environments.\"\n  },\n  \"publisher\": {\n    \"@type\": \"Organization\",\n    \"name\": \"Indoor Dog Park\",\n    \"logo\": {\n      \"@type\": \"ImageObject\",\n      \"url\": \"https://www.indoordogpark.org/images/logo/logo.png\",\n      \"width\": 200,\n      \"height\": 60\n    },\n    \"url\": \"https://www.indoordogpark.org\"\n  },\n  \"mainEntityOfPage\": {\n    \"@type\": \"WebPage\",\n    \"@id\": \"https://www.indoordogpark.org/blog/top-5-best-indoor-dog-parks-in-seattle\"\n  },\n  \"url\": \"https://www.indoordogpark.org/blog/top-5-best-indoor-dog-parks-in-seattle\",\n  \"wordCount\": 980,\n  \"timeRequired\": \"PT5M\",\n  \"inLanguage\": \"en-US\",\n  \"isPartOf\": {\n    \"@type\": \"Blog\",\n    \"name\": \"Indoor Dog Park Blog\",\n    \"url\": \"https://www.indoordogpark.org/blog\"\n  },\n  \"keywords\": \"Dog Recreation, Dog Daycare, indoor dog park, Climate control, indoor dog parks, dog parks, California, dog friendly, pet care, dog training\",\n  \"articleSection\": [\n    \"Dog Recreation\",\n    \"Dog Daycare\"\n  ]\n}1a:[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"$25\"}}],false,[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\n  \\\"@context\\\": \\\"https://schema.org\\\",\\n  \\\"@type\\\": \\\"BreadcrumbList\\\",\\n  \\\"itemListElement\\\": [\\n    {\\n      \\\"@type\\\": \\\"ListItem\\\",\\n      \\\"position\\\": 1,\\n      \\\"name\\\": \\\"Home\\\",\\n      \\\"item\\\": \\\"https://www.indoordogpark.org/\\\"\\n    },\\n    {\\n      \\\"@type\\\": \\\"ListItem\\\",\\n      \\\"position\\\": 2,\\n      \\\"name\\\": \\\"Blog\\\",\\n      \\\"item\\\": \\\"https://www.indoordogpark.org/blog\\\"\\n    },\\n    {\\n      \\\"@type\\\": \\\"ListItem\\\",\\n      \\\"position\\\": 3,\\n      \\\"name\\\": \\\"Dog Recreation\\\",\\n      \\\"item\\\": \\\"https://www.indoordogpark.org/blog/category/dog-recreation\\\"\\n    },\\n    {\\n      \\\"@type\\\": \\\"ListItem\\\",\\n      \\\"position\\\": 4,\\n      \\\"name\\\": \\\"Top 5 Best Indoor Dog Parks in Seattle\\\",\\n      \\\"item\\\": \\\"https://www.indoordogpark.org/blog/top-5-best-indoor-dog-parks-in-seattle\\\"\\n    }\\n  ]\\n}\"}}],[\"$\",\"$L12\",null,{\"variant\":\"light\"}],[\"$\",\"div\",null,{\"className\":\"min-h-screen bg-white\",\"children\":[[\"$\",\"div\",null,{\"className\":\"border-b border-gray-200 bg-white\",\"children\":[\"$\",\"div\",null,{\"className\":\"container mx-auto px-4 py-4