{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/blog/layout,_N_T_/blog/[slug]/layout,_N_T_/blog/[slug]/page,_N_T_/blog/top-5-best-indoor-dog-parks-in-seattle,blog-posts,blog-post-top-5-best-indoor-dog-parks-in-seattle,blog-list"},"segmentPaths":["/_tree","/_full","/blog/$d$slug/__PAGE__","/blog/$d$slug","/blog","/_index","/_head"]},"html":"<!DOCTYPE html><!--xtIjkXw61RXqLai7EqVaR--><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/e4af272ccee01ff0-s.p.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/images/logo/logo.png\" as=\"image\" type=\"image/png\"/><link rel=\"preload\" as=\"image\" href=\"https://cdn.sanity.io/images/ruuprk8g/production/1b2c39b52dd2c728ce0ac966c542dedd9af6d333-1024x1024.webp?w=1200\"/><link rel=\"stylesheet\" href=\"/_next/static/css/6aa7df2bae588751.css\" data-precedence=\"next\"/><link rel=\"stylesheet\" href=\"/_next/static/css/f4aeb25f618e7857.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/webpack-4879435cea3ede45.js\"/><script src=\"/_next/static/chunks/4bd1b696-10cb4c9d2844a506.js\" async=\"\"></script><script src=\"/_next/static/chunks/3794-c66343cd6a42366f.js\" async=\"\"></script><script src=\"/_next/static/chunks/main-app-1be938be5fb87de1.js\" async=\"\"></script><script src=\"/_next/static/chunks/8500-98e13bcce54aa7a0.js\" async=\"\"></script><script src=\"/_next/static/chunks/7828-fd723da158040787.js\" async=\"\"></script><script src=\"/_next/static/chunks/2365-40fbe64639b5ecd9.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/layout-1946b3c57b55ecba.js\" async=\"\"></script><script async=\"\" src=\"https://pagead2.googlesyndication.com/pagea