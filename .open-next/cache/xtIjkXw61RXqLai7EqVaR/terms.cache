{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/terms/layout,_N_T_/terms/page,_N_T_/terms"},"segmentPaths":["/_tree","/_full","/terms/__PAGE__","/terms","/_index","/_head"]},"html":"<!DOCTYPE html><!--xtIjkXw61RXqLai7EqVaR--><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/e4af272ccee01ff0-s.p.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/images/logo/logo.png\" as=\"image\" type=\"image/png\"/><link rel=\"preload\" as=\"image\" imageSrcSet=\"/_next/image?url=%2Fimages%2Fterms%2Fhero-indoor-dog-park.jpeg&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fimages%2Fterms%2Fhero-indoor-dog-park.jpeg&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fimages%2Fterms%2Fhero-indoor-dog-park.jpeg&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fimages%2Fterms%2Fhero-indoor-dog-park.jpeg&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fimages%2Fterms%2Fhero-indoor-dog-park.jpeg&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fimages%2Fterms%2Fhero-indoor-dog-park.jpeg&amp;w=1920&amp;q=75 1920w\" imageSizes=\"(max-width: 768px) 100vw, 896px\"/><link rel=\"stylesheet\" href=\"/_next/static/css/6aa7df2bae588751.css\" data-precedence=\"next\"/><link rel=\"stylesheet\" href=\"/_next/static/css/f4aeb25f618e7857.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/webpack-4879435cea3ede45.js\"/><script src=\"/_next/static/chunks/4bd1b696-10cb4c9d2844a506.js\" async=\"\"></script><script src=\"/_next/static/chunks/3794-c66343cd6a42366f.js\" async=\"\"></script><script src=\"/_next/static/chunks/main-app-1be938be5fb87de1.js\" async=\"\"></script><script src=\"/_next/static/chunks/8500-98e13bcce54aa7a0.js\" async=\"\"></script><scri