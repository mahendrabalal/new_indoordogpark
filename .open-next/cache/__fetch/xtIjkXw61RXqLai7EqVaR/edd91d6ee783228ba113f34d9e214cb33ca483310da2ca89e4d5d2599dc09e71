=\\\"http://www.w3.org/2000/svg\\\">\\n  <!-- Title -->\\n  <text x=\\\"300\\\" y=\\\"30\\\" text-anchor=\\\"middle\\\" font-size=\\\"18\\\" font-weight=\\\"bold\\\" fill=\\\"#333\\\">Average Daily Rates by Service Type</text>\\n  \\n  <!-- Horizontal bars -->\\n  <!-- Daycare -->\\n  <rect x=\\\"100\\\" y=\\\"80\\\" width=\\\"200\\\" height=\\\"40\\\" fill=\\\"#8B5CF6\\\" rx=\\\"4\\\"/>\\n  <text x=\\\"110\\\" y=\\\"105\\\" font-size=\\\"14\\\" fill=\\\"#fff\\\">Daycare: $40-65/day</text>\\n  \\n  <!-- Boarding -->\\n  <rect x=\\\"100\\\" y=\\\"140\\\" width=\\\"280\\\" height=\\\"40\\\" fill=\\\"#EC4899\\\" rx=\\\"4\\\"/>\\n  <text x=\\\"110\\\" y=\\\"165\\\" font-size=\\\"14\\\" fill=\\\"#fff\\\">Boarding: $60-90/night</text>\\n  \\n  <!-- Grooming -->\\n  <rect x=\\\"100\\\" y=\\\"200\\\" width=\\\"150\\\" height=\\\"40\\\" fill=\\\"#10B981\\\" rx=\\\"4\\\"/>\\n  <text x=\\\"110\\\" y=\\\"225\\\" font-size=\\\"14\\\" fill=\\\"#fff\\\">Grooming: $50-100</text>\\n  \\n  <!-- Training -->\\n  <rect x=\\\"100\\\" y=\\\"260\\\" width=\\\"180\\\" height=\\\"40\\\" fill=\\\"#F59E0B\\\" rx=\\\"4\\\"/>\\n  <text x=\\\"110\\\" y=\\\"285\\\" font-size=\\\"14\\\" fill=\\\"#fff\\\">Training: $80-150/session</text>\\n  \\n  <!-- X-axis scale -->\\n  <line x1=\\\"100\\\" y1=\\\"320\\\" x2=\\\"500\\\" y2=\\\"320\\\" stroke=\\\"#666\\\" stroke-width=\\\"2\\\"/>\\n  <text x=\\\"100\\\" y=\\\"340\\\" text-anchor=\\\"middle\\\" font-size=\\\"12\\\" fill=\\\"#666\\\">$0</text>\\n  <text x=\\\"200\\\" y=\\\"340\\\" text-anchor=\\\"middle\\\" font-size=\\\"12\\\" fill=\\\"#666\\\">$50</text>\\n  <text x=\\\"300\\\" y=\\\"340\\\" text-anchor=\\\"middle\\\" font-size=\\\"12\\\" fill=\\\"#666\\\">$100</text>\\n  <text x=\\\"400\\\" y=\\\"340\\\" text-anchor=\\\"middle\\\" font-size=\\\"12\\\" fill=\\\"#666\\\">$150</text>\\n  <text x=\\\"500\\\" y=\\\"340\\\" text-anchor=\\\"middle\\\" font-size=\\\"12\\\" fill=\\\"#666\\\">$200</text>\\n  \\n  <!-- Note -->\\n  <text x=\\\"300\\\" y=\\\"370\\\" text-anchor=\\\"middle\\\" font-size=\\\"11\\\" fill=\\\"#666\\\" font-style=\\\"italic\\\">*Prices vary by location, dog size, and package deals</text>\\n</svg>\\n</div>\\n<ul><li>Amenities Comparison Chart</li></ul>\\n<p>Most facilities offer indoor play and daycare as core services. Full-service facilities like Biscuits & Bath provide the most comprehensive offerings, while specialized facilities focus on specific services.</p>\\n<div style=\\\"width: 100%; max-width: 700px; margin: 2rem auto;\\\">\\n<svg viewBox=\\\"0 0 700 500\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\">\\n  <!-- Title -->\\n  <text x=\\\"350\\\" y=\\\"30\\\" text-anchor=\\\"middle\\\" font-size=\\\"18\\\" font-weight=\\\"bold\\\" fill=\\\"#333\\\">Common Amenities at NYC Indoor Dog Parks</text>\\n  \\n  <!-- Facility names -->\\n  <text x=\\\"20\\\" y=\\\"80\\\" font-size=\\\"12\\\" font-weight=\\\"bold\\\" fill=\\\"#333\\\">Fetch Club</text>\\n  <text x=\\\"20\\\" y=\\\"120\\\" font-size=\\\"12\\\" font-weight=\\\"bold\\\" fill=\\\"#333\\\">Biscuits & Bath</text>\\n  <text x=\\\"20\\\" y=\\\"160\\\" font-size=\\\"12\\\" font-weight=\\\"bold\\\" fill=\\\"#333\\\">Camp Canine</text>\\n  <text x=\\\"20\\\" y=\\\"200\\\" font-size=\\\"12\\\" font-weight=\\\"bold\\\" fill=\\\"#333\\\">Paws in Chelsea</text>\\n  <text x=\\\"20\\\" y=\\\"240\\\" font-size=\\\"12\\\" font-weight=\\\"bold\\\" fill=\\\"#333\\\">Happy Dogs</text>\\n  <text x=\\\"20\\\" y=\\\"280\\\" font-size=\\\"12\\\" font-weight=\\\"bold\\\" fill=\\\"#333\\\">Wag Club</text>\\n  \\n  <!-- Amenity columns -->\\n  <text x=\\\"150\\\" y=\\\"60\\\" text-anchor=\\\"middle\\\" font-size=\\\"11\\\" fill=\\\"#666\\\">Indoor Play</text>\\n  <text x=\\\"220\\\" y=\\\"60\\\" text-anchor=\\\"middle\\\" font-size=\\\"11\\\" fill=\\\"#666\\\">Daycare</text>\\n  <text x=\\\"290\\\" y=\\\"60\\\" text-anchor=\\\"middle\\\" font-size=\\\"11\\\" fill=\\\"#666\\\">Boarding</text>\\n  <text x=\\\"360\\\" y=\\\"60\\\" text-anchor=\\\"middle\\\" 