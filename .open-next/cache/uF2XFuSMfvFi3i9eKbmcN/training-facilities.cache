_address\":\"1205 Laurelwood Rd, Santa Clara, CA 95054\",\"latitude\":37.379721499999995,\"longitude\":-121.9537485,\"googlePlaceId\":\"ChIJk2t8JYfJj4ARu8x2Z2zoe5A\",\"phone\":\"(408) 988-3118\",\"website\":\"http://apetvilla.com/\",\"photos\":null,\"rating\":4.7,\"reviewCount\":315,\"pricing\":{\"pricingSource\":\"website\",\"isFree\":false},\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"lastUpdated\":null,\"dataQuality\":\"verified\",\"photo\":null,\"faqs\":[{\"question\":\"What should I bring for check-in at A Pet Villa Dog Boarding and Grooming?\",\"answer\":\"Bring proof of current rabies and core vaccinations, a leash for entry and exit, and an ID tag with up-to-date contact info to breeze through check-in at A Pet Villa Dog Boarding and Grooming. Download the waiver from http://apetvilla.com/ and submit your dog profile before your visit.\",\"lastUpdated\":\"2025-11-14T19:36:02.813163+00:00\"},{\"question\":\"How does pricing work at A Pet Villa Dog Boarding and Grooming?\",\"answer\":\"A Pet Villa Dog Boarding and Grooming offers flexible memberships and punch cards so you can tailor visits to your routine. Contact the desk for the latest promotions or multi-dog discounts.\",\"lastUpdated\":\"2025-11-14T19:36:02.813163+00:00\"},{\"question\":\"Which amenities does A Pet Villa Dog Boarding and Grooming offer?\",\"answer\":\"The team rotates toys, agility props, and splash features weekly so repeat visits to A Pet Villa Dog Boarding and Grooming never feel stale. Expect shaded seating, rinse stations, and staff roaming the yards to keep playgroups safe.\",\"lastUpdated\":\"2025-11-14T19:36:02.813163+00:00\"},{\"question\":\"When is A Pet Villa Dog Boarding and Grooming open and where do I park?\",\"answer\":\"Hours rotate with weather and staffing, so call ahead to confirm current play blocks. Street and shared-lot parking is available nearby; arrive a few minutes early to grab a spot. Use posted signage around Santa Clara to navigate any temporary closures.\",\"lastUpdated\":\"2025-11-14T19:36:02.813163+00:00\"},{\"question\":\"How do I contact the team at A Pet Villa Dog Boarding and Grooming?\",\"answer\":\"For reservations, temperament assessments, or party rentals, call (408) 988-3118, and visit http://apetvilla.com/. The concierge team at A Pet Villa Dog Boarding and Grooming typically replies within one business day.\",\"lastUpdated\":\"2025-11-14T19:36:02.813163+00:00\"}],\"source\":\"static\",\"listingType\":\"free\"},{\"id\":\"ChIJUetlFt7OxokRFqsJSocfz94\",\"name\":\"A Plus Pet Grooming\",\"businessType\":\"Dog Park\",\"description\":\"$31\",\"slug\":\"a-plus-pet-grooming\",\"address\":\"55 Crescent Blvd\",\"street\":\"55 Crescent Blvd\",\"city\":\"Gloucester City\",\"state\":\"NJ\",\"zipCode\":\"08030\",\"full_address\":\"55 Crescent Blvd, Gloucester City, NJ 08030, USA\",\"latitude\":39.8916248,\"longitude\":-75.1040242,\"googlePlaceId\":\"ChIJUetlFt7OxokRFqsJSocfz94\",\"phone\":\"(856) 742-0007\",\"website\":\"https://www.facebook.com/A-PLUS-PET-GROOMING-114184378604900/\",\"photos\":null,\"rating\":4.7,\"reviewCount\":168,\"openingHours\":{\"Monday\":\"Closed\",\"Tuesday\":\"9:00 AM – 3:00 PM\",\"Wednesday\":\"9:00 AM – 3:00 PM\",\"Thursday\":\"9:00 AM – 3:00 PM\",\"Friday\":\"9:00 AM – 3:00 PM\",\"Saturday\":\"9:00 AM – 3:00 PM\",\"Sunday\":\"Closed\"},\"amenities\":{\"Onsite services\":true,\"Indoor facilities\":true,\"Professional staff\":true,\"Climate controlled\":true,\"Wheelchair accessible entrance\":true,\"Parking available\":true,\"Easy access\":true},\"pricing\":{\"pricingSource\":\"website\",\"isFree\":false},\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"lastUpdated\":null,\"dataQuality\":\"verified\",\"photo\":null,\"faqs\":[],\"source\":\"static\",\"listingType\":\"free\"},{\"id\":\"ChIJf4G3XI4BsYkREWZI0-XGCTQ\",\"name\":\"A Stay in the Country Pet Lodge and Training Center\",\"businessType\":\"Dog Park\",\"description\":\"Pet parents in the area rave about A Stay in t