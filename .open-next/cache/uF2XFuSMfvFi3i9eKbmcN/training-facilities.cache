{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/training-facilities/layout,_N_T_/training-facilities/page,_N_T_/training-facilities,blog-posts,blog-list"},"segmentPaths":["/_tree","/_full","/training-facilities/__PAGE__","/training-facilities","/_index","/_head"]},"html":"<!DOCTYPE html><!--uF2XFuSMfvFi3i9eKbmcN--><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/e4af272ccee01ff0-s.p.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"stylesheet\" href=\"/_next/static/css/6aa7df2bae588751.css\" data-precedence=\"next\"/><link rel=\"stylesheet\" href=\"/_next/static/css/f4aeb25f618e7857.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/webpack-4879435cea3ede45.js\"/><script src=\"/_next/static/chunks/4bd1b696-10cb4c9d2844a506.js\" async=\"\"></script><script src=\"/_next/static/chunks/3794-c66343cd6a42366f.js\" async=\"\"></script><script src=\"/_next/static/chunks/main-app-1be938be5fb87de1.js\" async=\"\"></script><script src=\"/_next/static/chunks/8500-98e13bcce54aa7a0.js\" async=\"\"></script><script src=\"/_next/static/chunks/7828-fd723da158040787.js\" async=\"\"></script><script src=\"/_next/static/chunks/2365-40fbe64639b5ecd9.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/layout-1946b3c57b55ecba.js\" async=\"\"></script><script async=\"\" src=\"https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8688786543603411\" crossorigin=\"anonymous\"></script><script src=\"/_next/static/chunks/5772-dddb55abe608617a.js\" async=\"\"></script><script src=\"/_next/static/chunks/7206-1c8c946f4e44e54c.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/not-found-ee9f008ad1b