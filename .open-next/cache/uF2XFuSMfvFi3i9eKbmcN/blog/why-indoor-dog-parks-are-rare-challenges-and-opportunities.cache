\",\"meta\":{}},{\"id\":75385452,\"name\":\"Urbans-dogs\",\"slug\":\"urbans-dogs\",\"description\":\"\",\"count\":0,\"link\":\"/blog/tag/urbans-dogs\",\"taxonomy\":\"post_tag\",\"meta\":{}}],\"featuredImage\":{\"id\":73365672,\"date\":\"2026-01-14T22:16:53.360Z\",\"slug\":\"4-best-indoor-dog-parks-in-columbus-ohio\",\"type\":\"attachment\",\"link\":\"https://cdn.sanity.io/images/ruuprk8g/production/73ac3d6cd5a6b7e2764d01ea511f749c0a1341c9-1344x768.webp\",\"title\":{\"rendered\":\"indoor-dog-park-in-columbus\"},\"author\":3894619,\"caption\":{\"rendered\":\"Indoor dog park in columbus\"},\"alt_text\":\"indoor-dog-park-in-columbus\",\"media_type\":\"image\",\"mime_type\":\"image/jpeg\",\"media_details\":{\"width\":1344,\"height\":768,\"file\":\"4-best-indoor-dog-parks-in-columbus-ohio.jpg\",\"sizes\":{\"large\":{\"file\":\"4-best-indoor-dog-parks-in-columbus-ohio-large.jpg\",\"width\":1200,\"height\":686,\"mime_type\":\"image/jpeg\",\"source_url\":\"https://cdn.sanity.io/images/ruuprk8g/production/73ac3d6cd5a6b7e2764d01ea511f749c0a1341c9-1344x768.webp?w=1200\"},\"medium\":{\"file\":\"4-best-indoor-dog-parks-in-columbus-ohio-medium.jpg\",\"width\":800,\"height\":457,\"mime_type\":\"image/jpeg\",\"source_url\":\"https://cdn.sanity.io/images/ruuprk8g/production/73ac3d6cd5a6b7e2764d01ea511f749c0a1341c9-1344x768.webp?w=800\"}}},\"source_url\":\"https://cdn.sanity.io/images/ruuprk8g/production/73ac3d6cd5a6b7e2764d01ea511f749c0a1341c9-1344x768.webp?w=1200\"},\"link\":\"/blog/4-best-indoor-dog-parks-in-columbus-ohio\",\"status\":\"publish\",\"commentStatus\":\"open\"}}]\n3f:[\"$\",\"$L3d\",\"ChIJYR6I6Owzs1IRGFIDv9NEdsU\",{\"park\":{\"id\":\"ChIJYR6I6Owzs1IRGFIDv9NEdsU\",\"name\":\"Unleashed Hounds and Hops\",\"businessType\":\"Dog Park\",\"description\":\"Dog lovers in Minneapolis trust Unleashed Hounds and Hops for exceptional care. This facility features professional grooming stations, experienced and certified staff, offering pet care. Their services maintains your pet's r