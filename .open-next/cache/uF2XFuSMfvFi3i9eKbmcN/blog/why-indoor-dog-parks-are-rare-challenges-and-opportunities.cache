 Lyndale Ave N\",\"city\":\"Minneapolis\",\"state\":\"MN\",\"zipCode\":\"55405\",\"full_address\":\"200 East Lyndale Ave N, Minneapolis, MN 55405\",\"latitude\":44.9800017,\"longitude\":-93.2862281,\"googlePlaceId\":\"ChIJYR6I6Owzs1IRGFIDv9NEdsU\",\"phone\":\"+1 612-439-5060\",\"website\":\"http://unleashedhoundsandhops.com/\",\"photos\":null,\"rating\":4.7,\"reviewCount\":538,\"userRatingsTotal\":538,\"pricing\":{\"pricingSource\":\"unknown\",\"isFree\":false},\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"dataQuality\":\"verified\",\"photo\":null,\"openingHours\":{\"Sunday\":\"1-6PM\",\"Tuesday\":\"4-9PM\",\"Wednesday\":\"4-9PM\",\"Thursday\":\"4-9PM\",\"Friday\":\"4-9PM\",\"Saturday\":\"1-8PM\"},\"faqs\":[],\"amenities\":{\"handicapAccess\":true,\"parking\":true},\"source\":\"static\",\"listingType\":\"free\"}}]\n1c:[\"$\",\"$L19\",\"ChIJReYLENsdU4gRZrNcB9b97yE\",{\"park\":{\"id\":\"ChIJReYLENsdU4gRZrNcB9b97yE\",\"name\":\"Dog Park\",\"businessType\":\"Indoor Dog Park\",\"description\":\"Dog Park provides dependable care for Greensboro's furry friends. This facility features air-conditioned spaces for hot summers, North Carolina pet care professionals, offering pet care. Their services provides essential socialization for your pet. strategically positioned in Greensboro. Contact Dog Park today to schedule your dog's visit\",\"slug\":\"dog-park\",\"address\":\"Greensboro\",\"street\":\"Greensboro\",\"city\":\"Greensboro\",\"state\":\"NC\",\"zipCode\":\"27455\",\"full_address\":\"Greensboro, NC 27455, USA\",\"latitude\":36.1268796,\"longitude\":-79.83607339999999,\"googlePlaceId\":\"ChIJReYLENsdU4gRZrNcB9b97yE\",\"phone\":\"(336) 373-3648\",\"website\":\"https://www.greensboro-nc.gov/departments/parks-recreation/parks-gardens/country-park\",\"rating\":4.5,\"reviewCount\":18,\"userRatingsTotal\":18,\"pricing\":{\"pricingSource\":\"unknown\",\"isFree\":false},\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"dataQuality\":\"verified\",\"faqs\":[]