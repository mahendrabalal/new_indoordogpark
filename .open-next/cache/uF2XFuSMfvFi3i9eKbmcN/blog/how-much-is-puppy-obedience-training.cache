\\"}}]\\n\"])</script><script>self.__next_f.push([1,\"41:[\\\"$\\\",\\\"$L40\\\",\\\"ChIJ3Xa7vli_VogRFUqUnpwdMSA\\\",{\\\"park\\\":{\\\"id\\\":\\\"ChIJ3Xa7vli_VogRFUqUnpwdMSA\\\",\\\"name\\\":\\\"Dog Park\\\",\\\"businessType\\\":\\\"Indoor Dog Park\\\",\\\"description\\\":\\\"Pet owners in Gastonia find Dog Park to be a solid choice. This facility features modern training facilities, North Carolina pet care professionals, offering pet care. Their services creates a safe, climate-controlled environment. conveniently located in the heart of Gastonia. Discover why Gastonia pet parents choose Dog Park\\\",\\\"slug\\\":\\\"dog-park\\\",\\\"address\\\":\\\"Lowell\\\",\\\"street\\\":\\\"Lowell\\\",\\\"city\\\":\\\"Gastonia\\\",\\\"state\\\":\\\"NC\\\",\\\"zipCode\\\":\\\"28056\\\",\\\"full_address\\\":\\\"Lowell, NC 28056, USA\\\",\\\"latitude\\\":35.29180049999999,\\\"longitude\\\":-81.11528419999999,\\\"googlePlaceId\\\":\\\"ChIJ3Xa7vli_VogRFUqUnpwdMSA\\\",\\\"rating\\\":5,\\\"reviewCount\\\":5,\\\"userRatingsTotal\\\":5,\\\"pricing\\\":{\\\"pricingSource\\\":\\\"unknown\\\",\\\"isFree\\\":false},\\\"placeTypes\\\":[\\\"point_of_interest\\\",\\\"establishment\\\"],\\\"dataQuality\\\":\\\"verified\\\",\\\"openingHours\\\":{\\\"Monday\\\":\\\"Open 24 hours\\\",\\\"Tuesday\\\":\\\"Open 24 hours\\\",\\\"Wednesday\\\":\\\"Open 24 hours\\\",\\\"Thursday\\\":\\\"Open 24 hours\\\",\\\"Friday\\\":\\\"Open 24 hours\\\",\\\"Saturday\\\":\\\"Open 24 hours\\\",\\\"Sunday\\\":\\\"Open 24 hours\\\"},\\\"faqs\\\":[],\\\"amenities\\\":{},\\\"photos\\\":[{\\\"url\\\":\\\"/images/parks/northcarolina/dog-park/dog-park-1.jpg\\\",\\\"type\\\":\\\"photo\\\",\\\"source\\\":\\\"website\\\"},{\\\"url\\\":\\\"/images/parks/northcarolina/dog-park/dog-park-2.jpg\\\",\\\"type\\\":\\\"photo\\\",\\\"source\\\":\\\"website\\\"}],\\\"photo\\\":\\\"/images/parks/northcarolina/dog-park/dog-park-1.jpg\\\",\\\"source\\\":\\\"static\\\",\\\"listingType\\\":\\\"free\\\"}}]\\n\"])</script><script>self.__next_f