images/parks/northcarolina/dog-park/dog-park-1.jpg\",\"source\":\"static\",\"listingType\":\"free\"}}],\"$L21\",\"$L22\",\"$L23\"]}],\"$L24\"]}]}]\n11:[\"$\",\"div\",null,{\"className\":\"bg-gradient-to-r from-purple-50 to-purple-100 py-12 mt-12\",\"children\":[\"$\",\"div\",null,{\"className\":\"container mx-auto px-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-3xl font-bold text-gray-900 mb-4\",\"children\":\"Explore These Cities\"}],[\"$\",\"p\",null,{\"className\":\"text-gray-600 mb-6\",\"children\":\"This article mentions the following cities. Discover dog parks and resources in these locations.\"}],[\"$\",\"div\",null,{\"className\":\"flex flex-wrap gap-3\",\"children\":[[\"$\",\"$La\",\"san antonio\",{\"href\":\"/cities/san-antonio-tx\",\"className\":\"inline-flex items-center px-4 py-2 bg-white text-purple-700 rounded-lg hover:bg-purple-50 transition-colors font-medium shadow-sm\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-geo-alt mr-2\"}],\"San Antonio\"]}],[\"$\",\"$La\",\"austin\",{\"href\":\"/cities/austin\",\"className\":\"inline-flex items-center px-4 py-2 bg-white text-purple-700 rounded-lg hover:bg-purple-50 transition-colors font-medium shadow-sm\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-geo-alt mr-2\"}],\"Austin\"]}],[\"$\",\"$La\",\"erie\",{\"href\":\"/cities/erie\",\"className\":\"inline-flex items-center px-4 py-2 bg-white text-purple-700 rounded-lg hover:bg-purple-50 transition-colors font-medium shadow-sm\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-geo-alt mr-2\"}],\"Erie\"]}],[\"$\",\"$La\",\"allen\",{\"href\":\"/cities/allen-tx\",\"className\":\"inline-flex items-center px-4 py-2 bg-white text-purple-700 rounded-lg hover:bg-purple-50 transition-colors font-medium shadow-sm\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-geo-alt mr-2\"}],\"Allen\"]}],[\"$\",\"$La\",\"reno\",{\"href\":\"/cities/reno\",\"className\":\"inline-flex items-center px-4 py-2 bg-white text-purple-700 rounde