est\",\"title\":\"Follow us on Pinterest\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-pinterest\"}]}],\"$undefined\",\"$undefined\",[\"$\",\"a\",null,{\"href\":\"https://digg.com/indoordogpark\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"aria-label\":\"Follow us on Digg\",\"title\":\"Follow us on Digg\",\"children\":[\"$\",\"svg\",null,{\"xmlns\":\"http://www.w3.org/2000/svg\",\"width\":\"1em\",\"height\":\"1em\",\"fill\":\"currentColor\",\"className\":\"bi\",\"viewBox\":\"0 0 512 512\",\"children\":[\"$\",\"path\",null,{\"d\":\"M81.7 172.3l-81.7 0 0 174.4 132.7 0 0-250.7-51 0 0 76.3zm0 133.4l-30.8 0 0-92.3 30.8 0 0 92.3zM378.9 172.3l0 174.4 81.8 0 0 28.5-81.8 0 0 40.8 133.1 0 0-243.7-133.1 0zm81.8 133.4l-30.8 0 0-92.3 30.8 0 0 92.3zm-235.6 41l82.1 0 0 28.5-82.1 0 0 40.8 133.3 0 0-243.7-133.3 0 0 174.4zm51.2-133.3l30.8 0 0 92.3-30.8 0 0-92.3zM153.3 96l51.3 0 0 51-51.3 0 0-51zm0 76.3l51.3 0 0 174.4-51.3 0 0-174.4z\"}]}]}]]}],[\"$\",\"div\",null,{\"className\":\"mt-8 border-t border-white/10 pt-8 text-center\",\"children\":[\"$\",\"p\",null,{\"className\":\"text-sm text-white/50\",\"children\":\"IndoorDogPark is a participant in the Amazon Services LLC Associates Program, an affiliate advertising program designed to provide a means for sites to earn advertising fees by advertising and linking to Amazon.com. As an Amazon Associate I earn from qualifying purchases.\"}]}],[\"$\",\"div\",null,{\"className\":\"footer-bottom\",\"children\":[\"$L38\",\"$L39\"]}]]}]}]\n3a:I[64942,[\"8500\",\"static/chunks/8500-98e13bcce54aa7a0.js\",\"7828\",\"static/chunks/7828-fd723da158040787.js\",\"2365\",\"static/chunks/2365-40fbe64639b5ecd9.js\",\"5772\",\"static/chunks/5772-dddb55abe608617a.js\",\"7206\",\"static/chunks/7206-1c8c946f4e44e54c.js\",\"6107\",\"static/chunks/6107-1b6596bba5b5f106.js\",\"5953\",\"static/chunks/app/blog/%5Bslug%5D/page-eb0733b977073f3f.js\"],\"default\"]\n3e:I[32855,[\"8500\",\"static/chunks/8500-98e13bcce54aa7a0.js\",\"7828\",\"static/chunks/7828-fd723da158040787.js\",\"2365\",\"static/chunks/2365-40fbe64639b5ecd9.js\",\"5772\",\"static/chunks/5772-dddb55abe608617a.js\",\"7206\",\"static/chunks/7206-1c8c946f4e44e54c.js\",\"6107\",\"static/chunks/6107-1b6596bba5b5f106.js\",\"5953\",\"static/chunks/app/blog/%5Bslug%5D/page-eb0733b977073f3f.js\"],\"default\"]\n42:I[26107,[\"8500\",\"static/chunks/8500-98e13bcce54aa7a0.js\",\"7828\",\"static/chunks/7828-fd723da158040787.js\",\"2365\",\"static/chunks/2365-40fbe64639b5ecd9.js\",\"5772\",\"static/chunks/5772-dddb55abe608617a.js\",\"7206\",\"static/chunks/7206-1c8c946f4e44e54c.js\",\"6107\",\"static/chunks/6107-1b6596bba5b5f106.js\",\"5953\",\"static/chunks/app/blog/%5Bslug%5D/page-eb0733b977073f3f.js\"],\"default\"]\n33:[\"$\",\"aside\",null,{\"className\":\"lg:sticky lg:top-24 h-fit\",\"children\":[\"$\",\"div\",null,{\"className\":\"space-y-6\",\"children\":[[\"$\",\"$L3a\",null,{\"items\":[{\"id\":\"why-austin-dog-owners-need-indoor-parks\",\"title\":\"Why Austin Dog Owners Need Indoor Parks\",\"level\":2},{\"id\":\"extreme-weather-patterns\",\"title\":\"Extreme Weather Patterns\",\"level\":3},{\"id\":\"urban-density-and-limited-green-space\",\"title\":\"Urban Density and Limited Green Space\",\"level\":3},{\"id\":\"health-and-safety-benefits\",\"title\":\"Health and Safety Benefits\",\"level\":3},{\"id\":\"the-best-indoor-dog-parks-in-austin\",\"title\":\"The Best Indoor Dog Parks in Austin\",\"level\":2},{\"id\":\"1-work-woof-where-productivity-meets-play\",\"title\":\"1. Work & Woof - Where Productivity Meets Play\",\"level\":3},{\"id\":\"2-bark-house-social-austins-premier-dog-social-club\",\"title\":\"2. BARk House Social - Austin's Premier Dog Social Club\",\"level\":3},{\"id\":\"3-yard-bar-the-original-austin-dog-park-bar\",\"title\":\"3. Yard Bar - The Original Austin Dog Park Bar\",\"level\":3},{\"id\":\"4-cross-creek-ranch-canine-commons-premium-experience\",\"title\":\"4. Cross Creek Ranch Canine Commons - Premium Experience\",\"level\":3