":2},{\"id\":\"assess-your-dogs-needs\",\"title\":\"Assess Your Dog's Needs\",\"level\":3},{\"id\":\"evaluate-your-lifestyle\",\"title\":\"Evaluate Your Lifestyle\",\"level\":3},{\"id\":\"research-and-visit\",\"title\":\"Research and Visit\",\"level\":3},{\"id\":\"safety-tips-for-indoor-dog-park-visits\",\"title\":\"Safety Tips for Indoor Dog Park Visits\",\"level\":2},{\"id\":\"pre-visit-preparation\",\"title\":\"Pre-Visit Preparation\",\"level\":3},{\"id\":\"during-your-visit\",\"title\":\"During Your Visit\",\"level\":3},{\"id\":\"post-visit-care\",\"title\":\"Post-Visit Care\",\"level\":3},{\"id\":\"the-future-of-indoor-dog-parks-in-austin\",\"title\":\"The Future of Indoor Dog Parks in Austin\",\"level\":2},{\"id\":\"technology-integration\",\"title\":\"Technology Integration\",\"level\":3},{\"id\":\"expanded-services\",\"title\":\"Expanded Services\",\"level\":3},{\"id\":\"community-building\",\"title\":\"Community Building\",\"level\":3},{\"id\":\"sustainability-initiatives\",\"title\":\"Sustainability Initiatives\",\"level\":3},{\"id\":\"conclusion-indoor-dog-parks-as-essential-austin-infrastructure\",\"title\":\"Conclusion: Indoor Dog Parks as Essential Austin Infrastructure\",\"level\":2},{\"id\":\"references\",\"title\":\"References\",\"level\":2}]}],\"$L3b\",\"$L3c\"]}]}]\n34:[\"$\",\"div\",null,{\"className\":\"mt-12 pt-8 border-t border-gray-200\",\"children\":[\"$\",\"div\",null,{\"className\":\"grid grid-cols-1 md:grid-cols-[1fr_auto] gap-8 items-start\",\"children\":[[\"$\",\"div\",null,{\"children\":[\"$\",\"div\",null,{\"className\":\"flex gap-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"relative w-16 h-16 rounded-full overflow-hidden border-2 border-gray-100 flex-shrink-0\",\"children\":[\"$\",\"$L31\",null,{\"src\":\"https://cdn.sanity.io/images/ruuprk8g/production/f849e70b92252c6a55db9775da309c7f4009a685-2000x832.png?rect=584,0,832,832&w=96&h=96\",\"alt\":\"Indoor Dog Park Directory Team\",\"fill\":true,\"className\":\"object-cover\"}