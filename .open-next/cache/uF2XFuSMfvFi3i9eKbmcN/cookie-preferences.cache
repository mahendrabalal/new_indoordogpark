,opt out ads,personalized advertising,third-party advertising\"/><meta name=\"creator\" content=\"Indoor Dog Park\"/><meta name=\"publisher\" content=\"Indoor Dog Park\"/><meta name=\"robots\" content=\"index, follow\"/><meta name=\"category\" content=\"Pet Services\"/><meta name=\"theme-color\" content=\"#7c3aed\"/><meta name=\"msapplication-TileColor\" content=\"#7c3aed\"/><meta name=\"apple-mobile-web-app-capable\" content=\"yes\"/><meta name=\"apple-mobile-web-app-status-bar-style\" content=\"black-translucent\"/><meta name=\"apple-mobile-web-app-title\" content=\"Indoor Dog Park\"/><meta name=\"mobile-web-app-capable\" content=\"yes\"/><link rel=\"canonical\" href=\"https://www.indoordogpark.org/cookie-preferences\"/><meta name=\"format-detection\" content=\"telephone=no, address=no, email=no\"/><meta property=\"og:title\" content=\"Cookie Preferences | Privacy Settings - Indoor Dog Park\"/><meta property=\"og:description\" content=\"Manage your cookie preferences and control advertising cookies. Opt out of personalized advertising anytime.\"/><meta property=\"og:url\" content=\"https://www.indoordogpark.org/cookie-preferences\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:site\" content=\"@indoordogpark\"/><meta name=\"twitter:creator\" content=\"@indoordogpark\"/><meta name=\"twitter:title\" content=\"Best Indoor Dog Parks in California | Indoor Dog Park\"/><meta name=\"twitter:description\" content=\"Find year-round indoor dog parks across California. Search by city, neighborhood, or zip to discover safe, climate-controlled play spaces for your dog.\"/><meta name=\"twitter:image\" content=\"https://www.indoordogpark.org/images/hero/hero.webp\"/><link rel=\"icon\" href=\"/favicon.ico.svg\" type=\"image/svg+xml\"/><link rel=\"icon\" href=\"/icons/icon-192x192.png\" sizes=\"192x192\" type=\"image/png\"/><link rel=\"apple-touch-icon\" href=\"/icons/icon-192x192.png\" sizes=\"192x192\" type=\"image/png\"/><script data-grow-initializer=\"\">!(function(){window.growMe||((window.growMe=function(e){window.growMe._.push(e);}),(window.growMe._=[]));var e=document.createElement(\"script\");(e.type=\"text/javascript\"),(e.src=\"https://faves.grow.me/main.js\"),(e.defer=!0),e.setAttribute(\"data-grow-faves-site-id\",\"U2l0ZTo2NWU3MDY3YS0wNzI0LTQ0NjktYTZmYS1iYzU0YWYzNWYzOTg=\");var t=document.getElementsByTagName(\"script\")[0];t.parentNode.insertBefore(e,t);})();</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"Organization\",\"name\":\"Indoor Dog Park\",\"url\":\"https://www.indoordogpark.org\",\"logo\":\"https://www.indoordogpark.org/images/logo/logo-512.png\",\"description\":\"California's premier directory for indoor dog parks, play areas, and dog-friendly facilities.\",\"sameAs\":[\"https://www.facebook.com/IndoorDogParkDirectory\",\"https://x.com/Indoordogp40934\",\"https://www.instagram.com/indoordogpark2025/\"],\"contactPoint\":{\"@type\":\"ContactPoint\",\"contactType\":\"Customer Service\",\"availableLanguage\":\"en\"}}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"WebSite\",\"name\":\"Indoor Dog Park\",\"url\":\"https://www.indoordogpark.org\",\"description\":\"Find the best indoor dog parks and facilities across California\",\"potentialAction\":{\"@type\":\"SearchAction\",\"target\":{\"@type\":\"EntryPoint\",\"urlTemplate\":\"https://www.indoordogpark.org/?search={search_term_string}\"},\"query-input\":\"required name=search_term_string\"}}</script><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body class=\"__className_8a4156\"><div hidden=\"\"><!--$--><!--/$--></div><!--$!--><template data-dgst=\"BAILOUT_TO_CLIENT_SIDE_RENDERING\"></template><!--/$--><div class=\"flex flex-col min-h-screen bg-slate-50 text-slate-900\"><header class=\"header header-visible  header-light\"><div class=\"header-container\"><div class=\"header-left\"><a class=\"logo\" href=\"/\"><img alt=\"Indoor Dog Park logo\" width=\"140\" height=\"40\" decoding=\"async\" data-nimg=\"1\" style=\"color:transparent;object-fit:contain;height:auto\" src=\"/images/logo/logo.png\"/></a></div><div class=\"header-center\"><nav class=\"header-nav\" aria-label=\"Main navigation\"><a class=\"header-nav-link\" href=\"/\">Browse Parks</a><div class=\"header-nav-item\"><button class=\"header-nav-link\" aria-haspopup=\"true\" aria-expanded=\"false\">Discover <i class=\"bi bi-chevron-down dropdown-icon \"></i></button><div class=\"header-dropdown \"><a class=\"header-dropdown-link\" href=\"/parks-with-bars\">Parks with Bars</a><a class=\"header-dropdown-link\" href=\"/training-facilities\">Training Facilities</a><a class=\"header-dropdown-link\" href=\"/how-it-works\">How It Works</a></div></div><div class=\"header-nav-item\"><button class=\"header-nav-link\" aria-haspopup=\"true\" aria-expanded=\"false\">Locations <i class=\"bi bi-chevron-down dropdown-icon \"></i></button><div class=\"header-dropdown \"><a class=\"header-dropdown-link\" href=\"/cities/san-francisco\">San Francisco</a><a class=\"header-dropdown-link\" href=\"/cities/los-angeles\">Los Angeles</a><a class=\"header-dropdown-link\" href=\"/cities/san-diego\">San Diego</a><a class=\"header-dropdown-link\" href=\"/cities/new-york\">New York</a><a class=\"header-dropdown-link\" href=\"/cities/seattle\">Seattle</a></div></div><a class=\"header-nav-link\" href=\"/about\">About</a><a class=\"header-nav-link\" href=\"/blog\">Blog</a></nav></div><div class=\"header-right\"><a class=\"header-link\" href=\"/contact\">Contact us</a><a class=\"header-link header-link-primary\" href=\"/list-your-park\">List your park</a><a class=\"header-link\" href=\"/signup\">Sign up</a><a class=\"header-link\" href=\"/login\">Log in</a><button class=\"menu-toggle\" aria-label=\"Toggle menu\" aria-expanded=\"false\"><i class=\"bi bi-list\"></i></button></div></div><div class=\"mobile-menu \" aria-hidden=\"true\"><a class=\"mobile-menu-item\" href=\"/\">Browse Parks</a><a class=\"mobile-menu-item\" href=\"/parks-with-bars\">Parks with Bars</a><a class=\"mobile-menu-item\" href=\"/training-facilities\">Training Facilities</a><a class=\"mobile-menu-item\" href=\"/how-it-works\">How It Works</a><a class=\"mobile-menu-item\" href=\"/blog\">Blog &amp; Guides</a><a class=\"mobile-menu-item\" href=\"/about\">About</a><a class=\"mobile-menu-item\" href=\"/contact\">Contact us</a><a class=\"mobile-menu-item\" href=\"/list-your-park\">List your park</a><a class=\"mobile-menu-item\" href=\"/signup\">Sign up</a><a class=\"mobile-menu-item\" href=\"/login\">Log in</a></div></header><main class=\"flex-1 pt-[70px] \"><section class=\"bg-slate-900 py-20 text-white\"><div class=\"mx-auto max-w-4xl px-4 text-center\"><p class=\"text-sm font-semibold uppercase tracking-[0.3em] text-violet-200\">Privacy controls</p><h1 class=\"mt-4 text-4xl font-bold md:text-5xl\">Cookie preferences</h1><p class=\"mt-4 text-lg text-slate-200\">Choose how IndoorDogPark remembers your sessions, personalization settings, and marketing opt-ins.</p></div></section><section class=\"bg-white py-16\"><div class=\"mx-auto flex max-w-5xl flex-col gap-8 px-4\"><div class=\"grid gap-6 md:grid-cols-2\"><article class=\"rounded-3xl border p-6 transition-shadow hover:shadow-md border-slate-200 bg-slate-50/80\"><div class=\"flex items-start gap-3\"><div class=\"flex-1\"><h2 class=\"text-xl font-semibold text-slate-900\">Strictly necessary</h2><p class=\"mt-2 text-sm text-slate-600 leading-relaxed\">Keeps you signed in, remembers listings you create, and maintains site security. Required for core functionality. These cookies cannot be disabled.</p></div></div></article><article class=\"rounded-3xl border p-6 transition-shadow hover:shadow-md border-slate-200 bg-slate-50/80\"><div class=\"flex items-start gap-3\"><div class=\"flex-1\"><h2 class=\"text-xl font-semibold text-slate-900\">Functional</h2><p class=\"mt-2 text-sm text-slate-600 leading-relaxed\">Stores preferences such as preferred cities, saved parks, and accessibility settings so experiences feel familiar across your visits.</p></div></div></article><article class=\"rounded-3xl border p-6 transition-shadow hover:shadow-md border-slate-200 bg-slate-50/80\"><div class=\"flex items-start gap-3\"><div class=\"flex-1\"><h2 class=\"text-xl font-semibold text-slate-900\">Analytics</h2><p class=\"mt-2 text-sm text-slate-600 leading-relaxed\">Aggregated metrics that show which filters or guides are most helpful. We use privacy-focused tools like Google Analytics 4 (with IP anonymization) and Plausible to understand site usage patterns.</p></div></div></article><article class=\"rounded-3xl border p-6 transition-shadow hover:shadow-md border-violet-200 bg-violet-50/30\"><div class=\"flex items-start gap-3\"><div class=\"flex-shrink-0 mt-1\"><i class=\"bi bi-megaphone-fill text-violet-600 text-lg\" aria-hidden=\"true\"></i></div><div class=\"flex-1\"><h2 class=\"text-xl font-semibold text-slate-900\">Marketing &amp; Advertising</h2><p class=\"mt-2 text-sm text-slate-600 leading-relaxed\">Enables personalized advertising through third-party advertising partners. These cookies help display relevant ads based on your browsing behavior. You can opt out at any time through your ad preferences or the Digital Advertising Alliance.</p></div></div></article></div><div class=\"rounded-3xl border-2 border-violet-200 bg-gradient-to-br from-violet-50 to-white p-6 shadow-sm\"><div class=\"flex items-start gap-4\"><div class=\"flex-shrink-0 mt-1\"><i class=\"bi bi-info-circle-fill text-violet-600 text-2xl\" aria-hidden=\"true\"></i></div><div class=\"flex-1\"><h3 class=\"text-lg font-bold text-slate-900 mb-2\">About Personalized Advertising</h3><p class=\"text-sm text-slate-700 leading-relaxed mb-3\">When you enable marketing cookies, our third-party advertising partners may use cookies and similar technologies to display personalized advertisements on our site. These ads are based on your browsing history and interests, making them more relevant to you.</p><p class=\"text-sm text-slate-700 leading-relaxed mb-3\"><strong>You have full control:</strong> You can disable marketing cookies using the toggle above, or opt out of personalized advertising through<!-- --> <a href=\"https://adssettings.google.com\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"text-violet-700 underline font-semibold hover:text-violet-800\">ad preference settings</a> <!-- -->at any time. Disabling marketing cookies will show you non-personalized ads instead.</p><div class=\"mt-4 pt-4 border-t border-violet-200\"><p class=\"text-xs text-slate-600\">We work with trusted advertising partners who have their own privacy policies. You can learn more about how these partners use data through their respective privacy policies.</p></div></div></div></div><form class=\"space-y-6 rounded-2xl border border-slate-200 bg-white/80 p-6 shadow-lg shadow-slate-900/5 backdrop-blur\"><div class=\"flex flex-wrap items-center justify-between gap-4\"><div><p class=\"text-sm font-semibold uppercase tracking-wide text-violet-700\">Manage consent</p><h3 class=\"text-2xl font-bold text-slate-900\">Customize cookie settings</h3><p class=\"text-sm text-slate-500\">Adjust how we remember your preferences. Changes apply the next time you use the directory.</p></div><div class=\"flex flex-wrap gap-3\"><button type=\"button\" class=\"inline-flex items-center rounded-full border border-slate-300 px-4 py-2 text-sm font-medium text-slate-600 hover:border-slate-400\">Reset</button><button type=\"submit\" class=\"inline-flex items-center rounded-full bg-violet-600 px-5 py-2 text-sm font-semibold text-white shadow hover:bg-violet-500 disabled:cursor-not-allowed disabled:bg-violet-400\">Save preferences</button></div></div><div class=\"grid gap-4 md:grid-cols-2\"><label for=\"cookie-necessary\" class=\"group relative flex cursor-pointer flex-col gap-3 rounded-2xl border p-5 transition-all border-slate-200 bg-white/70 hover:border-violet-200 hover:bg-white\"><div class=\"flex items-start justify-between gap-4\"><div class=\"flex-1\"><div class=\"flex items-center gap-2 mb-1\"><p class=\"text-base font-semibold text-slate-900\">Strictly necessary</p></div><p class=\"text-sm leading-relaxed text-slate-500\">Required for authentication, security, and remembering your basic site preferences. These cookies are always on and cannot be disabled.</p></div><input id=\"cookie-necessary\" type=\"checkbox\" disabled=\"\" class=\"h-5 w-5 rounded border-slate-300 text-violet-600 focus:ring-violet-500 disabled:cursor-not-allowed flex-shrink-0 \" checked=\"\"/></div><span class=\"inline-flex w-fit items-center gap-2 rounded-full px-3 py-1 text-xs font-semibold bg-slate-100 text-slate-600\"><i class=\"bi bi-shield-lock\" aria-hidden=\"true\"></i>Required for site reliability</span></label><label for=\"cookie-functional\" class=\"group relative flex cursor-pointer flex-col gap-3 rounded-2xl border p-5 transition-all border-slate-200 bg-white/70 hover:border-violet-200 hover:bg-white\"><div class=\"flex items-start justify-between gap-4\"><div class=\"flex-1\"><div class=\"flex items-center gap-2 mb-1\"><p class=\"text-base font-semibold text-slate-900\">Functional experience</p></div><p class=\"text-sm leading-relaxed text-slate-500\">Helps us remember saved parks, recently viewed content, and personalization preferences across sessions.</p></div><input id=\"cookie-functional\" type=\"checkbox\" class=\"h-5 w-5 rounded border-slate-300 text-violet-600 focus:ring-violet-500 disabled:cursor-not-allowed flex-shrink-0 \" checked=\"\"/></div></label><label for=\"cookie-analytics\" class=\"group relative flex cursor-pointer flex-col gap-3 rounded-2xl border p-5 transition-all border-slate-200 bg-white/70 hover:border-violet-200 hover:bg-white\"><div class=\"flex items-start justify-between gap-4\"><div class=\"flex-1\"><div class=\"flex items-center gap-2 mb-1\"><p class=\"text-base font-semibold text-slate-900\">Analytics &amp; performance</p></div><p class=\"text-sm leading-relaxed text-slate-500\">Allows us to understand usage patterns so we can improve maps, search speed, and park discovery journeys. We use Google Analytics 4 with IP anonymization enabled.</p></div><input id=\"cookie-analytics\" type=\"checkbox\" class=\"h-5 w-5 rounded border-slate-300 text-violet-600 focus:ring-violet-500 disabled:cursor-not-allowed flex-shrink-0 \" checked=\"\"/></div></label><label for=\"cookie-marketing\" class=\"group relative flex cursor-pointer flex-col gap-3 rounded-2xl border p-5 transition-all border-violet-300 bg-violet-50/50 hover:border-violet-400 hover:bg-violet-50 hover:shadow-md\"><div class=\"flex items-start justify-between gap-4\"><div class=\"flex-1\"><div class=\"flex items-center gap-2 mb-1\"><i class=\"bi bi-megaphone-fill text-violet-600 text-sm\" aria-hidden=\"true\"></i><p class=\"text-base font-semibold text-violet-900\">Marketing &amp; advertising</p></div><p class=\"text-sm leading-relaxed text-slate-700\">Enables personalized advertising through third-party advertising partners. These cookies help display relevant ads based on your browsing behavior. You can opt out anytime.</p><p class=\"mt-2 text-xs text-slate-600 italic\">When enabled, third-party advertising partners may use cookies to personalize ads.</p></div><input id=\"cookie-marketing\" type=\"checkbox\" class=\"h-5 w-5 rounded border-slate-300 text-violet-600 focus:ring-violet-500 disabled:cursor-not-allowed flex-shrink-0 border-violet-400\"/></div><span class=\"inline-flex w-fit items-center gap-2 rounded-full px-3 py-1 text-xs font-semibold bg-violet-100 text-violet-800\"><i class=\"bi bi-megaphone\" aria-hidden=\"true\"></i>Third-party advertising</span></label></div><div class=\"rounded-xl border border-dashed border-slate-200 bg-slate-50/80 p-4 text-sm text-slate-600\"><p class=\"font-semibold text-slate-800\">Current summary</p><ul class=\"mt-2 list-disc space-y-1 pl-5\"><li><span class=\"font-medium capitalize\">necessary</span> — <!-- -->enabled</li><li><span class=\"font-medium capitalize\">functional</span> — <!-- -->enabled</li><li><span class=\"font-medium capitalize\">analytics</span> — <!-- -->enabled</li><li><span class=\"font-medium capitalize\">marketing</span> — <!-- -->disabled</li></ul></div></form><div class=\"rounded-3xl border border-slate-200 bg-white p-6\"><h2 class=\"text-xl font-semibold text-slate-900 mb-4\">Retention &amp; Third-Party Services</h2><div class=\"space-y-4 text-sm text-slate-600\"><p>Cookie data is retained for up to 13 months unless you clear your browser or opt out. When marketing cookies are enabled, we work with third-party advertising partners to display personalized advertisements.</p><div class=\"rounded-xl border border-slate-200 bg-slate-50/80 p-4\"><h3 class=\"font-semibold text-slate-900 mb-2\">Advertising Partners</h3><p class=\"mb-3\">Our third-party advertising partners use cookies and similar technologies to:</p><ul class=\"list-disc space-y-1 ml-5 mb-3\"><li>Display personalized advertisements based on your browsing history</li><li>Measure ad performance and effectiveness</li><li>Prevent fraud and ensure ad quality</li></ul><p class=\"text-xs text-slate-500\">These partners have their own privacy policies. We do not share your personally identifiable information (name, email) directly with advertisers.</p></div><div class=\"rounded-xl border border-violet-200 bg-violet-50/50 p-4\"><h3 class=\"font-semibold text-slate-900 mb-2\">Opt-Out Options</h3><p class=\"mb-2\">You have several ways to control personalized advertising:</p><ul class=\"space-y-2\"><li><strong>Ad Preference Settings:</strong> <a href=\"https://adssettings.google.com\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"text-violet-700 underline hover:text-violet-800\">Manage your ad preferences</a></li><li><strong>Digital Advertising Alliance:</strong> <a href=\"https://optout.aboutads.info\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"text-violet-700 underline hover:text-violet-800\">Opt out of interest-based advertising</a></li><li><strong>European Users:</strong> <a href=\"https://www.youronlinechoices.eu\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"text-violet-700 underline hover:text-violet-800\">Your Online Choices (EU)</a></li><li><strong>Browser Settings:</strong> You can also disable cookies entirely through your browser settings, though this may affect site functionality.</li></ul></div><p class=\"text-xs text-slate-500 pt-2 border-t border-slate-200\">Our advertising partners have their own privacy policies that govern how they collect and use data. We encourage you to review these policies to understand how your information is used for advertising purposes.</p></div></div></div></section></main><div class=\"jsx-80debf708dd09952 w-full bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 relative overflow-hidden\"><div class=\"jsx-80debf708dd09952 absolute inset-0 bg-[url(&#x27;/images/pattern.svg&#x27;)] opacity-5\"></div><div class=\"jsx-80debf708dd09952 absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent\"></div><div class=\"jsx-80debf708dd09952 absolute top-0 left-1/4 w-64 h-64 bg-indigo-500/20 rounded-full blur-[100px] animate-pulse\"></div><div style=\"animation-delay:1s\" class=\"jsx-80debf708dd09952 absolute bottom-0 right-1/4 w-64 h-64 bg-violet-500/20 rounded-full blur-[100px] animate-pulse\"></div><div class=\"jsx-80debf708dd09952 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-12 relative z-10\"><div class=\"jsx-80debf708dd09952 bg-white/95 backdrop-blur-xl rounded-[2rem] shadow-2xl border border-white/20 overflow-hidden transform hover:scale-[1.005] transition-all duration-500\"><div class=\"jsx-80debf708dd09952 grid md:grid-cols-2 gap-0 min-h-[320px]\"><div class=\"jsx-80debf708dd09952 p-6 md:p-8 flex flex-col justify-center relative bg-gradient-to-br from-white to-slate-50/50\"><div class=\"jsx-80debf708dd09952 inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-gradient-to-r from-indigo-500/10 to-violet-500/10 border border-indigo-200/50 backdrop-blur-sm mb-4 w-fit\"><span class=\"jsx-80debf708dd09952 relative flex h-2 w-2\"><span class=\"jsx-80debf708dd09952 animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-500 opacity-75\"></span><span class=\"jsx-80debf708dd09952 relative inline-flex rounded-full h-2 w-2 bg-gradient-to-r from-indigo-500 to-violet-500\"></span></span><span class=\"jsx-80debf708dd09952 text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-violet-600 text-[10px] font-black uppercase tracking-widest\">Live Safety Check</span></div><h2 class=\"jsx-80debf708dd09952 text-3xl md:text-4xl font-black text-slate-900 mb-4 leading-[1.1] tracking-tight\">Is it safe for<br class=\"jsx-80debf708dd09952\"/><span class=\"jsx-80debf708dd09952 text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 via-purple-600 to-violet-600 animate-gradient\">paws to pause?</span></h2><p class=\"jsx-80debf708dd09952 text-slate-600 text-base leading-relaxed font-medium mb-5 max-w-md\">Don&#x27;t guess. Check real-time pavement risk, heat index, and frostbite danger for your dog.</p><form class=\"jsx-80debf708dd09952 relative w-full max-w-lg\"><div class=\"jsx-80debf708dd09952 relative group\"><div class=\"jsx-80debf708dd09952 absolute -inset-1 bg-gradient-to-r from-indigo-600 via-purple-600 to-violet-600 rounded-3xl blur-xl opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-300 animate-tilt\"></div><div class=\"jsx-80debf708dd09952 relative flex items-center bg-white rounded-xl shadow-lg border-2 border-slate-100 focus-within:border-indigo-300 focus-within:shadow-xl focus-within:shadow-indigo-500/20 transition-all duration-300 overflow-hidden\"><div class=\"jsx-80debf708dd09952 pl-4 pr-2 text-slate-400\"><i cla