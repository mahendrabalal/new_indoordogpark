ildren\":\"IndoorDogPark is a participant in the Amazon Services LLC Associates Program, an affiliate advertising program designed to provide a means for sites to earn advertising fees by advertising and linking to Amazon.com. As an Amazon Associate I earn from qualifying purchases.\"}]}],[\"$\",\"div\",null,{\"className\":\"footer-bottom\",\"children\":[\"$L33\",\"$L34\"]}]]}]}]\n29:[\"$\",\"$L35\",null,{\"children\":[\"$\",\"$2d\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@36\"}]}]\n2f:[\"$\",\"$L12\",null,{\"href\":\"/cookie-preferences\",\"className\":\"text-violet-600 hover:text-violet-700 underline\",\"children\":\"Cookie Preferences\"}]\n30:[\"$\",\"p\",null,{\"className\":\"mt-3 text-sm leading-relaxed\",\"children\":\"When you intentionally request information, submit a booking inquiry, or interact with a listing form, we may share your contact information with the relevant park owner or partner to facilitate your request.\"}]\n31:[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-xl font-semibold text-slate-900\",\"children\":\"Business Transfers\"}],[\"$\",\"p\",null,{\"className\":\"mt-3 text-sm leading-relaxed\",\"children\":\"We may share or transfer your information in connection with, or during negotiations of, any merger, sale of company assets, financing, or acquisition of all or a portion of our business to another company. We will notify you before your personal information is transferred and becomes subject to a different privacy policy if applicable.\"}],[\"$\",\"p\",null,{\"className\":\"mt-3 text-sm leading-relaxed\",\"children\":\"Non-personally identifiable visitor information (e.g., aggregated analytics data) may be provided to other parties for marketing, advertising, or other uses, but this will not include information that can identify you personally.\"}]]}]\n33:[\"$\",\"p\",null,{\"children\":\"© 2025 IndoorDogPark. All rights reserved\"}]\n34:[\"$\",\"div\",null,{\"className\":\"footer-bottom-links\",\"children\":[[\"$\",\"$L12\",null,{\"href\":\"/terms\",\"children\":\"Terms\"}],[\"$\",\"$L12\",null,{\"href\":\"/privacy\",\"children\":\"Privacy\"}],[\"$\",\"$L12\",null,{\"href\":\"/cookie-preferences\",\"children\":\"Cookie Preferences\"}]]}]\n2b:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n37:I[86869,[],\"IconMark\"]\n2e:[[\"$\",\"title\",\"0\",{\"children\":\"Privacy Policy | Indoor Dog Park | Indoor Dog Park\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"Learn how IndoorDogPark collects, uses, discloses, and safeguards your information when you visit our website and use our directory services.\"}],[\"$\",\"meta\",\"2\",{\"name\":\"application-name\",\"content\":\"Indoor Dog Park\"}],[\"$\",\"link\",\"3\",{\"rel\":\"author\",\"href\":\"https://www.indoordogpark.org\"}],[\"$\",\"meta\",\"4\",{\"name\":\"author\",\"content\":\"Indoor Dog Park Team\"}],[\"$\",\"meta\",\"5\",{\"name\":\"keywords\",\"content\":\"privacy policy,data protection,privacy rights,GDPR,CCPA,data privacy,cookie policy,personal information\"}],[\"$\",\"meta\",\"6\",{\"name\":\"creator\",\"content\":\"Indoor Dog Park\"}],[\"$\",\"meta\",\"7\",{\"name\":\"publisher\",\"content\":\"Indoor Dog Park\"}],[\"$\",\"meta\",\"8\",{\"name\":\"robots\",\"content\":\"index, follow\"}],[\"$\",\"meta\",\"9\",{\"name\":\"category\",\"content\":\"Pet Services\"}],[\"$\",\"meta\",\"10\",{\"name\":\"theme-color\",\"content\":\"#7c3aed\"}],[\"$\",\"meta\",\"11\",{\"name\":\"msapplication-TileColor\",\"content\":\"#7c3aed\"}],[\"$\",\"meta\",\"12\",{\"name\":\"apple-mobile-web-app-capable\",\"content\":\"yes\"}],[\"$\",\"meta\",\"13\",{\"name\":\"apple-mobile-web-app-status-bar-style\",\"content\":\"black-translucent\"}],[\"$\",\"meta\",\"14\",{\"name\":\"apple-mobile-web-app-title\",\"content\":\"Indoor Dog Park\"}],[\"$\",\"meta\",\"15\",{\"name\":\"mobile-web-app-capable\",\"content\":\"yes\"}],[\"$\",\"link\",\"16\",{\"rel\":\"canonical\",\"href\":\"https://www.indoordogpark.org/privacy\"}],[\"$\",\"meta\",\"17\",{\"name\":\"format-detection\",\"content\":\"telephone=no, address=no, email=no\"}],[\"$\",\"meta\",\"18\",{\"property\":\"og:title\",\"content\":\"Privacy Policy | Indoor Dog Park\"}],[\"$\",\"meta\",\"19\",{\"property\":\"og:description\",\"content\":\"Learn how IndoorDogPark collects, uses, discloses, and safeguards your information when you visit our website and use our directory services.\"}],[\"$\",\"meta\",\"20\",{\"property\":\"og:url\",\"content\":\"https://www.indoordogpark.org/privacy\"}],[\"$\",\"meta\",\"21\",{\"property\":\"og:type\",\"content\":\"website\"}],[\"$\",\"meta\",\"22\",{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",\"23\",{\"name\":\"twitter:site\",\"content\":\"@indoordogpark\"}],[\"$\",\"meta\",\"24\",{\"name\":\"twitter:creator\",\"content\":\"@indoordogpark\"}],[\"$\",\"meta\",\"25\",{\"name\":\"twitter:title\",\"content\":\"Best Indoor Dog Parks in California | Indoor Dog Park\"}],[\"$\",\"meta\",\"26\",{\"name\":\"twitter:description\",\"content\":\"Find year-round indoor dog parks across California. Search by city, neighborhood, or zip to discover safe, climate-controlled play spaces for your dog.\"}],[\"$\",\"meta\",\"27\",{\"name\":\"twitter:image\",\"content\":\"https://www.indoordogpark.org/images/hero/hero.webp\"}],[\"$\",\"link\",\"28\",{\"rel\":\"icon\",\"href\":\"/favicon.ico.svg\",\"type\":\"image/svg+xml\"}],[\"$\",\"link\",\"29\",{\"rel\":\"icon\",\"href\":\"/icons/icon-192x192.png\",\"sizes\":\"192x192\",\"type\":\"image/png\"}],[\"$\",\"link\",\"30\",{\"rel\":\"apple-touch-icon\",\"href\":\"/icons/icon-192x192.png\",\"sizes\":\"192x192\",\"type\":\"image/png\"}],[\"$\",\"$L37\",\"31\",{}]]\n36:null\n","/privacy/__PAGE__":"1:\"$Sreact.fragment\"\n2:I[43676,[\"8500\",\"static/chunks/8500-98e13bcce54aa7a0.js\",\"7828\",\"static/chunks/7828-fd723da158040787.