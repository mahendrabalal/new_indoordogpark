ou before your personal information is transferred and becomes subject to a different privacy policy if applicable.\"}],[\"$\",\"p\",null,{\"className\":\"mt-3 text-sm leading-relaxed\",\"children\":\"Non-personally identifiable visitor information (e.g., aggregated analytics data) may be provided to other parties for marketing, advertising, or other uses, but this will not include information that can identify you personally.\"}]]}]\n18:[\"$\",\"p\",null,{\"children\":\"© 2025 IndoorDogPark. All rights reserved\"}]\n19:[\"$\",\"div\",null,{\"className\":\"footer-bottom-links\",\"children\":[[\"$\",\"$L15\",null,{\"href\":\"/terms\",\"children\":\"Terms\"}],[\"$\",\"$L15\",null,{\"href\":\"/privacy\",\"children\":\"Privacy\"}],[\"$\",\"$L15\",null,{\"href\":\"/cookie-preferences\",\"children\":\"Cookie Preferences\"}]]}]\n1c:null\n","/privacy":"1:\"$Sreact.fragment\"\n2:I[57121,[],\"\"]\n3:I[74581,[],\"\"]\n0:{\"buildId\":\"uF2XFuSMfvFi3i9eKbmcN\",\"rsc\":[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L2\",null,{\"parallelRouterKey\":\"children\",\"template\":[\"$\",\"$L3\",null,{}]}]]}],\"loading\":null,\"isPartial\":false}\n","/_index":"1:\"$Sreact.fragment\"\n2:I[85193,[\"8500\",\"static/chunks/8500-98e13bcce54aa7a0.js\",\"7828\",\"static/chunks/7828-fd723da158040787.js\",\"2365\",\"static/chunks/2365-40fbe64639b5ecd9.js\",\"7177\",\"static/chunks/app/layout-1946b3c57b55ecba.js\"],\"default\"]\n3:I[9512,[\"8500\",\"static/chunks/8500-98e13bcce54aa7a0.js\",\"7828\",\"static/chunks/7828-fd723da158040787.js\",\"2365\",\"static/chunks/2365-40fbe64639b5ecd9.js\",\"7177\",\"static/chunks/app/layout-1946b3c57b55ecba.js\"],\"default\"]\n4:I[77288,[\"8500\",\"static/chunks/8500-98e13bcce54aa7a0.js\",\"7828\",\"static/chunks/7828-fd723da158040787.js\",\"2365\",\"static/chunks/2365-40fbe64639b5ecd9.js\",\"7177\",\"static/chunks/app/layout-1946b3c57b55ecba.js\"],\"default\"]\n5:I[9794,[\"8500\",\"static/chunks/8500-98e13bcce54aa7a0.js\",\"7828\",\"static/chunks/7828-fd723