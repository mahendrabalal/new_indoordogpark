":[\"$\",\"$1\",\"c\",{\"children\":[[\"$\",\"div\",null,{\"className\":\"flex flex-col min-h-screen bg-slate-50 text-slate-900\",\"children\":[[\"$\",\"$L2\",null,{\"variant\":\"light\"}],[\"$\",\"main\",null,{\"className\":\"flex-1 pt-[70px] \",\"children\":[[\"$\",\"section\",null,{\"className\":\"terms-title-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"mx-auto max-w-4xl px-4 py-6\",\"children\":[[\"$\",\"h1\",null,{\"className\":\"terms-page-title\",\"children\":\"Privacy Policy\"}],[\"$\",\"p\",null,{\"className\":\"terms-page-date\",\"children\":\"Last Updated: December 25, 2025\"}]]}]}],[\"$\",\"section\",null,{\"className\":\"terms-hero-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"mx-auto max-w-4xl px-4\",\"children\":[\"$\",\"div\",null,{\"className\":\"terms-hero-background\",\"children\":[\"$\",\"$L3\",null,{\"src\":\"/images/privacy/privacy.webp\",\"alt\":\"Privacy and data protection illustration\",\"fill\":true,\"priority\":true,\"className\":\"terms-hero-image\",\"sizes\":\"(max-width: 768px) 100vw, 896px\",\"style\":{\"objectFit\":\"cover\"}}]}]}]}],[\"$\",\"section\",null,{\"className\":\"bg-white pt-8 pb-16\",\"children\":[\"$\",\"div\",null,{\"className\":\"mx-auto max-w-4xl px-4 space-y-10 text-slate-700\",\"children\":[[\"$\",\"article\",null,{\"className\":\"rounded-3xl border border-slate-200 bg-slate-50/80 p-6\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-2xl font-bold text-slate-900\",\"children\":\"1. Introduction\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 text-sm leading-relaxed\",\"children\":[\"Welcome to IndoorDogPark (\\\"we\\\", \\\"us\\\", \\\"our\\\"). We are committed to protecting your privacy and handling your data in an open and transparent manner. This Privacy Policy explains how we collect, use, disclose, and safeguard your information when you visit our website \",[\"$\",\"a\",null,{\"href\":\"https://www.indoordogpark.org\",\"className\":\"text-violet-600 hover:text-violet-700 underline\",\"children\":\"https://www.indoordogpark.org\"}],\" (the \\\"Site\\\") and use our directory services (the \\\"Services\\\").\"]}],[\"$\",\"p\",null,{\"className\":\"mt-4 text-sm leading-relaxed\",\"children\":\"Please read this Privacy Policy carefully. If you do not agree with the terms of this Privacy Policy, please do not access the Site or use our Services. By using our Site and Services, you signify your acceptance of this Privacy Policy.\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 text-sm leading-relaxed\",\"children\":\"We reserve the right to make changes to this Privacy Policy at any time and for any reason. We will alert you about any changes by updating the \\\"Last Updated\\\" date of this Privacy Policy. You are encouraged to periodically review this Privacy Policy to stay informed of updates.\"}]]}],[\"$\",\"article\",null,{\"className\":\"rounded-3xl border border-slate-200 bg-white p-6\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-2xl font-bold text-slate-900\",\"children\":\"2. Information We Collect\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 text-sm leading-relaxed\",\"children\":\"We may collect information about you in a variety of ways. The information we may collect on the Site includes:\"}],[\"$\",\"div\",null,{\"className\":\"mt-6 space-y-6\",\"children\":[[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-xl font-semibold text-slate-900\",\"children\":\"A. Personal Data You Provide to Us\"}],[\"$\",\"p\",null,{\"className\":\"mt-3 text-sm leading-relaxed\",\"children\":\"We collect personally identifiable information that you voluntarily give to us when you:\"}],[\"$\",\"ul\",null,{\"className\":\"mt-3 ml-6 list-disc space-y-2 text-sm text-slate-600\",\"children\":[[\"$\",\"li\",null,{\"children\":\"Create an account (name, email address, phone number)\"}],[\"$\",\"li\",null,{\"children\":\"Submit a park listing (business details, contact information, park descriptions)\"}],[\"$\",\"li\",null,{\"children\":\"Submit reviews, photos, or other content\"}],[\"$\",\"li\",null,{\"children\":\"Use our contact forms or communicate with our support team\"}],[\"$\",\"li\",null,{\"children\":\"Subscribe to newsletters or marketing communications\"}],[\"$\",\"li\",null,{\"children\":\"Make payments for premium services (billing details processed securely by our payment partners like Stripe; we do not store full payment credentials)\"}]]}],\"$L4\"]}],\"$L5\",\"$L6\"]}]]}],\"$L7\",\"$L8\",\"$L9\",\"$La\",\"$Lb\",\"$Lc\",\"$Ld\",\"$Le\"]}]}]]}],\"$Lf\",\"$L10\"]}],null,\"$L11\"]}],\"loading\":null,\"isPartial\":false}\n4:[\"$\",\"p\",null,{\"className\":\"mt-3 text-sm leading-relaxed\",\"children\":\"You are under no obligation to provide us with personal information of any kind; however, your refusal to do so may prevent you from using certain features of the Site, such as submitting listings, posting reviews, or receiving responses to your inquiries.\"}]\n5:[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-xl font-semibold text-slate-900\",\"children\":\"B. Derivative Data (Usage Data & Analytics)\"}],[\"$\",\"p\",null,{\"className\":\"mt-3 text-sm leading-relaxed\",\"children\":\"Our servers (or servers of our hosting providers and analytics services like Google Analytics) may automatically collect standard log information when you access the Site. This can include:\"}],[\"$\",\"ul\",null,{\"className\":\"mt-3 ml-6 list-disc space-y-2 text-sm text-slate-600\",\"children\":[[\"$\",\"li\",null,{\"children\":\"Your IP address (which may be anonymized by analytics services)\"}],[\"$\",\"li\",null,{\"children\":\"Browser type and version\"}],[\"$\",\"li\",null,{\"children\":\"Operating system\"}],[\"$\",\"li\",null,{\"children\":\"Access times and pages viewed\"}],[\"$\",\"li\",null,{\"children\":\"Referring URLs\"}],[\"$\",\"li\",null,{\"children\":\"Device information (device type, screen resolution)\"}],[\"$\",\"li\",null,{\"children\":\"Approximate location data\"}],[\"$\",\"li\",null,{\"children\":\"Interactions with site features (searches, filters, map interactions)\"}]]}],[\"$\",\"p\",null,{\"className\":\"mt-3 text-sm leading-relaxed\",\"children\":\"This data is generally aggregated and anonymized where possible and is used for:\"}],[\"$\",\"ul\",null,{\"className\":\"mt-3 ml-6 list-disc space-y-2 text-sm text-slate-600\",\"children\":[[\"$\",\"li\",null,{\"children\":\"Analytics to understand how users interact with our Site and improve our Services\"}],[\"$\",\"li\",null,{\"children\":\"Monitoring site performance, identifying technical issues, and ensuring security\"}],[\"$\",\"li\",null,{\"children\":\"Understanding trends to enhance user experience and develop new features\"}]]}]]}]\n6:[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-xl font-semibold text-slate-900\",\"children\":\"C. Cookies and Tracking Technologies\"}],[\"$\",\"p\",null,{\"className\":\"mt-3 text-sm leading-relaxed\",\"children\":\"We and our third-party partners, including advertising partners like Google AdSense and analytics providers like Google Analytics, may use cookies, web beacons, tracking pixels, and other tracking technologies on the Site. These technologies help customize the Site, improve your experience, measure the effectiveness of advertising campaigns, and display relevant advertisements.\"}],[\"$\",\"div\",null,{\"className\":\"mt-4 space-y-3\",\"children\":[[\"$\",\"p\",null,{\"className\":\"text-sm font-semibold text-slate-900\",\"children\":\"Essential Cookies:\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-slate-600\",\"children\":\"Some cookies are necessary for the basic functionality of the Site, such as remembering your preferences, keeping you signed in, and maintaining site security.\"}],[\"$\",\"p\",null,{\"className\":\"text-sm font-semibold text-slate-900\",\"children\":\"Analytics Cookies:\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-slate-600\",\"children\":\"We use services like Google Analytics to collect information about your use of the Site (e.g., pages visited, time spent). This information is aggregated and helps us understand user behavior and improve our Services.\"}],[\"$\",\"p\",null,{\"className\":\"text-sm font-semibold text-slate-900\",\"children\":\"Advertising Cookies:\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-slate-600\",\"children\":\"Third-party vendors, including Google (via AdSense), use cookies to serve ads based on a user's prior visits to our website or other websites. Google's use of advertising cookies enables it and its partners to serve ads to our users based on their visit to our Site and/or other sites on the Internet.\"}]]}],[\"$\",\"p\",null,{\"className\":\"mt-4 text-sm leading-relaxed\",\"children\":\"You can manage your ad preferences:\"}],[\"$\",\"ul\",null,{\"className\":\"mt-3 ml-6 list-disc space-y-2 text-sm text-slate-600\",\"children\":[[\"$\",\"li\",null,{\"children\":[\"Opt out of personalized advertising by visiting \",[\"$\",\"a\",null,{\"href\":\"https://adssettings.google.com\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"text-violet-600 hover:text-violet-700 underline\",\"children\":\"Google Ad Settings\"}]]}],[\"$\",\"li\",null,{\"children\":[\"Alternatively, you can opt out of many third-party vendor's use of cookies for personalized advertising by visiting \",[\"$\",\"a\",null,{\"href\":\"https://www.aboutads.info/choices\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"text-violet-600 hover:text-violet-700 underline\",\"children\":\"www.aboutads.info/choices\"}],\" or \",[\"$\",\"a\",null,{\"href\":\"https://www.youronlinechoices.eu\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"text-violet-600 hover:text-violet-700 underline\",\"children\":\"www.youronlinechoices.eu\"}],\" (for European users)\"]}],[\"$\",\"li\",null,{\"children\":[\"For more information on how Google uses data when you use our partners' sites or apps, please see \",[\"$\",\"a\",null,{\"href\":\"https://policies.google.com/privacy\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"text-violet-600 hover:text-violet-700 underline\",\"children\":\"Google's Privacy & Terms\"}]]}]]}],[\"$\",\"p\",null,{\"className\":\"mt-4 text-sm leading-relaxed\",\"children\":[\"You can typically remove or reject cookies via your browser settings. To do this, follow the instructions provided by your browser (usually located within the \\\"settings,\\\" \\\"help,\\\" \\\"tools,\\\" or \\\"edit\\\" facility). Most browsers are set to accept cookies by default. Note that if you remove or reject cookies, it could affect the availability and functionality of the Site. You can also manage your cookie preferences by visiting our \",\"$L12\",\" page.\"]}]]}]\n7:[\"$\",\"article\",null,{\"className\":\"rounded-3xl border border-slate-200 bg-slate-50/80 p-6\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-2xl font-bold text-slate-900\",\"children\":\"3. How We Use Your Information\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 text-sm leading-relaxed\",\"children\":\"Having accurate information permits us to provide you with a smooth, efficient, and customized experience. Specifically, we may use information collected about you via the Site to:\"}],[\"$\",\"ul\",null,{\"className\":\"mt-4 ml-6 list-disc space-y-2 text-sm text-slate-600\",\"children\":[[\"$\",\"li\",null,{\"children\":\"Provide, operate, and maintain our Site and Services, including displaying park listings, reviews, and directory information\"}],[\"$\",\"li\",null,{\"children\":\"Improve, personalize, and expand our Site and Services based on user interaction and feedback\"}],[\"$\",\"li\",null,{\"children\":\"Understand and analyze how you use our Site and Services to enhance user experience, develop new features, and optimize existing ones\"}],[\"$\",\"li\",null,{\"children\":\"Respond to your comments, questions, and requests submitted via contact forms or other communication channels\"}],[\"$\",\"li\",null,{\"children\":\"Verify businesses, prevent fraud, and enforce our community guidelines\"}],[\"$\",\"li\",null,{\"children\":\"Send transactional messages (account notifications, receipts, status updates) and marketing communications when permitted\"}],[\"$\",\"li\",null,{\"children\":\"Monitor and analyze usage patterns and trends to improve the Site's functionality, security, and performance\"}],[\"$\",\"li\",null,{\"children\":\"Prevent fraudulent activity, protect the security of our Site and users, and investigate potential violations of our terms\"}],[\"$\",\"li\",null,{\"children\":\"Display advertisements (e.g., via Google AdSense) to support the free nature of our Services and cover operational costs\"}],[\"$\",\"li\",null,{\"children\":\"Comply with legal obligations, resolve disputes, and enforce our terms and conditions\"}],[\"$\",\"li\",null,{\"children\":\"Send you technical notices, updates, security alerts, and support messages if necessary\"}]]}]]}]\n8:[\"$\",\"article\",null,{\"className\":\"rounded-3xl border border-slate-200 bg-white p-6\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-2xl font-bold text-slate-900\",\"children\":\"4. Disclosure of Your Information\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 text-sm leading-relaxed\",\"children\":\"We do not sell, trade, rent, or otherwise transfer your personally identifiable information (like name and email) to outside parties for their marketing purposes without your consent. We may share information under the following circumstances:\"}],[\"$\",\"div\",null,{\"className\":\"mt-6 space-y-6\",\"children\":[[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-xl font-semibold text-slate-900\",\"children\":\"By Law or to Protect Rights\"}],[\"$\",\"p\",null,{\"className\":\"mt-3 text-sm leading-relaxed\",\"children\":\"If we believe the release of information about you is necessary to respond to legal process (e.g., subpoena, court order), to investigate or remedy potential violations of our policies, or to protect the rights, property, and safety of IndoorDogPark, our users, or others, we may share your information as permitted or required by any applicable law, rule, or regulation.\"}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-xl font-semibold text-slate-900\",\"children\":\"Third-Party Service Providers\"}],[\"$\",\"p\",null,{\"className\":\"mt-3 text-sm leading-relaxed\",\"children\":\"We may share your information with third-party vendors, service providers, contractors, or agents who perform services for us or on our behalf and require access to such information to do that work. Examples include:\"}],[\"$\",\"ul\",null,{\"className\":\"mt-3 ml-6 list-disc space-y-2 text-sm text-slate-600\",\"children\":[[\"$\",\"li\",null,{\"children\":\"Data analysis and website analytics (e.g., Google Analytics)\"}],[\"$\",\"li\",null,{\"children\":\"Email delivery for contact form responses and newsletters\"}],[\"$\",\"li\",null,{\"children\":\"Hosting services and cloud infrastructure providers\"}],[\"$\",\"li\",null,{\"children\":\"Payment processing services (e.g., Stripe)\"}],[\"$\",\"li\",null,{\"children\":\"Map and geolocation services\"}]]}],[\"$\",\"p\",null,{\"className\":\"mt-3 text-sm leading-relaxed\",\"children\":\"We only share the minimum information necessary for them to perform their designated functions, and we make reasonable efforts to ensure they are obligated to maintain the confidentiality and security of your information.\"}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-xl font-semibold text-slate-900\",\"children\":\"Advertising Partners\"}],[\"$\",\"p\",null,{\"className\":\"mt-3 text-sm leading-relaxed\",\"children\":\"As mentioned, we allow third-party advertising partners like Google AdSense to use tracking technologies on the Site. This allows them to collect information about your interaction with our Site and other websites to display relevant advertisements. This information is collected directly by these third parties, and their use of it is governed by their own privacy policies. We do not share your personally identifiable information (like name or email) directly with advertisers.\"}],[\"$\",\"p\",null,{\"className\":\"mt-3 text-sm leading-relaxed\",\"children\":\"Specifically, Google and other third-party vendors may place and read cookies on your browser, or use web beacons to collect information, as a result of ad serving on our website. This includes collecting device-specific information (such as device type, operating system, and browser type), IP addresses, and approximate location data to deliver relevant advertisements.\"}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-xl font-semibold text-slate-900\",\"children\":\"Park Owners or Partners\"}],\"$L13\"]}],\"$L14\"]}]]}]\n9:[\"$\",\"article\",null,{\"className\":\"rounded-3xl border border-slate-200 bg-slate-50/80 p-6\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-2xl font-bold text-slate-900\",\"children\":\"5. Data Security\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 text-sm leading-relaxed\",\"children\":\"We use administrative, technical, and physical security measures to help protect your personal information. This includes using HTTPS (SSL/TLS) for data transmission between your browser and our Site, and relying on the security practices of our hosting providers and service partners.\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 text-sm leading-relaxed\",\"children\":\"However, please be aware that despite our efforts, no security measures are perfect or impenetrable, and no method of data transmission can be guaranteed against any interception or other type of misuse. Any information disclosed online is vulnerable to interception and misuse by unauthorized parties. Therefore, we cannot guarantee absolute security if you provide personal information.\"}]]}]\na:[\"$\",\"article\",null,{\"className\":\"rounded-3xl border border-slate-200 bg-white p-6\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-2xl font-bold text-slate-900\",\"children\":\"6. Your Data Rights (e.g., GDPR, CCPA)\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 text-sm leading-relaxed\",\"children\":\"Depending on your geographic location and applicable data protection laws, you may have certain rights regarding your personal information. These may include:\"}],[\"$\",\"ul\",null,{\"className\":\"mt-4 ml-6 list-disc space-y-2 text-sm text-slate-600\",\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"The right to access\"}],\" – You have the right to request copies of your personal data that we hold\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"The right to rectification\"}],\" – You have the right to request that we correct any information you believe is inaccurate or complete information you believe is incomplete\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"The right to erasure (Right to be Forgotten)\"}],\" – You have the right to request that we erase your personal data that we hold, under certain conditions\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"The right to restrict processing\"}],\" – You have the right to request that we restrict the processing of your personal data, under certain conditions\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"The right to object to processing\"}],\" – You have the right to object to our processing of your personal data, under certain conditions\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"The right to data portability\"}],\" – You have the right to request that we transfer the data that we have collected (that pertains to you) to another organization, or directly to you, under certain conditions\"]}]]}],[\"$\",\"p\",null,{\"className\":\"mt-4 text-sm leading-relaxed\",\"children\":\"If you are a resident of the European Economic Area (EEA), you are covered by the General Data Protection Regulation (GDPR). If you are a California resident, you are covered by the California Consumer Privacy Act (CCPA) / California Privacy Rights Act (CPRA).\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 text-sm leading-relaxed\",\"children\":[\"To exercise these rights, or to make inquiries about your data, please contact us at \",[\"$\",\"a\",null,{\"href\":\"mailto:media@indoordogpark.org\",\"className\":\"text-violet-600 hover:text-violet-700 underline\",\"children\":\"media@indoordogpark.org\"}],\". We respond within 30 days unless additional verification is required. For managing advertising preferences related to cookies, please refer to the \\\"Cookies and Tracking Technologies\\\" section and the opt-out links provided.\"]}],[\"$\",\"p\",null,{\"className\":\"mt-4 text-sm leading-relaxed\",\"children\":\"We do not \\\"sell\\\" your personal information in the traditional sense of exchanging it for monetary compensation. However, the use of advertising cookies by third parties like Google AdSense for personalized advertising may be considered a \\\"sale\\\" or \\\"sharing\\\" under laws like the CCPA/CPRA. You can opt-out of such personalized advertising as described in the \\\"Cookies and Tracking Technologies\\\" section.\"}]]}]\nb:[\"$\",\"article\",null,{\"className\":\"rounded-3xl border border-slate-200 bg-slate-50/80 p-6\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-2xl font-bold text-slate-900\",\"children\":\"7. Children's Privacy\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 text-sm leading-relaxed\",\"children\":\"Our Site and Services are not directed to, and we do not knowingly collect personally identifiable information from, children under the age of 13 (or a higher age threshold as required by applicable law, e.g., 16 in certain EEA jurisdictions). If we become aware that we have inadvertently collected personal information from a child under the relevant age without verifiable parental consent, we will take commercially reasonable steps to delete that information from our records as quickly as possible.\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 text-sm leading-relaxed\",\"children\":[\"If you believe we might have any information from or about a child under the relevant age, please contact us at \",[\"$\",\"a\",null,{\"href\":\"mailto:media@indoordogpark.org\",\"className\":\"text-violet-600 hover:text-violet-700 underline\",\"children\":\"media@indoordogpark.org\"}],\" so we can take appropriate action.\"]}]]}]\nc:[\"$\",\"article\",null,{\"className\":\"rounded-3xl border border-slate-200 bg-white p-6\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-2xl font-bold text-slate-900\",\"children\":\"8. Third-Party Websites\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 text-sm leading-relaxed\",\"children\":\"The Site may contain links to third-party websites and applications of interest, including advertisements and external services (e.g., social media platforms, park websites), that are not affiliated with us or operated by us. Once you have used these links to leave the Site, any information you provide to these third parties is not covered by this Privacy Policy, and we cannot guarantee the safety and privacy of your information.\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 text-sm leading-relaxed\",\"children\":\"Before visiting and providing any information to any third-party websites, you should inform yourself of the privacy policies and practices (if any) of the third party responsible for that website, and should take those steps necessary to, in your discretion, protect the privacy of your information. We are not responsible for the content or privacy and security practices and policies of any third parties, including other sites, services, or applications that may be linked to or from the Site.\"}]]}]\nd:[\"$\",\"article\",null,{\"className\":\"rounded-3xl border border-slate-200 bg-slate-50/80 p-6\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-2xl font-bold text-slate-900\",\"children\":\"9. Changes to This Privacy Policy\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 text-sm leading-relaxed\",\"children\":\"We may update this Privacy Policy from time to time to reflect changes to our practices, new features, or for other operational, legal, or regulatory reasons. We will notify you of any material changes by posting the new Privacy Policy on this page and updating the \\\"Last Updated\\\" date at the top. You are advised to review this Privacy Policy periodically for any changes. Changes to this Privacy Policy are effective when they are posted on this page.\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 text-sm leading-relaxed\",\"children\":\"Your continued use of our Site or Services after such modifications will constitute your: (a) acknowledgment of the modified Privacy Policy; and (b) agreement to abide and be bound by that Policy.\"}]]}]\ne:[\"$\",\"article\",null,{\"className\":\"rounded-3xl border border-slate-200 bg-white p-6\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-2xl font-bold text-slate-900\",\"children\":\"10. Contact Us\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 text-sm leading-relaxed\",\"children\":[\"If you have questions, comments, or concerns about this Privacy Policy, our data handling practices, or your choices, please contact us using the \",[\"$\",\"$L15\",null,{\"href\":\"/contact\",\"className\":\"text-violet-600 hover:text-violet-700 underline\",\"children\":\"Contact Us\"}],\" form available on our Site.\"]}]]}]\nf:[\"$\",\"$L16\",null,{}]\n10:[\"$\",\"footer\",null,{\"className\":\"footer-new\",\"children\":[\"$\",\"div\",null,{\"className\":\"footer-container\",\"children\":[[\"$\",\"div\",null,{\"className\":\"footer-grid\",\"children\":[[\"$\",\