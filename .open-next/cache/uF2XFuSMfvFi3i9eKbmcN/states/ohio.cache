:{\"buildId\":\"uF2XFuSMfvFi3i9eKbmcN\",\"rsc\":[\"$\",\"$1\",\"c\",{\"children\":[[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"suppressHydrationWarning\":true,\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://www.indoordogpark.org/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"States\\\",\\\"item\\\":\\\"https://www.indoordogpark.org/states\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Ohio\\\",\\\"item\\\":\\\"https://www.indoordogpark.org/states/ohio\\\"}]}\"}}],[\"$\",\"$L2\",null,{\"variant\":\"light\"}],[\"$\",\"$L3\",null,{}],[\"$\",\"main\",null,{\"className\":\"state-page-layout\",\"children\":[[\"$\",\"section\",null,{\"className\":\"state-hero-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell state-hero-shell\",\"children\":[[\"$\",\"div\",null,{\"className\":\"state-hero-copy\",\"children\":[[\"$\",\"nav\",null,{\"className\":\"hero-breadcrumbs\",\"aria-label\":\"Breadcrumb\",\"children\":[[\"$\",\"$L4\",null,{\"href\":\"/\",\"children\":\"Home\"}],[\"$\",\"span\",null,{\"children\":\"›\"}],[\"$\",\"$L4\",null,{\"href\":\"/states\",\"children\":\"States\"}],[\"$\",\"span\",null,{\"children\":\"›\"}],[\"$\",\"span\",null,{\"children\":\"Ohio\"}]]}],[\"$\",\"div\",null,{\"className\":\"hero-eyebrow\",\"children\":\"Buckeye State Dog Parks\"}],[\"$\",\"h1\",null,{\"children\":\"Dog Parks in Ohio\"}],[\"$\",\"div\",null,{\"className\":\"hero-description\",\"children\":[[\"$\",\"p\",\"0\",{\"children\":[\"Ohio has quietly emerged as a Midwestern leader in dog park development, driven by affordable land costs that allow for spacious facilities uncommon in coastal states. The Columbus metro area boasts one of the most impressive park systems in the region, with facilities like the 33-acre Scioto Audubon Metro Park dog area offering wetlands, prairie, and woodland terrain in a single visit. Cleveland's Metroparks system maintains dedicated off-leash areas with Lake Erie views, while Cincinnati's iconic Mount Airy Forest houses one of the oldest continuously operating dog parks in the Midwest, established in 1996.\"]}],[\"$\",\"p\",\"1\",{\"children\":[\"Ohio's four-season climate has shaped its dog park culture in practical ways. Indoor facilities have grown significantly in Columbus and Cleveland to serve dog owners during harsh winters, while summer brings packed weekend crowds to lakefront and river-adjacent parks. The state's strong community culture means most neighborhoods have active dog owner networks that organize regular cleanup days and social events. Ohio also leads the region in \\\"dog-friendly brewery\\\" culture, with taprooms across all major cities welcoming pups on patios. Our directory tracks over 120 verified Ohio locations with special attention to seasonal hours, surface conditions, and amenities that matter during the state's variable weather.\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-cta-row\",\"children\":[[\"$\",\"$L4\",null,{\"href\":\"/cities\",\"className\":\"hero-cta primary\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-map\"}],\"Browse cities\"]}],[\"$\",\"$L4\",null,{\"href\":\"/list-your-park\",\"className\":\"hero-cta ghost\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-plus-circle\"}],\"Submit a park\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-footnotes\",\"children\":[[\"$\",\"span\",\"Major metros fully covered\",{\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-arrow-repeat\"}],\" \",\"Major metros fully covered\"]}],[\"$\",\"span\",\"Seasonal hours tracked\",{\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-arrow-repeat\"}],\" \",\"Seasonal hours tracked\"]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"state-hero-visual\",\"children\":[\"$\",\"div\",