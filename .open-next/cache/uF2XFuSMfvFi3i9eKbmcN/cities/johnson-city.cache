\"className\\\":\\\"resource-icon\\\",\\\"children\\\":[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-journal-text\\\"}]}],[\\\"$\\\",\\\"h3\\\",null,{\\\"children\\\":\\\"Latest guides\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Training tips, travel itineraries, and product spotlights.\\\"}],[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-arrow-up-right\\\"}]]}]]}]]}]}]\\n\"])</script><script>self.__next_f.push([1,\"3e:[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"© 2025 IndoorDogPark. All rights reserved\\\"}]\\n3f:[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"footer-bottom-links\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L12\\\",null,{\\\"href\\\":\\\"/terms\\\",\\\"children\\\":\\\"Terms\\\"}],[\\\"$\\\",\\\"$L12\\\",null,{\\\"href\\\":\\\"/privacy\\\",\\\"children\\\":\\\"Privacy\\\"}],[\\\"$\\\",\\\"$L12\\\",null,{\\\"href\\\":\\\"/cookie-preferences\\\",\\\"children\\\":\\\"Cookie Preferences\\\"}]]}]\\n\"])</script><script>self.__next_f.push([1,\"4e:I[86869,[],\\\"IconMark\\\"]\\n1c:null\\n\"])</script><script>self.__next_f.push([1,\"20:[[\\\"$\\\",\\\"title\\\",\\\"0\\\",{\\\"children\\\":\\\"Dog Parks in Johnson City, TN | Map \\u0026 Reviews | Indoor...\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"1\\\",{\\\"name\\\":\\\"description\\\",\\\"content\\\":\\\"Explore 41 dog parks and dog-friendly spots in Johnson City. Compare ratings, amenities, hours, and map locations.\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"2\\\",{\\\"name\\\":\\\"application-name\\\",\\\"content\\\":\\\"Indoor Dog Park\\\"}],[\\\"$\\\",\\\"link\\\",\\\"3\\\",{\\\"rel\\\":\\\"author\\\",\\\"href\\\":\\\"https://www.indoordogpark.org\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"4\\\",{\\\"name\\\":\\\"author\\\",\\\"content\\\":\\\"Indoor Dog Park Team\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"5\\\",{\\\"name\\\":\\\"keywords\\\",\\\"content\\\":\\\"indoor dog park,dog play area,dog recreation,indoor dog facility,dog daycare,dog training,dog boarding,pet services,canine activities,off-leash dog a