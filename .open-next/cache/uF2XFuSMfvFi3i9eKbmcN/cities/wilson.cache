":\"city-hero-section \",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell city-hero-shell\",\"children\":[[\"$\",\"div\",null,{\"className\":\"city-hero-copy\",\"children\":[[\"$\",\"div\",null,{\"className\":\"hero-breadcrumbs\",\"children\":[[\"$\",\"$L12\",null,{\"href\":\"/\",\"children\":\"Home\"}],[\"$\",\"i\",null,{\"className\":\"bi bi-chevron-right\"}],[\"$\",\"span\",null,{\"children\":\"Dog Parks Directory\"}],[\"$\",\"i\",null,{\"className\":\"bi bi-chevron-right\"}],[\"$\",\"strong\",null,{\"children\":\"Wilson\"}]]}],[\"$\",\"p\",null,{\"className\":\"hero-eyebrow\",\"children\":\"City of Innovation\"}],[\"$\",\"h1\",null,{\"children\":\"Wilson Whirls\"}],[\"$\",\"div\",null,{\"className\":\"hero-chip-row\",\"children\":[[\"$\",\"div\",\"0\",{\"className\":\"hero-chip\",\"children\":[[\"$\",\"span\",null,{\"className\":\"chip-label\",\"children\":\"Dog Park\"}],[\"$\",\"span\",null,{\"className\":\"chip-value\",\"children\":\"yes\"}],\"$undefined\"]}],[\"$\",\"div\",\"1\",{\"className\":\"hero-chip\",\"children\":[[\"$\",\"span\",null,{\"className\":\"chip-label\",\"children\":\"Art Park\"}],[\"$\",\"span\",null,{\"className\":\"chip-value\",\"children\":\"Unique\"}],\"$undefined\"]}]]}],[\"$\",\"p\",null,{\"className\":\"hero-description\",\"children\":\"Wilson is famous for its Whirligig Park, but its investment in pet amenities is just as impressive. The Wilson Dog Park and Lake Wilson offer diverse experiences.\"}],[\"$\",\"div\",null,{\"className\":\"city-rich-description\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"rich-description-paragraph\",\"children\":[\"Wilson, North Carolina, offers a dog-friendly experience that is infused with art and innovation. The \",[\"$\",\"$L12\",\"1\",{\"href\":\"https://www.wilsonwhirligigpark.org\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"rich-link\",\"children\":\"Vollis Simpson Whirligig Park\"}],null,\" provides a stunning backdrop for a walk, with massive, kinetic sculptures spinning overhead. Leashed dogs are welcome in this green space, making for a walk unlike any other in the state. It serves as the anchor for a revitalized downtown that is becoming increasingly walkable and welcoming.\"]}],[\"$\",\"p\",\"1\",{\"className\":\"rich-description-paragraph\",\"children\":[\"For specialized canine recreation, the \",[\"$\",\"$L12\",\"1\",{\"href\":\"https://www.wilsonnc.org/government/departments/parks-recreation/dog-park\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"rich-link\",\"children\":\"Wilson Dog Park\"}],null,\" on Lawndale Drive is excellent. It features agility equipment, water stations, and separate areas for different sized dogs, showing the city’s commitment to providing high-quality amenities. Additionally, the loop trail around Lake Wilson offers a serene escape for those looking to enjoy nature. Wilson proves that a city can support both cultural tourism and a practical, \",[\"$\",\"$L12\",\"4\",{\"href\":\"https://www.indoordogpark.org/\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"rich-link\",\"children\":\"pet-friendly lifestyle\"}],null,\".\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-cta-row\",\"children\":[[\"$\",\"$L30\",null,{\"className\":\"hero-cta primary\",\"targetId\":\"park-directory\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-list-check\"}],\"Browse directory\"]}],[\"$\",\"$L30\",null,{\"className\":\"hero-cta ghost\",\"targetId\":\"map-and-neighborhoods\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-geo-alt\"}],\"Open map\"]}],[\"$\",\"$L12\",null,{\"href\":\"/list-your-park\",\"className\":\"hero-cta text-link\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-plus-circle\"}],\"Submit a park\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-footnotes\",\"children\":[[\"$\",\"span\",\"Wilson Dog Park\",{\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-sparkles\"}],\" \",\"Wilson Dog Park\"]}],[\"$