rt both cultural tourism and a practical, \",[\"$\",\"$L12\",\"4\",{\"href\":\"https://www.indoordogpark.org/\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"rich-link\",\"children\":\"pet-friendly lifestyle\"}],null,\".\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-cta-row\",\"children\":[[\"$\",\"$L30\",null,{\"className\":\"hero-cta primary\",\"targetId\":\"park-directory\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-list-check\"}],\"Browse directory\"]}],[\"$\",\"$L30\",null,{\"className\":\"hero-cta ghost\",\"targetId\":\"map-and-neighborhoods\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-geo-alt\"}],\"Open map\"]}],[\"$\",\"$L12\",null,{\"href\":\"/list-your-park\",\"className\":\"hero-cta text-link\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-plus-circle\"}],\"Submit a park\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-footnotes\",\"children\":[[\"$\",\"span\",\"Wilson Dog Park\",{\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-sparkles\"}],\" \",\"Wilson Dog Park\"]}],[\"$\",\"span\",\"Whirligig Park\",{\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-sparkles\"}],\" \",\"Whirligig Park\"]}],[\"$\",\"span\",\"Lake Wilson\",{\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-sparkles\"}],\" \",\"Lake Wilson\"]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"city-hero-visual\",\"children\":[\"$\",\"div\",null,{\"className\":\"hero-image-card\",\"children\":[[\"$\",\"$L31\",null,{\"src\":\"/images/cities/wilson-nc/hero.png\",\"alt\":\"Wilson dog park landscape\",\"fill\":true,\"priority\":true,\"sizes\":\"(max-width: 768px) 100vw, 540px\",\"unoptimized\":true}],\"$L32\"]}]}]]}]}],\"$L33\",\"$L34\",\"$L35\",\"$L36\",\"$L37\",\"$L38\",\"$undefined\",\"$L39\",\"$L3a\",\"$L3b\",\"$L3c\",\"$L3d\"]}]\n2b:[\"$\",\"footer\",null,{\"className\":\"footer-new\",\"children\":[\"$\",\"div\",null,{\"className\":\"footer-container\",\"children\":[[\"$\",\"div\",null,{\"className\":\"footer-grid\",