gpark.org/blog\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"rich-link\",\"children\":\"blog\"}],null,\" for upcoming event announcements.\"]}]]}]\n29:[\"$\",\"div\",null,{\"className\":\"hero-cta-row\",\"children\":[[\"$\",\"$L25\",null,{\"className\":\"hero-cta primary\",\"targetId\":\"park-directory\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-list-check\"}],\"Browse directory\"]}],[\"$\",\"$L25\",null,{\"className\":\"hero-cta ghost\",\"targetId\":\"map-and-neighborhoods\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-geo-alt\"}],\"Open map\"]}],[\"$\",\"$L12\",null,{\"href\":\"/list-your-park\",\"className\":\"hero-cta text-link\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-plus-circle\"}],\"Submit a park\"]}]]}]\n2a:[\"$\",\"div\",null,{\"className\":\"hero-footnotes\",\"children\":[[\"$\",\"span\",\"Data refreshed weekly\",{\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-sparkles\"}],\" \",\"Data refreshed weekly\"]}],[\"$\",\"span\",\"Live availability coming soon\",{\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-sparkles\"}],\" \",\"Live availability coming soon\"]}]]}]\n2b:[\"$\",\"div\",null,{\"className\":\"city-hero-visual\",\"children\":[\"$\",\"div\",null,{\"className\":\"hero-image-card\",\"children\":[[\"$\",\"$L38\",null,{\"src\":\"/images/cities/wichita-ks/hero.webp\",\"alt\":\"Wichita dog park landscape\",\"fill\":true,\"priority\":true,\"sizes\":\"(max-width: 768px) 100vw, 540px\",\"unoptimized\":true}],[\"$\",\"div\",null,{\"className\":\"hero-image-gradient\"}]]}]}]\n2c:[\"$\",\"$L39\",null,{\"city\":\"Wichita\",\"state\":\"KS\"}]\n2d:[\"$\",\"section\",null,{\"id\":\"city-insights\",\"className\":\"city-insights-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell\",\"children\":false}]}]\n2e:[\"$\",\"section\",null,{\"id\":\"city-comparison\",\"className\":\"city-comparison-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell\",