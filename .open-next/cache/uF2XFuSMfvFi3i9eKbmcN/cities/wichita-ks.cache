ial turf, making it a convenient stop for urban dwellers.\"}}]}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://www.indoordogpark.org/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Dog Parks Directory\",\"item\":\"https://www.indoordogpark.org/\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Wichita\"}]}</script><header class=\"header header-visible  header-light\"><div class=\"header-container\"><div class=\"header-left\"><a class=\"logo\" href=\"/\"><img alt=\"Indoor Dog Park logo\" width=\"140\" height=\"40\" decoding=\"async\" data-nimg=\"1\" style=\"color:transparent;object-fit:contain;height:auto\" src=\"/images/logo/logo.png\"/></a></div><div class=\"header-center\"><nav class=\"header-nav\" aria-label=\"Main navigation\"><a class=\"header-nav-link\" href=\"/\">Browse Parks</a><div class=\"header-nav-item\"><button class=\"header-nav-link\" aria-haspopup=\"true\" aria-expanded=\"false\">Discover <i class=\"bi bi-chevron-down dropdown-icon \"></i></button><div class=\"header-dropdown \"><a class=\"header-dropdown-link\" href=\"/parks-with-bars\">Parks with Bars</a><a class=\"header-dropdown-link\" href=\"/training-facilities\">Training Facilities</a><a class=\"header-dropdown-link\" href=\"/how-it-works\">How It Works</a></div></div><div class=\"header-nav-item\"><button class=\"header-nav-link\" aria-haspopup=\"true\" aria-expanded=\"false\">Locations <i class=\"bi bi-chevron-down dropdown-icon \"></i></button><div class=\"header-dropdown \"><a class=\"header-dropdown-link\" href=\"/cities/san-francisco\">San Francisco</a><a class=\"header-dropdown-link\" href=\"/cities/los-angeles\">Los Angeles</a><a class=\"header-dropdown-link\" href=\"/cities/san-diego\">San Diego</a><a class=\"header-dropdown-link\" href=\"/cities/new-york\">New York</a><a class=\"header-dropdown-link\" href=\"/cities/