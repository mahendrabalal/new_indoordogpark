sRegion\":\"MI\",\"postalCode\":\"48038\",\"addressCountry\":\"US\"},\"telephone\":\"+1 586-412-3900\",\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":4.3,\"reviewCount\":129},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":42.5855638,\"longitude\":-82.9532274}}]}25:T4dd,{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Does Clinton Township have a dog park?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes, the Clinton Township Dog Park is located at Civic Center Park. It is a member-only facility that offers a safe, fenced environment for off-leash play and socialization.\"}},{\"@type\":\"Question\",\"name\":\"How do I get a membership for the dog park?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Membership applications are available through the Parks and Recreation department. You will need to provide proof of current vaccinations and a valid dog license to register.\"}},{\"@type\":\"Question\",\"name\":\"What are the leash rules in Clinton Township?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Dogs must be kept on a leash no longer than six feet when on public property, including all parks and trails. Owners are also responsible for immediately cleaning up after their pets.\"}},{\"@type\":\"Question\",\"name\":\"Are there dog-friendly trails nearby?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"The Clinton River Trail and other local pathways offer great opportunities for leashed walks. These trails connect various parks and provide a scenic escape for you and your dog.\"}}]}19:[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"suppressHydrationWarning\":true,\"dangerouslySetInnerHTML\":{\"__html\":\"$24\"}}],[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"suppressHydrationWarning\":true,\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"ItemList\\\",\\\"@id\\\":\\\"https://