t\"}],[\"$\",\"h1\",null,{\"children\":\"Dog Parks in Hickory Creek, TX\"}],\"$undefined\",[\"$\",\"p\",null,{\"className\":\"hero-description\",\"children\":\"Explore the natural shoreline and wooded parks of Hickory Creek.\"}],[\"$\",\"div\",null,{\"className\":\"city-rich-description\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"rich-description-paragraph\",\"children\":[\"Hickory Creek maintains a rustic, small-town feel despite its location in the metroplex. The town's parks, like Sycamore Bend, offer direct access to Lewisville Lake for picnics and leashed walks. It is a community that embraces the natural landscape, with many residents enjoying the wooded surroundings. It is a quiet haven for dogs and nature lovers.\"]}],[\"$\",\"p\",\"1\",{\"className\":\"rich-description-paragraph\",\"children\":[\"Town ordinances mandate that dogs be leashed when off private property. Rabies vaccinations are required. Given the proximity to the lake and corps of engineers land, obeying posted rules about wildlife and habitat protection is critical. newer owners can find helpful tips in our \",[\"$\",\"$L12\",\"1\",{\"href\":\"https://www.indoordogpark.org/blog\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"rich-link\",\"children\":\"community blog\"}],null,\". By respecting the environment, Hickory Creek residents ensure their town remains a natural sanctuary.\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-cta-row\",\"children\":[[\"$\",\"$L30\",null,{\"className\":\"hero-cta primary\",\"targetId\":\"park-directory\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-list-check\"}],\"Browse directory\"]}],[\"$\",\"$L30\",null,{\"className\":\"hero-cta ghost\",\"targetId\":\"map-and-neighborhoods\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-geo-alt\"}],\"Open map\"]}],[\"$\",\"$L12\",null,{\"href\":\"/list-your-park\",\"className\":\"hero-cta text-link\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-plus-circle\"}],