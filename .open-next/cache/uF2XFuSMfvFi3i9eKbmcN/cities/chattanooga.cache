,\"Riverwalk accessible\",{\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-sparkles\"}],\" \",\"Riverwalk accessible\"]}]]}]\n14:[\"$\",\"div\",null,{\"className\":\"city-hero-visual\",\"children\":[\"$\",\"div\",null,{\"className\":\"hero-image-card\",\"children\":[[\"$\",\"$L27\",null,{\"src\":\"/images/cities/chattanooga/hero.webp\",\"alt\":\"Chattanooga dog park landscape\",\"fill\":true,\"priority\":true,\"sizes\":\"(max-width: 768px) 100vw, 540px\",\"unoptimized\":true}],[\"$\",\"div\",null,{\"className\":\"hero-image-gradient\"}]]}]}]\n15:[\"$\",\"$L28\",null,{\"city\":\"Chattanooga\",\"state\":\"TN\"}]\n16:[\"$\",\"section\",null,{\"id\":\"city-insights\",\"className\":\"city-insights-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell\",\"children\":[\"$\",\"$L29\",null,{\"parks\":[{\"id\":\"ChIJMzr36V5kYIgRh6GqjOGJ9I0\",\"name\":\"Aqua Dog Grooming Etc.\",\"businessType\":\"Dog Park\",\"description\":\"Pet parents in the area rave about Aqua Dog Grooming Etc..  What makes this dog facility special is its amazing, friendly, wonderful. The staff's dedication to creating a positive experience for both dogs and their owners is evident in every visit. thank you for your amazing service This facility specializes in Pet care and Professional services. For more information, call (423) 596-4748. Visit their website at http://aquadoggrooming.com/?utm_source=google-gmb-maps&utm_medium=gmb-website-button&utm_campaign=locl.io&utm_content=ecd29589-9e7a-4198-9a44-5ad7ddc35095 to learn more about their services and pricing.\",\"slug\":\"aqua-dog-grooming-etc\",\"address\":\"1325 Mackey Branch Dr\",\"street\":\"1325 Mackey Branch Dr\",\"city\":\"Chattanooga\",\"state\":\"TN\",\"zipCode\":\"37421\",\"full_address\":\"1325 Mackey Branch Dr, Chattanooga, TN 37421, USA\",\"latitude\":35.012655,\"longitude\":-85.15657569999999,\"googlePlaceId\":\"ChIJMzr36V5kYIgRh6GqjOGJ9I0\",\"phone\":\"(423) 596-4748\",\"website\":\"http://aquadoggrooming.com/?utm_source=google-gmb-maps&utm_medium=gmb-website-button&utm_campaign=locl.io&utm_content=ecd29589-9e7a-4198-9a44-5ad7ddc35095\",\"photos\":null,\"rating\":4.5,\"reviewCount\":300,\"openingHours\":{\"Monday\":\"7:00 AM – 6:30 PM\",\"Tuesday\":\"7:00 AM – 6:30 PM\",\"Wednesday\":\"7:00 AM – 6:30 PM\",\"Thursday\":\"7:00 AM – 6:30 PM\",\"Friday\":\"7:00 AM – 6:30 PM\",\"Saturday\":\"9:00 AM – 6:00 PM\",\"Sunday\":\"10:00 AM – 2:00 PM\"},\"amenities\":{\"Onsite services\":true,\"Indoor facilities\":true,\"Professional staff\":true,\"Climate controlled\":true,\"Wheelchair accessible entrance\":true,\"Parking available\":true,\"Easy access\":true},\"pricing\":{\"pricingSource\":\"website\",\"isFree\":false},\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"lastUpdated\":null,\"dataQuality\":\"verified\",\"photo\":null,\"faqs\":[],\"source\":\"static\",\"listingType\":\"free\"},{\"id\":\"ChIJmWAJgXweX4gRsgqdtv32SJ4\",\"name\":\"Barking Bubbles MOBILE Pet Salon\",\"businessType\":\"Dog Park\",\"description\":\"Pet parents in the area rave about Barking Bubbles MOBILE Pet Salon.  What makes this dog facility special is its amazing, wonderful, friendly. The staff's dedication to creating a positive experience for both dogs and their owners is evident in every visit. ashley is amazing This facility specializes in Pet care and Professional services. For more information, call (423) 203-0393. Visit their website at http://www.barkingbubblespet.com/ to learn more about their services and pricing.\",\"slug\":\"barking-bubbles-mobile-pet-salon\",\"address\":\"905 Spinnaker Way\",\"street\":\"905 Spinnaker Way\",\"city\":\"Chattanooga\",\"state\":\"TN\",\"zipCode\":\"37402\",\"full_address\":\"905 Spinnaker Way, Chattanooga, TN 37402, USA\",\"latitude\":35.0517842,\"longitude\":-85.32303859999999,\"googlePlaceId\":\"ChIJmWAJgXweX4gRsgqdtv32SJ4\",\"phone\":\"(423) 203-0393\",\"website\":\"http://www.barkingbubblespet.com/\",\"photos\":null,\"rating\":4.9,\"reviewCount\":363,\"