,\\\"children\\\":[\\\"$\\\",\\\"$L30\\\",null,{\\\"className\\\":\\\"mobile-toc-trigger\\\",\\\"targetSelector\\\":\\\".table-of-contents\\\",\\\"children\\\":[[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-list-ul\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"children\\\":\\\"Contents\\\"}]]}]}],[\\\"$\\\",\\\"section\\\",null,{\\\"id\\\":\\\"city-hero\\\",\\\"className\\\":\\\"city-hero-section \\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"section-shell city-hero-shell\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"city-hero-copy\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"hero-breadcrumbs\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L12\\\",null,{\\\"href\\\":\\\"/\\\",\\\"children\\\":\\\"Home\\\"}],[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-chevron-right\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"children\\\":\\\"Dog Parks Directory\\\"}],[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-chevron-right\\\"}],[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"Brooklyn\\\"}]]}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"hero-eyebrow\\\",\\\"children\\\":\\\"City spotlight\\\"}],[\\\"$\\\",\\\"h1\\\",null,{\\\"children\\\":\\\"Indoor Dog Park in Brooklyn\\\"}],\\\"$undefined\\\",[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"hero-description\\\",\\\"children\\\":\\\"From Prospect Park to industrial chic warehouse runs, explore Brooklyn’s legendary dog scene.\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"city-rich-description\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",\\\"0\\\",{\\\"className\\\":\\\"rich-description-paragraph\\\",\\\"children\\\":[\\\"Brooklyn is widely regarded as one of the most dog-friendly boroughs in the world, characterized by its massive parks and a culture that treats pets as family. Prospect Park, designed by the same architects as Central Park, offers legendary off-leash hours that transform the Long Meadow into a canine social hub every morning. The borough's diverse neighborhoods, from the historic brownstones of Park Slope to the industrial-chic warehouses of Williamsburg and Bushwick, have fostered a thriving industry of boutique pet shops, dog-friendly breweries, and specialized indoor play spaces.\\\"]}],[\\\"$\\\",\\\"p\\\",\\\"1\\\",{\\\"className\\\":\\\"rich-description-paragraph\\\",\\\"children\\\":[\\\"The Brooklyn dog experience is defined by community integration. Whether it's a stroll along the Brooklyn Heights Promenade with skyline views or a weekend outing to the McCarren Park dog run, there's always a place for pups to socialize. The borough's commitment to pet-friendly infrastructure is evident in its numerous well-maintained dog runs and the widespread acceptance of leashed pets in outdoor seating areas. For pet parents seeking a vibrant, urban lifestyle with plenty of green space, Brooklyn remains the gold standard.\\\"]}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"hero-cta-row\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L30\\\",null,{\\\"className\\\":\\\"hero-cta primary\\\",\\\"targetId\\\":\\\"park-directory\\\",\\\"children\\\":[[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-list-check\\\"}],\\\"Browse directory\\\"]}],[\\\"$\\\",\\\"$L30\\\",null,{\\\"className\\\":\\\"hero-cta ghost\\\",\\\"targetId\\\":\\\"map-and-neighborhoods\\\",\\\"children\\\":[[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-geo-alt\\\"}],\\\"Open map\\\"]}],[\\\"$\\\",\\\"$L12\\\",null,{\\\"href\\\":\\\"/list-your-park\\\",\\\"className\\\":\\\"hero-cta text-link\\\",\\\"children\\\":[[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-plus-circle\\\"}],\\\"Submit a park\\\"]}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"hero-footnotes\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",\\\"Data refreshed weekly\\\",{\\\"children\\\":[[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-sparkles\\\"}],\\\" \\\",\\\"Data refreshed weekly\\\"]}],[\\\"$\\\",\\\"span\\\",\\\"Live availability coming soon\\\",{\\\"children\\\":[[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-sparkles\\\"}],\\\" \\\",\\\"Live availability coming soon\\\"]}]]}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"city-hero-visual\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"hero-image-card\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L31\\\",null,{\\\"src\\\":\\\"/images/cities/brooklyn/hero.webp\\\",\\\"alt\\\":\\\"Brooklyn dog park landscape\\\",\\\"fill\\\":true,\\\"priority\\\":true,\\\"sizes\\\":\\\"(max-width: 768px) 100vw, 540px\\\",\\\"unoptimized\\\":true}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"hero-image-gradient\\\"}]]}]}]]}]}],[\\\"$\\\",\\\"$L32\\\",null,{\\\"city\\\":\\\"Brooklyn\\\",\\\"state\\\":\\\"NY\\\"}],[\\\"$\\\",\\\"section\\\",null,{\\\"id\\\":\\\"city-insights\\\",\\\"className\\\":\\\"city-insights-section\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"section-shell\\\",\\\"children\\\":[\\\"$\\\",\\\"$L33\\\",null,{\\\"parks\\\":[{\\\"id\\\":\\\"ChIJnXU4VkdbwokRwyeplUq8Sw0\\\",\\\"name\\\":\\\"Acme Dog Run\\\",\\\"businessType\\\":\\\"Dog-Friendly Establishment\\\",\\\"description\\\":\\\"Among Brooklyn's top-rated pet facilities, Acme Dog Run stands out. This facility features professional grooming stations, experienced and certified staff, offering pet care. Their services helps develop good behavior and social skills. conveniently situated for Brooklyn families. Discover why Brooklyn pet parents choose Acme Dog Run\\\",\\\"slug\\\":\\\"acme-dog-run\\\",\\\"address\\\":\\\"188 6th St\\\",\\\"street\\\":\\\"188 6th St\\\",\\\"city\\\":\\\"Brooklyn\\\",\\\"state\\\":\\\"NY\\\",\\\"zipCode\\\":\\\"11215\\\",\\\"full_address\\\":\\\"188 6th St, Brooklyn, NY 11215\\\",\\\"latitude\\\":40.673488,\\\"longitude\\\":-73.9904637,\\\"googlePlaceId\\\":\\\"ChIJnXU4VkdbwokRwyeplUq8Sw0\\\",\\\"phone\\\":\\\"+1 718-935-9364\\\",\\\"website\\\":\\\"http://www.acme