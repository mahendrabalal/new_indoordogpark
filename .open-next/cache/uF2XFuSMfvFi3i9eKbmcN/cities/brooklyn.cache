props:children:props:parks:32\"]}}]}],\"$undefined\"]}]}]\n36:[\"$\",\"section\",null,{\"id\":\"map-and-neighborhoods\",\"className\":\"map-experience-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell\",\"children\":[[\"$\",\"div\",null,{\"className\":\"section-heading\",\"children\":[[\"$\",\"span\",null,{\"className\":\"section-eyebrow\",\"children\":\"Interactive planning\"}],[\"$\",\"h2\",null,{\"children\":\"See everything laid out on the map\"}],[\"$\",\"p\",null,{\"children\":\"Use the live map to lock in nearby options, preview ratings, and save time hopping between neighborhoods.\"}]]}],[\"$\",\"div\",null,{\"className\":\"map-grid\",\"children\":[[\"$\",\"div\",null,{\"className\":\"map-panel\",\"children\":[\"$\",\"$L42\",null,{\"parks\":\"$2a:props:children:3:props:children:props:children:props:parks\"}]}],[\"$\",\"div\",null,{\"className\":\"map-sidebar\",\"children\":[[\"$\",\"div\",null,{\"className\":\"map-sidebar-card\",\"children\":[[\"$\",\"h3\",null,{\"children\":\"Quick filters\"}],[\"$\",\"div\",null,{\"className\":\"map-chip-grid\",\"children\":[[\"$\",\"$L30\",\"Dog-Friendly Establishment\",{\"targetId\":\"dog-friendly-establishment-parks\",\"children\":[[\"$\",\"span\",null,{\"children\":\"Dog-Friendly Establishment\"}],[\"$\",\"small\",null,{\"children\":21}]]}],[\"$\",\"$L30\",\"Dog Park\",{\"targetId\":\"dog-park-parks\",\"children\":[[\"$\",\"span\",null,{\"children\":\"Dog Park\"}],[\"$\",\"small\",null,{\"children\":14}]]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"map-sidebar-card\",\"children\":[[\"$\",\"h3\",null,{\"children\":\"Highest-rated nearby\"}],[\"$\",\"div\",null,{\"className\":\"mini-park-list\",\"children\":[[[\"$\",\"div\",\"ChIJBWNJh3tfwokRWi4OLdU5wnY\",{\"className\":\"mini-park-card\",\"children\":[[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"children\":\"All Dogs In The City Greenpoint\"}],[\"$\",\"span\",null,{\"children\":\"Dog-Friendly Establishment\"}]]}],[\"$\",\"strong\",nul