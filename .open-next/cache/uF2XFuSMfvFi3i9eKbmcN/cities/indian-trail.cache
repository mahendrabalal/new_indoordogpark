addressRegion\":\"NC\",\"addressCountry\":\"US\"},\"image\":\"/images/parks/northcarolina/petbar-boutique-indian-trail/petbar-boutique-indian-trail-1.jpg\"}},{\"@type\":\"ListItem\",\"position\":10,\"item\":{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/chestnut-square-park\",\"name\":\"Chestnut Square Park\",\"url\":\"https://www.indoordogpark.org/parks/chestnut-square-park\",\"description\":\"Among Indian Trail's top-rated facilities, Chestnut Square Park excels in year-round care. This facility features spacious exercise zones, caring and attentive team members, offering pet care. Their...\",\"address\":{\"@type\":\"PostalAddress\",\"addressLocality\":\"Indian Trail\",\"addressRegion\":\"NC\",\"addressCountry\":\"US\"},\"image\":\"/images/parks/northcarolina/chestnut-square-park/chestnut-square-park-1.jpg\"}}]}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Where is the dog park in Indian Trail?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Crooked Creek Park is home to a fantastic dog park with agility equipment and separate size zones. It is a hub for the local pet community.\"}},{\"@type\":\"Question\",\"name\":\"Are there walking trails in Indian Trail?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes, Crooked Creek Park and Chestnut Square Park both offer paved and natural trails loop systems that are perfect for daily dog walking.\"}},{\"@type\":\"Question\",\"name\":\"What are the rules for the dog park?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Crooked Creek Dog Park requires a pass/registration for entry. You will need to provide proof of current vaccinations to get access.\"}},{\"@type\":\"Question\",\"name\":\"Is Indian Trail a pet-friendly town?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes, with its growing park system and suburban layout, it is very family and pet-oriented. Many local events at Crossing Paths Park are pet-friendly.\"}}]}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://www.indoordogpark.org/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Dog Parks Directory\",\"item\":\"https://www.indoordogpark.org/\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Indian Trail\"}]}</script><header class=\"header header-visible  header-light\"><div class=\"header-container\"><div class=\"header-left\"><a class=\"logo\" href=\"/\"><img alt=\"Indoor Dog Park logo\" width=\"140\" height=\"40\" decoding=\"async\" data-nimg=\"1\" style=\"color:transparent;object-fit:contain;height:auto\" src=\"/images/logo/logo.png\"/></a></div><div class=\"header-center\"><nav class=\"header-nav\" aria-label=\"Main navigation\"><a class=\"header-nav-link\" href=\"/\">Browse Parks</a><div class=\"header-nav-item\"><button class=\"header-nav-link\" aria-haspopup=\"true\" aria-expanded=\"false\">Discover <i class=\"bi bi-chevron-down dropdown-icon \"></i></button><div class=\"header-dropdown \"><a class=\"header-dropdown-link\" href=\"/parks-with-bars\">Parks with Bars</a><a class=\"header-dropdown-link\" href=\"/training-facilities\">Training Facilities</a><a class=\"header-dropdown-link\" href=\"/how-it-works\">How It Works</a></div></div><div class=\"header-nav-item\"><button class=\"header-nav-link\" aria-haspopup=\"true\" aria-expanded=\"false\">Locations <i class=\"bi bi-chevron-down dropdown-icon \"></i></button><div class=\"header-dropdown \"><a class=\"header-dropdown-link\" href=\"/cities/san-francisco\">San Francisco</a><a class=\"header-dropdown-link\" href=\"/cities/los-angeles\">Los Angeles</a><a class=\"header-dropdown-link\" href=\"/cities/san-diego\">San Diego</a><a class=\"header-dropdown-link\" href=\"/cities/new-york\">New York</a><a class=\"header-dropdown-link\" h