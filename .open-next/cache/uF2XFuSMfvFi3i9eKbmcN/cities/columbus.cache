ation/ld+json\\\",\\\"suppressHydrationWarning\\\":true,\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"$2d\\\"}}]\\n2e:T4c3,{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"FAQPage\\\",\\\"mainEntity\\\":[{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"Where can I walk my dog indoors in Columbus, Ohio?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"Yes. Our directory currently lists 21 indoor dog parks in Columbus. Use the “Indoor Dog Park” filter on this page to jump straight to climate-controlled options.\\\"}},{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"How do indoor dog park prices work near Ohio State?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"Drop-ins hover around $16, while semester memberships range from $120–$180 and include tutoring lounge access, study nooks, or daycare bundles.\\\"}},{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"Can I combine daycare, boarding, and indoor play?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"Yes—Easton Enrichment Lab and German Village Loft both bundle overnight boarding, enrichment labs, and daytime play so busy students or medical staff can keep consistent routines.\\\"}},{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"Are there membership perks for college students?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"Many Columbus hubs include roommate guest passes, finals-week late hours, and discounted wellness pop-ups. Upload your student ID to unlock the campus tier.\\\"}}]}26:[\\\"$\\\",\\\"script\\\",null,{\\\"type\\\":\\\"application/ld+json\\\",\\\"suppressHydrationWarning\\\":true,\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"$2e\\\"}}]\\n27:[\\\"$\\\",\\\"script\\\",null,{\\\"type\\\":\\\"application/ld+json\\\",\\\"suppressHydrationWarning\\\":true,\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"{\\\\\\\"@context\\\\\\\":\\\\\\\"https://schema.org\\\\\\\",\\\\\\\"