n\",\"@id\":\"https://www.indoordogpark.org/parks/pet-supplies-plus-powell\",\"name\":\"Pet Supplies Plus Powell\",\"url\":\"https://www.indoordogpark.org/parks/pet-supplies-plus-powell\",\"description\":\"Chain carrying natural & U.S.-made pet supplies, plus services such as grooming &...\",\"address\":{\"@type\":\"PostalAddress\",\"addressLocality\":\"Columbus\",\"addressRegion\":\"OH\",\"addressCountry\":\"US\"}}},{\"@type\":\"ListItem\",\"position\":10,\"item\":{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/pet-supplies-plus-upper-arlington\",\"name\":\"Pet Supplies Plus Upper Arlington\",\"url\":\"https://www.indoordogpark.org/parks/pet-supplies-plus-upper-arlington\",\"description\":\"Chain carrying natural & U.S.-made pet supplies, plus services such as grooming &...\",\"address\":{\"@type\":\"PostalAddress\",\"addressLocality\":\"Columbus\",\"addressRegion\":\"OH\",\"addressCountry\":\"US\"}}}]}25:[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"suppressHydrationWarning\":true,\"dangerouslySetInnerHTML\":{\"__html\":\"$2d\"}}]\n2e:T4c3,{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Where can I walk my dog indoors in Columbus, Ohio?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Our directory currently lists 21 indoor dog parks in Columbus. Use the “Indoor Dog Park” filter on this page to jump straight to climate-controlled options.\"}},{\"@type\":\"Question\",\"name\":\"How do indoor dog park prices work near Ohio State?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Drop-ins hover around $16, while semester memberships range from $120–$180 and include tutoring lounge access, study nooks, or daycare bundles.\"}},{\"@type\":\"Question\",\"name\":\"Can I combine daycare, boarding, and indoor play?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes—Easton Enrichment Lab and German Village Loft both bundle overnight boarding, enrichment labs, and daytime play so busy students or medical staff can keep consistent routines.\"}},{\"@type\":\"Question\",\"name\":\"Are there membership perks for college students?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Many Columbus hubs include roommate guest passes, finals-week late hours, and discounted wellness pop-ups. Upload your student ID to unlock the campus tier.\"}}]}26:[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"suppressHydrationWarning\":true,\"dangerouslySetInnerHTML\":{\"__html\":\"$2e\"}}]\n27:[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"suppressHydrationWarning\":true,\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://www.indoordogpark.org/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Dog Parks Directory\\\",\\\"item\\\":\\\"https://www.indoordogpark.org/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Columbus\\\"}]}\"}}]\n28:[\"$\",\"$L11\",null,{\"variant\":\"light\"}]\n29:[\"$\",\"$L2f\",null,{\"items\":[{\"id\":\"city-hero\",\"title\":\"City Overview\",\"level\":1},{\"id\":\"city-insights\",\"title\":\"Quick Facts\",\"level\":1},{\"id\":\"city-comparison\",\"title\":\"Top Comparisons\",\"level\":1},{\"id\":\"park-collections\",\"title\":\"Park Collections\",\"level\":1},{\"id\":\"neighborhood-clusters\",\"title\":\"Neighborhoods\",\"level\":1},{\"id\":\"park-types-guide\",\"title\":\"Park Type Guide\",\"level\":1},{\"id\":\"map-and-neighborhoods\",\"title\":\"Map & Neighborhoods\",\"level\":1},{\"id\":\"planning-essentials\",\"title\":\"Planning Essentials\",\"level\":1},{\"id\":\"expert-tips\",\"title\":\"Expert Advice\",\"level\":1},{\"id\":\"park-directory\",\"title\":\"Full Directory\",\"level\":1},{\"id\":\"owner-cta\",\"title\":\"Owner & Franchise\",\"level\":1},{\"id\":\"faq-section\",\"title\":\"FAQs\",\"level\":1},{\"id\":\"related-resources\",\"title\":\"More Resources\",\"level\":1}]}]\n2a:[\"$\",\"main\",null,{\"className\":\"city-page-layout\",\"children\":[[\"$\",\"div\",null,{\"className\":\"mobile-toc-button\",\"children\":[\"$\",\"$L30\",null,{\"className\":\"mobile-toc-trigger\",\"targetSelector\":\".table-of-contents\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-list-ul\"}],[\"$\",\"span\",null,{\"children\":\"Contents\"}]]}]}],[\"$\",\"section\",null,{\"id\":\"city-hero\",\"className\":\"city-hero-section \",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell city-hero-shell\",\"children\":[[\"$\",\"div\",null,{\"className\":\"city-hero-copy\",\"children\":[[\"$\",\"div\",null,{\"className\":\"hero-breadcrumbs\",\"children\":[[\"$\",\"$L12\",null,{\"href\":\"/\",\"children\":\"Home\"}],[\"$\",\"i\",null,{\"className\":\"bi bi-chevron-right\"}],[\"$\",\"span\",null,{\"children\":\"Dog Parks Directory\"}],[\"$\",\"i\",null,{\"className\":\"bi bi-chevron-right\"}],[\"$\",\"strong\",null,{\"children\":\"Columbus\"}]]}],[\"$\",\"p\",null,{\"className\":\"hero-eyebrow\",\"children\":\"Campus-friendly indoor runs\"}],[\"$\",\"h1\",null,{\"children\":\"Indoor dog park in Columbus, Ohio\"}],\"$undefined\",[\"$\",\"p\",null,{\"className\":\"hero-description\",\"children\":\"College-town schedules crave memberships and combined daycare/boarding packages so students, med staff, and tech workers can keep a steady indoor routine.\"}],[\"$\",\"div\",null,{\"className\":\"city-rich-description\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"rich-description-paragraph\",\"children\":[\"Columbus has developed a unique indoor dog park culture that caters to its massive student population at Ohio State and a growing workforce of medical professionals. The city’s volatile weather, featuring humid summers and gray winters, makes climate-controlled play an essential part of local pet ownership. In districts like the Short North, facilities have pioneered a \\\"study-and-play\\\" model, blending traditional indoor runs with coworking pods and high-speed Wi-Fi. This concept is incredibly popular among the city’s 60,000+ college students, who use these spaces as a base of operations while their pets burn energy under staff supervision. While \",[\"$\",\"$L12\",\"1\",{\"href\":\"https://columbusrecparks.com\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"rich-link\",\"children\":\"Columbus Recreation and Parks\"}],null,\" offers excellent public grounds, the private indoor clubs distinguish themselves with premium amenities like lockers, barista service, and even dorm-friendly shuttle services that integrate into an active lifestyle.\"]}],[\"$\",\"p\",\"1\",{\"className\":\"rich-description-paragraph\",\"children\":[\"The operational focus in Columbus is heavily influenced by the academic calendar and the needs of shift workers. Professional membership structures are often flexible, featuring semester-based plans that align with OSU’s schedule, typically costing between $120 and $180 per term. Daily drop-ins are available for approximately $16 to $20, providing a convenient option for an occasional break from the elements. Safety and hygiene are maintained through rigorous standards, including antimicrobial turf and mandatory temperament checks for all new participants. Many facilities also offer \\\"sniffari\\\" sessions and scent-work labs for mental enrichment. Owners can find more detailed guidance on coordinating these sessions with their schedules in our \",[\"$\",\"$L12\",\"1\",{\"href\":\"#planning-essentials\",\"target\":\"$undefined\",\"rel\":\"$undefined\",\"className\":\"rich-link\",\"children\":\"planning essentials\"}],null,\" guide. By combining education-friendly environments with a focus on local demographics, Columbus’s indoor dog parks have established themselves as vital neighborhood anchors year-round.\"]}]]}],[\"$\",\"div\",null,{\"className\":\"hero-cta-row\",\"children\":[[\"$\",\"$L30\",null,{\"className\":\"hero-cta primary\",\"targetId\":\"park-directory\",\"children\":[[\"$\",\"i\",null,{\"className\":\"bi bi-list-check\"}],\"Browse directory\"]}],[\"$\",\"$L30\",null,{\"className\":\"hero-cta ghost\",\"targetId\":\"map-and-neighborhoods\",\"children\":[\"$L31\",\"Open map\"]}],\"$L32\"]}],\"$L33\"]}],\"$L34\"]}]}],\"$L35\",\"$L36\",\"$L37\",\"$L38\",\"$L39\",\"$L3a\",\"$undefined\",\"$L3b\",\"$L3c\",\"$L3d\",\"$L3e\",\"$L3f\"]}]\n2b:[\"$\",\"footer\",null,{\"className\":\"footer-new\",\"children\":[\"$\",\"div\",null,{\"className\":\"footer-container\",\"children\":[[\"$\",\"div\",null,{\"className\":\"footer-grid\",\"children\":[[\"$\",\"div\",null,{\"className\":\"footer-column\",\"children\":[[\"$\",\"h4\",null,{\"className\":\"footer-heading\",\"children\":\"IndoorDogPark\"}],[\"$\",\"ul\",null,{\"className\":\"footer-links\",\"children\":[[\"$\",\"li\",null,{\"children\":[\"$\",\"$L12\",null,{\"href\":\"/about\",\"children\":\"About us\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L12\",null,{\"href\":\"/partners\",\"children\":\"Partners\"}]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"footer-column\",\"children\":[[\"$\",\"h4\",null,{\"className\":\"footer-heading\",\"children\":\"Discover\"}],[\"$\",\"ul\",null,{\"className\":\"footer-links\",\"children\":[[\"$\",\"li\",null,{\"children\":[\"$\",\"$L12\",null,{\"href\":\"/\",\"children\":\"Browse parks\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L12\",null,{\"href\":\"/how-it-works\",\"children\":\"How it works\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L12\",null,{\"href\":\"/blog\",\"children\":\"Blog\"}]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"footer-column\",\"children\":[[\"$\",\"h4\",null,{\"className\":\"footer-heading\",\"children\":\"Park Owners\"}],[\"$\",\"ul\",null,{\"className\":\"footer-links\",\"children\":[[\"$\",\"li\",null,{\"children\":[\"$\",\"$L12\",null,{\"href\