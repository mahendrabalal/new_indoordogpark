-insights\",\"className\":\"city-insights-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell\",\"children\":[\"$\",\"$L29\",null,{\"parks\":[{\"id\":\"ChIJucjPyiGXf4gRZCP2srfEPDo\",\"name\":\"Ambrozia's Great Grooms\",\"businessType\":\"Dog Park\",\"description\":\"Pet parents in the area rave about Ambrozia's Great Grooms.  What makes this dog facility special is its professional, excellent, outstanding. The staff's dedication to creating a positive experience for both dogs and their owners is evident in every visit. kim c is an excellent professional groomer Located in a safe area, This facility specializes in Pet care and Professional services. For more information, call (901) 292-0334. Visit their website at https://www.ambroziasgreatgrooms.com/ to learn more about their services and pricing.\",\"slug\":\"ambrozia-s-great-grooms\",\"address\":\"5524 Forest Hill Irene Rd\",\"street\":\"5524 Forest Hill Irene Rd\",\"city\":\"Memphis\",\"state\":\"TN\",\"zipCode\":\"38125\",\"full_address\":\"5524 Forest Hill Irene Rd, Memphis, TN 38125, USA\",\"latitude\":34.997352,\"longitude\":-89.7590699,\"googlePlaceId\":\"ChIJucjPyiGXf4gRZCP2srfEPDo\",\"phone\":\"(901) 292-0334\",\"website\":\"https://www.ambroziasgreatgrooms.com/\",\"photos\":null,\"rating\":4.9,\"reviewCount\":16,\"openingHours\":{\"Monday\":\"Closed\",\"Tuesday\":\"9:00 AM – 12:00 PM\",\"Wednesday\":\"9:00 AM – 6:00 PM\",\"Thursday\":\"9:00 AM – 6:00 PM\",\"Friday\":\"9:00 AM – 12:00 PM\",\"Saturday\":\"Closed\",\"Sunday\":\"Closed\"},\"amenities\":{\"Onsite services\":true,\"Indoor facilities\":true,\"Professional staff\":true,\"Climate controlled\":true,\"Wheelchair accessible entrance\":true,\"Parking available\":true,\"Easy access\":true},\"pricing\":{\"pricingSource\":\"website\",\"isFree\":false},\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"lastUpdated\":null,\"dataQuality\":\"verified\",\"photo\":null,\"faqs\":[],\"source\":\"static\",\"listingType\":\"free\"},{\