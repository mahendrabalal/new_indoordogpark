\\"10 AM–3 PM weekdays: calm training-friendly window\\\"}],[\\\"$\\\",\\\"li\\\",\\\"After 4 PM: sunset crowd + cooler temps\\\",{\\\"children\\\":\\\"After 4 PM: sunset crowd + cooler temps\\\"}]]}]]}],[\\\"$\\\",\\\"article\\\",\\\"Essentials checklist\\\",{\\\"className\\\":\\\"planning-card\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"planning-icon\\\",\\\"children\\\":[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-backpack\\\"}]}],[\\\"$\\\",\\\"h3\\\",null,{\\\"children\\\":\\\"Essentials checklist\\\"}],[\\\"$\\\",\\\"ul\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"li\\\",\\\"Leash + harness for entry/exit control\\\",{\\\"children\\\":\\\"Leash + harness for entry/exit control\\\"}],[\\\"$\\\",\\\"li\\\",\\\"Collapsible water bowl and fresh water\\\",{\\\"children\\\":\\\"Collapsible water bowl and fresh water\\\"}],[\\\"$\\\",\\\"li\\\",\\\"Plenty of waste bags and high-value treats\\\",{\\\"children\\\":\\\"Plenty of waste bags and high-value treats\\\"}]]}]]}],[\\\"$\\\",\\\"article\\\",\\\"Local regulations\\\",{\\\"className\\\":\\\"planning-card\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"planning-icon\\\",\\\"children\\\":[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-shield-check\\\"}]}],[\\\"$\\\",\\\"h3\\\",null,{\\\"children\\\":\\\"Local regulations\\\"}],[\\\"$\\\",\\\"ul\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"li\\\",\\\"Keep proof of vaccinations or city license handy\\\",{\\\"children\\\":\\\"Keep proof of vaccinations or city license handy\\\"}],[\\\"$\\\",\\\"li\\\",\\\"Voice control required in most off-leash zones\\\",{\\\"children\\\":\\\"Voice control required in most off-leash zones\\\"}],[\\\"$\\\",\\\"li\\\",\\\"Limit three dogs per handler in public parks\\\",{\\\"children\\\":\\\"Limit three dogs per handler in public parks\\\"}]]}]]}],[\\\"$\\\",\\\"article\\\",\\\"Community etiquette\\\",{\\\"className\\\":\\\"planning-card\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"planning-icon\\\",\\\"children\\\":[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-heart\\\"}]}],[\\\"$\\\",\\\"h3\\\",null,{\\\"children\\\":\\\"Community etiquette\\\"}],[\\\"$\\\",\\\"ul\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"li\\\",\\\"Scan the park before entering and remove prong collars\\\",{\\\"children\\\":\\\"Scan the park before entering and remove prong collars\\\"}],[\\\"$\\\",\\\"li\\\",\\\"Monitor play styles and intervene early\\\",{\\\"children\\\":\\\"Monitor play styles and intervene early\\\"}],[\\\"$\\\",\\\"li\\\",\\\"Share shaded space and refill water when you're done\\\",{\\\"children\\\":\\\"Share shaded space and refill water when you're done\\\"}]]}]]}]]}]]}]}]\\n\"])</script><script>self.__next_f.push([1,\"3c:[\\\"$\\\",\\\"section\\\",null,{\\\"id\\\":\\\"owner-cta\\\",\\\"className\\\":\\\"owner-cta-section\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"section-shell\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"section-eyebrow\\\",\\\"children\\\":\\\"Partner with us\\\"}],[\\\"$\\\",\\\"h2\\\",null,{\\\"children\\\":\\\"Feature your Charlotte dog park\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Upgrade to a featured listing, share live availability, or pitch a new indoor concept. Our team drives qualified local pet parents every week.\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"hero-cta-row\\\",\\\"style\\\":{\\\"marginTop\\\":24},\\\"children\\\":[[\\\"$\\\",\\\"$L12\\\",null,{\\\"href\\\":\\\"/list-your-park\\\",\\\"className\\\":\\\"hero-cta primary\\\",\\\"children\\\":\\\"List a property\\\"}],[\\\"$\\\",\\\"$L12\\\",null,{\\\"href\\\":\\\"/contact\\\",\\\"className\\\":\\\"hero-cta ghost\\\",\\\"children\\\":\\\"Contact the team\\\"}]]}],\\\"$undefined\\\"]}]}]\\n3d:[\\\"$\\\",\\\"section\\\",null,{\\\"id\\\":\\\"park-directory\\\",\\\"className\\\":\\\"park-directory-section\\\",\\\"children\\\":[\\\"