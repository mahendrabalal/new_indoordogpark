e Petco\",\"city\":\"Redmond\",\"state\":\"WA\",\"zipCode\":\"98052\",\"full_address\":\"Inside Petco, 7215 170th Ave NE, Redmond, WA 98052, USA\",\"latitude\":47.6687427,\"longitude\":-122.115853,\"googlePlaceId\":\"ChIJvwVFw2BzkFQR6PgV-AkVR3c\",\"phone\":\"(425) 861-3907\",\"rating\":0,\"reviewCount\":0,\"userRatingsTotal\":0,\"photos\":null,\"photo\":null,\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"dataQuality\":\"verified\",\"website\":\"https://www.justfoodfordogs.com/store/7215-170th-ave-ne-redmond-wa-98052.html?utm_source=local&utm_medium=organic&utm_campaign=GMB&utm_content=petshop\",\"pricing\":{\"pricingSource\":\"unknown\",\"isFree\":false},\"source\":\"static\",\"listingType\":\"free\"},{\"id\":\"ChIJNe2z9kwNkFQR5isE3KKVV_E\",\"name\":\"Mud Bay\",\"businessType\":\"Indoor Dog Park\",\"description\":\"Mud Bay has become the premier destination for Redmond dog owners. This facility features modern training facilities, knowledgeable animal handlers, offering pet care. Their services creates a safe, dry environment year-round. situated in a prime Redmond location. Call (425) 250-0366 to learn more about their services\",\"slug\":\"mud-bay\",\"address\":\"8867 161st Avenue Northeast\",\"street\":\"8867 161st Avenue Northeast\",\"city\":\"Redmond\",\"state\":\"WA\",\"zipCode\":\"98052\",\"full_address\":\"8867 161st Avenue Northeast, Redmond, WA 98052, USA\",\"latitude\":47.68099489999999,\"longitude\":-122.1270892,\"googlePlaceId\":\"ChIJNe2z9kwNkFQR5isE3KKVV_E\",\"phone\":\"(425) 250-0366\",\"rating\":4.7,\"reviewCount\":252,\"userRatingsTotal\":252,\"photos\":null,\"photo\":null,\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"dataQuality\":\"verified\",\"website\":\"https://www.mudbay.com/pet-store/RED-redmond-WA\",\"openingHours\":{\"Monday\":\"10:00 AM – 7:30 PM\",\"Tuesday\":\"10:00 AM – 7:30 PM\",\"Wednesday\":\"10:00 AM – 7:30 PM\",\"Thursday\":\"10:00 AM – 7:30 PM\",\"Friday\":\"10:00 AM – 7:30 PM\",\"Saturday\":\"9:00 AM – 7:00 PM\",\"Sunday\":\"9:00 AM – 7:00 PM\"},\"pricing\":{\"pricingSource\":\"unknown\",\"isFree\":false},\"source\":\"static\",\"listingType\":\"free\"},{\"id\":\"ChIJhRoaz7pykFQR3EU-gTknohs\",\"name\":\"Petco\",\"businessType\":\"Indoor Dog Park\",\"description\":\"Petco provides dependable care for Redmond's furry friends. This facility features modern training facilities, caring and attentive team members, offering pet care. Their services creates a safe, dry environment year-round. situated in a prime Redmond location. Experience the difference at Petco\",\"slug\":\"petco\",\"address\":\"7215 170th Ave NE Ste. 115\",\"street\":\"7215 170th Ave NE Ste. 115\",\"city\":\"Redmond\",\"state\":\"WA\",\"zipCode\":\"98052\",\"full_address\":\"7215 170th Ave NE Ste. 115, Redmond, WA 98052, USA\",\"latitude\":47.6687681,\"longitude\":-122.1158301,\"googlePlaceId\":\"ChIJhRoaz7pykFQR3EU-gTknohs\",\"phone\":\"(425) 861-3907\",\"rating\":4.1,\"reviewCount\":531,\"userRatingsTotal\":531,\"photos\":null,\"photo\":null,\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"dataQuality\":\"verified\",\"website\":\"https://stores.petco.com/wa/redmond/pet-supplies-redmond-wa-1218.html\",\"openingHours\":{\"Monday\":\"9:00 AM – 9:00 PM\",\"Tuesday\":\"9:00 AM – 9:00 PM\",\"Wednesday\":\"9:00 AM – 9:00 PM\",\"Thursday\":\"9:00 AM – 9:00 PM\",\"Friday\":\"9:00 AM – 9:00 PM\",\"Saturday\":\"9:00 AM – 9:00 PM\",\"Sunday\":\"10:00 AM – 7:00 PM\"},\"pricing\":{\"pricingSource\":\"unknown\",\"isFree\":false},\"source\":\"static\",\"listingType\":\"free\"},{\"id\":\"ChIJpS2PxN8RkFQRu2B0vty9ACk\",\"name\":\"XL Canine Crates: Stylish, Durable Dog Crates for Large Breeds. Secure Kennels, Spacious Design, Portable Comfort.\",\"businessType\":\"Indoor Dog Park\",\"description\":\"XL Canine Crates: Stylish, Durable Dog Crates for Large Breeds. Secure Kennels, Spacious Design, Portable Comfort. serves the Redmond pet community with dedication. This facility features climate-controlled facilities for Washington's rainy climate, Washington pet care professionals, offering pet care. Their services ensures your dog stays active during Washington's rainy weather. strategically positioned in Redmond. Reach out to XL Canine Crates: Stylish, Durable Dog Crates for Large Breeds. Secure Kennels, Spacious Design, Portable Comfort. for a consultation\",\"slug\":\"xl-canine-crates-stylish-durable-dog-crates-for-large-breeds-secure-kennels-spacious-design-portable-comfort\",\"address\":\"NE 137th St\",\"street\":\"NE 137th St\",\"city\":\"Redmond\",\"state\":\"WA\",\"zipCode\":\"98034\",\"full_address\":\"NE 137th St, Kirkland, WA 98034, USA\",\"latitude\":47.72825719999999,\"longitude\":-122.2868929,\"googlePlaceId\":\"ChIJpS2PxN8RkFQRu2B0vty9ACk\",\"phone\":\"(321) 800-8603\",\"rating\":5,\"reviewCount\":1,\"userRatingsTotal\":1,\"placeTypes\":[\"point_of_interest\",\"establishment\"],\"dataQuality\":\"verified\",\"website\":\"http://xlcaninecrate.com/\",\"openingHours\":{\"Monday\":\"9:00 AM – 5:00 PM\",\"Tuesday\":\"9:00 AM – 5:00 PM\",\"Wednesday\":\"9:00 AM – 5:00 PM\",\"Thursday\":\"9:00 AM – 5:00 PM\",\"Friday\":\"9:00 AM – 5:00 PM\",\"Saturday\":\"Closed\",\"Sunday\":\"Closed\"},\"pricing\":{\"pricingSource\":\"unknown\",\"isFree\":false},\"source\":\"static\",\"listingType\":\"free\"}],\"cityName\":\"Redmond\",\"insightCards\":\"$undefined\",\"topAmenities\":[],\"insightIntro\":\"$undefined\"}]}]}]\n35:[\"$\",\"section\",null,{\"id\":\"city-comparison\",\"className\":\"city-comparison-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell\",\"children\":[\"$\",\"$L44\",null,{\"parks\":\"$34:props:children:props:children:props:parks\",\"cityName\":\"Redmond\"}]}]}]\n36:[\"$\",\"section\",null,{\"id\":\"park-collections\",\"className\":\"park-collections-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell\",\"children\":[[\"$\",\"div\",null,{\"className\":\"section-heading\",\"children\":[[\"$\",\"span\",null,{\"classNa