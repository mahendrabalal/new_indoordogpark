:\\\"hero-eyebrow\\\",\\\"children\\\":\\\"Lake Norman Life\\\"}],[\\\"$\\\",\\\"h1\\\",null,{\\\"children\\\":\\\"Huntersville Adventures\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"hero-chip-row\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",\\\"0\\\",{\\\"className\\\":\\\"hero-chip\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"chip-label\\\",\\\"children\\\":\\\"Nature Preserve\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"chip-value\\\",\\\"children\\\":\\\"1\\\"}],\\\"$undefined\\\"]}],[\\\"$\\\",\\\"div\\\",\\\"1\\\",{\\\"className\\\":\\\"hero-chip\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"chip-label\\\",\\\"children\\\":\\\"Lake Access\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"chip-value\\\",\\\"children\\\":\\\"Yes\\\"}],\\\"$undefined\\\"]}]]}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"hero-description\\\",\\\"children\\\":\\\"Nestled along Lake Norman, Huntersville offers the best of both worlds: rugged hiking at Latta Nature Preserve and refined patio dining at Birkdale Village.\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"city-rich-description\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",\\\"0\\\",{\\\"className\\\":\\\"rich-description-paragraph\\\",\\\"children\\\":[\\\"Huntersville, North Carolina, offers a lifestyle defined by its proximity to Lake Norman, and for dog owners, this means unparalleled access to nature and water. The crown jewel is the \\\",[\\\"$\\\",\\\"$L12\\\",\\\"1\\\",{\\\"href\\\":\\\"https://parkandrec.mecknc.gov/Places-to-Visit/Nature-Preserves-and-Nature-Centers/Latta-Nature-Preserve\\\",\\\"target\\\":\\\"_blank\\\",\\\"rel\\\":\\\"noopener noreferrer\\\",\\\"className\\\":\\\"rich-link\\\",\\\"children\\\":\\\"Latta Nature Preserve\\\"}],null,\\\", a sprawling natural area that serves as the county’s largest nature preserve. Here, miles of hiking trails wind through hardwood forests and along the shoreline, offering a sensory feast for dogs. While swimming is restricted in many areas, the views and the quality of the hike make it a top destination for active owners.\\\"]}],[\\\"$\\\",\\\"p\\\",\\\"1\\\",{\\\"className\\\":\\\"rich-description-paragraph\\\",\\\"children\\\":[\\\"Contrast this rugged beauty with Birkdale Village, an open-air shopping and dining destination that mimics a classic main street. It is the social heart of Huntersville and is famously dog-friendly. You will see countless residents walking their dogs past shop windows, stopping for water bowls left out by merchants, or lounging on restaurant patios. Rosedale Nature Park adds a dedicated off-leash facility to the mix, ensuring that whether you want a vigorous hike, a social shopping trip, or a game of fetch, Huntersville has a high-quality option \\\",[\\\"$\\\",\\\"$L12\\\",\\\"1\\\",{\\\"href\\\":\\\"https://www.indoordogpark.org/training-facilities\\\",\\\"target\\\":\\\"_blank\\\",\\\"rel\\\":\\\"noopener noreferrer\\\",\\\"className\\\":\\\"rich-link\\\",\\\"children\\\":\\\"ready for you\\\"}],null,\\\".\\\"]}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"hero-cta-row\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L30\\\",null,{\\\"className\\\":\\\"hero-cta primary\\\",\\\"targetId\\\":\\\"park-directory\\\",\\\"children\\\":[[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-list-check\\\"}],\\\"Browse directory\\\"]}],[\\\"$\\\",\\\"$L30\\\",null,{\\\"className\\\":\\\"hero-cta ghost\\\",\\\"targetId\\\":\\\"map-and-neighborhoods\\\",\\\"children\\\":[[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-geo-alt\\\"}],\\\"Open map\\\"]}],[\\\"$\\\",\\\"$L12\\\",null,{\\\"href\\\":\\\"/list-your-park\\\",\\\"className\\\":\\\"hero-cta text-link\\\",\\\"children\\\":[[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"bi bi-plus-circle\\\"}],\\\"Submit a park\\\"]}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"hero-footnotes\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",\\\"Latta