\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"Can dogs swim in Lake Norman?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"At Ramsey Creek Park (nearby), there is a dog park with water access. However, generally, dogs should be kept on leash near the water in public parks unless designated otherwise.\\\"}}]}26:[\\\"$\\\",\\\"script\\\",null,{\\\"type\\\":\\\"application/ld+json\\\",\\\"suppressHydrationWarning\\\":true,\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"$2e\\\"}}]\\n27:[\\\"$\\\",\\\"script\\\",null,{\\\"type\\\":\\\"application/ld+json\\\",\\\"suppressHydrationWarning\\\":true,\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"{\\\\\\\"@context\\\\\\\":\\\\\\\"https://schema.org\\\\\\\",\\\\\\\"@type\\\\\\\":\\\\\\\"BreadcrumbList\\\\\\\",\\\\\\\"itemListElement\\\\\\\":[{\\\\\\\"@type\\\\\\\":\\\\\\\"ListItem\\\\\\\",\\\\\\\"position\\\\\\\":1,\\\\\\\"name\\\\\\\":\\\\\\\"Home\\\\\\\",\\\\\\\"item\\\\\\\":\\\\\\\"https://www.indoordogpark.org/\\\\\\\"},{\\\\\\\"@type\\\\\\\":\\\\\\\"ListItem\\\\\\\",\\\\\\\"position\\\\\\\":2,\\\\\\\"name\\\\\\\":\\\\\\\"Dog Parks Directory\\\\\\\",\\\\\\\"item\\\\\\\":\\\\\\\"https://www.indoordogpark.org/\\\\\\\"},{\\\\\\\"@type\\\\\\\":\\\\\\\"ListItem\\\\\\\",\\\\\\\"position\\\\\\\":3,\\\\\\\"name\\\\\\\":\\\\\\\"Huntersville\\\\\\\"}]}\\\"}}]\\n28:[\\\"$\\\",\\\"$L11\\\",null,{\\\"variant\\\":\\\"light\\\"}]\\n29:[\\\"$\\\",\\\"$L2f\\\",null,{\\\"items\\\":[{\\\"id\\\":\\\"city-hero\\\",\\\"title\\\":\\\"City Overview\\\",\\\"level\\\":1},{\\\"id\\\":\\\"city-insights\\\",\\\"title\\\":\\\"Quick Facts\\\",\\\"level\\\":1},{\\\"id\\\":\\\"city-comparison\\\",\\\"title\\\":\\\"Top Comparisons\\\",\\\"level\\\":1},{\\\"id\\\":\\\"park-collections\\\",\\\"title\\\":\\\"Park Collections\\\",\\\"level\\\":1},{\\\"id\\\":\\\"neighborhood-clusters\\\",\\\"title\\\":\\\"Neighborhoods\\\",\\\"level\\\":1},{\\\"id\\\":\\\"park-types-guide\\\",\\\"title\\\":\\\"Park Type Guide\\\",\\\"level\\