home-boarding-grooming\",\"sameAs\":[\"http://www.almosthome-kennels.com/\"],\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"7903 Cramer Ct\",\"addressLocality\":\"Greensboro\",\"addressRegion\":\"NC\",\"postalCode\":\"27455\",\"addressCountry\":\"US\"},\"telephone\":\"(336) 644-7777\",\"image\":\"/images/parks/northcarolina/almost-home-boarding-grooming/almost-home-boarding-grooming-1.jpg\",\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":4.5,\"reviewCount\":114},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":36.2199938,\"longitude\":-79.7851487}},{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/amandas-ark-pet-care-llc\",\"name\":\"Amanda's Ark Pet Care, LLC\",\"url\":\"https://www.indoordogpark.org/parks/amandas-ark-pet-care-llc\",\"sameAs\":[\"https://www.facebook.com/profile.php?id=100091953931871\"],\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"2608 Nana Ln\",\"addressLocality\":\"Greensboro\",\"addressRegion\":\"NC\",\"postalCode\":\"27405\",\"addressCountry\":\"US\"},\"telephone\":\"(336) 327-3509\",\"image\":\"/images/parks/northcarolina/amanda-s-ark-pet-care-llc/amanda-s-ark-pet-care-llc-1.jpg\",\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":4.9,\"reviewCount\":48},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":36.127261,\"longitude\":-79.7858162}},{\"@type\":\"SportsActivityLocation\",\"@id\":\"https://www.indoordogpark.org/parks/backyard-canine-academy\",\"name\":\"Backyard Canine Academy\",\"url\":\"https://www.indoordogpark.org/parks/backyard-canine-academy\",\"sameAs\":[\"http://backyardcanineacademy.com/\"],\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"2164 Colony Rd\",\"addressLocality\":\"Greensboro\",\"addressRegion\":\"NC\",\"postalCode\":\"27249\",\"addressCountry\":\"US\"},\"telephone\":\"(336) 209-9957\",\"image\":\"/images/parks/northcarolina/backyard-canine-academy/backyard-canine-academy-1.jpg\",\"aggregateRating\":{\"