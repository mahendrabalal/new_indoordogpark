do Dog Daycare & Boarding\"]},{\"slug\":\"smyrna-ga\",\"name\":\"Smyrna\",\"parkCount\":2,\"avgRating\":4.8,\"totalReviews\":431,\"featuredImage\":\"/images/cities/atlanta/hero.webp\",\"longitude\":-84.5186121,\"state\":\"GA\",\"topParks\":[\"Puppy Haven - Smyrna\",\"Bark, Play & Stay\"]},{\"slug\":\"decatur\",\"name\":\"Decatur\",\"parkCount\":2,\"avgRating\":4.7,\"totalReviews\":533,\"featuredImage\":\"/images/cities/decatur-ga/hero.webp\",\"longitude\":-84.270516,\"state\":\"GA\",\"topParks\":[\"Frogs to Dogs, Training & Pet Care\",\"Barking Hound Village Decatur\"]},{\"slug\":\"roswell\",\"name\":\"Roswell\",\"parkCount\":2,\"avgRating\":4.7,\"totalReviews\":511,\"featuredImage\":\"/images/cities/roswell-ga/hero.webp\",\"longitude\":-84.3495848,\"state\":\"GA\",\"topParks\":[\"Cage Free Doggy Hotel, Roswell, Atlanta\",\"PetSuites Roswell\"]},{\"slug\":\"dunwoody\",\"name\":\"Dunwoody\",\"parkCount\":2,\"avgRating\":4.7,\"totalReviews\":1075,\"featuredImage\":\"/images/cities/dunwoody-ga/hero.webp\",\"longitude\":-84.3374278,\"state\":\"GA\",\"topParks\":[\"Dunwoody Nature Center\",\"Camp Run-A-Mutt Dunwoody\"]}]}]]}]}]\n3d:[\"$\",\"section\",null,{\"id\":\"faq-section\",\"className\":\"city-faq-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell\",\"children\":[\"$\",\"$L4a\",null,{\"cityName\":\"Atlanta\",\"parkCount\":15,\"faqs\":[{\"question\":\"Where can I walk my dog indoors in Atlanta?\",\"answer\":\"Not yet in our verified directory for Atlanta. If you know a great indoor option, you can submit it and we’ll review it for inclusion.\",\"category\":\"facilities\",\"popular\":true},{\"question\":\"What are the leash laws in the City of Atlanta?\",\"answer\":\"Atlanta strictly enforces leash laws in all public spaces. Dogs must be on a leash at all times unless they are within the fenced boundaries of a designated off-leash dog park. Owners must also maintain control of their pets and are legally required to remove any waste immediately.\",\"category\":\"legal\",\"popular\":true},{\"question\":\"Are dogs allowed in Piedmont Park?\",\"answer\":\"Yes, Piedmont Park is extremely dog-friendly. It features the Piedmont Park Dog Park, a premier off-leash area with separate enclosures for large and small breeds. Outside of this area, dogs are welcome on leashes throughout the park's many scenic paths and meadows.\",\"category\":\"facilities\"},{\"question\":\"What are the requirements for Atlanta dog parks?\",\"answer\":\"Dogs must be at least four months old, current on rabies vaccinations, and wearing visible tags. Prong, pinch, or spiked collars are typically prohibited within the off-leash zones to ensure a safe play environment for all canine visitors.\",\"category\":\"planning\"}],\"supportCard\":\"$undefined\"}]}]}]\n3e:[\"$\",\"section\",null,{\"id\":\"related-resources\",\"className\":\"related-resources-section\",\"children\":[\"$\",\"div\",null,{\"className\":\"section-shell\",\"children\":[[\"$\",\"div\",null,{\"className\":\"section-heading\",\"children\":[[\"$\",\"span\",null,{\"className\":\"section-eyebrow\",\"children\":\"Keep exploring\"}],[\"$\",\"h2\",null,{\"children\":\"More ways to plan\"}],[\"$\",\"p\",null,{\"children\":\"Browse statewide guides, submit a listing, or connect with our team.\"}]]}],[\"$\",\"div\",null,{\"className\":\"resources-grid\",\"children\":[[\"$\",\"$L12\",null,{\"href\":\"/\",\"className\":\"resource-card\",\"children\":[[\"$\",\"div\",null,{\"className\":\"resource-icon\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-globe\"}]}],[\"$\",\"h3\",null,{\"children\":\"California overview\"}],[\"$\",\"p\",null,{\"children\":\"See every city we cover plus statewide insights.\"}],[\"$\",\"i\",null,{\"className\":\"bi bi-arrow-up-right\"}]]}],[\"$\",\"$L12\",null,{\"href\":\"/contact\",\"className\":\"resource-card\",\"children\":[[\"$\",\"div\",null,{\"className\":\"resource-icon\",\"children\":[\"$\",\"i\",null,{\"className\":\"bi bi-chat-dots\"}]}],[\"$\