g\\\":4.7,\\\"totalReviews\\\":16428,\\\"featuredImage\\\":\\\"/images/cities/virginia-beach/hero.webp\\\",\\\"longitude\\\":-76.1163622,\\\"state\\\":\\\"VA\\\",\\\"topParks\\\":[\\\"Kitty Island, LLC\\\",\\\"K9 Functional Training\\\",\\\"Beach Pups Pet Styling\\\"]},{\\\"slug\\\":\\\"richmond-va\\\",\\\"name\\\":\\\"Richmond\\\",\\\"parkCount\\\":50,\\\"avgRating\\\":4.6,\\\"totalReviews\\\":11045,\\\"featuredImage\\\":\\\"/images/cities/richmond-va/hero.webp\\\",\\\"longitude\\\":-77.5722323,\\\"state\\\":\\\"VA\\\",\\\"topParks\\\":[\\\"Zoom Room\\\",\\\"Best Paw Forward K9 Training\\\",\\\"Playful Paws Petcare\\\"]},{\\\"slug\\\":\\\"roanoke-va\\\",\\\"name\\\":\\\"Roanoke\\\",\\\"parkCount\\\":45,\\\"avgRating\\\":4.5,\\\"totalReviews\\\":9442,\\\"featuredImage\\\":\\\"/images/cities/roanoke-va/hero.webp\\\",\\\"longitude\\\":-79.895499,\\\"state\\\":\\\"VA\\\",\\\"topParks\\\":[\\\"Smoochie Pooch\\\",\\\"Bindee's biscuits and bows\\\",\\\"LuxePup Salon\\\"]},{\\\"slug\\\":\\\"alexandria\\\",\\\"name\\\":\\\"Alexandria\\\",\\\"parkCount\\\":44,\\\"avgRating\\\":4.6,\\\"totalReviews\\\":7568,\\\"featuredImage\\\":\\\"/images/cities/alexandria/hero.webp\\\",\\\"longitude\\\":-77.1129879,\\\"state\\\":\\\"VA\\\",\\\"topParks\\\":[\\\"Happy Cat Hotel \\u0026 Spa Alexandria\\\",\\\"Best Behaved Dogs\\\",\\\"Sit \\u0026 Stay Affordable Pet Care LLC\\\"]},{\\\"slug\\\":\\\"leesburg\\\",\\\"name\\\":\\\"Leesburg\\\",\\\"parkCount\\\":43,\\\"avgRating\\\":4.4,\\\"totalReviews\\\":7776,\\\"featuredImage\\\":\\\"/images/cities/leesburg/hero.webp\\\",\\\"longitude\\\":-77.5740693,\\\"state\\\":\\\"VA\\\",\\\"topParks\\\":[\\\"The Pet Spa\\\",\\\"Happy Paws K-9\\\",\\\"A Windy Day Farm\\\"]},{\\\"slug\\\":\\\"danville\\\",\\\"name\\\":\\\"Danville\\\",\\\"parkCount\\\":40,\\\"avgRating\\\":4.4,\\\"totalReviews\\\":4944,\\\"featuredImage\\\":\\\"/images/cities/danville-va/hero.webp\\\",\\\"longitude\\\":-79.4346102,\\\"state\\\":\\\"VA\\\",\\\"topParks\\\":[\\\"Enlightened