rginia’s humid summers. Most other regional parks like Maplewood or Winona are also well-maintained by Norfolk Parks \\u0026 Recreation.\\\"}}]}\"])</script><script>self.__next_f.push([1,\"26:[\\\"$\\\",\\\"script\\\",null,{\\\"type\\\":\\\"application/ld+json\\\",\\\"suppressHydrationWarning\\\":true,\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"$2e\\\"}}]\\n27:[\\\"$\\\",\\\"script\\\",null,{\\\"type\\\":\\\"application/ld+json\\\",\\\"suppressHydrationWarning\\\":true,\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"{\\\\\\\"@context\\\\\\\":\\\\\\\"https://schema.org\\\\\\\",\\\\\\\"@type\\\\\\\":\\\\\\\"BreadcrumbList\\\\\\\",\\\\\\\"itemListElement\\\\\\\":[{\\\\\\\"@type\\\\\\\":\\\\\\\"ListItem\\\\\\\",\\\\\\\"position\\\\\\\":1,\\\\\\\"name\\\\\\\":\\\\\\\"Home\\\\\\\",\\\\\\\"item\\\\\\\":\\\\\\\"https://www.indoordogpark.org/\\\\\\\"},{\\\\\\\"@type\\\\\\\":\\\\\\\"ListItem\\\\\\\",\\\\\\\"position\\\\\\\":2,\\\\\\\"name\\\\\\\":\\\\\\\"Dog Parks Directory\\\\\\\",\\\\\\\"item\\\\\\\":\\\\\\\"https://www.indoordogpark.org/\\\\\\\"},{\\\\\\\"@type\\\\\\\":\\\\\\\"ListItem\\\\\\\",\\\\\\\"position\\\\\\\":3,\\\\\\\"name\\\\\\\":\\\\\\\"Norfolk\\\\\\\"}]}\\\"}}]\\n28:[\\\"$\\\",\\\"$L11\\\",null,{\\\"variant\\\":\\\"light\\\"}]\\n29:[\\\"$\\\",\\\"$L2f\\\",null,{\\\"items\\\":[{\\\"id\\\":\\\"city-hero\\\",\\\"title\\\":\\\"City Overview\\\",\\\"level\\\":1},{\\\"id\\\":\\\"city-insights\\\",\\\"title\\\":\\\"Quick Facts\\\",\\\"level\\\":1},{\\\"id\\\":\\\"city-comparison\\\",\\\"title\\\":\\\"Top Comparisons\\\",\\\"level\\\":1},{\\\"id\\\":\\\"park-collections\\\",\\\"title\\\":\\\"Park Collections\\\",\\\"level\\\":1},{\\\"id\\\":\\\"neighborhood-clusters\\\",\\\"title\\\":\\\"Neighborhoods\\\",\\\"level\\\":1},{\\\"id\\\":\\\"park-types-guide\\\",\\\"title\\\":\\\"Park Type Guide\\\",\\\"level\\\":1},{\\\"id\\\":\\\"map-and-neighborhoods\\\",\\\"title\\\":\\\"Map \\u0026 Neighborhoods\\\",\\\"level\\\":1},{\\\"id\\\":\\\"planning-essentials\\\"