# ============================================
# DOG PARKS DIRECTORY - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git!

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_PHOTOS_BUCKET=park-submissions

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_FEATURED_PRICE_ID=price_your_featured_listing_price_id

# Google Places API
GOOGLE_PLACES_API_KEY=your_google_places_api_key


# Application Configuration
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional: Analytics endpoint
# NEXT_PUBLIC_ANALYTICS_ENDPOINT=https://your-analytics-endpoint.com

# Optional: Cache invalidation secret
# REVALIDATE_SECRET=your_secret_key_here